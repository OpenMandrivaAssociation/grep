+  while (p + blk_end_off <= end)
+    {
+      uint8x16_t blk0 = vld1q_u8 (reinterpret_cast<const uint8_t *> (p));
+      uint8x16_t blk1 = vld1q_u8 (reinterpret_cast<const uint8_t *> (p + 1));
+      uint8x16_t nib0lo = vandq_u8 (blk0, nib_mask);
+      uint8x16_t nib0hi = vandq_u8 (vshrq_n_u8 (blk0, 4), nib_mask);
+      uint8x16_t nib1lo = vandq_u8 (blk1, nib_mask);
+      uint8x16_t nib1hi = vandq_u8 (vshrq_n_u8 (blk1, 4), nib_mask);
+
+      uint8x16_t cand = vandq_u8 (
+        vandq_u8 (vqtbl1q_u8 (vlo0v, nib0lo),
+                  vqtbl1q_u8 (vhi0v, nib0hi)),
+        vandq_u8 (vqtbl1q_u8 (vlo1v, nib1lo),
+                  vqtbl1q_u8 (vhi1v, nib1hi)));
+
+      if (use3)
+        {
+          uint8x16_t blk2 = vld1q_u8 (
+            reinterpret_cast<const uint8_t *> (p + 2));
+          uint8x16_t nib2lo = vandq_u8 (blk2, nib_mask);
+          uint8x16_t nib2hi = vandq_u8 (vshrq_n_u8 (blk2, 4), nib_mask);
+          cand = vandq_u8 (cand,
+            vandq_u8 (vqtbl1q_u8 (vlo2v, nib2lo),
+                      vqtbl1q_u8 (vhi2v, nib2hi)));
+        }
