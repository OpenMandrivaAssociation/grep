+/* ---- RISC-V Vector (RVV) core search ---- */
+
+static const char *
+memchr_rvv (const char *s, size_t n, unsigned char c)
+{
+  const char *p = s;
+  size_t rem = n;
+  while (rem > 0)
+    {
+      size_t vl = __riscv_vsetvl_e8m8 (rem);
+      vuint8m8_t block = __riscv_vle8_v_u8m8 (
+        reinterpret_cast<const uint8_t *> (p), vl);
+      vbool1_t mask = __riscv_vmseq_vx_u8m8_b1 (block, c, vl);
+      long idx = __riscv_vfirst_m_b1 (mask, vl);
+      if (idx >= 0)
+        return p + idx;
+      p += vl;
+      rem -= vl;
+    }
+  return nullptr;
+}
