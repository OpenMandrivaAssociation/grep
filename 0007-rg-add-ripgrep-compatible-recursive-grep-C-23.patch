+        size_t avail = static_cast<size_t> (end - np - max_nlen + 1);
+        size_t vl = __riscv_vsetvl_e8m1 (avail);
+        vuint8m1_t block = __riscv_vle8_v_u8m1 (
+            reinterpret_cast<const uint8_t *> (np), vl);
+        vbool8_t any = __riscv_vmclr_m_b8 (vl);
+        for (int i = 0; i < nfb; i++)
+          any = __riscv_vmor_mm_b8 (any,
+              __riscv_vmseq_vx_u8m1_b8 (block, fbs[i], vl), vl);
+        if (__riscv_vcpop_m_b8 (any, vl) == 0)
+          {
+            np += vl;
+            continue;
+          }
+        /* Walk hits within this chunk using scalar verification.  */
+        for (size_t i = 0; i < vl; i++)
+          {
+            const char *cand = np + i;
+            if (!pf.lits_fb[static_cast<unsigned char> (*cand)])
+              continue;
+            if (!lits_any_match_at (pf, cand, end))
+              continue;
+            nmatches++;
+            if (only_exists)
+              return 1;
+            if (max_count > 0 && nmatches >= max_count)
+              return nmatches;
+            const char *nl = static_cast<const char *> (
+                memchr (cand, '\n', static_cast<size_t> (end - cand)));
+            if (!nl)
+              return nmatches;
+            np = nl + 1;
+            goto next_teddy1_rvv;
+          }
+        np += vl;
+      next_teddy1_rvv:;
+      }
+    /* Scalar tail.  */
+    while (np < end)
+      {
+        while (np < end && !pf.lits_fb[static_cast<unsigned char> (*np)])
+          np++;
+        if (np >= end)
+          break;
+        if (lits_any_match_at (pf, np, end))
+          {
+            nmatches++;
+            if (only_exists)
+              return 1;
+            if (max_count > 0 && nmatches >= max_count)
+              return nmatches;
+            const char *nl = static_cast<const char *> (
+                memchr (np, '\n', static_cast<size_t> (end - np)));
+            if (!nl)
+              return nmatches;
+            np = nl + 1;
+          }
+        else
+          np++;
+      }
+    return nmatches;
+  }
+#endif
+
+  /* Scalar: first-byte bitmap then verify.  */
+  const char *p = data;
+  intmax_t matches = 0;
+  while (p < end)
+    {
+      while (p < end && !pf.lits_fb[static_cast<unsigned char> (*p)])
+        p++;
+      if (p >= end)
+        break;
+      if (lits_any_match_at (pf, p, end))
+        {
+          matches++;
+          if (only_exists)
+            return 1;
+          if (max_count > 0 && matches >= max_count)
+            return matches;
+          const char *nl = static_cast<const char *> (
+            memchr (p, '\n', static_cast<size_t> (end - p)));
+          if (!nl)
+            return matches;
+          p = nl + 1;
+        }
+      else
+        p++;
+    }
+  return matches;
+}
+
+/* Sample first-byte frequencies in DATA (cheap proxy for needle rarity).  */
+static void
+sample_fb_hist (const char *data, size_t size, uint32_t hist[256])
+{
+  std::memset (hist, 0, 256 * sizeof (uint32_t));
+  const size_t step = size > (1u << 20) ? 64 : (size > (1u << 16) ? 16 : 1);
+  const size_t lim = size > step ? size - step + 1 : size;
+  for (size_t i = 0; i < lim; i += step)
+    hist[static_cast<unsigned char> (data[i])]++;
+}
+
+/* Hybrid multi-memmem: rarest needle first (sample fb hist + length tie-break),
+   union line-starts via hash set (O(1) membership; later needles skip dups).
+   only_exists exits on first new hit.  */
+static intmax_t
+lits_any_scan_lines_multimem (const Prefilter &pf, const char *data, size_t size,
+                              bool only_exists, intmax_t max_count)
+{
+  const char *end = data + size;
+  uint32_t fb_hist[256];
+  sample_fb_hist (data, size, fb_hist);
+
+  std::vector<size_t> order;
+  order.reserve (pf.lits.size ());
+  for (size_t i = 0; i < pf.lits.size (); i++)
+    if (!pf.lits[i].empty ())
+      order.push_back (i);
+
+  /* Rarest first: low first-byte frequency in sample, then longest needle.  */
+  std::sort (order.begin (), order.end (), [&] (size_t a, size_t b) {
+    unsigned char fa = static_cast<unsigned char> (pf.lits[a][0]);
+    unsigned char fb = static_cast<unsigned char> (pf.lits[b][0]);
+    uint32_t ha = fb_hist[fa], hb = fb_hist[fb];
+    if (ha != hb)
+      return ha < hb;
+    if (pf.lits[a].size () != pf.lits[b].size ())
+      return pf.lits[a].size () > pf.lits[b].size ();
+    return pf.lits[a] < pf.lits[b];
+  });
+
+  std::unordered_set<const char *> hit_lines;
+  hit_lines.reserve (1024);
+
+  for (size_t oi = 0; oi < order.size (); oi++)
+    {
+      const auto &lit = pf.lits[order[oi]];
+      const size_t nlen = lit.size ();
+      const char *cur = data;
+      while (cur < end)
+        {
+          const char *m = memmem_fast (cur, static_cast<size_t> (end - cur),
+                                       lit.data (), nlen);
+          if (!m)
+            break;
+          const char *ls = static_cast<const char *> (
+            memrchr (data, '\n', static_cast<size_t> (m - data)));
+          ls = ls ? ls + 1 : data;
+          if (hit_lines.insert (ls).second)
+            {
+              if (only_exists)
+                return 1;
+              if (max_count > 0
+                  && static_cast<intmax_t> (hit_lines.size ()) >= max_count)
+                return max_count;
+            }
+          const char *nl = static_cast<const char *> (
+            memchr (m, '\n', static_cast<size_t> (end - m)));
+          if (!nl)
+            break;
+          cur = nl + 1;
+        }
+    }
+  return static_cast<intmax_t> (hit_lines.size ());
+}
+
+intmax_t
+lits_any_scan_lines (const Prefilter &pf, const char *data, size_t size,
+                     bool only_exists, intmax_t max_count)
+{
+  if (!data || !size || pf.lits.empty ())
+    return 0;
+
+  const size_t n = pf.lits.size ();
+
+  /* Icase: try nibble Teddy icase (PSHUFB/TBL, no per-byte tolower), then AC.  */
+  if (pf.icase)
+    {
+#if defined(RG_ARCH_X86_64)
+      if (n >= 2 && n <= 16)
+        {
+          intmax_t tn = lits_any_scan_lines_teddy_nibble_icase (
+            pf, data, size, only_exists, max_count);
+          if (tn >= 0)
+            return tn;
+        }
+#elif defined(RG_ARCH_AARCH64)
+      if (n >= 2 && n <= 16)
+        {
+          intmax_t tn = lits_any_teddy_nibble_icase_neon (
+            pf, data, size, only_exists, max_count);
+          if (tn >= 0)
+            return tn;
+        }
+#elif defined(RG_HAVE_LSX)
+      if (n >= 2 && n <= 8)
+        {
+          intmax_t tn = lits_any_teddy_nibble_icase_lsx (
+            pf, data, size, only_exists, max_count);
+          if (tn >= 0)
+            return tn;
+        }
+#endif
+      if (pf.use_ac && pf.ac.built)
+        return pf.ac.scan_lines_icase (data, size, only_exists, max_count);
+      /* Fall through to generic find loop.  */
+    }
+  else
+    {
+      /* Case-sensitive: try nibble Teddy (PSHUFB single-pass), Teddy2 for
+         exists, then AC single-pass.  */
+      if (n >= 2 && n <= 16)
+        {
+          intmax_t tn = lits_any_scan_lines_teddy_nibble (pf, data, size,
+                                                          only_exists, max_count);
+          if (tn >= 0)
+            return tn;
+          /* Teddy2 for exists: still useful when nibble N/A (len<2 needles).  */
+        }
+
+      if (only_exists && n >= 2 && n <= 16)
+        {
+          intmax_t t2 = lits_any_scan_lines_teddy2 (pf, data, size, only_exists,
+                                                    max_count);
+          if (t2 >= 0)
+            return t2;
+        }
+
+      if (pf.use_ac && pf.ac.built)
+        return pf.ac.scan_lines (data, size, only_exists, max_count);
+
+      if (n >= 2 && n <= 16)
+        {
+          intmax_t t1 = lits_any_scan_lines_teddy (pf, data, size, only_exists,
+                                                   max_count);
+          if (t1 >= 0)
+            return t1;
+        }
+    }
+
+  const char *end = data + size;
+  const char *cur = data;
+  intmax_t matches = 0;
+  while (cur < end)
+    {
+      while (cur < end && !pf.lits_fb[static_cast<unsigned char> (*cur)])
+        cur++;
+      if (cur >= end)
+        break;
+      size_t mlen = 0;
+      const char *best = lits_any_find_first (pf, cur, end, &mlen);
+      if (best >= end)
+        break;
+      matches++;
+      if (only_exists)
+        return 1;
+      if (max_count > 0 && matches >= max_count)
+        return matches;
+      const char *nl = static_cast<const char *> (
+        memchr (best, '\n', static_cast<size_t> (end - best)));
+      if (!nl)
+        return matches;
+      cur = nl + 1;
+    }
+  return matches;
+}
+
+/* ---------- ASCII class-run fast path (e.g. [A-Za-z]{8}) ---------- */
+
+static bool
+parse_class_body (std::string_view body, ClassKind *out)
+{
+  if (body == "A-Za-z" || body == "a-zA-Z")
+    {
+      *out = ClassKind::Alpha;
+      return true;
+    }
+  if (body == "a-z")
+    {
+      *out = ClassKind::Lower;
+      return true;
+    }
+  if (body == "A-Z")
+    {
+      *out = ClassKind::Upper;
+      return true;
+    }
+  if (body == "0-9")
+    {
+      *out = ClassKind::Digit;
+      return true;
+    }
+  if (body == "A-Za-z0-9" || body == "0-9A-Za-z" || body == "a-zA-Z0-9")
+    {
+      *out = ClassKind::Alnum;
+      return true;
+    }
+  if (body == "A-Za-z0-9_" || body == "_A-Za-z0-9" || body == "A-Za-z_0-9"
+      || body == "A-Za-z_" || body == "_A-Za-z" || body == "a-zA-Z_")
+    {
+      /* A-Za-z_ alone is identifier-start; treat as Word (superset) for scanning.
+         Patterns that need stricter first-char use first_kind separately.  */
+      *out = ClassKind::Word;
+      return true;
+    }
+  return false;
+}
+
+/* Parse {n}, {n,}, {n,m}, +, or fail.  Advances *ip past quantifier.  */
+static bool
+parse_quantifier (std::string_view pattern, size_t *ip, unsigned *min_r, unsigned *max_r)
+{
+  size_t i = *ip;
+  if (i >= pattern.size ())
+    return false;
+  if (pattern[i] == '+')
+    {
+      *min_r = 1;
+      *max_r = 0;
+      *ip = i + 1;
+      return true;
+    }
+  if (pattern[i] == '*')
+    return false;
+  if (pattern[i] != '{')
+    return false;
+  size_t j = i + 1;
+  unsigned n1 = 0;
+  bool got = false;
+  while (j < pattern.size () && pattern[j] >= '0' && pattern[j] <= '9')
+    {
+      n1 = n1 * 10u + static_cast<unsigned> (pattern[j] - '0');
+      j++;
+      got = true;
+    }
+  if (!got)
+    return false;
+  *min_r = n1;
+  *max_r = n1;
+  if (j < pattern.size () && pattern[j] == ',')
+    {
+      j++;
+      if (j < pattern.size () && pattern[j] == '}')
+        *max_r = 0;
+      else
+        {
+          unsigned n2 = 0;
+          bool got2 = false;
+          while (j < pattern.size () && pattern[j] >= '0' && pattern[j] <= '9')
+            {
+              n2 = n2 * 10u + static_cast<unsigned> (pattern[j] - '0');
+              j++;
+              got2 = true;
+            }
+          if (!got2)
+            return false;
+          *max_r = n2;
+        }
+    }
+  if (j >= pattern.size () || pattern[j] != '}')
+    return false;
+  *ip = j + 1;
+  return true;
+}
+
+/* Parse one [class] at *ip; advances *ip past ']'.  */
+static bool
+parse_bracket_class (std::string_view pattern, size_t *ip, ClassKind *ck)
+{
+  size_t i = *ip;
+  if (i >= pattern.size () || pattern[i] != '[')
+    return false;
+  size_t close = pattern.find (']', i + 1);
+  if (close == std::string_view::npos)
+    return false;
+  std::string_view body = pattern.substr (i + 1, close - i - 1);
+  if (body.empty () || body[0] == '^')
+    return false;
+  if (!parse_class_body (body, ck))
+    return false;
+  *ip = close + 1;
+  return true;
+}
+
+/* ERE/PCRE shorthand: \w \d \s then quantifier, e.g. \w{5,} \d+ \w{8}  */
+static bool
+parse_esc_class (std::string_view pattern, size_t *i, ClassKind *out)
+{
+  size_t p = *i;
+  if (p + 1 >= pattern.size () || pattern[p] != '\\')
+    return false;
+  char e = pattern[p + 1];
+  if (e == 'w')
+    *out = ClassKind::Word;
+  else if (e == 'd')
+    *out = ClassKind::Digit;
+  else if (e == 's')
+    /* Treat as non-newline space-ish: for class-run we approximate with
+       horizontal space only is insufficient; skip — only digit/word here.  */
+    return false;
+  else
+    return false;
+  *i = p + 2;
+  return true;
+}
+
+/* Promote a ClassKind to its case-insensitive equivalent.
+   Lower/Upper → Alpha; Alpha/Alnum/Digit/Word stay the same.  */
+static ClassKind
+class_kind_icase (ClassKind k)
+{
+  switch (k)
+    {
+    case ClassKind::Lower: return ClassKind::Alpha;
+    case ClassKind::Upper: return ClassKind::Alpha;
+    default:               return k;
+    }
+}
+
+ClassRunPat
+build_class_run_pat (std::string_view pattern, bool ignore_case)
+{
+  ClassRunPat cr;
+  if (pattern.empty ())
+    return cr;
+
+  size_t i = 0;
+  if (pattern[0] == '^')
+    i = 1;
+
+  /* \w{n,} / \d{n,} / \w+ (ERE and PCRE share these shorthands).  */
+  {
+    size_t j = i;
+    ClassKind ek;
+    if (parse_esc_class (pattern, &j, &ek))
+      {
+        unsigned min_r = 0, max_r = 0;
+        if (!parse_quantifier (pattern, &j, &min_r, &max_r))
+          return cr;
+        if (j < pattern.size () && !(pattern[j] == '$' && j + 1 == pattern.size ()))
+          return cr;
+        if (min_r == 0)
+          return cr;
+        cr.kind = ignore_case ? class_kind_icase (ek) : ek;
+        cr.min_run = min_r;
+        cr.max_run = max_r;
+        return cr;
+      }
+  }
+
+  ClassKind ck1;
+  if (!parse_bracket_class (pattern, &i, &ck1))
+    return cr;
+
+  /* Two-class form: [c1][c2]{n,}  e.g. [A-Za-z_][A-Za-z0-9_]{7,}  */
+  if (i < pattern.size () && pattern[i] == '[')
+    {
+      ClassKind ck2;
+      if (!parse_bracket_class (pattern, &i, &ck2))
+        return cr;
+      unsigned min_r = 0, max_r = 0;
+      if (!parse_quantifier (pattern, &i, &min_r, &max_r))
+        return cr;
+      if (i < pattern.size () && !(pattern[i] == '$' && i + 1 == pattern.size ()))
+        return cr;
+      if (min_r == 0)
+        return cr;
+      /* Fold for icase before comparing.  */
+      ClassKind fck1 = ignore_case ? class_kind_icase (ck1) : ck1;
+      ClassKind fck2 = ignore_case ? class_kind_icase (ck2) : ck2;
+      /* Same class twice: collapse to one run of length 1+min_r (faster scan).  */
+      if (fck1 == fck2)
+        {
+          cr.kind = fck1;
+          cr.min_run = 1u + min_r;
+          cr.max_run = (max_r == 0) ? 0 : (1u + max_r);
+          return cr;
+        }
+      cr.first_kind = fck1;
+      cr.kind = fck2;
+      cr.min_run = min_r;
+      cr.max_run = max_r;
+      return cr;
+    }
+
+  /* Single-class form: [c]{n} / [c]+  */
+  unsigned min_r = 0, max_r = 0;
+  if (!parse_quantifier (pattern, &i, &min_r, &max_r))
+    return cr;
+  if (i < pattern.size () && !(pattern[i] == '$' && i + 1 == pattern.size ()))
+    return cr;
+  if (min_r == 0)
+    return cr;
+
+  cr.kind = ignore_case ? class_kind_icase (ck1) : ck1;
+  cr.min_run = min_r;
+  cr.max_run = max_r;
+  return cr;
+}
+
+static inline bool
+class_byte_ok (ClassKind k, unsigned char c) noexcept
+{
+  switch (k)
+    {
+    case ClassKind::Alpha:
+      return (c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z');
+    case ClassKind::Lower:
+      return c >= 'a' && c <= 'z';
+    case ClassKind::Upper:
+      return c >= 'A' && c <= 'Z';
+    case ClassKind::Digit:
+      return c >= '0' && c <= '9';
+    case ClassKind::Alnum:
+      return (c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z')
+             || (c >= '0' && c <= '9');
+    case ClassKind::Word:
+      return (c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z')
+             || (c >= '0' && c <= '9') || c == '_';
+    default:
+      return false;
+    }
+}
+
+/* True if any of 8 bytes is in class k (byte-wise).  */
+static inline int
+first_class_byte_in_u64 (ClassKind k, uint64_t v) noexcept
+{
+  for (int i = 0; i < 8; i++)
+    {
+      unsigned char c = static_cast<unsigned char> ((v >> (i * 8)) & 0xffu);
+      if (class_byte_ok (k, c))
+        return i;
+    }
+  return -1;
+}
+
+/* Word class (A-Za-z0-9_): branchless per-byte check on 8-byte chunks.  */
+static inline int
+first_word_byte_in_u64 (uint64_t v) noexcept
+{
+  for (int i = 0; i < 8; i++)
+    {
+      unsigned char c = static_cast<unsigned char> ((v >> (i * 8)) & 0xffu);
+      if ((c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z')
+          || (c >= '0' && c <= '9') || c == '_')
+        return i;
+    }
+  return -1;
+}
+
+/* SIMD: find first Alpha byte in a block; return offset or -1.  */
+#if defined(RG_ARCH_X86_64)
+static inline int
+first_alpha_sse2 (const char *p) noexcept
+{
+  __m128i block = _mm_loadu_si128 (reinterpret_cast<const __m128i *> (p));
+  /* isalpha-ish: (c|0x20)-'a' <= 25 */
+  __m128i lo = _mm_or_si128 (block, _mm_set1_epi8 (0x20));
+  __m128i a = _mm_set1_epi8 ('a');
+  __m128i z = _mm_set1_epi8 ('z');
+  __m128i ge_a = _mm_cmpgt_epi8 (lo, _mm_sub_epi8 (a, _mm_set1_epi8 (1)));
+  __m128i le_z = _mm_cmpgt_epi8 (_mm_add_epi8 (z, _mm_set1_epi8 (1)), lo);
+  __m128i is_az = _mm_and_si128 (ge_a, le_z);
+  /* Also require original was A-Za-z (reject {|}~ via high bit / range on original).  */
+  __m128i hi_ok = _mm_cmpgt_epi8 (block, _mm_set1_epi8 (0x40 - 1)); /* >= '@'+1 wait '@' is 0x40, 'A' is 0x41 */
+  hi_ok = _mm_cmpgt_epi8 (block, _mm_set1_epi8 (0x40)); /* c > '@' i.e. >= 'A' if we exclude @ separately */
+  /* Simpler: accept if (c>='A'&&c<='Z')||(c>='a'&&c<='z') via two ranges on original.  */
+  __m128i A = _mm_set1_epi8 ('A' - 1);
+  __m128i Z = _mm_set1_epi8 ('Z' + 1);
+  __m128i aa = _mm_set1_epi8 ('a' - 1);
+  __m128i zz = _mm_set1_epi8 ('z' + 1);
+  __m128i up = _mm_and_si128 (_mm_cmpgt_epi8 (block, A), _mm_cmpgt_epi8 (Z, block));
+  __m128i low = _mm_and_si128 (_mm_cmpgt_epi8 (block, aa), _mm_cmpgt_epi8 (zz, block));
+  __m128i ok = _mm_or_si128 (up, low);
+  int mask = _mm_movemask_epi8 (ok);
+  (void) is_az;
+  (void) hi_ok;
+  if (!mask)
+    return -1;
+  return __builtin_ctz (static_cast<unsigned> (mask));
+}
+
+#if defined(__GNUC__) || defined(__clang__)
+__attribute__ ((target ("avx2")))
+#endif
+static inline int
+first_alpha_avx2 (const char *p) noexcept
+{
+  __m256i block = _mm256_loadu_si256 (reinterpret_cast<const __m256i *> (p));
+  __m256i A = _mm256_set1_epi8 ('A' - 1);
+  __m256i Z = _mm256_set1_epi8 ('Z' + 1);
+  __m256i aa = _mm256_set1_epi8 ('a' - 1);
+  __m256i zz = _mm256_set1_epi8 ('z' + 1);
+  __m256i up = _mm256_and_si256 (_mm256_cmpgt_epi8 (block, A), _mm256_cmpgt_epi8 (Z, block));
+  __m256i low = _mm256_and_si256 (_mm256_cmpgt_epi8 (block, aa), _mm256_cmpgt_epi8 (zz, block));
+  __m256i ok = _mm256_or_si256 (up, low);
+  int mask = _mm256_movemask_epi8 (ok);
+  if (!mask)
+    return -1;
+  return __builtin_ctz (static_cast<unsigned> (mask));
+}
+#elif defined(RG_ARCH_AARCH64)
+static inline int
+first_alpha_neon (const char *p) noexcept
+{
+  uint8x16_t block = vld1q_u8 (reinterpret_cast<const uint8_t *> (p));
+  uint8x16_t A = vdupq_n_u8 ('A');
+  uint8x16_t Z = vdupq_n_u8 ('Z');
+  uint8x16_t aa = vdupq_n_u8 ('a');
+  uint8x16_t zz = vdupq_n_u8 ('z');
+  uint8x16_t up = vandq_u8 (vcgeq_u8 (block, A), vcleq_u8 (block, Z));
+  uint8x16_t low = vandq_u8 (vcgeq_u8 (block, aa), vcleq_u8 (block, zz));
+  uint8x16_t ok = vorrq_u8 (up, low);
+  uint8x8_t narrow = vshrn_n_u16 (vreinterpretq_u16_u8 (ok), 4);
+  uint64_t mask = vget_lane_u64 (vreinterpret_u64_u8 (narrow), 0);
+  if (!mask)
+    return -1;
+  for (int i = 0; i < 16; i++)
+    if (class_byte_ok (ClassKind::Alpha, static_cast<unsigned char> (p[i])))
+      return i;
+  return -1;
+}
+#endif
+
+#if defined(RG_HAVE_LSX)
+/* first_alpha_lsx: find first alphabetic byte in 16-byte block.  */
+static inline int
+first_alpha_lsx (const char *p) noexcept
+{
+  __m128i block = __lsx_vld (reinterpret_cast<const void *> (p), 0);
+  __m128i up = __lsx_vand_v (
+      __lsx_vsle_bu (__lsx_vreplgr2vr_b ('A'), block),
+      __lsx_vsle_bu (block, __lsx_vreplgr2vr_b ('Z')));
+  __m128i lo = __lsx_vand_v (
+      __lsx_vsle_bu (__lsx_vreplgr2vr_b ('a'), block),
+      __lsx_vsle_bu (block, __lsx_vreplgr2vr_b ('z')));
+  unsigned mask = lsx_movemask (__lsx_vor_v (up, lo));
+  if (!mask)
+    return -1;
+  return __builtin_ctz (mask);
+}
+#endif
+
+/* AVX2: generate 32-bit bitmask of class membership for 32 bytes.
+   Bit i is set iff byte p[i] belongs to class k.  */
+#if defined(RG_ARCH_X86_64)
+#if defined(__GNUC__) || defined(__clang__)
+__attribute__ ((target ("avx2")))
+#endif
+static inline uint32_t
+class_mask_avx2 (ClassKind k, const char *p) noexcept
+{
+  __m256i block = _mm256_loadu_si256 (reinterpret_cast<const __m256i *> (p));
+  __m256i ok;
+  switch (k)
+    {
+    case ClassKind::Alpha:
+      {
+        __m256i A = _mm256_set1_epi8 ('A' - 1);
+        __m256i Z = _mm256_set1_epi8 ('Z' + 1);
+        __m256i aa = _mm256_set1_epi8 ('a' - 1);
+        __m256i zz = _mm256_set1_epi8 ('z' + 1);
+        __m256i up = _mm256_and_si256 (_mm256_cmpgt_epi8 (block, A),
+                                       _mm256_cmpgt_epi8 (Z, block));
+        __m256i lo = _mm256_and_si256 (_mm256_cmpgt_epi8 (block, aa),
+                                       _mm256_cmpgt_epi8 (zz, block));
+        ok = _mm256_or_si256 (up, lo);
+        break;
+      }
+    case ClassKind::Lower:
+      {
+        ok = _mm256_and_si256 (
+            _mm256_cmpgt_epi8 (block, _mm256_set1_epi8 ('a' - 1)),
+            _mm256_cmpgt_epi8 (_mm256_set1_epi8 ('z' + 1), block));
+        break;
+      }
+    case ClassKind::Upper:
+      {
+        ok = _mm256_and_si256 (
+            _mm256_cmpgt_epi8 (block, _mm256_set1_epi8 ('A' - 1)),
+            _mm256_cmpgt_epi8 (_mm256_set1_epi8 ('Z' + 1), block));
+        break;
+      }
+    case ClassKind::Digit:
+      {
+        ok = _mm256_and_si256 (
+            _mm256_cmpgt_epi8 (block, _mm256_set1_epi8 ('0' - 1)),
+            _mm256_cmpgt_epi8 (_mm256_set1_epi8 ('9' + 1), block));
+        break;
+      }
+    case ClassKind::Alnum:
+      {
+        __m256i A = _mm256_set1_epi8 ('A' - 1);
+        __m256i Z = _mm256_set1_epi8 ('Z' + 1);
+        __m256i aa = _mm256_set1_epi8 ('a' - 1);
+        __m256i zz = _mm256_set1_epi8 ('z' + 1);
+        __m256i d0 = _mm256_set1_epi8 ('0' - 1);
+        __m256i d9 = _mm256_set1_epi8 ('9' + 1);
+        __m256i up = _mm256_and_si256 (_mm256_cmpgt_epi8 (block, A),
+                                       _mm256_cmpgt_epi8 (Z, block));
+        __m256i lo = _mm256_and_si256 (_mm256_cmpgt_epi8 (block, aa),
+                                       _mm256_cmpgt_epi8 (zz, block));
+        __m256i dg = _mm256_and_si256 (_mm256_cmpgt_epi8 (block, d0),
+                                       _mm256_cmpgt_epi8 (d9, block));
+        ok = _mm256_or_si256 (_mm256_or_si256 (up, lo), dg);
+        break;
+      }
+    case ClassKind::Word:
+      {
+        __m256i A = _mm256_set1_epi8 ('A' - 1);
+        __m256i Z = _mm256_set1_epi8 ('Z' + 1);
+        __m256i aa = _mm256_set1_epi8 ('a' - 1);
+        __m256i zz = _mm256_set1_epi8 ('z' + 1);
+        __m256i d0 = _mm256_set1_epi8 ('0' - 1);
+        __m256i d9 = _mm256_set1_epi8 ('9' + 1);
+        __m256i up = _mm256_and_si256 (_mm256_cmpgt_epi8 (block, A),
+                                       _mm256_cmpgt_epi8 (Z, block));
+        __m256i lo = _mm256_and_si256 (_mm256_cmpgt_epi8 (block, aa),
+                                       _mm256_cmpgt_epi8 (zz, block));
+        __m256i dg = _mm256_and_si256 (_mm256_cmpgt_epi8 (block, d0),
+                                       _mm256_cmpgt_epi8 (d9, block));
+        __m256i un = _mm256_cmpeq_epi8 (block, _mm256_set1_epi8 ('_'));
+        ok = _mm256_or_si256 (_mm256_or_si256 (_mm256_or_si256 (up, lo), dg),
+                              un);
+        break;
+      }
+    default:
+      return 0;
+    }
+  return static_cast<uint32_t> (_mm256_movemask_epi8 (ok));
+}
+
+/* Full AVX2 scan_class_run for non-prefix patterns.  Processes 32 bytes per
+   iteration via class_mask_avx2 + shift-AND to detect min_r consecutive
+   class bytes in O(min_r) per chunk instead of O(32).  */
+#if defined(__GNUC__) || defined(__clang__)
+__attribute__ ((target ("avx2")))
+#endif
+static intmax_t
+scan_class_run_avx2_impl (ClassKind k, unsigned min_r, const char *data,
+                          size_t size, bool count_lines, bool only_exists,
+                          intmax_t max_count)
+{
+  const char *p = data;
+  const char *const end = data + size;
+  intmax_t matches = 0;
+  unsigned carry = 0; /* trailing class bytes from previous chunk */
+
+  while (p + 32 <= end)
+    {
+      uint32_t mask = class_mask_avx2 (k, p);
+
+      if (mask == 0)
+        {
+          /* All 32 bytes are non-class.  Check if accumulated carry qualifies.  */
+          if (carry >= min_r)
+            {
+              matches++;
+              if (only_exists)
+                return 1;
+              if (matches >= max_count)
+                return matches;
+              if (count_lines)
+                {
+                  const void *nl
+                      = std::memchr (p, '\n', static_cast<size_t> (end - p));
+                  if (!nl)
+                    return matches;
+                  p = static_cast<const char *> (nl) + 1;
+                  carry = 0;
+                  continue;
+                }
+            }
+          carry = 0;
+          p += 32;
+          continue;
+        }
+
+      if (mask == 0xFFFFFFFFu)
+        {
+          /* All 32 bytes are class members.  Extend current run.  */
+          carry += 32;
+          p += 32;
+          continue;
+        }
+
+      /* Mixed chunk.  Iterate over maximal contiguous runs of 1-bits.
+         Use carry to merge runs that span chunk boundaries.  */
+      {
+        uint32_t rem = mask;
+        unsigned bit = 0;
+        /* Handle carry: check if leading 1-bits extend previous run.  */
+        if (carry > 0 && (mask & 1u))
+          {
+            /* Count leading 1-bits in mask.  */
+            uint32_t inv0 = ~mask;
+            unsigned leading = static_cast<unsigned> (__builtin_ctz (inv0));
+            carry += leading;
+            if (carry >= min_r)
+              {
+                matches++;
+                if (only_exists)
+                  return 1;
+                if (matches >= max_count)
+                  return matches;
+                if (count_lines)
+                  {
+                    const char *after = p + leading;
+                    const void *nl = std::memchr (
+                        after, '\n', static_cast<size_t> (end - after));
+                    if (!nl)
+                      return matches;
+                    p = static_cast<const char *> (nl) + 1;
+                    carry = 0;
+                    continue;
+                  }
+              }
+            carry = 0;
+            rem >>= leading;
+            bit += leading;
+          }
+        else
+          {
+            /* Carry didn't extend — run ended at prev chunk boundary.  */
+            if (carry >= min_r)
+              {
+                matches++;
+                if (only_exists)
+                  return 1;
+                if (matches >= max_count)
+                  return matches;
+                if (count_lines)
+                  {
+                    const void *nl = std::memchr (
+                        p, '\n', static_cast<size_t> (end - p));
+                    if (!nl)
+                      return matches;
+                    p = static_cast<const char *> (nl) + 1;
+                    carry = 0;
+                    continue;
+                  }
+              }
+            carry = 0;
+          }
+
+        /* Iterate remaining runs of 1-bits.  */
+        while (rem)
+          {
+            /* Skip 0-bits to next run start.  */
+            unsigned skip = static_cast<unsigned> (__builtin_ctz (rem));
+            rem >>= skip;
+            bit += skip;
+            if (!rem)
+              break;
+            /* Count length of this run of 1-bits.  */
+            uint32_t inv1 = ~rem;
+            unsigned run_len;
+            if (inv1)
+              run_len = static_cast<unsigned> (__builtin_ctz (inv1));
+            else
+              run_len = 32 - bit;
+            if (bit + run_len >= 32)
+              {
+                /* Run extends to end of chunk → becomes carry.  */
+                carry = run_len;
+                break;
+              }
+            if (run_len >= min_r)
+              {
+                matches++;
+                if (only_exists)
+                  return 1;
+                if (matches >= max_count)
+                  return matches;
+                if (count_lines)
+                  {
+                    const char *after = p + bit + run_len;
+                    const void *nl = std::memchr (
+                        after, '\n', static_cast<size_t> (end - after));
+                    if (!nl)
+                      return matches;
+                    p = static_cast<const char *> (nl) + 1;
+                    carry = 0;
+                    goto next_chunk;
+                  }
+              }
+            rem >>= run_len;
+            bit += run_len;
+          }
+      }
+      p += 32;
+    next_chunk:;
+    }
+
+  /* Scalar tail (< 32 bytes remaining).  */
+  while (p < end)
+    {
+      if (class_byte_ok (k, static_cast<unsigned char> (*p)))
+        {
+          carry++;
+        }
+      else
+        {
+          if (carry >= min_r)
+            {
+              matches++;
+              if (only_exists)
+                return 1;
+              if (matches >= max_count)
+                return matches;
+              if (count_lines)
+                {
+                  const void *nl = std::memchr (
+                      p, '\n', static_cast<size_t> (end - p));
+                  if (!nl)
+                    return matches;
+                  p = static_cast<const char *> (nl) + 1;
+                  carry = 0;
+                  continue;
+                }
+            }
+          carry = 0;
+        }
+      p++;
+    }
+  /* Final run at end of data.  */
+  if (carry >= min_r)
+    matches++;
+  return matches;
+}
+#endif /* RG_ARCH_X86_64 */
+
+#if defined(RG_ARCH_AARCH64)
+/* NEON: generate 16-bit bitmask of class membership for 16 bytes.
+   Bit i is set iff byte p[i] belongs to class k.  */
+static inline uint16_t
+class_mask_neon (ClassKind k, const char *p) noexcept
+{
+  uint8x16_t block = vld1q_u8 (reinterpret_cast<const uint8_t *> (p));
+  uint8x16_t ok;
+  switch (k)
+    {
+    case ClassKind::Alpha:
+      {
+        uint8x16_t up = vandq_u8 (vcgeq_u8 (block, vdupq_n_u8 ('A')),
+                                   vcleq_u8 (block, vdupq_n_u8 ('Z')));
+        uint8x16_t lo = vandq_u8 (vcgeq_u8 (block, vdupq_n_u8 ('a')),
+                                   vcleq_u8 (block, vdupq_n_u8 ('z')));
+        ok = vorrq_u8 (up, lo);
+        break;
+      }
+    case ClassKind::Lower:
+      ok = vandq_u8 (vcgeq_u8 (block, vdupq_n_u8 ('a')),
+                      vcleq_u8 (block, vdupq_n_u8 ('z')));
+      break;
+    case ClassKind::Upper:
+      ok = vandq_u8 (vcgeq_u8 (block, vdupq_n_u8 ('A')),
+                      vcleq_u8 (block, vdupq_n_u8 ('Z')));
+      break;
+    case ClassKind::Digit:
+      ok = vandq_u8 (vcgeq_u8 (block, vdupq_n_u8 ('0')),
+                      vcleq_u8 (block, vdupq_n_u8 ('9')));
+      break;
+    case ClassKind::Alnum:
+      {
+        uint8x16_t up = vandq_u8 (vcgeq_u8 (block, vdupq_n_u8 ('A')),
+                                   vcleq_u8 (block, vdupq_n_u8 ('Z')));
+        uint8x16_t lo = vandq_u8 (vcgeq_u8 (block, vdupq_n_u8 ('a')),
+                                   vcleq_u8 (block, vdupq_n_u8 ('z')));
+        uint8x16_t dg = vandq_u8 (vcgeq_u8 (block, vdupq_n_u8 ('0')),
+                                   vcleq_u8 (block, vdupq_n_u8 ('9')));
+        ok = vorrq_u8 (vorrq_u8 (up, lo), dg);
+        break;
+      }
+    case ClassKind::Word:
+      {
+        uint8x16_t up = vandq_u8 (vcgeq_u8 (block, vdupq_n_u8 ('A')),
+                                   vcleq_u8 (block, vdupq_n_u8 ('Z')));
+        uint8x16_t lo = vandq_u8 (vcgeq_u8 (block, vdupq_n_u8 ('a')),
+                                   vcleq_u8 (block, vdupq_n_u8 ('z')));
+        uint8x16_t dg = vandq_u8 (vcgeq_u8 (block, vdupq_n_u8 ('0')),
+                                   vcleq_u8 (block, vdupq_n_u8 ('9')));
+        uint8x16_t un = vceqq_u8 (block, vdupq_n_u8 ('_'));
+        ok = vorrq_u8 (vorrq_u8 (vorrq_u8 (up, lo), dg), un);
+        break;
+      }
+    default:
+      return 0;
+    }
+  /* Extract one bit per byte → 16-bit mask.
+     vshrn narrows 16→8, giving a nibble per lane; but we want 1 bit/byte.
+     Use the addv approach: shift each 0xFF lane to its bit position.  */
+  static const uint8_t bit_pos[16]
+      = {1,2,4,8,16,32,64,128, 1,2,4,8,16,32,64,128};
+  uint8x16_t bits = vandq_u8 (ok, vld1q_u8 (bit_pos));
+  /* Add the low 8 and high 8 lanes separately.  */
+  uint8_t lo8 = vaddv_u8 (vget_low_u8 (bits));
+  uint8_t hi8 = vaddv_u8 (vget_high_u8 (bits));
+  return static_cast<uint16_t> (lo8) | (static_cast<uint16_t> (hi8) << 8);
+}
+
+/* Full NEON scan_class_run for non-prefix patterns.  16 bytes/chunk.  */
+static intmax_t
+scan_class_run_neon_impl (ClassKind k, unsigned min_r, const char *data,
+                          size_t size, bool count_lines, bool only_exists,
+                          intmax_t max_count)
+{
+  const char *p = data;
+  const char *const end = data + size;
+  intmax_t matches = 0;
+  unsigned carry = 0;
+
+  while (p + 16 <= end)
+    {
+      uint16_t mask = class_mask_neon (k, p);
+
+      if (mask == 0)
+        {
+          if (carry >= min_r)
+            {
+              matches++;
+              if (only_exists)
+                return 1;
+              if (matches >= max_count)
+                return matches;
+              if (count_lines)
+                {
+                  const void *nl
+                      = std::memchr (p, '\n', static_cast<size_t> (end - p));
+                  if (!nl)
+                    return matches;
+                  p = static_cast<const char *> (nl) + 1;
+                  carry = 0;
+                  continue;
+                }
+            }
+          carry = 0;
+          p += 16;
+          continue;
+        }
+
+      if (mask == 0xFFFFu)
+        {
+          carry += 16;
+          p += 16;
+          continue;
+        }
+
+      /* Mixed chunk.  */
+      {
+        uint16_t rem = mask;
+        unsigned bit = 0;
+        if (carry > 0 && (mask & 1u))
+          {
+            uint16_t inv0 = static_cast<uint16_t> (~mask);
+            unsigned leading = static_cast<unsigned> (__builtin_ctz (inv0));
+            carry += leading;
+            if (carry >= min_r)
+              {
+                matches++;
+                if (only_exists)
+                  return 1;
+                if (matches >= max_count)
+                  return matches;
+                if (count_lines)
+                  {
+                    const char *after = p + leading;
+                    const void *nl = std::memchr (
+                        after, '\n', static_cast<size_t> (end - after));
+                    if (!nl)
+                      return matches;
+                    p = static_cast<const char *> (nl) + 1;
+                    carry = 0;
+                    continue;
+                  }
+              }
+            carry = 0;
+            rem = static_cast<uint16_t> (rem >> leading);
+            bit += leading;
+          }
+        else
+          {
+            if (carry >= min_r)
+              {
+                matches++;
+                if (only_exists)
+                  return 1;
+                if (matches >= max_count)
+                  return matches;
+                if (count_lines)
+                  {
+                    const void *nl = std::memchr (
+                        p, '\n', static_cast<size_t> (end - p));
+                    if (!nl)
+                      return matches;
+                    p = static_cast<const char *> (nl) + 1;
+                    carry = 0;
+                    continue;
+                  }
+              }
+            carry = 0;
+          }
+
+        while (rem)
+          {
+            unsigned skip = static_cast<unsigned> (__builtin_ctz (rem));
+            rem = static_cast<uint16_t> (rem >> skip);
+            bit += skip;
+            if (!rem)
+              break;
+            uint16_t inv1 = static_cast<uint16_t> (~rem);
+            unsigned run_len;
+            if (inv1)
+              run_len = static_cast<unsigned> (__builtin_ctz (inv1));
+            else
+              run_len = 16 - bit;
+            if (bit + run_len >= 16)
+              {
+                carry = run_len;
+                break;
+              }
+            if (run_len >= min_r)
+              {
+                matches++;
+                if (only_exists)
+                  return 1;
+                if (matches >= max_count)
+                  return matches;
+                if (count_lines)
+                  {
+                    const char *after = p + bit + run_len;
+                    const void *nl = std::memchr (
+                        after, '\n', static_cast<size_t> (end - after));
+                    if (!nl)
+                      return matches;
+                    p = static_cast<const char *> (nl) + 1;
+                    carry = 0;
+                    goto next_chunk;
+                  }
+              }
+            rem = static_cast<uint16_t> (rem >> run_len);
+            bit += run_len;
+          }
+      }
+      p += 16;
+    next_chunk:;
+    }
+
+  /* Scalar tail.  */
+  while (p < end)
+    {
+      if (class_byte_ok (k, static_cast<unsigned char> (*p)))
+        carry++;
+      else
+        {
+          if (carry >= min_r)
+            {
+              matches++;
+              if (only_exists)
+                return 1;
+              if (matches >= max_count)
+                return matches;
+              if (count_lines)
+                {
+                  const void *nl = std::memchr (
+                      p, '\n', static_cast<size_t> (end - p));
+                  if (!nl)
+                    return matches;
+                  p = static_cast<const char *> (nl) + 1;
+                  carry = 0;
+                  continue;
+                }
+            }
+          carry = 0;
+        }
+      p++;
+    }
+  if (carry >= min_r)
+    matches++;
+  return matches;
+}
+
+/* NEON forward scan: find first class run >= min_r.  */
+static const char *
+find_class_run_forward_neon (ClassKind k, unsigned min_r,
+                              const char *data, size_t size,
+                              const char **run_end_out) noexcept
+{
+  const char *p = data;
+  const char *const end = data + size;
+  unsigned carry = 0;
+  const char *carry_start = nullptr;
+
+  while (p + 16 <= end)
+    {
+      uint16_t mask = class_mask_neon (k, p);
+
+      if (mask == 0)
+        {
+          if (carry >= min_r)
+            {
+              *run_end_out = p;
+              return carry_start;
+            }
+          carry = 0;
+          p += 16;
+          continue;
+        }
+
+      if (mask == 0xFFFFu)
+        {
+          if (carry == 0)
+            carry_start = p;
+          carry += 16;
+          p += 16;
+          continue;
+        }
+
+      /* Mixed chunk.  */
+      uint16_t inv = static_cast<uint16_t> (~mask);
+
+      if (carry > 0 && (mask & 1u))
+        {
+          unsigned leading = static_cast<unsigned> (__builtin_ctz (inv));
+          carry += leading;
+          if (carry >= min_r)
+            {
+              const char *re = p + leading;
+              while (re < end
+                     && class_byte_ok (k, static_cast<unsigned char> (*re)))
+                re++;
+              *run_end_out = re;
+              return carry_start;
+            }
+          carry = 0;
+        }
+      else if (carry > 0)
+        {
+          if (carry >= min_r)
+            {
+              *run_end_out = p;
+              return carry_start;
+            }
+          carry = 0;
+        }
+
+      uint16_t rem = mask;
+      unsigned bit = 0;
+      if (mask & 1u)
+        {
+          unsigned skip = static_cast<unsigned> (__builtin_ctz (inv));
+          rem = static_cast<uint16_t> (rem >> skip);
+          bit += skip;
+        }
+      while (rem)
+        {
+          unsigned skip = static_cast<unsigned> (__builtin_ctz (rem));
+          rem = static_cast<uint16_t> (rem >> skip);
+          bit += skip;
+          if (!rem)
+            break;
+          uint16_t inv1 = static_cast<uint16_t> (~rem);
+          unsigned run_len;
+          if (inv1)
+            run_len = static_cast<unsigned> (__builtin_ctz (inv1));
+          else
+            run_len = 16 - bit;
+          if (bit + run_len >= 16)
+            {
+              carry = run_len;
+              carry_start = p + bit;
+              goto next_fwd;
+            }
+          if (run_len >= min_r)
+            {
+              const char *rs = p + bit;
+              const char *re = p + bit + run_len;
+              while (re < end
+                     && class_byte_ok (k, static_cast<unsigned char> (*re)))
+                re++;
+              *run_end_out = re;
+              return rs;
+            }
+          rem = static_cast<uint16_t> (rem >> run_len);
+          bit += run_len;
+        }
+      carry = 0;
+    next_fwd:
+      p += 16;
+    }
+
+  /* Scalar tail.  */
+  unsigned run = carry;
+  const char *run_start = carry_start;
+  while (p < end)
+    {
+      if (class_byte_ok (k, static_cast<unsigned char> (*p)))
+        {
+          if (run == 0)
+            run_start = p;
+          run++;
+          if (run >= min_r)
+            {
+              const char *re = p + 1;
+              while (re < end
+                     && class_byte_ok (k, static_cast<unsigned char> (*re)))
+                re++;
+              *run_end_out = re;
+              return run_start;
+            }
+        }
+      else
+        {
+          if (run >= min_r)
+            {
+              *run_end_out = p;
+              return run_start;
+            }
+          run = 0;
+        }
+      p++;
+    }
+  if (run >= min_r)
+    {
+      *run_end_out = p;
+      return run_start;
+    }
+  return nullptr;
+}
