+/* Count trailing zero nibbles → index of first matching byte.  */
+static inline int
+neon_ctz4 (uint64_t mask)
+{
+  return __builtin_ctzll (mask) >> 2;
+}
+
+/* Clear the lowest set nibble in a NEON mask.  */
+static inline uint64_t
+neon_clear_low (uint64_t mask, int idx)
+{
+  return mask & ~(uint64_t (0xF) << (idx * 4));
+}
