+}
+
+/* Minimal copy of fgrep_to_grep_pattern from grep.c for F->G fallbacks.  */
+void
+fgrep_to_grep_pattern (char **keys, idx_t *len)
+{
+  idx_t n = *len;
+  char *p = *keys;
+  char *q = p;
+  for (idx_t i = 0; i < n; i++)
+    {
+      if (strchr ("\\.[]*+?{}|()^$", p[i]))
+        *q++ = '\\';
+      *q++ = p[i];
+    }
+  *len = q - p;
+}
diff --git a/src/rg_simd.cpp b/src/rg_simd.cpp
