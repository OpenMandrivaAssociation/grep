+          }
+
+          /* Emit the match line with color highlighting.  */
+          emit_line_pfx (match_ls, match_lno, true);
+          if (cmatch && !opt_replace)
+            {
+              intmax_t so = 0, eo = 0, nspans = 0;
+              find_match_span (match_ls, match_llen, &so, &eo, &nspans);
+              if (nspans > 0 && so >= 0 && eo > so)
+                {
+                  if (so > 0)
+                    tls_obuf.append (match_ls, static_cast<size_t> (so));
+                  tls_obuf.append (col_match, col_match_len);
+                  tls_obuf.append (match_ls + so, static_cast<size_t> (eo - so));
+                  tls_obuf.append (col_reset, col_reset_len);
+                  if (static_cast<size_t> (eo) < match_llen)
+                    tls_obuf.append (match_ls + eo, match_llen - static_cast<size_t> (eo));
+                }
+              else
+                tls_obuf.append (match_ls, match_llen);
+            }
+          else if (opt_replace)
+            {
+              intmax_t so = 0, eo = 0, nspans = 0;
+              find_match_span (match_ls, match_llen, &so, &eo, &nspans);
+              if (so > 0)
+                tls_obuf.append (match_ls, static_cast<size_t> (so));
+              if (cmatch)
+                tls_obuf.append (col_match, col_match_len);
+              tls_obuf.append (opt_replace, opt_replace_len);
+              if (cmatch)
+                tls_obuf.append (col_reset, col_reset_len);
+              size_t tail = static_cast<size_t> (eo);
+              if (tail < match_llen)
+                tls_obuf.append (match_ls + tail, match_llen - tail);
+            }
+          else
+            tls_obuf.append (match_ls, match_llen);
+          if (!match_llen || match_ls[match_llen - 1] != '\n')
+            tls_obuf.append ('\n');
+          tls_last_printed_lno = match_lno;
+
+          /* Emit after-context lines.  Use next_hit to skip expensive
+             line_matches_pattern when the next match is beyond the
+             after-context window.  */
+          const char *after_end = match_le;
+          {
+            const char *p = match_le;
+            intmax_t lno = match_lno + 1;
+            for (intmax_t a = 0; a < ctx_a && p < end; a++)
+              {
+                const char *nl = static_cast<const char *> (
+                  memchr (p, '\n', static_cast<size_t> (end - p)));
+                const char *le = nl ? nl + 1 : end;
+                size_t llen = static_cast<size_t> (le - p);
+                /* Check if this after-context line is itself a match.
+                   Fast path: if next_hit is beyond this line's end, the
+                   line cannot be a match — skip find_fixed_word entirely.  */
+                size_t cl = nl ? static_cast<size_t> (nl - p)
+                               : static_cast<size_t> (end - p);
+                bool ctx_is_match;
+                if (next_hit >= le)
+                  ctx_is_match = false;
+                else if (next_hit >= p && next_hit < le)
+                  {
+                    ctx_is_match = line_matches_pattern (p, cl);
+                    if (ctx_is_match)
+                      {
+                        /* This context line is actually a match — advance
+                           next_hit past this line for subsequent checks.  */
+                        next_hit = find_match (le);
+                      }
+                  }
+                else
+                  ctx_is_match = line_matches_pattern (p, cl);
+                if (ctx_is_match)
+                  {
+                    r.found = true;
+                    r.matches++;
+                    if (__builtin_expect (opt_stats, 0))
+                      stat_lines_matched.fetch_add (1, std::memory_order_relaxed);
+                  }
+                emit_line_pfx (p, lno, ctx_is_match);
+                if (ctx_is_match && cmatch)
+                  {
+                    intmax_t mso, meo, mns;
+                    find_match_span (p, cl, &mso, &meo, &mns);
+                    if (mns > 0 && mso >= 0 && meo > mso)
+                      {
+                        if (mso > 0)
+                          tls_obuf.append (p, static_cast<size_t> (mso));
+                        tls_obuf.append (col_match, col_match_len);
+                        tls_obuf.append (p + mso, static_cast<size_t> (meo - mso));
+                        tls_obuf.append (col_reset, col_reset_len);
+                        if (static_cast<size_t> (meo) < llen)
+                          tls_obuf.append (p + meo, llen - static_cast<size_t> (meo));
+                      }
+                    else
+                      tls_obuf.append (p, llen);
+                  }
+                else
+                  tls_obuf.append (p, llen);
+                if (!llen || p[llen - 1] != '\n')
+                  tls_obuf.append ('\n');
+                tls_last_printed_lno = lno;
+                lno++;
+                p = le;
+                after_end = le;
+                if (ctx_is_match)
+                  {
+                    a = -1;
+                    if (r.matches >= opt_max_count)
+                      break;
+                  }
+              }
+          }
+          last_emitted_end = after_end;
+
+          if (tls_obuf.should_flush ())
+            out_flush_tls ();
+          if (r.matches >= opt_max_count)
+            break;
+          cur_pos = match_le;
+          cur_lno = match_lno + 1;
+        }
+      out_flush_tls ();
+      return r;
+    }
+
+  /* Context / json / invert / passthru: unified line walker for rg-compatible output.  */
+  if (needs_line_mode ())
+    return search_lines_with_context (path, data, size);
+
+  bool count_mode = opt_count || opt_quiet || opt_files_with_matches || opt_files_without_match;
+
+  /* Multi-literal chain fast path: `lit1.*lit2[.*lit3...]` without DFA.  */
+  if (g_lit_chain_active && !opt_passthru && !opt_invert)
+    {
+      if (count_mode)
+        return search_lit_chain_count (path, data, size,
+                                       opt_quiet || opt_files_with_matches);
+      return search_lit_chain_print (path, data, size);
+    }
+
+  /* Class-run print: bypass DFA for patterns like [a-z]{8} — scan_class_run
+     uses SIMD byte-class skip, much faster than DFA per-byte execute.  */
+  if (g_class_run.active () && !opt_passthru && !opt_invert && !count_mode
+      && !opt_word && !opt_line)
+    return search_class_run_print (path, data, size);
+
+  if (!opt_fixed && g_use_dfa && !opt_passthru && !opt_invert)
+    {
+      if (count_mode)
+        return search_dfa_count_or_exists (path, data, size, opt_quiet || opt_files_with_matches);
+      return search_dfa_print (path, data, size);
+    }
+
+  if (opt_fixed && !opt_invert && !opt_passthru)
+    return search_fixed (path, data, size);
+
+  if (g_use_dfa && !opt_passthru && !opt_invert)
+    {
+      if (count_mode)
+        return search_dfa_count_or_exists (path, data, size, opt_quiet || opt_files_with_matches);
+      return search_dfa_print (path, data, size);
+    }
+
+  /* Fallback: line mode covers remaining cases.  */
+  return search_lines_with_context (path, data, size);
+}
+
+/* --pre=COMMAND: search stdout of `COMMAND path` instead of file contents.  */
+static bool
+pre_glob_ok (const std::string &path)
+{
+  if (opt_pre_globs.empty ())
+    return true;
+  auto slash = path.rfind ('/');
+  std::string_view base = slash == std::string::npos ? std::string_view (path)
+                                                     : std::string_view (path).substr (slash + 1);
+  for (const auto &g : opt_pre_globs)
+    if (glob_match (g, base) || glob_match (g, path))
+      return true;
+  return false;
+}
+
+static SearchResult
+search_pre_command (const std::string &path)
+{
+  SearchResult r{};
+  if (!opt_pre_command || !*opt_pre_command || path == "-")
+    return r;
+  if (!pre_glob_ok (path))
+    return r;
+
+  /* Build: COMMAND PATH  (shell-escape path minimally via single quotes).  */
+  std::string cmd = opt_pre_command;
+  cmd.push_back (' ');
+  cmd.push_back ('\'');
+  for (char ch : path)
+    {
+      if (ch == '\'')
+        cmd += "'\\''";
+      else
+        cmd.push_back (ch);
+    }
+  cmd.push_back ('\'');
+
+  FILE *fp = popen (cmd.c_str (), "r");
+  if (!fp)
+    {
+      if (!opt_no_messages)
+        fprintf (stderr, "%s: --pre failed for %s: %s\n", g_prog, path.c_str (),
+                 strerror (errno));
+      return r;
+    }
+
+  size_t cap = 1 << 20, len = 0;
+  char *buf = static_cast<char *> (malloc (cap));
+  if (!buf)
+    {
+      pclose (fp);
+      die ("out of memory");
+    }
+  for (;;)
+    {
+      if (len + (1 << 16) > cap)
+        {
+          cap *= 2;
+          buf = static_cast<char *> (realloc (buf, cap));
+          if (!buf)
+            {
+              pclose (fp);
+              die ("out of memory");
+            }
+        }
+      size_t n = fread (buf + len, 1, cap - len, fp);
+      if (n == 0)
+        break;
+      len += n;
+    }
+  pclose (fp);
+  stat_files_searched.fetch_add (1, std::memory_order_relaxed);
+  r = search_buffer (path.c_str (), buf, len);
+  free (buf);
+  if (r.found)
+    stat_files_matched.fetch_add (1, std::memory_order_relaxed);
+  return r;
+}
+
+/* mmap for large files; TLS read for small recurse files (mmap/munmap per
+   tiny/mid file dominates).  */
+/* mmap avoids copying large files into TLS; 16 KiB for recurse (many small
+   files still use TLS read; slightly lower bar helps medium sources).  */
+static constexpr off_t k_mmap_min_size = 16 * 1024;
+
+static bool
+engine_needs_bol_sentinel ()
+{
+#if HAVE_LIBPCRE
+  return g_exec == Pexecute || g_exec == Pexecute_whole;
+#else
+  return false;
+#endif
+}
+
+struct TlsReadBuf {
+  char *p = nullptr;
+  size_t cap = 0;
+  ~TlsReadBuf () { free (p); }
+  char *ensure (size_t need)
+  {
+    if (cap >= need)
+      return p;
+    size_t nc = cap ? cap : 65536;
+    while (nc < need)
+      nc *= 2;
+    char *np = static_cast<char *> (realloc (p, nc));
+    if (!np)
+      die ("out of memory");
+    p = np;
+    cap = nc;
+    return p;
+  }
+};
+
+static thread_local TlsReadBuf tls_rbuf;
+
+/* known_size >= 0: caller already stat'd (walk path); skip fstat.  */
+/* Search a file.  When DIRFD >= 0 and NAME is non-null, try openat(dirfd,name)
+   first (walk hot path — avoids re-walking the path in the kernel).  PATH is
+   still the display/report path.  */
+static SearchResult
+search_file_ex (const std::string &path, off_t known_size,
+                int dirfd = -1, const char *at_name = nullptr)
+{
+  SearchResult r{};
+  /* Only set engine filename when errors may report it (PCRE/DFA die paths);
+     skip in the common recursive hot path for -c/-l/-q.  */
+  if (!opt_count && !opt_quiet && !opt_files_with_matches && !opt_files_without_match)
+    rg_set_input_filename (path.c_str ());
+  bool is_stdin = path == "-";
+
+  if (!is_stdin && opt_pre_command && *opt_pre_command)
+    return search_pre_command (path);
+
+  if (!is_stdin && opt_max_filesize > 0 && known_size > 0
+      && known_size > opt_max_filesize)
+    return r;
+
+  int fd = STDIN_FILENO;
+  if (!is_stdin)
+    {
+      if (dirfd >= 0 && at_name)
+        fd = openat (dirfd, at_name, O_RDONLY | O_CLOEXEC);
+      else
+        fd = -1;
+      if (fd < 0)
+        fd = open (path.c_str (), O_RDONLY | O_CLOEXEC);
+      if (fd < 0)
+        return r;
+    }
+
+  struct stat st;
+  if (known_size >= 0 && !is_stdin)
+    {
+      /* Walk already classified as regular file; synthesize st for size/mode.  */
+      st = {};
+      st.st_mode = S_IFREG;
+      st.st_size = known_size;
+    }
+  else if (!is_stdin && known_size == -2)
+    {
+      /* Walk: DT_REG, size unknown; skip fstat — grow-read / mmap-after-probe.  */
+      st = {};
+      st.st_mode = S_IFREG;
+      st.st_size = -1; /* unknown; use read-fallback path below */
+    }
+  else if (fstat (fd, &st) != 0)
+    {
+      if (!is_stdin)
+        close (fd);
+      return r;
+    }
+  if (opt_max_filesize > 0 && S_ISREG (st.st_mode) && st.st_size > opt_max_filesize)
+    {
+      if (!is_stdin)
+        close (fd);
+      return r;
+    }
+
+  /* Stats atomics are relatively hot under parallel recursive; only if --stats.  */
+  if (opt_stats)
+    stat_files_searched.fetch_add (1, std::memory_order_relaxed);
+
+  /* Skip fadvise on tiny/medium files (syscall cost > benefit under parallel load).  */
+#ifdef POSIX_FADV_SEQUENTIAL
+  if (!is_stdin && S_ISREG (st.st_mode) && st.st_size >= (1 << 20))
+    posix_fadvise (fd, 0, st.st_size, POSIX_FADV_SEQUENTIAL);
+#endif
+
+  const bool need_bol = engine_needs_bol_sentinel ();
+
+  /* PCRE + large file: map file at +1 byte offset inside an anonymous region
+     so Pexecute can read data[-1] as eolbyte without copying the whole file.  */
+  auto try_pcre_sentinel_mmap = [&] (off_t fsz) -> bool {
+    if (!need_bol || is_stdin || !opt_mmap || !S_ISREG (st.st_mode))
+      return false;
+    if (fsz < k_mmap_min_size || fsz > static_cast<off_t> (SIZE_MAX / 4))
+      return false;
+    size_t fsz_s = static_cast<size_t> (fsz);
+    size_t total = fsz_s + 2; /* [0]=eol, [1..fsz]=file, [fsz+1]=0 */
+    void *base = mmap (nullptr, total, PROT_READ | PROT_WRITE,
+                       MAP_PRIVATE | MAP_ANONYMOUS, -1, 0);
+    if (base == MAP_FAILED)
+      return false;
+    char *cbase = static_cast<char *> (base);
+    cbase[0] = static_cast<char> (eolbyte ? eolbyte : '\n');
+    /* Map file contents at offset 1 (may fail if no MAP_FIXED support).  */
+    void *fmap = mmap (cbase + 1, fsz_s, PROT_READ | PROT_WRITE,
+                       MAP_PRIVATE | MAP_FIXED, fd, 0);
+    if (fmap == MAP_FAILED)
+      {
+        /* Fall back: read file into the anon region (still avoids TLS realloc).  */
+        size_t got = 0;
+        while (got < fsz_s)
+          {
+            ssize_t n = pread (fd, cbase + 1 + got, fsz_s - got,
+                               static_cast<off_t> (got));
+            if (n < 0)
+              {
+                if (errno == EINTR)
+                  continue;
+                munmap (base, total);
+                return false;
+              }
+            if (n == 0)
+              break;
+            got += static_cast<size_t> (n);
+          }
+        cbase[1 + got] = 0;
+        r = search_buffer (path.c_str (), cbase + 1, got);
+      }
+    else
+      {
+        cbase[fsz_s + 1] = 0;
+#ifdef MADV_SEQUENTIAL
+        madvise (cbase + 1, fsz_s, MADV_SEQUENTIAL);
+#endif
+        r = search_buffer (path.c_str (), cbase + 1, fsz_s);
+      }
+    munmap (base, total);
+    close (fd);
+    if (r.found)
+      stat_files_matched.fetch_add (1, std::memory_order_relaxed);
+    return true;
+  };
+
+  if (try_pcre_sentinel_mmap (st.st_size))
+    return r;
+
+  /* Known size: one-shot read into TLS buffer (+1 DFA / +2 PCRE BOL sentinel).
+     st_size < 0 (DT_REG without fstat): fall through to grow-read.  */
+  if (!is_stdin && S_ISREG (st.st_mode) && st.st_size >= 0
+      && st.st_size < k_mmap_min_size)
+    {
+      size_t sz = static_cast<size_t> (st.st_size);
+      if (sz == 0)
+        {
+          close (fd);
+          if (opt_count && opt_include_zero)
+            emit_count (path.c_str (), 0);
+          return r;
+        }
+      size_t off0 = need_bol ? 1 : 0;
+      char *buf = tls_rbuf.ensure (sz + off0 + 1);
+      if (need_bol)
+        buf[0] = static_cast<char> (eolbyte ? eolbyte : '\n');
+      size_t got = 0;
+      while (got < sz)
+        {
+          ssize_t n = read (fd, buf + off0 + got, sz - got);
+          if (n < 0)
+            {
+              if (errno == EINTR)
+                continue;
+              close (fd);
+              return r;
+            }
+          if (n == 0)
+            break;
+          got += static_cast<size_t> (n);
+        }
+      close (fd);
+      buf[off0 + got] = 0;
+      r = search_buffer (path.c_str (), buf + off0, got);
+      if (r.found && opt_stats)
+        stat_files_matched.fetch_add (1, std::memory_order_relaxed);
+      return r;
+    }
+
+  /* Huge single files: mmap avoids copying tens of MiB into TLS.  */
+  if (!is_stdin && opt_mmap && !need_bol && S_ISREG (st.st_mode)
+      && st.st_size >= k_mmap_min_size
+      && st.st_size >= 0
+      && st.st_size <= static_cast<off_t> (SIZE_MAX / 2))
+    {
+      size_t mlen = 0;
+      void *map = perf_try_mmap (fd, st.st_size, &mlen);
+      size_t unmap_len = mlen;
+      if (!map)
+        {
+          size_t map_sz = static_cast<size_t> (st.st_size) + 1;
+          map = mmap (nullptr, map_sz, PROT_READ | PROT_WRITE, MAP_PRIVATE, fd, 0);
+          if (map != MAP_FAILED)
+            {
+              mlen = static_cast<size_t> (st.st_size);
+              unmap_len = map_sz;
+              static_cast<char *> (map)[mlen] = 0;
+#ifdef MADV_SEQUENTIAL
+              madvise (map, mlen, MADV_SEQUENTIAL);
+#endif
+            }
+          else
+            map = nullptr;
+        }
+      else
+        {
+          unmap_len = mlen + 1;
+#ifdef MADV_SEQUENTIAL
+          madvise (map, mlen, MADV_SEQUENTIAL);
+#endif
+        }
+      if (map)
+        {
+          r = search_buffer (path.c_str (), static_cast<const char *> (map), mlen);
+          /* Unmap is optional for short-lived processes; still do it for
+             multi-file recurse so we do not accumulate address space.  */
+          munmap (map, unmap_len);
+          close (fd);
+          if (r.found && opt_stats)
+            stat_files_matched.fetch_add (1, std::memory_order_relaxed);
+          return r;
+        }
+    }
+
+  /* Fallback read path.  */
+  size_t off0 = need_bol ? 1 : 0;
+  size_t len = 0;
+  char *buf = tls_rbuf.ensure ((1 << 20) + off0);
+  if (need_bol)
+    buf[0] = static_cast<char> (eolbyte ? eolbyte : '\n');
+  size_t cap = tls_rbuf.cap;
+  for (;;)
+    {
+      if (off0 + len + (1 << 16) + 1 > cap)
+        {
+          buf = tls_rbuf.ensure (cap * 2);
+          if (need_bol)
+            buf[0] = static_cast<char> (eolbyte ? eolbyte : '\n');
+          cap = tls_rbuf.cap;
+        }
+      ssize_t n = read (fd, buf + off0 + len, cap - off0 - len - 1);
+      if (n < 0)
+        {
+          if (errno == EINTR)
+            continue;
+          break;
+        }
+      if (n == 0)
+        break;
+      len += static_cast<size_t> (n);
+    }
+  if (!is_stdin)
+    close (fd);
+  buf[off0 + len] = 0;
+  r = search_buffer (path.c_str (), buf + off0, len);
+  if (r.found && opt_stats)
+    stat_files_matched.fetch_add (1, std::memory_order_relaxed);
+  return r;
+}
+
+static SearchResult
+search_file (const std::string &path)
+{
+  return search_file_ex (path, -1);
+}
+
+/* ---------- parallel search (lock-free index steal; no per-file mutex) ---------- */
+
+static std::atomic<bool> g_any{false};
+static std::atomic<bool> g_stop{false};
+static std::atomic<size_t> g_job_idx{0};
+static const std::vector<std::string> *g_jobs = nullptr;
+
+static int
+n_workers ()
+{
+  int n = opt_threads > 0 ? opt_threads : 0;
+  if (n <= 0)
+    {
+      long nc = sysconf (_SC_NPROCESSORS_ONLN);
+      /* Lock-free steal scales well; sweet spot often ~cores, not 2×cores.  */
+      if (nc <= 0)
+        n = 8;
+      else if (nc > 24)
+        n = 24;
+      else
+        n = static_cast<int> (nc);
+    }
+  return n < 1 ? 1 : n;
+}
+
+static void
+worker_steal ()
+{
+  if (!g_jobs)
+    return;
+  const size_t n = g_jobs->size ();
+  for (;;)
+    {
+      if (g_stop.load (std::memory_order_relaxed))
+        break;
+      size_t i = g_job_idx.fetch_add (1, std::memory_order_relaxed);
+      if (i >= n)
+        break;
+      SearchResult r = search_file ((*g_jobs)[i]);
+      if (r.found)
+        g_any.store (true, std::memory_order_relaxed);
+      if (opt_quiet && g_any.load (std::memory_order_relaxed))
+        {
+          g_stop.store (true, std::memory_order_relaxed);
+          break;
+        }
+    }
+}
+
+/* Search a pre-collected file list with N workers stealing indices.
+   Workers flush TLS batched output at exit.  */
+static bool
+parallel_search_files (const std::vector<std::string> &files)
+{
+  if (files.empty ())
+    return false;
+
+  g_any = false;
+  g_stop = false;
+  g_job_idx = 0;
+  g_jobs = &files;
+
+  int nw = n_workers ();
+  /* Thread spawn costs ~µs–ms; only tiny lists stay single-threaded.  */
+  if (files.size () < 4 || nw <= 1 || opt_passthru)
+    {
+      for (const auto &p : files)
+        {
+          if (g_stop.load (std::memory_order_relaxed))
+            break;
+          SearchResult r = search_file (p);
+          if (r.found)
+            g_any.store (true, std::memory_order_relaxed);
+          if (opt_quiet && g_any.load (std::memory_order_relaxed))
+            break;
+        }
+      out_flush_tls ();
+      g_jobs = nullptr;
+      return g_any.load ();
+    }
+
+  if (static_cast<size_t> (nw) > files.size ())
+    nw = static_cast<int> (files.size ());
+  /* Cap workers: allow up to min(nw, files) — steal scales; recurse benefits.  */
+  {
+    size_t max_w = files.size ();
+    if (max_w > 1 && static_cast<size_t> (nw) > max_w)
+      nw = static_cast<int> (max_w);
+  }
+
+  auto worker = [] () {
+    worker_steal ();
+    out_flush_tls ();
+  };
+
+  std::vector<std::thread> ths;
+  ths.reserve (static_cast<size_t> (nw));
+  for (int i = 0; i < nw; i++)
+    ths.emplace_back (worker);
+  for (auto &t : ths)
+    t.join ();
+  out_flush_tls ();
+  g_jobs = nullptr;
+  return g_any.load ();
+}
+
+/* ---------- directory walk ---------- */
+
+static void collect_dir (const std::string &dirpath, const std::string &relbase,
+                         std::vector<std::string> *files_out, bool queue_mode);
+
+/* Open directory for walk: prefer O_DIRECTORY|O_CLOEXEC then fdopendir so we
+   keep a dirfd for fstatat/statx of children (cheaper than full-path lstat).  */
+static DIR *
+rg_opendir_fd (const std::string &dirpath, int *out_fd)
+{
+  *out_fd = -1;
+  int fd = open (dirpath.c_str (), O_RDONLY | O_DIRECTORY | O_CLOEXEC);
+  if (fd < 0)
+    return opendir (dirpath.c_str ());
+  DIR *d = fdopendir (fd);
+  if (!d)
+    {
+      close (fd);
+      return opendir (dirpath.c_str ());
+    }
+  *out_fd = fd; /* owned by DIR; do not close separately */
+  return d;
+}
+
+/* Append dirpath/name into OUT (reuses capacity).  */
+static void
+path_join_into (std::string &out, const std::string &dirpath, const char *name)
+{
+  out.assign (dirpath);
+  out.push_back ('/');
+  out.append (name);
+}
+
+/* Skip well-known heavy / non-source trees without reading .gitignore.  */
+static bool
+is_skip_dirname (const char *name)
+{
+  /* Always skip VCS metadata unless -uuu.  */
+  if (opt_unrestricted < 3)
+    {
+      if (str_eq (name, ".git") || str_eq (name, ".hg") || str_eq (name, ".svn")
+          || str_eq (name, ".bzr"))
+        return true;
+    }
+  /* Always skip a few universally-useless dirs even when honoring gitignore
+     (ripgrep also effectively avoids these via ignore files, but early exit
+     avoids opening/reading their .gitignore at all).  Keep this list SMALL —
+     over-skipping here under-searches vs rust rg.  */
+  static const char *const always_skip[] = {
+    "node_modules", "__pycache__", ".tox", ".venv", "venv",
+    ".mypy_cache", ".pytest_cache",
+    nullptr
+  };
+  for (int i = 0; always_skip[i]; i++)
+    if (str_eq (name, always_skip[i]))
+      return true;
+  /* Broader heuristics only when ignore files are disabled (-u / --no-ignore).  */
+  if (opt_unrestricted >= 1 || opt_no_ignore)
+    {
+      static const char *const extra[] = {
+        "target", "build", "dist", ".cache",
+        "CMakeFiles", ".gradle", "vendor", "third_party",
+        nullptr
+      };
+      for (int i = 0; extra[i]; i++)
+        if (str_eq (name, extra[i]))
+          return true;
+    }
+  return false;
+}
+
+/* Ripgrep skips many binary/archive extensions by default (no --text).  */
+static bool
+is_likely_binary_name (const char *name)
+{
+  /* -uuu, -a/--text, or --binary: search everything.  */
+  if (opt_text || opt_binary_search || opt_unrestricted >= 3)
+    return false;
+  /* Extensionless build artifacts (grep tree ships many *.gcc / rg_g etc.).  */
+  if (str_eq (name, "core") || str_eq (name, "a.out"))
+    return true;
+  const char *dot = std::strrchr (name, '.');
+  if (!dot || !dot[1])
+    return false;
+  const char *ext = dot + 1;
+  /* Extension heuristic aligned with ripgrep's default binary filter:
+     objects/archives/media are skipped; tracked text and most other files
+     are listed in --files (ignore rules still apply).  */
+  static const char *const bin_ext[] = {
+    "o", "a", "lo", "la", "so", "dylib", "dll", "exe", "bin",
+    "obj", "lib", "pdb",
+    "png", "jpg", "jpeg", "gif", "webp", "ico", "bmp", "tif", "tiff",
+    "mp3", "mp4", "mkv", "avi", "mov", "wav", "flac", "ogg", "webm",
+    "zip", "7z", "rar", "tar", "tgz",
+    "pdf", "doc", "docx", "xls", "xlsx", "ppt", "pptx",
+    "pyc", "pyo", "jar", "war", "ear",
+    "woff", "woff2", "ttf", "otf", "eot",
+    "db", "sqlite", "sqlite3",
+    nullptr
+  };
+  for (int i = 0; bin_ext[i]; i++)
+    if (strcasecmp (ext, bin_ext[i]) == 0)
+      return true;
+  return false;
+}
+
+static void
+collect_dir (const std::string &dirpath, const std::string &relbase,
+             std::vector<std::string> *files_out, bool queue_mode)
+{
+  int dfd = -1;
+  DIR *d = rg_opendir_fd (dirpath, &dfd);
+  if (!d)
+    return;
+
+  /* --no-ignore / -uuu: skip all ignore file I/O and matching (big win on
+     large trees).  -u still skips VCS dirs via is_skip_dirname.  */
+  const bool skip_ignore = opt_no_ignore || opt_unrestricted >= 3;
+  int ignore_frames = 0;
+  if (!skip_ignore)
+    {
+      maybe_note_vcs_root (relbase, dirpath, dfd);
+      ignore_frames = push_dir_ignores (dirpath, relbase);
+    }
+
+  /* Track depth for --max-depth (ripgrep counts from search root).  */
+  int depth = 0;
+  if (!relbase.empty ())
+    {
+      depth = 1;
+      for (char ch : relbase)
+        if (ch == '/')
+          depth++;
+    }
+
+  const bool need_sort = opt_sort_files
+                         || (opt_sort_by && !str_eq (opt_sort_by, "none"));
+
+  struct Ent {
+    std::string full, rel;
+    bool is_dir = false;
+    bool is_reg = false;
+  };
+  std::vector<Ent> ents;
+  if (need_sort)
+    ents.reserve (64);
+
+  /* Reuse path buffers in the non-sort fast path.  */
+  std::string full_buf;
+  full_buf.reserve (dirpath.size () + 64);
+  std::string rel_buf;
+  rel_buf.reserve (relbase.size () + 64);
+
+  /* Process entries; recurse/queue inline when unsorted (avoids second pass
+     and keeps memory lower on huge trees).  */
+  auto handle_file = [&] (std::string &&full, std::string &&rel) {
+    if (opt_max_depth >= 0 && depth > opt_max_depth)
+      return;
+    if (!glob_ok (rel))
+      return;
+    /* queue_mode is legacy; always collect into files_out when provided.  */
+    (void) queue_mode;
+    if (files_out)
+      files_out->push_back (std::move (full));
+  };
+  auto handle_dir = [&] (std::string &&full, std::string &&rel) {
+    if (opt_max_depth >= 0 && depth >= opt_max_depth)
+      return;
+    collect_dir (std::move (full), std::move (rel), files_out, queue_mode);
+  };
+
+  while (dirent *de = readdir (d))
+    {
+      if (g_stop.load (std::memory_order_relaxed))
+        break;
+      if (str_eq (de->d_name, ".") || str_eq (de->d_name, ".."))
+        continue;
+      bool know_dir = false, know_reg = false, know_lnk = false;
+#ifdef DT_DIR
+      if (de->d_type == DT_DIR)
+        know_dir = true;
+      else if (de->d_type == DT_REG)
+        know_reg = true;
+      else if (de->d_type == DT_LNK)
+        know_lnk = true;
+#endif
+      if (know_dir && is_skip_dirname (de->d_name))
+        continue;
+      if (know_lnk && !opt_follow)
+        continue;
+      if (know_reg && is_likely_binary_name (de->d_name))
+        continue;
+
+      bool is_dir = know_dir;
+      bool is_reg = know_reg;
+      bool have_full = false;
+      if (!know_dir && !know_reg)
+        {
+          path_join_into (full_buf, dirpath, de->d_name);
+          have_full = true;
+          struct stat st;
+          if (!rg_lstat_at (dfd, de->d_name, full_buf.c_str (), &st))
+            continue;
+          if (S_ISLNK (st.st_mode) && !opt_follow)
+            continue;
+          is_dir = S_ISDIR (st.st_mode);
+          is_reg = S_ISREG (st.st_mode);
+          if (opt_one_file_system)
+            {
+              if (!g_root_dev_set)
+                {
+                  g_root_dev = st.st_dev;
+                  g_root_dev_set = true;
+                }
+              else if (st.st_dev != g_root_dev)
+                continue;
+            }
+          if (is_dir && is_skip_dirname (de->d_name))
+            continue;
+          if (is_reg && is_likely_binary_name (de->d_name))
+            continue;
+        }
+
+      if (relbase.empty ())
+        rel_buf.assign (de->d_name);
+      else
+        {
+          rel_buf.assign (relbase);
+          rel_buf.push_back ('/');
+          rel_buf.append (de->d_name);
+        }
+
+      /* Hidden skip after we know is_dir (whitelist may un-hide .github).  */
+      if (skip_hidden_entry (de->d_name, rel_buf, is_dir))
+        continue;
+
+      if (!skip_ignore && should_ignore_path (rel_buf, is_dir))
+        continue;
+
+      if (!have_full)
+        path_join_into (full_buf, dirpath, de->d_name);
+
+      if (need_sort)
+        {
+          Ent e;
+          e.full = full_buf;
+          e.rel = rel_buf;
+          e.is_dir = is_dir;
+          e.is_reg = is_reg;
+          ents.push_back (std::move (e));
+        }
+      else if (is_dir)
+        handle_dir (std::string (full_buf), std::string (rel_buf));
+      else if (is_reg)
+        handle_file (std::string (full_buf), std::string (rel_buf));
+    }
+  closedir (d);
+
+  if (need_sort)
+    {
+      std::sort (ents.begin (), ents.end (),
+                 [] (const Ent &a, const Ent &b) {
+                   int c = a.rel.compare (b.rel);
+                   return opt_sort_reverse ? c > 0 : c < 0;
+                 });
+      for (auto &e : ents)
+        {
+          if (e.is_dir)
+            handle_dir (std::move (e.full), std::move (e.rel));
+          else if (e.is_reg)
+            handle_file (std::move (e.full), std::move (e.rel));
+        }
+    }
+
+  while (ignore_frames-- > 0)
+    pop_ignore ();
+}
+
+/* Shared parallel directory walk (optional ignore via registry).  */
+static void
+parallel_collect_dirs (const std::vector<std::string> &roots,
+                       std::vector<std::string> *files_out, bool with_ignore)
+{
+  std::deque<std::pair<std::string, std::string>> seed; /* full, rel */
+  for (const auto &root : roots)
+    {
+      struct stat st;
+      if (stat (root.c_str (), &st) != 0)
+        continue;
+      if (S_ISDIR (st.st_mode))
+        seed.emplace_back (root, root == "." ? "" : root);
+      else if (S_ISREG (st.st_mode))
+        files_out->push_back (root);
+    }
+  if (seed.empty ())
+    return;
+
+  if (with_ignore)
+    register_global_frames_from_stack ();
+
+  std::mutex mu;
+  std::deque<std::pair<std::string, std::string>> dq = std::move (seed);
+  std::condition_variable cv;
+  int active = 0;
+  bool done = false;
+  std::mutex files_mu;
+
+  auto worker = [&] () {
+    for (;;)
+      {
+        std::pair<std::string, std::string> job;
+        {
+          std::unique_lock lk (mu);
+          cv.wait (lk, [&] { return !dq.empty () || (done && active == 0); });
+          if (dq.empty ())
+            return;
+          job = std::move (dq.front ());
+          dq.pop_front ();
+          active++;
+        }
+        const std::string &dirpath = job.first;
+        const std::string &relbase = job.second;
+        if (with_ignore)
+          ensure_dir_ignores_registered (dirpath, relbase);
+
+        int dfd = -1;
+        DIR *d = rg_opendir_fd (dirpath, &dfd);
+        if (d)
+          {
+            if (with_ignore)
+              maybe_note_vcs_root (relbase, dirpath, dfd);
+            int depth = 0;
+            if (!relbase.empty ())
+              {
+                depth = 1;
+                for (char ch : relbase)
+                  if (ch == '/')
+                    depth++;
+              }
+            std::vector<std::pair<std::string, std::string>> local_dirs;
+            std::vector<std::string> local_files;
+            std::string full_b, rel_b;
+            full_b.reserve (dirpath.size () + 64);
+            rel_b.reserve (relbase.size () + 64);
+            while (dirent *de = readdir (d))
+              {
+                if (str_eq (de->d_name, ".") || str_eq (de->d_name, ".."))
+                  continue;
+                bool know_dir = false, know_reg = false, know_lnk = false;
+#ifdef DT_DIR
+                if (de->d_type == DT_DIR)
+                  know_dir = true;
+                else if (de->d_type == DT_REG)
+                  know_reg = true;
+                else if (de->d_type == DT_LNK)
+                  know_lnk = true;
+#endif
+                if (know_dir && is_skip_dirname (de->d_name))
+                  continue;
+                if (know_lnk && !opt_follow)
+                  continue;
+                if (know_reg && is_likely_binary_name (de->d_name))
+                  continue;
+                bool is_dir = know_dir, is_reg = know_reg;
+                bool have_full = false;
+                if (!know_dir && !know_reg)
+                  {
+                    path_join_into (full_b, dirpath, de->d_name);
+                    have_full = true;
+                    struct stat st;
+                    if (!rg_lstat_at (dfd, de->d_name, full_b.c_str (), &st))
+                      continue;
+                    if (S_ISLNK (st.st_mode) && !opt_follow)
+                      continue;
+                    is_dir = S_ISDIR (st.st_mode);
+                    is_reg = S_ISREG (st.st_mode);
+                    if (is_dir && is_skip_dirname (de->d_name))
+                      continue;
+                    if (is_reg && is_likely_binary_name (de->d_name))
+                      continue;
+                  }
+                if (relbase.empty ())
+                  rel_b.assign (de->d_name);
+                else
+                  {
+                    rel_b.assign (relbase);
+                    rel_b.push_back ('/');
+                    rel_b.append (de->d_name);
+                  }
+                if (skip_hidden_entry (de->d_name, rel_b, is_dir))
+                  continue;
+                if (with_ignore)
+                  {
+                    bool ign = !g_ignore_reg.empty ()
+                      ? should_ignore_path_reg (rel_b, is_dir)
+                      : should_ignore_path (rel_b, is_dir);
+                    if (ign)
+                      continue;
+                  }
+                if (!have_full)
+                  path_join_into (full_b, dirpath, de->d_name);
+                if (is_dir)
+                  {
+                    if (opt_max_depth < 0 || depth < opt_max_depth)
+                      local_dirs.emplace_back (full_b, rel_b);
+                  }
+                else if (is_reg)
+                  {
+                    if (opt_max_depth >= 0 && depth > opt_max_depth)
+                      continue;
+                    if (glob_ok (rel_b))
+                      local_files.push_back (full_b);
+                  }
+              }
+            closedir (d);
+            if (!local_files.empty ())
+              {
+                std::lock_guard lk (files_mu);
+                for (auto &f : local_files)
+                  files_out->push_back (std::move (f));
+              }
+            if (!local_dirs.empty ())
+              {
+                std::lock_guard lk (mu);
+                for (auto &dd : local_dirs)
+                  dq.push_back (std::move (dd));
+                cv.notify_all ();
+              }
+          }
+        {
+          std::lock_guard lk (mu);
+          active--;
+          if (dq.empty () && active == 0)
+            {
+              done = true;
+              cv.notify_all ();
+            }
+        }
+      }
+  };
+
+  int nw = n_workers ();
+  if (nw > 8)
+    nw = 8;
+  std::vector<std::thread> ths;
+  for (int i = 0; i < nw; i++)
+    ths.emplace_back (worker);
+  for (auto &t : ths)
+    t.join ();
+}
+
+static void
+parallel_collect_no_ignore (const std::vector<std::string> &roots,
+                            std::vector<std::string> *files_out)
+{
+  parallel_collect_dirs (roots, files_out, false);
+}
+
+static void
+parallel_collect_with_ignore (const std::vector<std::string> &roots,
+                              std::vector<std::string> *files_out)
+{
+  parallel_collect_dirs (roots, files_out, true);
+}
+
+/* Walk a directory tree and search files immediately (no intermediate path
+   vector).  Fast for small/medium recurse where collect+search is wasteful.
+   openat/fdopendir + fstatat/statx for DT_UNKNOWN; defer full-path build.  */
+static void
+walk_search_dir (const std::string &dirpath, const std::string &relbase,
+                 bool *any_found)
+{
+  if (g_stop.load (std::memory_order_relaxed))
+    return;
+  int dfd = -1;
+  DIR *d = rg_opendir_fd (dirpath, &dfd);
+  if (!d)
+    return;
+
+  const bool skip_ignore = opt_no_ignore || opt_unrestricted >= 3;
+  int ignore_frames = 0;
+  if (!skip_ignore)
+    {
+      maybe_note_vcs_root (relbase, dirpath, dfd);
+      ignore_frames = push_dir_ignores (dirpath, relbase);
+    }
+  const bool have_ignore = !skip_ignore
+    && (!g_ignore_stack.empty () || !g_ignore_reg.empty ());
+
+  int depth = 0;
+  if (!relbase.empty ())
+    {
+      depth = 1;
+      for (char ch : relbase)
+        if (ch == '/')
+          depth++;
+    }
+
+  /* Reuse path buffers across dirents to cut allocator traffic.  */
+  std::string full;
+  full.reserve (dirpath.size () + 64);
+  std::string rel;
+  rel.reserve (relbase.size () + 64);
+
+  while (dirent *de = readdir (d))
+    {
+      if (g_stop.load (std::memory_order_relaxed))
+        break;
+      if (str_eq (de->d_name, ".") || str_eq (de->d_name, ".."))
+        continue;
+      bool know_dir = false, know_reg = false, know_lnk = false;
+#ifdef DT_DIR
+      if (de->d_type == DT_DIR)
+        know_dir = true;
+      else if (de->d_type == DT_REG)
+        know_reg = true;
+      else if (de->d_type == DT_LNK)
+        know_lnk = true;
+#endif
+      if (know_dir && is_skip_dirname (de->d_name))
+        continue;
+      if (know_lnk && !opt_follow)
+        continue;
+      if (know_reg && is_likely_binary_name (de->d_name))
+        continue;
+
+      bool is_dir = know_dir;
+      bool is_reg = know_reg;
+      off_t reg_size = -1;
+      bool have_full = false;
+      if (!know_dir && !know_reg)
+        {
+          full.assign (dirpath);
+          full.push_back ('/');
+          full.append (de->d_name);
+          have_full = true;
+          struct stat st;
+          if (!rg_lstat_at (dfd, de->d_name, full.c_str (), &st))
+            continue;
+          is_dir = S_ISDIR (st.st_mode);
+          is_reg = S_ISREG (st.st_mode);
+          if (is_reg)
+            reg_size = st.st_size;
+          if (S_ISLNK (st.st_mode) && !opt_follow)
+            continue;
+        }
+      if (is_dir && is_skip_dirname (de->d_name))
+        continue;
+      if (relbase.empty ())
+        rel.assign (de->d_name);
+      else
+        {
+          rel.assign (relbase);
+          rel.push_back ('/');
+          rel.append (de->d_name);
+        }
+      /* Fast hidden skip without whitelist probe when no ignore frames exist.  */
+      if (!opt_hidden && opt_unrestricted < 2 && is_hidden_name (de->d_name))
+        {
+          if (str_eq (de->d_name, ".git") || rel == ".git"
+              || rel.starts_with (".git/"))
+            continue;
+          if (have_ignore || !g_ignore_stack.empty () || !g_ignore_reg.empty ())
+            {
+              if (!ignore_whitelists_path (rel, is_dir))
+                continue;
+            }
+          else
+            continue; /* no ignore frames ⇒ cannot whitelist hidden */
+        }
+      if (!skip_ignore && (!g_ignore_stack.empty () || !g_ignore_reg.empty ())
+          && should_ignore_path (rel, is_dir))
+        continue;
+      if (!have_full)
+        {
+          full.assign (dirpath);
+          full.push_back ('/');
+          full.append (de->d_name);
+        }
+      if (is_dir)
+        {
+          if (opt_max_depth >= 0 && depth >= opt_max_depth)
+            continue;
+          walk_search_dir (full, rel, any_found);
+        }
+      else if (is_reg)
+        {
+          if (opt_max_depth >= 0 && depth > opt_max_depth)
+            continue;
+          if (!glob_ok (rel))
+            continue;
+          /* DT_REG: pass -2 to skip fstat; openat via walk dirfd when possible.  */
+          SearchResult r = search_file_ex (full, reg_size >= 0 ? reg_size : -2,
+                                           dfd, de->d_name);
+          if (r.found)
+            {
+              *any_found = true;
+              if (opt_quiet)
+                {
+                  g_stop.store (true, std::memory_order_relaxed);
+                  break;
+                }
+            }
+        }
+    }
+  closedir (d);
+  while (ignore_frames-- > 0)
+    pop_ignore ();
+}
+
+/* Count direct children of a directory (capped) — recurse scheduling heuristic.  */
+static int
+dir_child_count_cap (const std::string &dirpath, int cap)
+{
+  DIR *td = opendir (dirpath.c_str ());
+  if (!td)
+    return 0;
+  int ents = 0;
+  while (ents < cap && readdir (td))
+    ents++;
+  closedir (td);
+  return ents;
+}
+
+static bool
+run_walk_and_search (const std::vector<std::string> &roots)
+{
+  const bool need_sort = opt_sort_files
+                         || (opt_sort_by && !str_eq (opt_sort_by, "none"));
+  const bool no_ign = opt_no_ignore || opt_unrestricted >= 1;
+
+  /* Fast path: sequential walk+search (no collect phase) when not sorting
+     and the tree is small.  Larger trees: collect+parallel_search beats
+     single-threaded walk+search (rust rg parallelizes recurse).  */
+  if (!need_sort && !opt_passthru)
+    {
+      bool do_inline = true;
+      if (roots.size () == 1)
+        {
+          struct stat rst;
+          if (stat (roots[0].c_str (), &rst) == 0 && S_ISDIR (rst.st_mode))
+            {
+              int ents = dir_child_count_cap (roots[0], 96);
+              if (opt_unrestricted >= 1 || opt_no_ignore)
+                {
+                  /* Huge -u trees: parallel collect still wins.  */
+                  if (ents >= 48)
+                    do_inline = false;
+                }
+              else
+                {
+                  /* Normal recurse with ignore: parallelize earlier — walk
+                     ignore is serial but search dominates on source trees.  */
+                  if (ents >= 12)
+                    do_inline = false;
+                }
+            }
+        }
+      else if (roots.size () > 1)
+        do_inline = false; /* multi-root: collect once, search in parallel */
+      if (do_inline)
+        {
+          g_any = false;
+          g_stop = false;
+          bool any = false;
+          for (const auto &root : roots)
+            {
+              struct stat st;
+              if (stat (root.c_str (), &st) != 0)
+                continue;
+              if (S_ISDIR (st.st_mode))
+                walk_search_dir (root, root == "." ? "" : root, &any);
+              else if (S_ISREG (st.st_mode))
+                {
+                  SearchResult r = search_file_ex (root, st.st_size);
+                  if (r.found)
+                    any = true;
+                }
+              if (opt_quiet && any)
+                break;
+            }
+          out_flush_tls ();
+          return any;
+        }
+    }
+
+  std::vector<std::string> files;
+  files.reserve (4096);
+
+  /* Parallel walk pays off on large trees; for a single shallow root prefer
+     sequential collect (avoids thread+queue overhead on micro recurse benches).  */
+  bool do_par_walk = !need_sort && roots.size () == 1;
+  if (do_par_walk)
+    {
+      struct stat rst;
+      if (stat (roots[0].c_str (), &rst) == 0 && S_ISDIR (rst.st_mode))
+        {
+          /* Heuristic: only parallel-walk when root has many direct children
+             or we are unrestricted (huge trees / -u).  Otherwise sequential.  */
+          if (!(opt_unrestricted >= 1 || opt_no_ignore))
+            {
+              DIR *td = opendir (roots[0].c_str ());
+              if (td)
+                {
+                  int ents = 0;
+                  while (ents < 64 && readdir (td))
+                    ents++;
+                  closedir (td);
+                  if (ents < 48)
+                    do_par_walk = false;
+                }
+            }
+        }
+      else
+        do_par_walk = false;
+    }
+  if (do_par_walk)
+    {
+      if (no_ign)
+        parallel_collect_no_ignore (roots, &files);
+      else
+        parallel_collect_with_ignore (roots, &files);
+    }
+  else
+    {
+      for (const auto &root : roots)
+        {
+          struct stat st;
+          if (stat (root.c_str (), &st) != 0)
+            continue;
+          if (S_ISDIR (st.st_mode))
+            collect_dir (root, root == "." ? "" : root, &files, false);
+          else if (S_ISREG (st.st_mode))
+            files.push_back (root);
+        }
+    }
+
+  if (need_sort)
+    {
+      std::sort (files.begin (), files.end ());
+      if (opt_sort_reverse)
+        std::reverse (files.begin (), files.end ());
+    }
+
+  return parallel_search_files (files);
+}
+
+static bool
+run_paths (const std::vector<std::string> &paths)
+{
+  return parallel_search_files (paths);
+}
+
+/* ---------- CLI ---------- */
+
+static void
+usage (int code)
+{
+  fprintf (code ? stderr : stdout,
+           "rg [OPTIONS] PATTERN [PATH ...]\n"
+           "Try 'rg --help' for more information.\n");
+  exit (code);
+}
+
+static void
+print_type_list ()
+{
+  /* Subset of ripgrep --type-list; enough for scripts that probe types.  */
+  static const char *const lines[] = {
+    "c: *.c, *.h, *.H, *.hh, *.hpp, *.hxx, *.cc, *.cpp, *.cxx, *.C",
+    "cpp: *.c, *.h, *.H, *.hh, *.hpp, *.hxx, *.cc, *.cpp, *.cxx, *.C",
+    "rust: *.rs",
+    "py: *.py",
+    "python: *.py",
+    "js: *.js, *.jsx, *.vue",
+    "ts: *.ts, *.tsx",
+    "go: *.go",
+    "java: *.java",
+    "md: *.markdown, *.md, *.mdown, *.mkdn",
+    "sh: *.bash, *.bashrc, *.csh, *.sh, …",
+    "make: *.mak, *.mk, GNUmakefile, Gnumakefile, Makefile, makefile",
+    nullptr
+  };
+  for (int i = 0; lines[i]; i++)
+    puts (lines[i]);
+  exit (0);
+}
