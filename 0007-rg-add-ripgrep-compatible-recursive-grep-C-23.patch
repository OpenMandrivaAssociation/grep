+/* RVV class_byte_vec: for a vector of bytes, produce a mask of those
+   matching character class k.  Uses strip-mined vector compares.  */
+static inline vbool8_t
+class_mask_rvv (ClassKind k, vuint8m1_t block, size_t vl) noexcept
+{
+  switch (k)
