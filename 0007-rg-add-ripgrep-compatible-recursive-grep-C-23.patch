+static dev_t g_root_dev = 0;
+
+/* ANSI colors (rg defaults: path purple/bold, line_no green, match red/bold).
+   Pre-computed lengths avoid strlen() in inner loops (176k+ calls/search).  */
+static const char *col_reset = "\033[0m";
+static const char *col_path = "\033[1;35m";
+static const char *col_line = "\033[32m";
+static const char *col_match = "\033[1;31m";
+static const char *col_column = "\033[32m";
+static size_t col_reset_len = 4;
+static size_t col_path_len  = 7;
+static size_t col_line_len  = 5;
+static size_t col_match_len = 7;
+static size_t col_column_len = 5;
+
+/* Pre-built colored fixed literal: col_match + g_fixed + col_reset.
+   Built once after compile_pattern + resolve_color; avoids per-file
+   std::string allocation in search_fixed / search_dfa_print LitsAny.  */
+static char *g_colored_fixed = nullptr;
+static size_t g_colored_fixed_len = 0;
+
+static std::atomic<intmax_t> stat_files_searched{0};
+static std::atomic<intmax_t> stat_files_matched{0};
+static std::atomic<intmax_t> stat_lines_matched{0};
+static std::atomic<intmax_t> stat_bytes_searched{0};
+static std::atomic<intmax_t> stat_bytes_printed{0};
+static std::atomic<intmax_t> stat_match_spans{0}; /* total regex/literal hits */
+
+using Clock = std::chrono::steady_clock;
+static Clock::time_point g_t0;
+static thread_local Clock::time_point tls_search_t0;
+
+static void
+maybe_flush ()
+{
+  if (opt_line_buffered)
+    fflush (stdout);
+}
+
+static intmax_t
+elapsed_nanos (Clock::time_point from)
+{
+  return std::chrono::duration_cast<std::chrono::nanoseconds> (Clock::now () - from).count ();
+}
+
+static void
+format_human_dur (intmax_t nanos, char *buf, size_t buflen)
+{
+  double s = static_cast<double> (nanos) / 1e9;
+  if (s < 0.001)
+    snprintf (buf, buflen, "%.0fus", s * 1e6);
+  else if (s < 1.0)
+    snprintf (buf, buflen, "%.6fs", s);
+  else
+    snprintf (buf, buflen, "%.3fs", s);
+}
+
+static bool str_eq (const char *a, const char *b); /* fwd */
+
+static void
+resolve_color ()
+{
+  if (opt_json)
+    {
+      g_use_color = false;
+      return;
+    }
+  if (!opt_color_when || !std::strcmp (opt_color_when, "never")
+      || !std::strcmp (opt_color_when, "none"))
+    g_use_color = false;
+  else if (!std::strcmp (opt_color_when, "always"))
+    g_use_color = true;
+  else /* auto */
+    g_use_color = isatty (STDOUT_FILENO) != 0;
+  if (opt_pretty)
+    {
+      opt_heading = true;
+      if (!opt_color_when || !std::strcmp (opt_color_when, "auto"))
+        g_use_color = isatty (STDOUT_FILENO) != 0;
+    }
+}
+
+/* Parse --colors=type:attr:... like path:fg:magenta or match:style:bold */
+static void
+apply_color_spec (const char *spec)
+{
+  if (!spec)
+    return;
+  /* Minimal: accept and map a few common rg --colors settings.  */
+  std::string s (spec);
+  auto colon = s.find (':');
+  if (colon == std::string::npos)
+    return;
+  std::string kind = s.substr (0, colon);
+  std::string rest = s.substr (colon + 1);
+  const char **slot = nullptr;
+  if (kind == "path")
+    slot = &col_path;
+  else if (kind == "line" || kind == "line-number")
+    slot = &col_line;
+  else if (kind == "match")
+    slot = &col_match;
+  else if (kind == "column")
+    slot = &col_column;
+  if (!slot)
+    return;
+  if (rest.find ("red") != std::string::npos)
+    *slot = "\033[1;31m";
+  else if (rest.find ("green") != std::string::npos)
+    *slot = "\033[32m";
+  else if (rest.find ("blue") != std::string::npos)
+    *slot = "\033[34m";
+  else if (rest.find ("magenta") != std::string::npos || rest.find ("purple") != std::string::npos)
+    *slot = "\033[1;35m";
+  else if (rest.find ("cyan") != std::string::npos)
+    *slot = "\033[36m";
+  else if (rest.find ("yellow") != std::string::npos)
+    *slot = "\033[33m";
+  else if (rest.find ("none") != std::string::npos)
+    *slot = "";
+  /* Recompute cached lengths after any color change.  */
+  col_reset_len  = std::strlen (col_reset);
+  col_path_len   = std::strlen (col_path);
+  col_line_len   = std::strlen (col_line);
+  col_match_len  = std::strlen (col_match);
+  col_column_len = std::strlen (col_column);
+}
+
+static void c_write (const char *s, size_t n)
+{
+  if (n)
+    {
+      fwrite (s, 1, n, stdout);
+      stat_bytes_printed.fetch_add (static_cast<intmax_t> (n), std::memory_order_relaxed);
+    }
+}
+
+static void c_puts (const char *s)
+{
+  if (s)
+    c_write (s, std::strlen (s));
+}
+
+static void c_putc (char c)
+{
+  putchar (c);
+  stat_bytes_printed.fetch_add (1, std::memory_order_relaxed);
+}
+
+static void color_on (const char *code)
+{
+  if (g_use_color && code && *code)
+    c_puts (code);
+}
+
+static void color_off ()
+{
+  if (g_use_color)
+    c_puts (col_reset);
+}
+
+static std::mutex g_out_mu;
+
+/* Grep engine */
+static void *g_pat = nullptr;
+static ptrdiff_t (*g_exec) (void *, char const *, idx_t, idx_t *, char const *) = nullptr;
+static bool g_use_dfa = false;
+/* Multiline: engine needs the full buffer + start_ptr (Pexecute_whole, or
+   ERE/fixed when the pattern itself contains a real newline).  Otherwise
+   EGexecute line-orients via data+off / size-off (start_ptr=nullptr).  */
+static bool g_ml_whole_buffer = false;
+static std::string g_ml_fixed; /* multiline literal pattern (preprocessed) */
+static std::string g_fixed;
+static std::string g_keys_storage; /* must outlive g_pat */
+static rg_simd::Prefilter g_prefilter; /* SIMD/literal skip before DFA */
+static rg_simd::ClassRunPat g_class_run; /* SIMD class quantifier fast path */
+/* Multi-literal chain fast path: regex of the form `lit1.*lit2[.*lit3...]`.
+   Each segment connected by `.*` or `.+`.  When active, bypass DFA and do
+   sequential memmem for each literal on the same line.  */
+struct LitChainSeg {
+  std::string lit;
+  bool dotplus; /* true = .+ (gap >=1), false = .* (gap >=0) */
+};
+static std::vector<LitChainSeg> g_lit_chain;
+static bool g_lit_chain_active = false;
+
+/* ---------- ignore stack (compiled gitignore-ish rules) ---------- */
+
+struct IgnoreRule {
+  std::string pat;
+  bool neg = false;
+  bool dir_only = false;
+  bool anchored = false;   /* leading / — match from start of relpath */
+  bool anywhere = false;   /* contains / mid-pattern (not only trailing) */
+  bool is_lit = false;     /* no glob metacharacters — exact/segment match */
+};
+
+struct IgnoreFrame {
+  std::string dir; /* relative dir this frame applies under (empty = global) */
+  std::vector<IgnoreRule> rules; /* non-literal / negation / dir_only only */
+  /* Fast indices for exact-literal unanchored basename / segment names.  */
+  std::unordered_set<std::string> lit_names;      /* ignore these basenames */
+  std::unordered_set<std::string> lit_names_neg;  /* re-include these basenames */
+  std::unordered_set<std::string> lit_paths;      /* full relative path literals */
+  std::unordered_set<std::string> lit_paths_neg;
+  /* Extension fast path: *.ext / *.<ext> (case-sensitive, no other meta).  */
+  std::unordered_set<std::string> lit_exts;       /* ignore if basename ends .ext */
+  std::unordered_set<std::string> lit_exts_neg;
+  bool has_glob_rules = false;
+  bool empty () const
+  {
+    return rules.empty () && lit_names.empty () && lit_paths.empty ()
+           && lit_names_neg.empty () && lit_paths_neg.empty ()
+           && lit_exts.empty () && lit_exts_neg.empty ();
+  }
+};
+
+static std::vector<IgnoreFrame> g_ignore_stack;
+/* Directories we already probed for ignore files (avoid repeat open/stat).  */
+static std::unordered_map<std::string, int> g_ignore_dir_cache; /* dirpath -> frames added */
+
+/* Parallel-walk registry: append-only frames keyed by relative dir.
+   Mutex only on first visit; reads during walk use the map (stable pointers).  */
+static std::mutex g_ignore_reg_mu;
+static std::vector<IgnoreFrame> g_ignore_reg; /* owns frame storage */
+static std::unordered_map<std::string, std::vector<size_t>> g_ignore_reg_by_dir;
+static std::unordered_set<std::string> g_ignore_reg_loaded; /* dirpaths fully probed */
+/* Directories that are separate VCS roots (submodules: `.git` file/dir).
+   Parent .gitignore frames do not apply under these (ripgrep/ignore crate).  */
+static std::unordered_set<std::string> g_vcs_roots; /* relative dir paths */
+
+#if defined(__linux__) && defined(SYS_statx) && defined(STATX_TYPE)
+static bool
+rg_statx_at (int dirfd, const char *name, struct stat *st, bool follow)
+{
+  struct statx sx;
+  unsigned int flags = follow ? 0 : AT_SYMLINK_NOFOLLOW;
+  if (syscall (SYS_statx, dirfd, name, flags, STATX_TYPE | STATX_SIZE, &sx) != 0)
+    return false;
+  memset (st, 0, sizeof *st);
+  st->st_mode = sx.stx_mode;
+  st->st_size = static_cast<off_t> (sx.stx_size);
+  st->st_dev = static_cast<dev_t> ((static_cast<uint64_t> (sx.stx_dev_major) << 32)
+                                   | sx.stx_dev_minor);
+  st->st_ino = sx.stx_ino;
+  return true;
+}
+#else
+static bool
+rg_statx_at (int, const char *, struct stat *, bool)
+{
+  return false;
+}
+#endif
+
+static bool
+rg_lstat_at (int dirfd, const char *name, const char *fullpath_fallback,
+             struct stat *st)
+{
+  if (dirfd >= 0)
+    {
+      if (rg_statx_at (dirfd, name, st, false))
+        return true;
+      if (fstatat (dirfd, name, st, AT_SYMLINK_NOFOLLOW) == 0)
+        return true;
+    }
+  return lstat (fullpath_fallback, st) == 0;
+}
+
+static bool
+rg_path_exists_at (int dirfd, const char *name, const std::string &full_probe)
+{
+  if (dirfd >= 0)
+    {
+      struct stat st;
+      if (rg_statx_at (dirfd, name, &st, false))
+        return true;
+      if (fstatat (dirfd, name, &st, AT_SYMLINK_NOFOLLOW) == 0)
+        return true;
+    }
+  struct stat st;
+  return lstat (full_probe.c_str (), &st) == 0;
+}
+
+static void
+maybe_note_vcs_root (const std::string &relbase, const std::string &dirpath,
+                     int dirfd = -1)
+{
+  if (relbase.empty ())
+    return; /* search root itself is not a barrier for its own frames */
+  std::string probe = dirpath;
+  probe += "/.git";
+  if (rg_path_exists_at (dirfd, ".git", probe))
+    {
+      std::lock_guard lk (g_ignore_reg_mu);
+      g_vcs_roots.insert (relbase);
+    }
+}
+
+/* Ripgrep: .gitignore applies only inside a git work tree (ancestor has
+   .git file or directory).  .ignore / .rgignore always apply.  Cache by
+   absolute-ish dirpath to avoid repeated upward walks.  */
+static std::unordered_map<std::string, bool> g_git_worktree_cache;
+
+static bool
+dir_in_git_worktree (const std::string &dirpath)
+{
+  auto it = g_git_worktree_cache.find (dirpath);
+  if (it != g_git_worktree_cache.end ())
+    return it->second;
+
+  std::string cur = dirpath.empty () ? "." : dirpath;
+  /* Normalize relative "." to abs when possible so cache hits align.  */
+  if (cur == ".")
+    {
+      char cwd[PATH_MAX];
+      if (getcwd (cwd, sizeof cwd))
+        cur = cwd;
+    }
+  bool found = false;
+  std::string walk = cur;
+  for (int guard = 0; guard < 64; guard++)
+    {
+      std::string probe = walk;
+      probe += "/.git";
+      struct stat st;
+      if (lstat (probe.c_str (), &st) == 0)
+        {
+          found = true;
+          break;
+        }
+      auto slash = walk.rfind ('/');
+      if (slash == std::string::npos || slash == 0)
+        {
+          /* Also check walk+"/.git" done; try parent of single-component path.  */
+          if (walk == "/" || walk.empty ())
+            break;
+          /* Relative path without slash: climb via abs_path later not needed.  */
+          if (slash == std::string::npos)
+            break;
+        }
+      if (slash == 0)
+        {
+          walk = "/";
+          probe = "/.git";
+          if (lstat (probe.c_str (), &st) == 0)
+            found = true;
+          break;
+        }
+      std::string parent = walk.substr (0, slash);
+      if (parent.empty ())
+        parent = "/";
+      if (parent == walk)
+        break;
+      walk = parent;
+    }
+  g_git_worktree_cache.emplace (dirpath, found);
+  if (cur != dirpath)
+    g_git_worktree_cache.emplace (cur, found);
+  return found;
+}
+
+/* Deepest VCS root that is a prefix of relpath; returns pointer into g_vcs_roots
+   storage or nullptr.  Avoids per-call std::string alloc.  */
+static const std::string *
+enclosing_vcs_root_ptr (const std::string &relpath)
+{
+  const std::string *best = nullptr;
+  for (const auto &vr : g_vcs_roots)
+    {
+      if (relpath == vr
+          || (relpath.size () > vr.size () && relpath.compare (0, vr.size (), vr) == 0
+              && relpath[vr.size ()] == '/'))
+        {
+          if (!best || vr.size () > best->size ())
+            best = &vr;
+        }
+    }
+  return best;
+}
+
+/* Frame at `frame_dir` applies to path under `vcs_root` (nullptr = no barrier).  */
+static bool
+frame_applies_under_vcs (const std::string &frame_dir, const std::string *vcs_root)
+{
+  if (!vcs_root || vcs_root->empty ())
+    return true;
+  if (frame_dir.empty ())
+    return true;
+  if (frame_dir == *vcs_root)
+    return true;
+  if (frame_dir.size () > vcs_root->size ()
+      && frame_dir.compare (0, vcs_root->size (), *vcs_root) == 0
+      && frame_dir[vcs_root->size ()] == '/')
+    return true;
+  return false;
+}
