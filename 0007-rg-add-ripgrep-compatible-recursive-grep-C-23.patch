+  if (nlits <= 8)
+    return lits_any_teddy_nibble_slim_avx2 (pf, data, size, only_exists,
+                                             max_count, nlits);
+  return lits_any_teddy_nibble_fat_avx2 (pf, data, size, only_exists,
+                                          max_count, nlits);
+}
