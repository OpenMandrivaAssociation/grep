+/* ---- LoongArch LSX class-run functions (16 bytes/chunk) ---- */
+
+/* class_mask_lsx: produce 16-bit bitmask (one bit per byte) for bytes
+   matching the given character class.  Structurally identical to the
+   NEON version but uses LSX unsigned-byte compare intrinsics.  */
+static inline uint16_t
+class_mask_lsx (ClassKind k, const char *p) noexcept
+{
+  __m128i block = __lsx_vld (reinterpret_cast<const void *> (p), 0);
+  __m128i ok;
+  switch (k)
+    {
+    case ClassKind::Alpha:
+      {
+        __m128i up = __lsx_vand_v (
+            __lsx_vsle_bu (__lsx_vreplgr2vr_b ('A'), block),
+            __lsx_vsle_bu (block, __lsx_vreplgr2vr_b ('Z')));
+        __m128i lo = __lsx_vand_v (
+            __lsx_vsle_bu (__lsx_vreplgr2vr_b ('a'), block),
+            __lsx_vsle_bu (block, __lsx_vreplgr2vr_b ('z')));
+        ok = __lsx_vor_v (up, lo);
+        break;
+      }
+    case ClassKind::Lower:
+      ok = __lsx_vand_v (
+          __lsx_vsle_bu (__lsx_vreplgr2vr_b ('a'), block),
+          __lsx_vsle_bu (block, __lsx_vreplgr2vr_b ('z')));
+      break;
+    case ClassKind::Upper:
+      ok = __lsx_vand_v (
+          __lsx_vsle_bu (__lsx_vreplgr2vr_b ('A'), block),
+          __lsx_vsle_bu (block, __lsx_vreplgr2vr_b ('Z')));
+      break;
+    case ClassKind::Digit:
+      ok = __lsx_vand_v (
+          __lsx_vsle_bu (__lsx_vreplgr2vr_b ('0'), block),
+          __lsx_vsle_bu (block, __lsx_vreplgr2vr_b ('9')));
+      break;
+    case ClassKind::Alnum:
+      {
+        __m128i up = __lsx_vand_v (
+            __lsx_vsle_bu (__lsx_vreplgr2vr_b ('A'), block),
+            __lsx_vsle_bu (block, __lsx_vreplgr2vr_b ('Z')));
+        __m128i lo = __lsx_vand_v (
+            __lsx_vsle_bu (__lsx_vreplgr2vr_b ('a'), block),
+            __lsx_vsle_bu (block, __lsx_vreplgr2vr_b ('z')));
+        __m128i dg = __lsx_vand_v (
+            __lsx_vsle_bu (__lsx_vreplgr2vr_b ('0'), block),
+            __lsx_vsle_bu (block, __lsx_vreplgr2vr_b ('9')));
+        ok = __lsx_vor_v (__lsx_vor_v (up, lo), dg);
+        break;
+      }
+    case ClassKind::Word:
+      {
+        __m128i up = __lsx_vand_v (
+            __lsx_vsle_bu (__lsx_vreplgr2vr_b ('A'), block),
+            __lsx_vsle_bu (block, __lsx_vreplgr2vr_b ('Z')));
+        __m128i lo = __lsx_vand_v (
+            __lsx_vsle_bu (__lsx_vreplgr2vr_b ('a'), block),
+            __lsx_vsle_bu (block, __lsx_vreplgr2vr_b ('z')));
+        __m128i dg = __lsx_vand_v (
+            __lsx_vsle_bu (__lsx_vreplgr2vr_b ('0'), block),
+            __lsx_vsle_bu (block, __lsx_vreplgr2vr_b ('9')));
+        __m128i un = __lsx_vseq_b (block, __lsx_vreplgr2vr_b ('_'));
+        ok = __lsx_vor_v (__lsx_vor_v (__lsx_vor_v (up, lo), dg), un);
+        break;
+      }
+    default:
+      return 0;
+    }
+  return static_cast<uint16_t> (lsx_movemask (ok));
+}
+
+/* Full LSX scan_class_run — structurally identical to NEON version.  */
+static intmax_t
+scan_class_run_lsx_impl (ClassKind k, unsigned min_r, const char *data,
+                          size_t size, bool count_lines, bool only_exists,
+                          intmax_t max_count)
+{
+  const char *p = data;
+  const char *const end = data + size;
+  intmax_t matches = 0;
+  unsigned carry = 0;
+
+  while (p + 16 <= end)
+    {
+      uint16_t mask = class_mask_lsx (k, p);
+
+      if (mask == 0)
+        {
+          if (carry >= min_r)
+            {
+              matches++;
+              if (only_exists)
+                return 1;
+              if (matches >= max_count)
+                return matches;
+              if (count_lines)
+                {
+                  const void *nl
+                      = std::memchr (p, '\n', static_cast<size_t> (end - p));
+                  if (!nl)
+                    return matches;
+                  p = static_cast<const char *> (nl) + 1;
+                  carry = 0;
+                  continue;
+                }
+            }
+          carry = 0;
+          p += 16;
+          continue;
+        }
+
+      if (mask == 0xFFFFu)
+        {
+          carry += 16;
+          p += 16;
+          continue;
+        }
+
+      /* Mixed chunk.  */
+      {
+        uint16_t rem = mask;
+        unsigned bit = 0;
+        if (carry > 0 && (mask & 1u))
+          {
+            uint16_t inv0 = static_cast<uint16_t> (~mask);
+            unsigned leading = static_cast<unsigned> (__builtin_ctz (inv0));
+            carry += leading;
+            if (carry >= min_r)
+              {
+                matches++;
+                if (only_exists)
+                  return 1;
+                if (matches >= max_count)
+                  return matches;
+                if (count_lines)
+                  {
+                    const char *after = p + leading;
+                    const void *nl = std::memchr (
+                        after, '\n', static_cast<size_t> (end - after));
+                    if (!nl)
+                      return matches;
+                    p = static_cast<const char *> (nl) + 1;
+                    carry = 0;
+                    continue;
+                  }
+              }
+            carry = 0;
+            rem = static_cast<uint16_t> (rem >> leading);
+            bit += leading;
+          }
+        else
+          {
+            if (carry >= min_r)
+              {
+                matches++;
+                if (only_exists)
+                  return 1;
+                if (matches >= max_count)
+                  return matches;
+                if (count_lines)
+                  {
+                    const void *nl = std::memchr (
+                        p, '\n', static_cast<size_t> (end - p));
+                    if (!nl)
+                      return matches;
+                    p = static_cast<const char *> (nl) + 1;
+                    carry = 0;
+                    continue;
+                  }
+              }
+            carry = 0;
+          }
+
+        while (rem)
+          {
+            unsigned skip = static_cast<unsigned> (__builtin_ctz (rem));
+            rem = static_cast<uint16_t> (rem >> skip);
+            bit += skip;
+            if (!rem)
+              break;
+            uint16_t inv1 = static_cast<uint16_t> (~rem);
+            unsigned run_len;
+            if (inv1)
+              run_len = static_cast<unsigned> (__builtin_ctz (inv1));
+            else
+              run_len = 16 - bit;
+            if (bit + run_len >= 16)
+              {
+                carry = run_len;
+                break;
+              }
+            if (run_len >= min_r)
+              {
+                matches++;
+                if (only_exists)
+                  return 1;
+                if (matches >= max_count)
+                  return matches;
+                if (count_lines)
+                  {
+                    const char *after = p + bit + run_len;
+                    const void *nl = std::memchr (
+                        after, '\n', static_cast<size_t> (end - after));
+                    if (!nl)
+                      return matches;
+                    p = static_cast<const char *> (nl) + 1;
+                    carry = 0;
+                    goto next_chunk_lsx;
+                  }
+              }
+            rem = static_cast<uint16_t> (rem >> run_len);
+            bit += run_len;
+          }
+      }
+      p += 16;
+    next_chunk_lsx:;
+    }
+
+  /* Scalar tail.  */
+  while (p < end)
+    {
+      if (class_byte_ok (k, static_cast<unsigned char> (*p)))
+        carry++;
+      else
+        {
+          if (carry >= min_r)
+            {
+              matches++;
+              if (only_exists)
+                return 1;
+              if (matches >= max_count)
+                return matches;
+              if (count_lines)
+                {
+                  const void *nl = std::memchr (
+                      p, '\n', static_cast<size_t> (end - p));
+                  if (!nl)
+                    return matches;
+                  p = static_cast<const char *> (nl) + 1;
+                  carry = 0;
+                  continue;
+                }
+            }
+          carry = 0;
+        }
+      p++;
+    }
+  if (carry >= min_r)
+    matches++;
+  return matches;
+}
