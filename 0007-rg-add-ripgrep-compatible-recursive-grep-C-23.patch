index 0000000..e9a480a
--- /dev/null
+++ b/src/rg_simd.cpp
@@ -0,0 +1,7865 @@
+/* rg_simd.cpp - SIMD / portable fast search for rg.
+   Backends: x86_64 SSE2/AVX2, aarch64 NEON, loongarch64 & riscv64 word-at-a-time
+   (plus GCC vector builtins where available).  */
+
+/* config.h first (gnulib), then drop gnulib's nullptr macro before C++ stdlib. */
+#include <config.h>
+#ifdef nullptr
+# undef nullptr
+#endif
+
+#include "rg_simd.hpp"
+
+#include <algorithm>
+#include <cctype>
+#include <cstdint>
+#include <cstring>
+#include <queue>
+#include <unordered_set>
+#include <vector>
+
+#if defined(__x86_64__) || defined(_M_X64)
+# define RG_ARCH_X86_64 1
+# include <immintrin.h>
+# include <cpuid.h>
+#elif defined(__aarch64__) || defined(_M_ARM64)
+# define RG_ARCH_AARCH64 1
+# include <arm_neon.h>
+#elif defined(__loongarch64) || defined(__loongarch__)
+# define RG_ARCH_LOONGARCH64 1
+# if defined(__loongarch_sx)
+#  include <lsxintrin.h>
+#  define RG_HAVE_LSX 1
+# endif
+#elif defined(__riscv) && (__riscv_xlen == 64)
+# define RG_ARCH_RISCV64 1
+# if defined(__riscv_v) || defined(__riscv_vector)
+#  include <riscv_vector.h>
+#  define RG_HAVE_RVV 1
+# endif
+#endif
+
+/* GCC/Clang generic vectors: useful on loongarch64 / riscv64 without arch SIMD.  */
+#if !defined(RG_ARCH_X86_64) && !defined(RG_ARCH_AARCH64) \
+    && (defined(__GNUC__) || defined(__clang__))
+# define RG_HAVE_GCC_VECTOR 1
+#endif
+
+namespace rg_simd {
+
+/* ---------- Aho–Corasick (multi-pattern ANY) ---------- */
+
+void
+AhoCorasick::build (const std::vector<std::string> &pats)
+{
+  nodes.clear ();
+  nodes.emplace_back (); /* root = 0 */
+  for (const auto &pat : pats)
+    {
+      if (pat.empty ())
+        continue;
+      int u = 0;
+      for (unsigned char c : pat)
+        {
+          if (nodes[u].next[c] < 0)
+            {
+              nodes[u].next[c] = static_cast<int> (nodes.size ());
+              nodes.emplace_back ();
+            }
+          u = nodes[u].next[c];
+        }
+      if (static_cast<int> (pat.size ()) > nodes[u].out_len)
+        nodes[u].out_len = static_cast<int> (pat.size ());
+    }
+
+  /* BFS failure links, then complete transition table (goto via fail).  */
+  std::queue<int> q;
+  for (int c = 0; c < 256; c++)
+    {
+      int v = nodes[0].next[c];
+      if (v >= 0)
+        {
+          nodes[v].fail = 0;
+          q.push (v);
+        }
+      else
+        nodes[0].next[c] = 0;
+    }
+  while (!q.empty ())
+    {
+      int u = q.front ();
+      q.pop ();
+      for (int c = 0; c < 256; c++)
+        {
+          int v = nodes[u].next[c];
+          if (v >= 0)
+            {
+              int f = nodes[u].fail;
+              nodes[v].fail = nodes[f].next[c];
+              int fo = nodes[v].fail;
+              if (fo > 0 && nodes[fo].out_len > nodes[v].out_len)
+                nodes[v].out_len = nodes[fo].out_len;
+              q.push (v);
+            }
+          else
+            nodes[u].next[c] = nodes[nodes[u].fail].next[c];
+        }
+    }
+  built = nodes.size () > 1 || !pats.empty ();
+}
+
+/* Build with all patterns lowered; scan with tolower on input byte.  */
+void
+AhoCorasick::build_icase (const std::vector<std::string> &pats)
+{
+  std::vector<std::string> folded;
+  folded.reserve (pats.size ());
+  for (const auto &p : pats)
+    {
+      std::string f;
+      f.reserve (p.size ());
+      for (char c : p)
+        f.push_back (static_cast<char> (
+          std::tolower (static_cast<unsigned char> (c))));
+      folded.push_back (std::move (f));
+    }
+  build (folded);
+}
+
+const char *
+AhoCorasick::find_first (const char *cur, const char *end, size_t *mlen) const
+{
+  if (!built || nodes.empty () || cur >= end)
+    {
+      if (mlen)
+        *mlen = 0;
+      return end;
+    }
+  int s = 0;
+  for (const char *p = cur; p < end; p++)
+    {
+      unsigned char c = static_cast<unsigned char> (*p);
+      s = nodes[s].next[c];
+      if (s < 0)
+        s = 0;
+      if (nodes[s].out_len > 0)
+        {
+          if (mlen)
+            *mlen = static_cast<size_t> (nodes[s].out_len);
+          return p - nodes[s].out_len + 1;
+        }
+    }
+  if (mlen)
+    *mlen = 0;
+  return end;
+}
+
+const char *
+AhoCorasick::find_first_icase (const char *cur, const char *end, size_t *mlen) const
+{
+  if (!built || nodes.empty () || cur >= end)
+    {
+      if (mlen)
+        *mlen = 0;
+      return end;
+    }
+  int s = 0;
+  for (const char *p = cur; p < end; p++)
+    {
+      unsigned char c = static_cast<unsigned char> (*p);
+      /* ASCII tolower: avoids locale overhead in the inner loop.  */
+      if (c >= 'A' && c <= 'Z')
+        c += 32;
+      s = nodes[s].next[c];
+      if (s < 0)
+        s = 0;
+      if (nodes[s].out_len > 0)
+        {
+          if (mlen)
+            *mlen = static_cast<size_t> (nodes[s].out_len);
+          return p - nodes[s].out_len + 1;
+        }
+    }
+  if (mlen)
+    *mlen = 0;
+  return end;
+}
+
+intmax_t
+AhoCorasick::scan_lines (const char *data, size_t size, bool only_exists,
+                         intmax_t max_count) const
+{
+  if (!built || nodes.empty () || size == 0)
+    return 0;
+  const char *end = data + size;
+  intmax_t matches = 0;
+  int s = 0;
+  /* Transition table is fully completed at build; s is always a valid node.  */
+  for (const char *p = data; p < end; p++)
+    {
+      s = nodes[s].next[static_cast<unsigned char> (*p)];
+      if (nodes[s].out_len > 0)
+        {
+          matches++;
+          if (only_exists)
+            return 1;
+          if (max_count > 0 && matches >= max_count)
+            return matches;
+          /* Advance to next line (grep -c counts lines).  */
+          const char *nl = static_cast<const char *> (
+            memchr (p, '\n', static_cast<size_t> (end - p)));
+          if (!nl)
+            return matches;
+          p = nl; /* loop ++p lands on first char after \n */
+          s = 0;
+        }
+    }
+  return matches;
+}
+
+intmax_t
+AhoCorasick::scan_lines_icase (const char *data, size_t size, bool only_exists,
+                                intmax_t max_count) const
+{
+  if (!built || nodes.empty () || size == 0)
+    return 0;
+  const char *end = data + size;
+  intmax_t matches = 0;
+  int s = 0;
+  for (const char *p = data; p < end; p++)
+    {
+      unsigned char c = static_cast<unsigned char> (*p);
+      /* ASCII tolower: avoids locale overhead in inner loop.  */
+      if (c >= 'A' && c <= 'Z')
+        c += 32;
+      s = nodes[s].next[c];
+      if (nodes[s].out_len > 0)
+        {
+          matches++;
+          if (only_exists)
+            return 1;
+          if (max_count > 0 && matches >= max_count)
+            return matches;
+          const char *nl = static_cast<const char *> (
+            memchr (p, '\n', static_cast<size_t> (end - p)));
+          if (!nl)
+            return matches;
+          p = nl;
+          s = 0;
+        }
+    }
+  return matches;
+}
+
+/* ---------- portable word-at-a-time (all arches, baseline) ---------- */
+
+static inline uint64_t
+has_zero_byte (uint64_t v)
+{
+  return (v - 0x0101010101010101ULL) & ~v & 0x8080808080808080ULL;
+}
+
+static inline uint64_t
+has_byte (uint64_t v, unsigned char c)
+{
+  uint64_t x = v ^ (0x0101010101010101ULL * c);
+  return has_zero_byte (x);
+}
+
+static const char *
+memchr_portable (const char *s, size_t n, unsigned char c)
+{
+  const unsigned char *p = reinterpret_cast<const unsigned char *> (s);
+  const unsigned char *end = p + n;
+
+  while (p < end && (reinterpret_cast<uintptr_t> (p) & 7))
+    {
+      if (*p == c)
+        return reinterpret_cast<const char *> (p);
+      p++;
+    }
+
+  uint64_t splat = 0x0101010101010101ULL * c;
+  while (p + 8 <= end)
+    {
+      uint64_t v;
+      std::memcpy (&v, p, 8);
+      uint64_t m = has_zero_byte (v ^ splat);
+      if (m)
+        {
+          unsigned off = static_cast<unsigned> (__builtin_ctzll (m)) >> 3;
+          return reinterpret_cast<const char *> (p + off);
+        }
+      p += 8;
+    }
+
+  while (p < end)
+    {
+      if (*p == c)
+        return reinterpret_cast<const char *> (p);
+      p++;
+    }
+  return nullptr;
+}
+
+static const char *
+memmem_portable (const char *hay, size_t hlen, const char *ndl, size_t nlen)
+{
+  if (nlen == 0)
+    return hay;
+  if (nlen > hlen)
+    return nullptr;
+  if (nlen == 1)
+    return memchr_portable (hay, hlen, static_cast<unsigned char> (ndl[0]));
+
+  unsigned char first = static_cast<unsigned char> (ndl[0]);
+  const char *end = hay + hlen - nlen + 1;
+  const char *p = hay;
+  while (p < end)
+    {
+      const char *q = memchr_portable (p, static_cast<size_t> (end - p), first);
+      if (!q)
+        return nullptr;
+      if (std::memcmp (q, ndl, nlen) == 0)
+        return q;
+      p = q + 1;
+    }
+  return nullptr;
+}
+
+#if defined(RG_HAVE_GCC_VECTOR)
+
+/* 16-byte vector memchr via GCC __attribute__((vector_size)).  */
+using u8x16 = unsigned char __attribute__ ((vector_size (16)));
+
+static const char *
+memchr_gcc_vec (const char *s, size_t n, unsigned char c)
+{
+  const char *p = s;
+  const char *end = s + n;
+  u8x16 needle = {};
+  for (int i = 0; i < 16; i++)
+    needle[i] = c;
+
+  while (p + 16 <= end)
+    {
+      u8x16 block;
+      std::memcpy (&block, p, 16);
+      u8x16 eq = block == needle;
+      /* Collapse to scalar mask by OR-ing all lanes.  */
+      unsigned char any = 0;
+      for (int i = 0; i < 16; i++)
+        any |= eq[i];
+      if (any)
+        {
+          for (int i = 0; i < 16; i++)
+            if (p[i] == static_cast<char> (c))
+              return p + i;
+        }
+      p += 16;
+    }
+  return memchr_portable (p, static_cast<size_t> (end - p), c);
+}
+
+static const char *
+memmem_gcc_vec_first (const char *hay, size_t hlen, const char *ndl, size_t nlen)
+{
+  if (nlen == 0)
+    return hay;
+  if (nlen > hlen)
+    return nullptr;
+  unsigned char first = static_cast<unsigned char> (ndl[0]);
+  const char *end = hay + hlen - nlen + 1;
+  const char *p = hay;
+  while (p < end)
+    {
+      const char *q = memchr_gcc_vec (p, static_cast<size_t> (end - p), first);
+      if (!q)
+        return nullptr;
+      if (std::memcmp (q, ndl, nlen) == 0)
+        return q;
+      p = q + 1;
+    }
+  return nullptr;
+}
+
+#endif /* RG_HAVE_GCC_VECTOR */
+
+#if defined(RG_ARCH_X86_64)
+
+static bool g_have_avx2 = false;
+static bool g_x86_inited = false;
+
+static void
+x86_init ()
+{
+  if (g_x86_inited)
+    return;
+  g_x86_inited = true;
+  unsigned eax, ebx, ecx, edx;
+  if (__get_cpuid_count (7, 0, &eax, &ebx, &ecx, &edx))
+    g_have_avx2 = (ebx & (1u << 5)) != 0;
+}
+
+static const char *
+memchr_sse2 (const char *s, size_t n, unsigned char c)
+{
+  const char *p = s;
+  const char *end = s + n;
+  __m128i needle = _mm_set1_epi8 (static_cast<char> (c));
+
+  while (p + 16 <= end)
+    {
+      __m128i block = _mm_loadu_si128 (reinterpret_cast<const __m128i *> (p));
+      __m128i eq = _mm_cmpeq_epi8 (block, needle);
+      int mask = _mm_movemask_epi8 (eq);
+      if (mask)
+        return p + __builtin_ctz (static_cast<unsigned> (mask));
+      p += 16;
+    }
+  return memchr_portable (p, static_cast<size_t> (end - p), c);
+}
+
+/* target("avx2"): compile with AVX2 without requiring -mavx2 for whole TU.  */
+#if defined(__GNUC__) || defined(__clang__)
+__attribute__ ((target ("avx2")))
+#endif
+static const char *
+memchr_avx2 (const char *s, size_t n, unsigned char c)
+{
+  const char *p = s;
+  const char *end = s + n;
+  __m256i needle = _mm256_set1_epi8 (static_cast<char> (c));
+
+  while (p + 32 <= end)
+    {
+      __m256i block = _mm256_loadu_si256 (reinterpret_cast<const __m256i *> (p));
+      __m256i eq = _mm256_cmpeq_epi8 (block, needle);
+      int mask = _mm256_movemask_epi8 (eq);
+      if (mask)
+        return p + __builtin_ctz (static_cast<unsigned> (mask));
+      p += 32;
+    }
+  return memchr_sse2 (p, static_cast<size_t> (end - p), c);
+}
+
+static const char *
+memmem_sse2_first (const char *hay, size_t hlen, const char *ndl, size_t nlen)
+{
+  if (nlen == 0)
+    return hay;
+  if (nlen > hlen)
+    return nullptr;
+  unsigned char first = static_cast<unsigned char> (ndl[0]);
+  const char *end = hay + hlen - nlen + 1;
+  const char *p = hay;
+  while (p < end)
+    {
+      const char *q = memchr_sse2 (p, static_cast<size_t> (end - p), first);
+      if (!q)
+        return nullptr;
+      if (std::memcmp (q, ndl, nlen) == 0)
+        return q;
+      p = q + 1;
+    }
+  return nullptr;
+}
+
+#if defined(__GNUC__) || defined(__clang__)
+__attribute__ ((target ("avx2")))
+#endif
+static const char *
