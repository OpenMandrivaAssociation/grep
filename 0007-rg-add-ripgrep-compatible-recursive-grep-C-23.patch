+/* ---------- 2-byte prefix Teddy (N=2 buckets) ----------
+   Much sparser than 1-byte: e.g. foo|bar|baz|quux → prefixes fo/ba/qu only.
+   AVX2: for each distinct (b0,b1), AND(eq(block,b0), eq(block+1,b1)).  */
+
+#if defined(RG_ARCH_X86_64)
+#if defined(__GNUC__) || defined(__clang__)
+__attribute__ ((target ("avx2")))
+#endif
+static intmax_t
+lits_any_teddy2_avx2 (const Prefilter &pf, const char *data, size_t size,
+                      bool only_exists, intmax_t max_count,
+                      const uint16_t *prefs, int npref, size_t max_nlen)
+{
+  const char *end = data + size;
+  const char *p = data;
+  intmax_t matches = 0;
+
+  /* Up to 8 distinct 2-byte prefixes as parallel lanes.  */
+  __m256i v0[8], v1[8];
+  int np = npref > 8 ? 8 : npref;
+  for (int i = 0; i < np; i++)
+    {
+      unsigned char b0 = static_cast<unsigned char> (prefs[i] & 0xff);
+      unsigned char b1 = static_cast<unsigned char> ((prefs[i] >> 8) & 0xff);
+      v0[i] = _mm256_set1_epi8 (static_cast<char> (b0));
+      v1[i] = _mm256_set1_epi8 (static_cast<char> (b1));
+    }
+
+  while (p + 33 + max_nlen <= end)
+    {
+      __m256i blk0 = _mm256_loadu_si256 (reinterpret_cast<const __m256i *> (p));
+      __m256i blk1 = _mm256_loadu_si256 (reinterpret_cast<const __m256i *> (p + 1));
+      __m256i any = _mm256_setzero_si256 ();
+      for (int i = 0; i < np; i++)
+        {
+          __m256i m0 = _mm256_cmpeq_epi8 (blk0, v0[i]);
+          __m256i m1 = _mm256_cmpeq_epi8 (blk1, v1[i]);
+          any = _mm256_or_si256 (any, _mm256_and_si256 (m0, m1));
+        }
+      unsigned mask = static_cast<unsigned> (_mm256_movemask_epi8 (any));
+      bool advanced = false;
+      while (mask)
+        {
+          unsigned bit = static_cast<unsigned> (__builtin_ctz (mask));
+          mask &= mask - 1;
+          const char *cand = p + bit;
+          uint16_t pref = load_u16_le (cand);
+          if (!lits_any_match_at_pref2 (pf, cand, end, pref))
+            continue;
+          matches++;
+          if (only_exists)
+            return 1;
+          if (max_count > 0 && matches >= max_count)
+            return matches;
+          const char *nl = static_cast<const char *> (
+            memchr (cand, '\n', static_cast<size_t> (end - cand)));
+          p = nl ? nl + 1 : end;
+          advanced = true;
+          break;
+        }
+      if (!advanced)
+        p += 32;
+    }
+
+  /* Scalar tail with 2-byte has-table (built by caller path via prefs).  */
+  while (p + max_nlen <= end)
+    {
+      uint16_t w = load_u16_le (p);
+      bool ok = false;
+      for (int i = 0; i < npref; i++)
+        if (prefs[i] == w)
+          {
+            ok = true;
+            break;
+          }
+      if (ok && lits_any_match_at_pref2 (pf, p, end, w))
+        {
+          matches++;
+          if (only_exists)
+            return 1;
+          if (max_count > 0 && matches >= max_count)
+            return matches;
+          const char *nl = static_cast<const char *> (
+            memchr (p, '\n', static_cast<size_t> (end - p)));
+          if (!nl)
+            return matches;
+          p = nl + 1;
+        }
+      else
+        p++;
+    }
+  return matches;
+}
