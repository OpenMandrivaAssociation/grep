+            extra_pats.emplace_back (line);
+        }
+      free (line);
+      fclose (f);
+    }
+  if (!extra_pats.empty ())
+    {
+      for (size_t i = 0; i < extra_pats.size (); i++)
+        {
+          if (i)
+            pattern += opt_fixed ? "\n" : "|";
+          pattern += extra_pats[i];
+        }
+    }
+  /* --files has no pattern; remaining argv entries are only search roots.  */
+  else if (!files_only && pattern.empty () && optind < argc)
+    pattern = argv[optind++];
+
+  if (!files_only && pattern.empty ())
+    usage (2);
+
+  if (smart_case && !files_only)
+    {
+      bool has_upper = false;
+      for (char ch : pattern)
+        if (std::isupper (static_cast<unsigned char> (ch)))
+          has_upper = true;
+      opt_ignore_case = !has_upper;
+    }
+
+  if (!files_only)
+    compile_pattern (pattern);
+
+  /* Pre-build colored fixed literal once (used by search_fixed / LitsAny print).  */
+  if (g_use_color && col_match_len && opt_fixed && !g_fixed.empty () && !opt_replace)
+    {
+      size_t total = col_match_len + g_fixed.size () + col_reset_len;
+      g_colored_fixed = static_cast<char *> (std::malloc (total));
+      if (g_colored_fixed)
+        {
+          char *p = g_colored_fixed;
+          std::memcpy (p, col_match, col_match_len); p += col_match_len;
+          std::memcpy (p, g_fixed.data (), g_fixed.size ()); p += g_fixed.size ();
+          std::memcpy (p, col_reset, col_reset_len);
+          g_colored_fixed_len = total;
+        }
+    }
+
+  int path_argc = argc - optind;
+  bool any = false;
+
+  if (files_only)
+    {
+      /* --files never consumes a pattern; all remaining args are search roots.  */
+      std::vector<std::string> files;
+      const bool no_ign = opt_no_ignore || opt_unrestricted >= 1;
+      std::vector<std::string> roots;
+      if (path_argc <= 0)
+        roots.push_back (".");
+      else
+        for (int i = optind; i < argc; i++)
+          roots.emplace_back (argv[i]);
+      if (!no_ign)
+        {
+          for (const auto &r : roots)
+            load_global_and_parent_ignores (r == "." ? "." : r);
+        }
+      /* Always honor explicit roots (single or multi); do not parallel-walk
+         "." when the user passed an absolute/relative path.  */
+      for (const auto &r : roots)
+        {
+          struct stat st;
+          if (stat (r.c_str (), &st))
+            continue;
+          if (S_ISDIR (st.st_mode))
+            collect_dir (r, r == "." ? "" : r, &files, false);
+          else if (S_ISREG (st.st_mode))
+            files.emplace_back (r);
+        }
+      for (const auto &f : files)
+        puts (display_path (f));
+      return files.empty () ? 1 : 0;
+    }
+
+  if (path_argc <= 0)
+    {
+      if (!isatty (STDIN_FILENO))
+        {
+          opt_with_filename = false;
+          any = run_paths ({"-"});
+        }
+      else
+        {
+          opt_with_filename = !opt_no_filename;
+          any = run_walk_and_search ({"."});
+        }
+    }
+  else
+    {
+      bool any_dir = false;
+      for (int i = optind; i < argc; i++)
+        {
+          struct stat st;
+          if (!stat (argv[i], &st) && S_ISDIR (st.st_mode))
+            any_dir = true;
+        }
+      if (any_dir && !opt_passthru)
+        {
+          opt_with_filename = !opt_no_filename;
+          std::vector<std::string> roots;
+          for (int i = optind; i < argc; i++)
+            roots.emplace_back (argv[i]);
+          any = run_walk_and_search (roots);
+        }
+      else
+        {
+          std::vector<std::string> paths;
+          for (int i = optind; i < argc; i++)
+            paths.emplace_back (argv[i]);
+          if (paths.size () > 1)
+            opt_with_filename = !opt_no_filename;
+          any = run_paths (paths);
+        }
+    }
+
+  intmax_t total_ns = elapsed_nanos (g_t0);
+  if (opt_json)
+    {
+      std::lock_guard<std::mutex> lock (g_out_mu);
+      intmax_t ml = stat_lines_matched.load ();
+      intmax_t ms = stat_match_spans.load ();
+      if (ms < ml)
+        ms = ml;
+      intmax_t fs = stat_files_searched.load ();
+      intmax_t fm = stat_files_matched.load ();
+      intmax_t bs = stat_bytes_searched.load ();
+      json_emit_summary (ml, ms, bs, fs, fm, total_ns, total_ns);
+    }
+
+  if (opt_stats)
+    {
+      char human[64];
+      format_human_dur (total_ns, human, sizeof human);
+      fprintf (stderr,
+               "\n%s stats:\n  files searched: %" PRIdMAX
+               "\n  files matched: %" PRIdMAX
+               "\n  lines matched: %" PRIdMAX
+               "\n  match spans: %" PRIdMAX
+               "\n  bytes searched: %" PRIdMAX
+               "\n  bytes printed: %" PRIdMAX
+               "\n  elapsed: %s\n  simd backend: %s\n",
+               g_prog,
+               stat_files_searched.load (),
+               stat_files_matched.load (),
+               stat_lines_matched.load (),
+               stat_match_spans.load (),
+               stat_bytes_searched.load (),
+               stat_bytes_printed.load (),
+               human,
+               rg_simd::backend_name ());
+    }
+
+  (void) opt_iglob;
+  (void) g_seen_devs;
+  (void) opt_ignore_files_cli;
+
+  return any ? 0 : 1;
+}
