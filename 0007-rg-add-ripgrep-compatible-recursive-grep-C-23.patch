@@ -0,0 +1,159 @@
+/* rg_simd.hpp - multi-arch SIMD byte/string search + regex prefilter (rg only).
+   Targets: x86_64 (SSE2/AVX2), aarch64 (NEON), loongarch64 & riscv64 (portable
+   word / GCC vector fallbacks).  */
+
+#ifndef RG_SIMD_HPP
+#define RG_SIMD_HPP
+
+#include <cstddef>
+#include <cstdint>
+#include <string>
+#include <string_view>
+#include <vector>
+
+/* intmax_t for scan_class_run match counts.  */
+#include <cinttypes>
+
+namespace rg_simd {
+
+/* Fast memchr / memmem (case-sensitive).  */
+const char *memchr_fast (const char *s, size_t n, unsigned char c);
+const char *memmem_fast (const char *hay, size_t hlen, const char *ndl, size_t nlen);
+
+/* Case-insensitive memmem (ASCII tolower).  AVX2 two-byte filter path.  */
+const char *memmem_icase_fast (const char *hay, size_t hlen,
+                               const char *ndl, size_t nlen);
+
+/* Prefilter derived from a pattern (ripgrep-style required-byte / literal).  */
+enum class PrefKind : uint8_t {
+  None,       /* no useful prefilter; always run matcher */
+  Byte,       /* must see this byte before a possible match */
+  Bytes2,     /* must see either of two bytes (e.g. class span) */
+  Literal,    /* must contain this literal substring */
+  LitsAny,    /* must contain ANY of these literals (alternation branches) */
+};
+
+/* Compact Aho–Corasick automaton for multi-literal ANY match (alternation).
+   Built once per Prefilter; scan is O(n) single pass.  */
+struct AhoCorasick {
+  struct Node {
+    int next[256];
+    int fail = 0;
+    int out_len = 0; /* longest match ending here (0 = none) */
+    Node ()
+    {
+      for (int &x : next)
+        x = -1;
+    }
+  };
+  std::vector<Node> nodes;
+  bool built = false;
+
+  void clear ()
+  {
+    nodes.clear ();
+    built = false;
+  }
+  void build (const std::vector<std::string> &pats);
+  void build_icase (const std::vector<std::string> &pats);
+  /* First match start in [cur, end), or end if none.  *mlen = pattern length.  */
+  const char *find_first (const char *cur, const char *end, size_t *mlen) const;
+  /* Icase variant: ASCII tolower on each input byte before transitioning.  */
+  const char *find_first_icase (const char *cur, const char *end, size_t *mlen) const;
+  /* Count line-oriented hits (one per line), stop early if only_exists.  */
+  intmax_t scan_lines (const char *data, size_t size, bool only_exists,
+                       intmax_t max_count) const;
+  /* Icase scan: fold input byte through tolower before transition.  */
+  intmax_t scan_lines_icase (const char *data, size_t size, bool only_exists,
+                             intmax_t max_count) const;
+};
+
+struct Prefilter {
+  PrefKind kind = PrefKind::None;
+  unsigned char b0 = 0;
+  unsigned char b1 = 0;
+  std::string lit; /* for PrefKind::Literal */
+  std::vector<std::string> lits; /* for PrefKind::LitsAny */
+  AhoCorasick ac; /* built only when AC is profitable (many/short needles) */
+  bool use_ac = false; /* prefer AC over multi-memmem for LitsAny */
+  bool icase = false; /* ASCII case-insensitive LitsAny verify */
+  /* First-byte bitmap for LitsAny memmem hybrid (any branch first byte).  */
+  bool lits_fb[256] = {};
+
+  bool active () const { return kind != PrefKind::None; }
+};
+
+/* Hybrid LitsAny: scan for earliest hit; *mlen set when found.  */
+const char *lits_any_find_first (const Prefilter &pf, const char *cur, const char *end,
+                                 size_t *mlen);
+/* Line-oriented match count for LitsAny (grep -c style).  */
+intmax_t lits_any_scan_lines (const Prefilter &pf, const char *data, size_t size,
+                              bool only_exists, intmax_t max_count);
+
+/* Fast path: whole pattern is one ASCII class + exact quantifier, e.g. [A-Za-z]{8}.  */
+enum class ClassKind : uint8_t {
+  None = 0,
+  Alpha,      /* [A-Za-z] / [a-zA-Z] */
+  Alnum,      /* [A-Za-z0-9] */
+  Digit,      /* [0-9] */
+  Word,       /* [A-Za-z0-9_]  (ERE \w-ish subset) */
+  Lower,      /* [a-z] */
+  Upper,      /* [A-Z] */
+};
+
+struct ClassRunPat {
+  ClassKind kind = ClassKind::None;
+  unsigned min_run = 0; /* minimum consecutive class members (from {n} or {n,}) */
+  unsigned max_run = 0; /* 0 = unlimited ({n,} / +); else exact/max from quantifier */
+  /* Optional leading single-class atom before the quantified run, e.g.
+     [A-Za-z_][A-Za-z0-9_]{7,}  — first_kind is the leading class (exactly one
+     member required), then `kind` runs for min_run..max_run more members.
+     Total minimum length = 1 + min_run when first_kind is set.  */
+  ClassKind first_kind = ClassKind::None;
+
+  bool active () const { return kind != ClassKind::None && min_run > 0; }
+  bool has_prefix () const { return first_kind != ClassKind::None; }
+};
+
+/* Build prefilter from ERE/fixed pattern text (no anchors/backrefs analysis).  */
+Prefilter build_prefilter (std::string_view pattern, bool ignore_case, bool is_fixed);
+
+/* Detect class-run fast path; returns inactive ClassRunPat if not applicable.  */
+ClassRunPat build_class_run_pat (std::string_view pattern, bool ignore_case);
+
+/* Advance cursor to next position where prefilter may pass (or end).
+   Returns pointer within [cur, end) or end.  */
+const char *prefilter_next (const Prefilter &pf, const char *cur, const char *end);
+
+/* Scan buffer for class-run matches.  count_lines: increment once per line that
+   contains a match (grep -c style).  only_exists: stop at first match.
+   Returns number of matches (or 1 if only_exists && found).  */
+intmax_t scan_class_run (const ClassRunPat &pat, const char *data, size_t size,
+                         bool count_lines, bool only_exists, intmax_t max_count);
+
+/* Fast exists check for class_run in a short line (≤ line_len bytes).
+   Returns true if the line contains at least one class run of min_run.  */
+bool class_run_line_exists (const ClassRunPat &pat, const char *data, size_t size);
+
+/* Find first class_run match span in [data, data+size).
+   Returns true and sets *so/*eo to byte offsets of the match.  */
+bool find_class_run_span (const ClassRunPat &pat, const char *data, size_t size,
+                          intmax_t *so, intmax_t *eo);
+
+/* Fast newline count in [data, data+size) using SIMD.  Also returns pointer
+   to byte after the last \n found (*last_nl_next) or data if none.  */
+intmax_t count_newlines (const char *data, size_t size, const char **last_nl_next);
+
+/* SIMD line-index builder: scan data for newlines, store line-start pointers
+   into out[].  out[0] = data (first line always starts at offset 0).
+   Returns the number of lines found.  out must have capacity for at least
+   count_newlines()+1 entries.  Uses AVX2 bitmask extraction.  */
+size_t build_line_starts (const char *data, size_t size,
+                          const char **out, size_t out_cap);
+
+/* Human-readable backend name for --stats / debugging.  */
+const char *backend_name ();
+
+} /* namespace rg_simd */
+
+#endif
