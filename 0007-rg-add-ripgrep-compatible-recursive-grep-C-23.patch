diff --git a/src/pcresearch.c b/src/pcresearch.c
index 00162c5..7dacef1 100644
--- a/src/pcresearch.c
+++ b/src/pcresearch.c
@@ -419,3 +419,112 @@ Pexecute (void *vcp, char const *buf, idx_t size, idx_t *match_size,
       return beg - buf;
     }
 }
+
+/* Whole-buffer PCRE execute for multiline (-U) search.  Unlike Pexecute,
+   the subject is the entire BUF (not split on eolbyte), so patterns such as
+   (?s).*\\n.* and patterns containing a real newline can match across lines.
+   Returns the byte offset of the match in BUF and stores the match length in
+   *MATCH_SIZE (always the true match span, not the containing line).  */
+ptrdiff_t
+Pexecute_whole (void *vcp, char const *buf, idx_t size, idx_t *match_size,
+                char const *start_ptr)
+{
+  struct pcre_comp *pc = vcp;
+  PCRE2_SIZE *sub = pcre2_get_ovector_pointer (pc->data);
+  char const *p = start_ptr ? start_ptr : buf;
+  bool bol = (p == buf) ? (p[-1] == eolbyte) : false;
+  char const *subject = buf;
+  int e = PCRE2_ERROR_NOMATCH;
+
+  if (PCRE2_SIZE_MAX < size)
+    die (EXIT_TROUBLE, 0, _("exceeded PCRE's line length limit"));
+
+  for (;;)
+    {
+      while (p < buf + size && localeinfo.sbclen[to_uchar (*p)] == -1)
+        {
+          p++;
+          subject = p;
+          bol = false;
+        }
+
+      if (p >= buf + size)
+        {
+          e = PCRE2_ERROR_NOMATCH;
+          break;
+        }
+
+      idx_t search_offset = p - subject;
+      int options = 0;
+      if (!bol)
+        options |= PCRE2_NOTBOL;
+
+      /* Empty subject at end: use precomputed empty-match table.  */
+      if (search_offset == size - (subject - buf) && size == (idx_t) (p - buf))
+        {
+          /* p at end of buffer with empty remaining — check empty match only.  */
+        }
+
+      e = jit_exec (pc, subject, size - (subject - buf), search_offset, options);
+      if (MATCH_INVALID_UTF != 0 && bad_utf8_from_pcre2 (e))
+        {
+          idx_t valid_bytes = pcre2_get_startchar (pc->data);
+          if (search_offset <= valid_bytes)
+            {
+              if (valid_bytes == 0)
+                {
+                  sub[0] = sub[1] = 0;
+                  e = pc->empty_match[bol];
+                }
+              else
+                e = jit_exec (pc, subject, valid_bytes, search_offset,
+                              options | PCRE2_NO_UTF_CHECK | PCRE2_NOTEOL);
+              if (e != PCRE2_ERROR_NOMATCH)
+                break;
+              p = subject + valid_bytes + 1;
+              bol = false;
+            }
+          subject += valid_bytes + 1;
+          continue;
+        }
+      break;
+    }
+
+  if (e <= 0)
+    {
+      switch (e)
+        {
+        case PCRE2_ERROR_NOMATCH:
+          break;
+        case PCRE2_ERROR_NOMEMORY:
+          die (EXIT_TROUBLE, 0, _("%s: memory exhausted"), input_filename ());
+        case PCRE2_ERROR_JIT_STACKLIMIT:
+          die (EXIT_TROUBLE, 0, _("%s: exhausted PCRE JIT stack"),
+               input_filename ());
+        case PCRE2_ERROR_MATCHLIMIT:
+          die (EXIT_TROUBLE, 0, _("%s: exceeded PCRE's backtracking limit"),
+               input_filename ());
+        case PCRE2_ERROR_DEPTHLIMIT:
+          die (EXIT_TROUBLE, 0,
+               _("%s: exceeded PCRE's nested backtracking limit"),
+               input_filename ());
+        case PCRE2_ERROR_RECURSELOOP:
+          die (EXIT_TROUBLE, 0, _("%s: PCRE detected recurse loop"),
+               input_filename ());
+#ifdef PCRE2_ERROR_HEAPLIMIT
+        case PCRE2_ERROR_HEAPLIMIT:
+          die (EXIT_TROUBLE, 0, _("%s: exceeded PCRE's heap limit"),
+               input_filename ());
+#endif
+        default:
+          die (EXIT_TROUBLE, 0, _("%s: internal PCRE error: %d"),
+               input_filename (), e);
+        }
+      return -1;
+    }
+
+  char const *matchbeg = subject + sub[0];
+  char const *matchend = subject + sub[1];
+  *match_size = matchend - matchbeg;
+  return matchbeg - buf;
+}
