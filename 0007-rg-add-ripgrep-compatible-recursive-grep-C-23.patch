diff --git a/scripts/build-rg-pgo.sh b/scripts/build-rg-pgo.sh
new file mode 100755
index 0000000..c12b130
--- /dev/null
+++ b/scripts/build-rg-pgo.sh
@@ -0,0 +1,111 @@
+#!/usr/bin/env bash
+# Two-pass GCC PGO build for src/rg (instrument → train → optimize).
+#
+# Usage:
+#   ./scripts/build-rg-pgo.sh
+#   CORPUS_DIR=/path/to/tree CORPUS_FILE=/path/to/big.bin ./scripts/build-rg-pgo.sh
+#
+# Produces: src/rg  (PGO+LTO). Intermediate: src/rg.pgo-gen, $PROFDIR/*.gcda
+# Prefer CXX=g++ (clang has ICE'd on this tree with LTO).
+set -euo pipefail
+
+ROOT="$(cd "$(dirname "$0")/.." && pwd)"
+SRC="$ROOT/src"
+CXX="${CXX:-/usr/bin/g++}"
+PROFDIR="${PROFDIR:-/tmp/rg-pgo-profdata}"
+CORPUS_DIR="${CORPUS_DIR:-/tmp/rgbench}"
+CORPUS_FILE="${CORPUS_FILE:-/tmp/rgbench_2210/corpus.bin}"
+
+cd "$SRC"
+make -e CXX="$CXX" rg >/dev/null 2>&1 || make -e CXX="$CXX" rg
+
+pass1_c="-O3 -std=gnu++23 -Wall -flto=auto -fprofile-generate=$PROFDIR"
+pass1_cc="-O3 -std=gnu23 -flto=auto -fprofile-generate=$PROFDIR"
+pass1_ld="-flto=auto -fprofile-generate=$PROFDIR"
+pass2_c="-O3 -std=gnu++23 -Wall -flto=auto -fprofile-use=$PROFDIR -fprofile-correction"
+pass2_cc="-O3 -std=gnu23 -flto=auto -fprofile-use=$PROFDIR -fprofile-correction"
+pass2_ld="-flto=auto -fprofile-use=$PROFDIR"
+
+echo "==> Pass 1: instrumented build"
+rm -rf "$PROFDIR"
+mkdir -p "$PROFDIR"
+# Drop any prior clang/g++ mix of .o files (LTO/format mismatch).
+rm -f rg rg.pgo-gen rg-*.o
+make -e CXX="$CXX" CC="${CC:-${CXX/g++/gcc}}" rg_CXXFLAGS="$pass1_c" rg_CFLAGS="$pass1_cc" rg_LDFLAGS="$pass1_ld" rg
+cp -f rg rg.pgo-gen
+
+echo "==> Training runs"
+RG="$SRC/rg.pgo-gen"
+# Cover fixed / LitsAny / class_run / PCRE / multiline / ignore / recurse.
+if [[ -f "$CORPUS_FILE" ]]; then
+  "$RG" -c 'hello' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -F -c 'hello' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -c 'zzzzzNOMATCH' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -c 'foo|bar|baz|quux' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -c '\w{5,}' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -P -c '\w{5,}' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -P -c '\d+' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -F -c -i 'include' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -c -i 'foo|bar|baz|quux' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -n -F 'include' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -n -i -F 'include' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -c 'static.*void' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -n 'static.*void' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -c -i 'static.*void' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -c 'static.*void.*\(' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -w -F -c 'static' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -w -F -n 'static' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -v -c 'include' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -v -n 'include' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -C2 'include' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -C2 -n 'static' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -C2 -n -F 'include' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -b -F 'include' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" --heading -n 'static' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -r REPL -F 'include' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  # Extra weight for color/print paths (PGO tends to over-optimize count paths).
+  "$RG" --color=always -n 'static' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" --color=always -n 'static' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" --color=always -n -F 'include' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -n 'static' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -n -F 'static' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -v 'include' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  # Regex-print two-pass parallel path + multiline.
+  "$RG" '[a-z]{8}' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -i '[a-z]{8}' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  "$RG" -U -c 'void\n' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  # Alt-icase print (two-pass parallel LitsAny).
+  "$RG" -i 'include|define|struct|return|static' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  # Fixed-string print (two-pass parallel).
+  "$RG" -F 'include' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  # Byte-offset (backward-scan fast path).
+  "$RG" -b -F 'include' "$CORPUS_FILE" >/dev/null 2>&1 || true
+  # Context (context-C2).
+  "$RG" -C2 -F 'include' "$CORPUS_FILE" >/dev/null 2>&1 || true
+fi
+if [[ -d "$CORPUS_DIR" ]]; then
+  "$RG" --count 'foo|bar|baz|quux' "$CORPUS_DIR" >/dev/null 2>&1 || true
+  "$RG" 'foo|bar' "$CORPUS_DIR" >/dev/null 2>&1 || true
+  "$RG" -u --count 'include' "$CORPUS_DIR" >/dev/null 2>&1 || true
+fi
+if [[ -d "$SRC" ]]; then
+  "$RG" --count 'foo|bar|baz|quux' "$SRC" >/dev/null 2>&1 || true
+  "$RG" -c 'include' "$SRC" >/dev/null 2>&1 || true
+  "$RG" -n 'static' "$SRC/rg.cpp" >/dev/null 2>&1 || true
+  "$RG" -U 'void\n' "$SRC/rg.cpp" >/dev/null 2>&1 || true
+  "$RG" -U -P '(?s)static.*bool' "$SRC/rg.cpp" >/dev/null 2>&1 || true
+fi
+if [[ -d "$ROOT/../ripgrep/crates" ]]; then
+  "$RG" --count 'fn |pub |struct ' "$ROOT/../ripgrep/crates" >/dev/null 2>&1 || true
+fi
+
+nprof=$(find "$PROFDIR" -name '*.gcda' 2>/dev/null | wc -l)
+echo "    profile files: $nprof in $PROFDIR"
+[[ "$nprof" -ge 1 ]] || { echo "error: no .gcda in $PROFDIR" >&2; exit 1; }
+
+echo "==> Pass 2: profile-use"
+rm -f rg rg-*.o
+make -e CXX="$CXX" CC="${CC:-${CXX/g++/gcc}}" rg_CXXFLAGS="$pass2_c" rg_CFLAGS="$pass2_cc" rg_LDFLAGS="$pass2_ld" rg
+
+echo "==> Done: $SRC/rg"
+"$SRC/rg" --version | head -1
diff --git a/scripts/rg-correctness.sh b/scripts/rg-correctness.sh
new file mode 100755
index 0000000..6419cb6
--- /dev/null
+++ b/scripts/rg-correctness.sh
@@ -0,0 +1,282 @@
+#!/usr/bin/env bash
+# Ripgrep-oriented correctness / regression checks for cpp rg.
+# Exit 0 if all pass.  Override: RG=/path/to/rg ./scripts/rg-correctness.sh
+set -euo pipefail
+RG="${RG:-$(cd "$(dirname "$0")/../src" && pwd)/rg}"
+fail=0
+pass() { echo "  ok: $*"; }
+bad() { echo "  FAIL: $*" >&2; fail=1; }
+
+tmp=$(mktemp -d)
+trap 'rm -rf "$tmp"' EXIT
+
+echo 'hello world' > "$tmp/a.txt"
+echo 'foo bar' > "$tmp/b.txt"
+mkdir -p "$tmp/sub"
+echo 'baz' > "$tmp/sub/c.txt"
+echo 'noise' > "$tmp/x.log"
+echo '*.log' > "$tmp/.gitignore"
+mkdir -p "$tmp/nest"
+echo 'hitme' > "$tmp/nest/tracked.txt"
+echo 'tracked.txt' > "$tmp/nest/.gitignore"
+echo '.secret' > "$tmp/.hidden"
+# .ignore always applies (even outside git)
+echo 'b.txt' > "$tmp/.ignore"
+# binary-ish
+printf 'bin\0ary\n' > "$tmp/hasnul.bin"
+echo 'printable' > "$tmp/ok.txt"
+
+# ========== ignore / git worktree ==========
+# Outside git: .gitignore must NOT apply (ripgrep parity)
+out=$("$RG" 'noise' "$tmp" 2>&1 || true)
+echo "$out" | grep -q noise && pass "outside git: .gitignore not applied (x.log searchable)" \
+  || bad "outside git should search x.log despite .gitignore: $out"
+
+out=$("$RG" 'hitme' "$tmp" 2>&1 || true)
+echo "$out" | grep -q hitme && pass "outside git: nested .gitignore not applied" \
+  || bad "outside git nested .gitignore wrongly applied: $out"
+
+# .ignore still applies outside git
+out=$("$RG" 'foo' "$tmp" 2>&1 || true)
+echo "$out" | grep -q 'b.txt' && bad ".ignore should suppress b.txt: $out" \
+  || pass ".ignore applies outside git (b.txt suppressed)"
+
+# Inside git: .gitignore applies
+(cd "$tmp" && git init -q 2>/dev/null || true)
+out=$("$RG" 'noise' "$tmp" 2>&1 || true)
+[[ -z "$out" ]] && pass "inside git: .gitignore suppresses x.log" || bad "git .gitignore: $out"
+
+out=$("$RG" 'hitme' "$tmp" 2>&1 || true)
+[[ -z "$out" ]] && pass "inside git: nested .gitignore suppresses tracked.txt" || bad "git nested: $out"
+
+# ========== -r replace (not recurse) ==========
+out=$("$RG" -r 'X' 'hello' "$tmp" 2>&1 || true)
+echo "$out" | grep -q 'X world' && pass "-r is replace" || bad "-r replace: $out"
+set +e
+out=$("$RG" -r 'hello' "$tmp" 2>&1)
+set -e
+echo "$out" | grep -q 'hello world' && bad "-r hello dir recurse-searched" || pass "-r hello dir does not recurse-search"
+
+# ========== line numbers ==========
+out=$("$RG" 'hello' "$tmp/a.txt" 2>&1 || true)
+echo "$out" | grep -qE '^[0-9]+:' && bad "line numbers default on: $out" || pass "line numbers off by default"
+out=$("$RG" -n 'hello' "$tmp/a.txt" 2>&1 || true)
+echo "$out" | grep -qE '(^|:)1:' && pass "-n line number" || bad "-n: $out"
+
+# ========== hidden / -u / -uu / -uuu ==========
+out=$("$RG" 'secret' "$tmp" 2>&1 || true)
+[[ -z "$out" ]] && pass "hidden skipped by default" || bad "hidden: $out"
+out=$("$RG" -uu 'secret' "$tmp" 2>&1 || true)
+echo "$out" | grep -q secret && pass "-uu searches hidden" || bad "-uu: $out"
+# -u disables ignore (gitignore + ignore); x.log should match inside git tree
+out=$("$RG" -u 'noise' "$tmp" 2>&1 || true)
+echo "$out" | grep -q noise && pass "-u disables ignore (x.log searchable)" || bad "-u: $out"
+# -uuu / --text searches binary; without it NUL file is skipped for normal search
+out=$("$RG" 'bin' "$tmp/hasnul.bin" 2>&1 || true)
+[[ -z "$out" ]] && pass "binary/NUL file skipped by default" || bad "binary searched without -a: $out"
+out=$("$RG" -a 'bin' "$tmp/hasnul.bin" 2>&1 || true)
+echo "$out" | grep -q bin && pass "-a/--text searches binary" || bad "-a: $out"
+
+# ========== --files path + ignore ==========
+out=$("$RG" --files "$tmp" 2>&1 | sort || true)
+echo "$out" | grep -q 'PERFORMANCE_REPORT\|grep/AUTHORS' && bad "--files walked CWD" || pass "--files stays in path"
+echo "$out" | grep -q 'x.log' && bad "--files lists gitignored x.log" || pass "--files omits x.log (git)"
+echo "$out" | grep -q 'a.txt' && pass "--files lists a.txt" || bad "--files missing a.txt: $out"
+
+# ========== recurse / exit ==========
+out=$("$RG" 'baz' "$tmp" 2>&1 || true)
+echo "$out" | grep -q 'sub/c.txt' && pass "default recurse" || bad "recurse: $out"
+set +e
+"$RG" 'nomatch_xyz' "$tmp" >/dev/null 2>&1; ec=$?
+set -e
+[[ "$ec" == 1 ]] && pass "exit 1 no match" || bad "exit $ec no match"
+set +e
+"$RG" 'hello' "$tmp" >/dev/null 2>&1; ec=$?
+set -e
+[[ "$ec" == 0 ]] && pass "exit 0 match" || bad "exit $ec match"
+
+# ========== counts ==========
+out=$("$RG" -c 'o' "$tmp/a.txt" 2>&1 || true)
+echo "$out" | grep -qE '^1$|a.txt:1' && pass "count lines" || bad "count: $out"
+
+# ========== fixed / LitsAny / class_run vs baseline counts ==========
+# Build a corpus with known content
+corp="$tmp/corpus.txt"
+{
+  echo 'hello world hello'
+  echo 'foo and bar and baz and quux'
+  echo 'AAAAAAAABBBBBBBB'   # alpha run
+  echo 'id_12345_wordy'
+} > "$corp"
+
+# Extract count: last field after ':' or whole line if numeric only
+count_field() { local s="$1"; if [[ "$s" == *:* ]]; then echo "${s##*:}"; else echo "$s"; fi | tr -d '[:space:]'; }
+
+c_hello=$(count_field "$("$RG" -c 'hello' "$corp" 2>/dev/null | tail -1)")
+c_hello_f=$(count_field "$("$RG" -F -c 'hello' "$corp" 2>/dev/null | tail -1)")
+[[ "$c_hello" == "$c_hello_f" && -n "$c_hello" ]] && pass "fixed -F count matches ERE for literal hello ($c_hello)" \
+  || bad "hello counts diverge: ere=$c_hello fixed=$c_hello_f"
+
+c_alt=$(count_field "$("$RG" -c 'foo|bar|baz|quux' "$corp" 2>/dev/null | tail -1)")
+# Expect 1 line with all alts (line-oriented count)
+[[ "$c_alt" == "1" ]] && pass "LitsAny alt counts 1 line" || bad "alt count=$c_alt want 1"
+
+c_w=$(count_field "$("$RG" -c '\w{5,}' "$corp" 2>/dev/null | tail -1)")
+c_w_p=$(count_field "$("$RG" -P -c '\w{5,}' "$corp" 2>/dev/null | tail -1)")
+[[ "$c_w" == "$c_w_p" && -n "$c_w" ]] && pass "class_run/ERE \w{5,} matches -P count ($c_w)" \
+  || bad "\w{5,} counts: ere=$c_w pcre=$c_w_p"
+
+c_d=$(count_field "$("$RG" -P -c '\d+' "$corp" 2>/dev/null | tail -1 || echo err)")
+
+# ========== multiline -U ==========
+printf 'line1\nline2 foo\nline3\n' > "$tmp/ml.txt"
+# Ripgrep: `\n` in -U patterns is a real newline (spans lines)
+out=$("$RG" -U 'line1\nline2' "$tmp/ml.txt" 2>&1 || true)
+echo "$out" | grep -q 'line1' && pass "-U line1\\nline2 hits line1" || bad "-U \\n pattern: $out"
+echo "$out" | grep -q 'line2' && pass "-U line1\\nline2 hits line2" || bad "-U \\n span line2: $out"
+# Without -U, same pattern is stray \n (no span) or no match depending on engine
+out_no=$("$RG" 'line1\nline2' "$tmp/ml.txt" 2>&1 || true)
+echo "$out_no" | grep -qE 'line1.*line2|stray' || true  # may warn; must not equal full span match only if it worked without -U wrongly
+# PCRE multiline with (?s) and -U uses whole-buffer Pexecute_whole
+out=$("$RG" -U -P '(?s)line1.*foo' "$tmp/ml.txt" 2>&1 || true)
+echo "$out" | grep -q 'line1' && pass "-U -P (?s)line1.*foo spans" || bad "-U -P span: $out"
+# -U --multiline-dotall without (?s) in pattern
+out=$("$RG" -U --multiline-dotall -P 'line1.*foo' "$tmp/ml.txt" 2>&1 || true)
+echo "$out" | grep -q 'line1' && pass "-U --multiline-dotall -P" || bad "multiline-dotall: $out"
+# ERE -U with real newline in pattern via \\n escape
+out=$("$RG" -U 'line2.*foo' "$tmp/ml.txt" 2>&1 || true)
+echo "$out" | grep -q 'line2' && pass "-U single-line still works" || bad "-U single: $out"
+# -U -F must not fall through to empty-needle search_fixed
+out=$("$RG" -U -F 'line2' "$tmp/ml.txt" 2>&1 || true)
+echo "$out" | grep -q 'line2' && ! echo "$out" | grep -q 'line1' \
+  && pass "-U -F line2 only" || bad "-U -F: $out"
+out=$("$RG" -U -F 'zzz' "$tmp/ml.txt" 2>&1 || true)
+[[ -z "$out" ]] && pass "-U -F no-match is empty" || bad "-U -F zzz should miss: $out"
+ec_ml=0
+"$RG" -U 'foo' "$tmp/ml.txt" >/dev/null 2>&1 || ec_ml=$?
+[[ "$ec_ml" == 0 ]] && pass "multiline -U foo exit 0" || bad "multiline -U foo exit=$ec_ml"
+
+# ========== submodule / nested VCS root ==========
+# Parent .gitignore must not apply inside a submodule (.git file or dir)
+submod="$tmp/submod"
+mkdir -p "$submod"
+echo 'noise' > "$submod/x.log"
+echo 'keepme' > "$submod/ok.txt"
+# parent already has git init + *.log in .gitignore; submodule has its own .git
+mkdir -p "$submod/.git"
+echo 'ref: refs/heads/main' > "$submod/.git/HEAD"
+# Inside submodule, without its own .gitignore, x.log should be searchable
+# (parent *.log must not apply under separate VCS root)
+out=$("$RG" 'noise' "$submod" 2>&1 || true)
+echo "$out" | grep -q noise && pass "submodule: parent .gitignore not applied" \
+  || bad "submodule should search x.log (parent gitignore must not apply): $out"
+out=$("$RG" 'keepme' "$submod" 2>&1 || true)
+echo "$out" | grep -q keepme && pass "submodule: normal file searchable" || bad "submod ok: $out"
+
+# ========== icase fixed ==========
+echo -e "Hello World\nhello world\nHELLO WORLD\nfoo" > "$tmp/icase.txt"
+ic=$("$RG" -F -i -c 'hello' "$tmp/icase.txt" 2>&1 | sed 's/.*://' || true)
+[[ "$ic" == "3" ]] && pass "icase -F -i -c count=3" || bad "icase -F count=$ic (want 3)"
+ip=$("$RG" -F -i 'hello' "$tmp/icase.txt" 2>&1 | wc -l)
+[[ "$ip" == "3" ]] && pass "icase -F -i print=3 lines" || bad "icase -F print=$ip (want 3)"
+# short needle
+ic2=$("$RG" -F -i -c 'he' "$tmp/icase.txt" 2>&1 | sed 's/.*://' || true)
+[[ "$ic2" == "3" ]] && pass "icase short needle -c" || bad "icase short=$ic2 (want 3)"
+# single char
+echo -e "aAbB" > "$tmp/icase1.txt"
+ic3=$("$RG" -F -i -c 'a' "$tmp/icase1.txt" 2>&1 | sed 's/.*://' || true)
+[[ "$ic3" == "1" ]] && pass "icase single char -c" || bad "icase single=$ic3 (want 1)"
+# ERE icase (not fixed)
+ic4=$("$RG" -i -c 'hello' "$tmp/icase.txt" 2>&1 | sed 's/.*://' || true)
+[[ "$ic4" == "3" ]] && pass "icase ERE -c" || bad "icase ERE=$ic4 (want 3)"
+
+# ========== dual-literal fast path (lit.*lit) ==========
+cat > "$tmp/dual.txt" << 'DLEOF'
+static void foo
+static int bar
+void static baz
+staticvoid
+static  void
+STATIC VOID
+static
+void
+static something void here
+DLEOF
+dl1=$("$RG" -c 'static.*void' "$tmp/dual.txt" 2>&1 | sed 's/.*://' || true)
+[[ "$dl1" == "4" ]] && pass "dual-lit .* count=4" || bad "dual-lit .*=$dl1 (want 4)"
+dl2=$("$RG" -c 'static.+void' "$tmp/dual.txt" 2>&1 | sed 's/.*://' || true)
+[[ "$dl2" == "3" ]] && pass "dual-lit .+ count=3" || bad "dual-lit .+=$dl2 (want 3)"
+dl3=$("$RG" -n 'static.*void' "$tmp/dual.txt" 2>&1 | sed 's/.*://' | wc -l)
+[[ "$dl3" == "4" ]] && pass "dual-lit .* print=4 lines" || bad "dual-lit print=$dl3 (want 4)"
+dl4=$("$RG" -c -i 'static.*void' "$tmp/dual.txt" 2>&1 | sed 's/.*://' || true)
+[[ "$dl4" == "5" ]] && pass "dual-lit icase .* count=5" || bad "dual-lit icase=$dl4 (want 5)"
+dl5=$("$RG" -c 'static.*void' "$tmp/dual.txt" "$tmp/dual.txt" 2>&1 | sed 's/.*://' | paste -sd+ | bc)
+[[ "$dl5" == "8" ]] && pass "dual-lit multi-file sum=8" || bad "dual-lit multi=$dl5 (want 8)"
+# Triple-literal with escaped metachar
+cat > "$tmp/triple.txt" << 'TLEOF'
+static void foo(int x)
+static void foo
+void static(
+static int bar(
+static void
+TLEOF
+tl1=$("$RG" -c 'static.*void.*\(' "$tmp/triple.txt" 2>&1 | sed 's/.*://' || true)
+[[ "$tl1" == "1" ]] && pass "triple-lit escaped paren count=1" || bad "triple-lit=$tl1 (want 1)"
+tl2=$("$RG" -n 'static.*void.*\(' "$tmp/triple.txt" 2>&1 | sed 's/.*://' | head -1)
+[[ "$tl2" == "static void foo(int x)" ]] && pass "triple-lit print correct" || bad "triple-lit print=$tl2"
+# \bLITERAL\b -> -w fast path
+echo -e "static int\nstatics\nstatic_t\nmy_static\nstatic" > "$tmp/wb.txt"
+wb1=$("$RG" -c '\bstatic\b' "$tmp/wb.txt" 2>&1 | sed 's/.*://' || true)
+[[ "$wb1" == "2" ]] && pass "word-boundary \\b count=2" || bad "wb=$wb1 (want 2)"
+wb2=$("$RG" -w -F -c static "$tmp/wb.txt" 2>&1 | sed 's/.*://' || true)
+[[ "$wb2" == "2" ]] && pass "word-fixed -w -F count=2" || bad "wf=$wb2 (want 2)"
+wb3=$("$RG" -w -c static "$tmp/wb.txt" 2>&1 | sed 's/.*://' || true)
+[[ "$wb3" == "2" ]] && pass "word-ere -w count=2" || bad "we=$wb3 (want 2)"
+wb4=$("$RG" -w -F -i -c STATIC "$tmp/wb.txt" 2>&1 | sed 's/.*://' || true)
+[[ "$wb4" == "2" ]] && pass "word-fixed icase -w -F -i count=2" || bad "wfi=$wb4 (want 2)"
+# Color mode produces same match count as non-color
+cc1=$("$RG" --color=always -c 'static.*void' "$tmp/dual.txt" 2>&1 | sed 's/.*://' || true)
+[[ "$cc1" == "4" ]] && pass "color .* count=4" || bad "color=$cc1 (want 4)"
+
+# ========== Invert count (-v -c) ==========
+echo -e "hello\nworld\nfoo\nbar\nbaz" > "$tmp/inv.txt"
+iv1=$("$RG" -v -c hello "$tmp/inv.txt" 2>&1 | sed 's/.*://' || true)
+[[ "$iv1" == "4" ]] && pass "invert count -v -c=4" || bad "inv-count=$iv1 (want 4)"
+iv2=$("$RG" -v -c -F hello "$tmp/inv.txt" 2>&1 | sed 's/.*://' || true)
+[[ "$iv2" == "4" ]] && pass "invert count -v -c -F=4" || bad "inv-count-F=$iv2 (want 4)"
+iv3=$("$RG" -v -c 'zzz' "$tmp/inv.txt" 2>&1 | sed 's/.*://' || true)
+[[ "$iv3" == "5" ]] && pass "invert count nomatch=5" || bad "inv-nomatch=$iv3 (want 5)"
+iv4=$("$RG" -v -n hello "$tmp/inv.txt" 2>&1 | wc -l)
+[[ "$iv4" == "4" ]] && pass "invert print -v -n=4 lines" || bad "inv-print=$iv4 (want 4)"
+iv5=$("$RG" -v -F -n hello "$tmp/inv.txt" 2>&1 | wc -l)
+[[ "$iv5" == "4" ]] && pass "invert print -v -F -n=4 lines" || bad "inv-printF=$iv5 (want 4)"
+# ========== Byte offset (-b) ==========
+echo -e "aaa\nbbb\nccc" > "$tmp/boff.txt"
+bo1=$("$RG" -b bbb "$tmp/boff.txt" 2>&1 | sed 's/.*://' || true)
+[[ "$bo1" == "bbb" ]] && pass "byte-offset -b basic" || bad "boff=$bo1"
+bo2=$("$RG" -b -F bbb "$tmp/boff.txt" 2>&1)
+[[ "$bo2" == *"4:"* ]] && pass "byte-offset value=4" || bad "boff-val=$bo2"
+# ========== Heading (--heading) ==========
+echo -e "one\ntwo\nthree" > "$tmp/head1.txt"
+echo -e "four\nfive\nsix" > "$tmp/head2.txt"
+h1=$("$RG" --heading -n 'o' "$tmp/head1.txt" "$tmp/head2.txt" 2>&1 | head -1 || true)
+# First line should be the file path (heading mode)
+[[ "$h1" == *"head"* ]] && pass "heading first line is path" || bad "heading=$h1"
+# ========== Replace (-r) ==========
+echo -e "foo bar baz\nhello world" > "$tmp/rep.txt"
+rp1=$("$RG" -F -r REPL bar "$tmp/rep.txt" 2>&1 | head -1)
+[[ "$rp1" == *"REPL"* ]] && pass "replace -r REPL" || bad "replace=$rp1"
+# ========== Context ==========
+echo -e "a\nb\nmatch1\nc\nd\ne\nmatch2\nf\ng" > "$tmp/ctx.txt"
+ct1=$("$RG" -C1 match "$tmp/ctx.txt" 2>&1 | wc -l)
+[[ "$ct1" == "7" ]] && pass "context -C1 lines=7" || bad "ctx=$ct1 (want 7)"
+ct2=$("$RG" -C1 -n match "$tmp/ctx.txt" 2>&1 | grep -c ':')
+[[ "$ct2" == "2" ]] && pass "context match lines=2" || bad "ctx-match=$ct2 (want 2)"
+# ========== PCRE -P simple ==========
+[[ "${c_d:-}" != "err" && -n "${c_d:-}" ]] && pass "PCRE -P \d+ count=$c_d" || bad "PCRE -P failed"
+
+if [[ "$fail" -ne 0 ]]; then
+  echo "FAILED some checks" >&2
+  exit 1
+fi
+echo "All correctness checks passed ($RG)"
