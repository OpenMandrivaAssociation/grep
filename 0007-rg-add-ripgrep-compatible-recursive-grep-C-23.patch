+
+/* RVV scan_class_run: strip-mined approach.  Each iteration processes
+   vl bytes.  We count consecutive class-matching bytes using a scalar
+   carry across chunks.  Use vcpop for all-match / no-match fast paths
+   and vfirst for finding the first mismatch position.  */
+static intmax_t
+scan_class_run_rvv_impl (ClassKind k, unsigned min_r, const char *data,
+                          size_t size, bool count_lines, bool only_exists,
+                          intmax_t max_count)
+{
+  const char *p = data;
+  const char *const end = data + size;
+  intmax_t matches = 0;
+  unsigned carry = 0;
+
+  while (p < end)
+    {
+      size_t avail = static_cast<size_t> (end - p);
+      size_t vl = __riscv_vsetvl_e8m1 (avail);
+      vuint8m1_t block = __riscv_vle8_v_u8m1 (
+          reinterpret_cast<const uint8_t *> (p), vl);
+      vbool8_t mask = class_mask_rvv (k, block, vl);
+      unsigned long pop = __riscv_vcpop_m_b8 (mask, vl);
+
+      if (pop == 0)
+        {
+          /* No matches in this chunk.  */
+          if (carry >= min_r)
+            {
+              matches++;
+              if (only_exists)
+                return 1;
+              if (matches >= max_count)
+                return matches;
+              if (count_lines)
+                {
+                  const void *nl
+                      = std::memchr (p, '\n', static_cast<size_t> (end - p));
+                  if (!nl)
+                    return matches;
+                  p = static_cast<const char *> (nl) + 1;
+                  carry = 0;
+                  continue;
+                }
+            }
+          carry = 0;
+          p += vl;
+          continue;
+        }
+
+      if (pop == vl)
+        {
+          /* All match.  */
+          carry += static_cast<unsigned> (vl);
+          p += vl;
+          continue;
+        }
+
+      /* Mixed chunk — fall back to scalar for this chunk.  */
+      for (size_t i = 0; i < vl; i++)
+        {
+          if (class_byte_ok (k, static_cast<unsigned char> (p[i])))
+            carry++;
+          else
+            {
+              if (carry >= min_r)
+                {
+                  matches++;
+                  if (only_exists)
+                    return 1;
+                  if (matches >= max_count)
+                    return matches;
+                  if (count_lines)
+                    {
+                      const char *after = p + i;
+                      const void *nl = std::memchr (
+                          after, '\n', static_cast<size_t> (end - after));
+                      if (!nl)
+                        return matches;
+                      p = static_cast<const char *> (nl) + 1;
+                      carry = 0;
+                      goto next_rvv;
+                    }
+                }
+              carry = 0;
+            }
+        }
+      p += vl;
+    next_rvv:;
+    }
+
+  if (carry >= min_r)
+    matches++;
+  return matches;
+}
+
+/* RVV first_alpha: find first A-Z/a-z byte using vector compare.  */
+static inline long
+first_alpha_rvv (const char *p, size_t n) noexcept
+{
+  size_t vl = __riscv_vsetvl_e8m1 (n);
+  vuint8m1_t block = __riscv_vle8_v_u8m1 (
+      reinterpret_cast<const uint8_t *> (p), vl);
+  vbool8_t up = __riscv_vmand_mm_b8 (
+      __riscv_vmsgeu_vx_u8m1_b8 (block, 'A', vl),
+      __riscv_vmsleu_vx_u8m1_b8 (block, 'Z', vl), vl);
+  vbool8_t lo = __riscv_vmand_mm_b8 (
+      __riscv_vmsgeu_vx_u8m1_b8 (block, 'a', vl),
+      __riscv_vmsleu_vx_u8m1_b8 (block, 'z', vl), vl);
+  vbool8_t any = __riscv_vmor_mm_b8 (up, lo, vl);
+  long idx = __riscv_vfirst_m_b8 (any, vl);
+  return idx;  /* -1 if none found */
+}
