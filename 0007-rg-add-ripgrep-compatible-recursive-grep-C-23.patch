+static const char *
+memmem_rvv_first (const char *hay, size_t hlen, const char *ndl, size_t nlen)
+{
+  if (nlen == 0)
+    return hay;
+  if (nlen > hlen)
+    return nullptr;
+  unsigned char first = static_cast<unsigned char> (ndl[0]);
+  const char *end = hay + hlen - nlen + 1;
+  const char *p = hay;
+
+  if (nlen >= 2)
+    {
+      unsigned char second = static_cast<unsigned char> (ndl[1]);
+      size_t avail = static_cast<size_t> (end - p);
+      while (avail > 0)
+        {
+          size_t vl = __riscv_vsetvl_e8m4 (avail);
+          if (vl < 2)
+            break;
+          vuint8m4_t b0 = __riscv_vle8_v_u8m4 (
+            reinterpret_cast<const uint8_t *> (p), vl);
+          vuint8m4_t b1 = __riscv_vle8_v_u8m4 (
+            reinterpret_cast<const uint8_t *> (p + 1), vl);
+          vbool2_t m0 = __riscv_vmseq_vx_u8m4_b2 (b0, first, vl);
+          vbool2_t m1 = __riscv_vmseq_vx_u8m4_b2 (b1, second, vl);
+          vbool2_t hits = __riscv_vmand_mm_b2 (m0, m1, vl);
