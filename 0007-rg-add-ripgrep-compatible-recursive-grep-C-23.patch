+/* NEON dispatch: slim or fat nibble Teddy.  */
+static intmax_t
+lits_any_teddy_nibble_neon (const Prefilter &pf, const char *data, size_t size,
+                            bool only_exists, intmax_t max_count)
+{
+  const size_t nlits = pf.lits.size ();
+  if (nlits < 2 || nlits > 16)
+    return -1;
+  for (const auto &lit : pf.lits)
+    if (lit.size () < 2)
+      return -1;
+  if (nlits <= 8)
+    return lits_any_teddy_nibble_slim_neon (pf, data, size, only_exists,
+                                             max_count, nlits);
+  return lits_any_teddy_nibble_fat_neon (pf, data, size, only_exists,
+                                          max_count, nlits);
+}
+#endif /* RG_ARCH_AARCH64 nibble Teddy */
