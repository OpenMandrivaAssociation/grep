+
+const char *
+memchr_fast (const char *s, size_t n, unsigned char c)
+{
+  if (!s || !n)
+    return nullptr;
+#if defined(RG_ARCH_X86_64)
+  x86_init ();
+  if (g_have_avx2 && n >= 32)
+    return memchr_avx2 (s, n, c);
+  if (n >= 16)
+    return memchr_sse2 (s, n, c);
+#elif defined(RG_ARCH_AARCH64)
+  if (n >= 16)
+    return memchr_neon (s, n, c);
+#elif defined(RG_HAVE_LSX)
+  if (n >= 16)
+    return memchr_lsx (s, n, c);
+#elif defined(RG_HAVE_RVV)
+  return memchr_rvv (s, n, c);
+#elif defined(RG_HAVE_GCC_VECTOR)
+  if (n >= 16)
+    return memchr_gcc_vec (s, n, c);
+#endif
+  return memchr_portable (s, n, c);
+}
+
+const char *
+memmem_fast (const char *hay, size_t hlen, const char *ndl, size_t nlen)
+{
+  if (!hay)
+    return nullptr;
+  if (nlen == 0)
+    return hay;
+  if (nlen > hlen)
+    return nullptr;
+#if defined(RG_ARCH_X86_64)
+  x86_init ();
+  if (g_have_avx2 && hlen >= 32)
+    return memmem_avx2_first (hay, hlen, ndl, nlen);
+  if (hlen >= 16)
+    return memmem_sse2_first (hay, hlen, ndl, nlen);
+#elif defined(RG_ARCH_AARCH64)
+  if (hlen >= 16)
+    return memmem_neon_first (hay, hlen, ndl, nlen);
+#elif defined(RG_HAVE_LSX)
+  if (hlen >= 16)
+    return memmem_lsx_first (hay, hlen, ndl, nlen);
+#elif defined(RG_HAVE_RVV)
+  if (hlen >= 8)
+    return memmem_rvv_first (hay, hlen, ndl, nlen);
+#elif defined(RG_HAVE_GCC_VECTOR)
+  if (hlen >= 16)
+    return memmem_gcc_vec_first (hay, hlen, ndl, nlen);
+#endif
+  /* glibc Two-Way / SSE memmem as portable fallback.  */
+  {
+    const void *r = memmem (hay, hlen, ndl, nlen);
+    return static_cast<const char *> (r);
+  }
+}
