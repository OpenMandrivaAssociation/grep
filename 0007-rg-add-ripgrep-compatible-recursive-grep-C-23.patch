+/* ---------- Icase nibble Teddy (PSHUFB / TBL) ----------
+   Instead of tolower per input byte, build LUTs that accept BOTH cases:
+   for each needle byte c, register nibble patterns for both tolower(c) and
+   toupper(c).  VPSHUFB/TBL on raw input matches either case automatically.
+   Verify with bytes_equal_icase.  Avoids ~6x AC tolower overhead.  */
+
+/* Helper: register byte c into nibble LUTs for bucket mask m, considering
+   both cases if alpha.  (Arch-neutral — used by both AVX2 and NEON.)  */
+static inline void
+icase_nib_register (uint8_t lo[16], uint8_t hi[16], unsigned char c, uint8_t m)
+{
+  lo[c & 0xF] |= m;
+  hi[c >> 4]  |= m;
+  if (c >= 'a' && c <= 'z')
+    {
+      unsigned char u = c - 32;
+      lo[u & 0xF] |= m;
+      hi[u >> 4]  |= m;
+    }
+  else if (c >= 'A' && c <= 'Z')
+    {
+      unsigned char l = c + 32;
+      lo[l & 0xF] |= m;
+      hi[l >> 4]  |= m;
+    }
+}
