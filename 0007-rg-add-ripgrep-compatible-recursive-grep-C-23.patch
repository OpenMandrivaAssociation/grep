+/* AVX2 case-insensitive memmem: scan for both cases of first two needle bytes
+   in a single 32-byte pass (4 cmpeqs + 2 ORs + 1 AND), verify candidates with
+   pre-folded needle.  Massively faster than dual-memchr when first byte is
+   common (e.g. 'i'/'I' in "include" across C/C++ sources).  */
+__attribute__ ((target ("avx2"))) static const char *
+memmem_icase_avx2 (const char *hay, size_t hlen, const char *ndl, size_t nlen)
+{
+  if (nlen == 0)
+    return hay;
+  if (nlen > hlen)
+    return nullptr;
