+
+extern "C" {
+void init_localeinfo (struct localeinfo *);
+void wordinit (void);
+void *GEAcompile (char *, idx_t, reg_syntax_t, bool);
+ptrdiff_t EGexecute (void *, char const *, idx_t, idx_t *, char const *);
+void *Fcompile (char *, idx_t, reg_syntax_t, bool);
