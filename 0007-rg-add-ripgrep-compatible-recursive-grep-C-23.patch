+/* Teddy nibble icase find_first: SIMD scan from cur→end returning the first
+   verified icase match position (and its length in *out_len).  Returns end if
+   no match found; returns nullptr if nlits out of range (caller fallback).
+   Handles up to 8 needles (slim variant).  */
+#if defined(__GNUC__) || defined(__clang__)
+__attribute__ ((target ("avx2")))
+#endif
+static const char *
+teddy_nibble_icase_find_first_avx2 (const Prefilter &pf, const char *cur,
+                                     const char *end, size_t *out_len)
+{
+  const size_t nlits = pf.lits.size ();
+  if (nlits < 2 || nlits > 8)
+    return nullptr; /* signal caller to use fallback */
+
+  bool use3 = true;
+  for (size_t i = 0; i < nlits; i++)
+    if (pf.lits[i].size () < 3)
+      { use3 = false; break; }
+
+  uint8_t lo0[16]={}, hi0[16]={}, lo1[16]={}, hi1[16]={};
+  uint8_t lo2[16]={}, hi2[16]={};
+  for (size_t i = 0; i < nlits; i++)
+    {
+      uint8_t m = static_cast<uint8_t> (1u << i);
+      icase_nib_register (lo0, hi0,
+        static_cast<unsigned char> (pf.lits[i][0]), m);
+      icase_nib_register (lo1, hi1,
+        static_cast<unsigned char> (pf.lits[i][1]), m);
+      if (use3)
+        icase_nib_register (lo2, hi2,
+          static_cast<unsigned char> (pf.lits[i][2]), m);
+    }
+
+  #define BCAST128_FF(arr) _mm256_broadcastsi128_si256 ( \
+    _mm_loadu_si128 (reinterpret_cast<const __m128i *> (arr)))
+  __m256i vlo0v = BCAST128_FF (lo0), vhi0v = BCAST128_FF (hi0);
+  __m256i vlo1v = BCAST128_FF (lo1), vhi1v = BCAST128_FF (hi1);
+  __m256i vlo2v, vhi2v;
+  if (use3)
+    { vlo2v = BCAST128_FF (lo2);  vhi2v = BCAST128_FF (hi2); }
+  else
+    { vlo2v = vhi2v = _mm256_setzero_si256 (); }
+  #undef BCAST128_FF
+  __m256i nib_mask = _mm256_set1_epi8 (0x0F);
+  __m256i zeroes = _mm256_setzero_si256 ();
+
+  const char *p = cur;
+  const int blk_end_off = use3 ? 34 : 33;
+
+  while (p + blk_end_off <= end)
+    {
+      __m256i blk0 = _mm256_loadu_si256 (reinterpret_cast<const __m256i *> (p));
+      __m256i blk1 = _mm256_loadu_si256 (reinterpret_cast<const __m256i *> (p + 1));
+      __m256i nib0lo = _mm256_and_si256 (blk0, nib_mask);
+      __m256i nib0hi = _mm256_and_si256 (_mm256_srli_epi16 (blk0, 4), nib_mask);
+      __m256i nib1lo = _mm256_and_si256 (blk1, nib_mask);
+      __m256i nib1hi = _mm256_and_si256 (_mm256_srli_epi16 (blk1, 4), nib_mask);
+
+      __m256i cand = _mm256_and_si256 (
+        _mm256_and_si256 (
+          _mm256_shuffle_epi8 (vlo0v, nib0lo),
+          _mm256_shuffle_epi8 (vhi0v, nib0hi)),
+        _mm256_and_si256 (
+          _mm256_shuffle_epi8 (vlo1v, nib1lo),
+          _mm256_shuffle_epi8 (vhi1v, nib1hi)));
+
+      if (use3)
+        {
+          __m256i blk2 = _mm256_loadu_si256 (
+            reinterpret_cast<const __m256i *> (p + 2));
+          __m256i nib2lo = _mm256_and_si256 (blk2, nib_mask);
+          __m256i nib2hi = _mm256_and_si256 (
+            _mm256_srli_epi16 (blk2, 4), nib_mask);
+          cand = _mm256_and_si256 (cand,
+            _mm256_and_si256 (
+              _mm256_shuffle_epi8 (vlo2v, nib2lo),
+              _mm256_shuffle_epi8 (vhi2v, nib2hi)));
+        }
+
+      unsigned mask = ~static_cast<unsigned> (
+        _mm256_movemask_epi8 (_mm256_cmpeq_epi8 (cand, zeroes)));
+      alignas (32) uint8_t cand_bytes[32];
+      if (mask)
+        _mm256_store_si256 (reinterpret_cast<__m256i *> (cand_bytes), cand);
+      while (mask)
+        {
+          unsigned bit = static_cast<unsigned> (__builtin_ctz (mask));
+          mask &= mask - 1;
+          const char *c = p + bit;
+          uint8_t buckets = cand_bytes[bit];
+          while (buckets)
+            {
+              unsigned bi = static_cast<unsigned> (__builtin_ctz (buckets));
+              buckets &= buckets - 1;
+              const auto &lit = pf.lits[bi];
+              size_t n = lit.size ();
+              if (c + n <= end && bytes_equal_icase (c, lit.data (), n))
+                {
+                  if (out_len)
+                    *out_len = n;
+                  return c;
+                }
+            }
+        }
+      p += 32;
+    }
+
+  /* Scalar tail.  */
+  while (p < end)
+    {
+      size_t ml = 0;
+      if (pf.lits_fb[static_cast<unsigned char> (*p)]
+          && lits_any_match_at_mlen (pf, p, end, &ml))
+        {
+          if (out_len)
+            *out_len = ml;
+          return p;
+        }
+      p++;
+    }
+  return end;
+}
