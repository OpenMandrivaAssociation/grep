+          uint8_t m = static_cast<uint8_t> (1u << (i - 8));
+          blo0[c0 & 0xF] |= m;  bhi0[c0 >> 4] |= m;
+          blo1[c1 & 0xF] |= m;  bhi1[c1 >> 4] |= m;
+          if (use3)
+            {
+              unsigned char c2 = static_cast<unsigned char> (pf.lits[i][2]);
+              blo2[c2 & 0xF] |= m;  bhi2[c2 >> 4] |= m;
+            }
+        }
+    }
+
+  uint8x16_t valo0v = vld1q_u8 (alo0), vahi0v = vld1q_u8 (ahi0);
+  uint8x16_t valo1v = vld1q_u8 (alo1), vahi1v = vld1q_u8 (ahi1);
+  uint8x16_t vblo0v = vld1q_u8 (blo0), vbhi0v = vld1q_u8 (bhi0);
+  uint8x16_t vblo1v = vld1q_u8 (blo1), vbhi1v = vld1q_u8 (bhi1);
+  uint8x16_t valo2v, vahi2v, vblo2v, vbhi2v;
+  if (use3)
+    {
+      valo2v = vld1q_u8 (alo2);  vahi2v = vld1q_u8 (ahi2);
+      vblo2v = vld1q_u8 (blo2);  vbhi2v = vld1q_u8 (bhi2);
+    }
+  else
+    {
+      valo2v = vahi2v = vblo2v = vbhi2v = vdupq_n_u8 (0);
+    }
+  uint8x16_t nib_mask = vdupq_n_u8 (0x0F);
+
+  const char *end = data + size;
+  const char *p = data;
+  intmax_t matches = 0;
+  const int blk_end_off = use3 ? 18 : 17;
+
+  while (p + blk_end_off <= end)
+    {
+      uint8x16_t blk0 = vld1q_u8 (reinterpret_cast<const uint8_t *> (p));
+      uint8x16_t blk1 = vld1q_u8 (reinterpret_cast<const uint8_t *> (p + 1));
+      uint8x16_t nib0lo = vandq_u8 (blk0, nib_mask);
+      uint8x16_t nib0hi = vandq_u8 (vshrq_n_u8 (blk0, 4), nib_mask);
+      uint8x16_t nib1lo = vandq_u8 (blk1, nib_mask);
+      uint8x16_t nib1hi = vandq_u8 (vshrq_n_u8 (blk1, 4), nib_mask);
+
+      uint8x16_t a01 = vandq_u8 (
+        vandq_u8 (vqtbl1q_u8 (valo0v, nib0lo),
+                  vqtbl1q_u8 (vahi0v, nib0hi)),
+        vandq_u8 (vqtbl1q_u8 (valo1v, nib1lo),
+                  vqtbl1q_u8 (vahi1v, nib1hi)));
+
+      uint8x16_t b01 = vandq_u8 (
+        vandq_u8 (vqtbl1q_u8 (vblo0v, nib0lo),
+                  vqtbl1q_u8 (vbhi0v, nib0hi)),
+        vandq_u8 (vqtbl1q_u8 (vblo1v, nib1lo),
+                  vqtbl1q_u8 (vbhi1v, nib1hi)));
+
+      uint8x16_t candA, candB;
+      if (use3)
+        {
+          uint8x16_t blk2 = vld1q_u8 (
+            reinterpret_cast<const uint8_t *> (p + 2));
+          uint8x16_t nib2lo = vandq_u8 (blk2, nib_mask);
+          uint8x16_t nib2hi = vandq_u8 (vshrq_n_u8 (blk2, 4), nib_mask);
+          candA = vandq_u8 (a01,
+            vandq_u8 (vqtbl1q_u8 (valo2v, nib2lo),
+                      vqtbl1q_u8 (vahi2v, nib2hi)));
+          candB = vandq_u8 (b01,
+            vandq_u8 (vqtbl1q_u8 (vblo2v, nib2lo),
+                      vqtbl1q_u8 (vbhi2v, nib2hi)));
+        }
+      else
+        {
+          candA = a01;
+          candB = b01;
+        }
+
+      uint8x16_t any_cand = vorrq_u8 (candA, candB);
+      uint8x16_t nonzero = vcgtq_u8 (any_cand, vdupq_n_u8 (0));
+      uint64_t nmask = neon_mask (nonzero);
+
+      alignas (16) uint8_t abytes[16], bbytes[16];
+      if (nmask)
+        {
+          vst1q_u8 (abytes, candA);
+          vst1q_u8 (bbytes, candB);
+        }
+      bool advanced = false;
+      while (nmask)
+        {
+          int bit = neon_ctz4 (nmask);
+          nmask = neon_clear_low (nmask, bit);
+          const char *c = p + bit;
+
+          bool hit = false;
+          uint8_t ba = abytes[bit];
+          while (ba)
+            {
+              unsigned bi = static_cast<unsigned> (__builtin_ctz (ba));
+              ba &= ba - 1;
+              const auto &lit = pf.lits[bi];
+              size_t n = lit.size ();
+              if (c + n <= end && std::memcmp (c, lit.data (), n) == 0)
+                { hit = true; break; }
+            }
+          if (!hit)
+            {
+              uint8_t bb = bbytes[bit];
+              while (bb)
+                {
+                  unsigned bi = static_cast<unsigned> (__builtin_ctz (bb));
+                  bb &= bb - 1;
+                  const auto &lit = pf.lits[8 + bi];
+                  size_t n = lit.size ();
+                  if (c + n <= end && std::memcmp (c, lit.data (), n) == 0)
+                    { hit = true; break; }
+                }
+            }
+
+          if (hit)
+            {
+              matches++;
+              if (only_exists)
+                return 1;
+              if (max_count > 0 && matches >= max_count)
+                return matches;
+              const char *nl = static_cast<const char *> (
+                memchr (c, '\n', static_cast<size_t> (end - c)));
+              p = nl ? nl + 1 : end;
+              advanced = true;
+              break;
+            }
+        }
+      if (!advanced)
+        p += 16;
+    }
+
+  /* Scalar tail.  */
+  while (p < end)
+    {
+      if (pf.lits_fb[static_cast<unsigned char> (*p)]
+          && lits_any_match_at (pf, p, end))
+        {
+          matches++;
+          if (only_exists)
+            return 1;
+          if (max_count > 0 && matches >= max_count)
+            return matches;
+          const char *nl = static_cast<const char *> (
+            memchr (p, '\n', static_cast<size_t> (end - p)));
+          if (!nl)
+            return matches;
+          p = nl + 1;
+          continue;
+        }
+      p++;
+    }
+  return matches;
+}
