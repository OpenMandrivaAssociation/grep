+      __m256i v0u = _mm256_set1_epi8 (static_cast<char> (n0u));
+      __m256i v1l = _mm256_set1_epi8 (static_cast<char> (n1l));
+      __m256i v1u = _mm256_set1_epi8 (static_cast<char> (n1u));
+      const char *scan_end = hay + hlen - 1;
