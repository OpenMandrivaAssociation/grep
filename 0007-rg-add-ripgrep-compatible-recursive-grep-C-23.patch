+/* LSX forward scan: find first class run >= min_r.  */
+static const char *
+find_class_run_forward_lsx (ClassKind k, unsigned min_r,
+                              const char *data, size_t size,
+                              const char **run_end_out) noexcept
+{
+  const char *p = data;
+  const char *const end = data + size;
+  unsigned carry = 0;
+  const char *carry_start = nullptr;
+
+  while (p + 16 <= end)
+    {
+      uint16_t mask = class_mask_lsx (k, p);
+
+      if (mask == 0)
+        {
+          if (carry >= min_r)
+            {
+              *run_end_out = p;
+              return carry_start;
+            }
+          carry = 0;
+          p += 16;
+          continue;
+        }
+
+      if (mask == 0xFFFFu)
+        {
+          if (carry == 0)
+            carry_start = p;
+          carry += 16;
+          p += 16;
+          continue;
+        }
+
+      /* Mixed chunk.  */
+      uint16_t inv = static_cast<uint16_t> (~mask);
+
+      if (carry > 0 && (mask & 1u))
+        {
+          unsigned leading = static_cast<unsigned> (__builtin_ctz (inv));
+          carry += leading;
+          if (carry >= min_r)
+            {
+              const char *re = p + leading;
+              while (re < end
+                     && class_byte_ok (k, static_cast<unsigned char> (*re)))
+                re++;
+              *run_end_out = re;
+              return carry_start;
+            }
+          carry = 0;
+        }
+      else if (carry > 0)
+        {
+          if (carry >= min_r)
+            {
+              *run_end_out = p;
+              return carry_start;
+            }
+          carry = 0;
+        }
+
+      uint16_t rem = mask;
+      unsigned bit = 0;
+      if (mask & 1u)
+        {
+          unsigned skip = static_cast<unsigned> (__builtin_ctz (inv));
+          rem = static_cast<uint16_t> (rem >> skip);
+          bit += skip;
+        }
+      while (rem)
+        {
+          unsigned skip = static_cast<unsigned> (__builtin_ctz (rem));
+          rem = static_cast<uint16_t> (rem >> skip);
+          bit += skip;
+          if (!rem)
+            break;
+          uint16_t inv1 = static_cast<uint16_t> (~rem);
+          unsigned run_len;
+          if (inv1)
+            run_len = static_cast<unsigned> (__builtin_ctz (inv1));
+          else
+            run_len = 16 - bit;
+          if (bit + run_len >= 16)
+            {
+              carry = run_len;
+              carry_start = p + bit;
+              goto next_fwd_lsx;
+            }
+          if (run_len >= min_r)
+            {
+              const char *rs = p + bit;
+              const char *re = p + bit + run_len;
+              while (re < end
+                     && class_byte_ok (k, static_cast<unsigned char> (*re)))
+                re++;
+              *run_end_out = re;
+              return rs;
+            }
+          rem = static_cast<uint16_t> (rem >> run_len);
+          bit += run_len;
+        }
+      carry = 0;
+    next_fwd_lsx:
+      p += 16;
+    }
+
+  /* Scalar tail.  */
+  unsigned run = carry;
+  const char *run_start = carry_start;
+  while (p < end)
+    {
+      if (class_byte_ok (k, static_cast<unsigned char> (*p)))
+        {
+          if (run == 0)
+            run_start = p;
+          run++;
+          if (run >= min_r)
+            {
+              const char *re = p + 1;
+              while (re < end
+                     && class_byte_ok (k, static_cast<unsigned char> (*re)))
+                re++;
+              *run_end_out = re;
+              return run_start;
+            }
+        }
+      else
+        {
+          if (run >= min_r)
+            {
+              *run_end_out = p;
+              return run_start;
+            }
+          run = 0;
+        }
+      p++;
+    }
+  if (run >= min_r)
+    {
+      *run_end_out = p;
+      return run_start;
+    }
+  return nullptr;
+}
