+        {
+          __m256i a0 = _mm256_loadu_si256 (reinterpret_cast<const __m256i *> (p));
+          __m256i a1 = _mm256_loadu_si256 (reinterpret_cast<const __m256i *> (p + 1));
+          __m256i am0 = _mm256_or_si256 (_mm256_cmpeq_epi8 (a0, v0l),
+                                         _mm256_cmpeq_epi8 (a0, v0u));
+          __m256i am1 = _mm256_or_si256 (_mm256_cmpeq_epi8 (a1, v1l),
+                                         _mm256_cmpeq_epi8 (a1, v1u));
+          int mask0 = _mm256_movemask_epi8 (_mm256_and_si256 (am0, am1));
+          __m256i c0 = _mm256_loadu_si256 (reinterpret_cast<const __m256i *> (p + 32));
+          __m256i c1 = _mm256_loadu_si256 (reinterpret_cast<const __m256i *> (p + 33));
+          __m256i cm0 = _mm256_or_si256 (_mm256_cmpeq_epi8 (c0, v0l),
+                                         _mm256_cmpeq_epi8 (c0, v0u));
+          __m256i cm1 = _mm256_or_si256 (_mm256_cmpeq_epi8 (c1, v1l),
+                                         _mm256_cmpeq_epi8 (c1, v1u));
+          int mask1 = _mm256_movemask_epi8 (_mm256_and_si256 (cm0, cm1));
+          while (mask0)
+            {
+              int bit = __builtin_ctz (static_cast<unsigned> (mask0));
+              const char *q = p + bit;
+              if (q < end && verify (q))
+                return q;
+              mask0 &= mask0 - 1;
+            }
+          while (mask1)
+            {
+              int bit = __builtin_ctz (static_cast<unsigned> (mask1));
+              const char *q = p + 32 + bit;
+              if (q < end && verify (q))
+                return q;
+              mask1 &= mask1 - 1;
+            }
+          p += 64;
+        }
+      /* Handle remaining 32-byte block.  */
+      if (p + 33 <= scan_end)
+        {
+          __m256i b0 = _mm256_loadu_si256 (reinterpret_cast<const __m256i *> (p));
+          __m256i b1 = _mm256_loadu_si256 (reinterpret_cast<const __m256i *> (p + 1));
+          __m256i bm0 = _mm256_or_si256 (_mm256_cmpeq_epi8 (b0, v0l),
+                                         _mm256_cmpeq_epi8 (b0, v0u));
+          __m256i bm1 = _mm256_or_si256 (_mm256_cmpeq_epi8 (b1, v1l),
+                                         _mm256_cmpeq_epi8 (b1, v1u));
+          int mask = _mm256_movemask_epi8 (_mm256_and_si256 (bm0, bm1));
+          while (mask)
+            {
+              int bit = __builtin_ctz (static_cast<unsigned> (mask));
+              const char *q = p + bit;
+              if (q < end && verify (q))
+                return q;
+              mask &= mask - 1;
+            }
+          p += 32;
+        }
+      /* Scalar tail.  */
+      while (p < end)
+        {
+          if (lut[static_cast<unsigned char> (*p)] == n0l && verify (p))
+            return p;
+          p++;
+        }
+      return nullptr;
+    }
+
+  /* nlen == 1: find either case of single byte.  */
+  bool same = (n0l == n0u);
+  __m256i vl = _mm256_set1_epi8 (static_cast<char> (n0l));
+  __m256i vu = _mm256_set1_epi8 (static_cast<char> (n0u));
+  while (p + 32 <= end)
+    {
+      __m256i b = _mm256_loadu_si256 (reinterpret_cast<const __m256i *> (p));
+      __m256i m = same
+                      ? _mm256_cmpeq_epi8 (b, vl)
+                      : _mm256_or_si256 (_mm256_cmpeq_epi8 (b, vl),
+                                         _mm256_cmpeq_epi8 (b, vu));
+      int mask = _mm256_movemask_epi8 (m);
+      if (mask)
+        return p + __builtin_ctz (static_cast<unsigned> (mask));
+      p += 32;
+    }
+  while (p < end)
+    {
+      if (lut[static_cast<unsigned char> (*p)] == n0l)
+        return p;
+      p++;
+    }
+  return nullptr;
+}
