+            __riscv_vmsgeu_vx_u8m1_b8 (block, 'A', vl),
+            __riscv_vmsleu_vx_u8m1_b8 (block, 'Z', vl), vl);
+        vbool8_t lo = __riscv_vmand_mm_b8 (
+            __riscv_vmsgeu_vx_u8m1_b8 (block, 'a', vl),
+            __riscv_vmsleu_vx_u8m1_b8 (block, 'z', vl), vl);
+        return __riscv_vmor_mm_b8 (up, lo, vl);
+      }
+    case ClassKind::Lower:
+      return __riscv_vmand_mm_b8 (
+          __riscv_vmsgeu_vx_u8m1_b8 (block, 'a', vl),
+          __riscv_vmsleu_vx_u8m1_b8 (block, 'z', vl), vl);
+    case ClassKind::Upper:
+      return __riscv_vmand_mm_b8 (
+          __riscv_vmsgeu_vx_u8m1_b8 (block, 'A', vl),
+          __riscv_vmsleu_vx_u8m1_b8 (block, 'Z', vl), vl);
+    case ClassKind::Digit:
+      return __riscv_vmand_mm_b8 (
+          __riscv_vmsgeu_vx_u8m1_b8 (block, '0', vl),
+          __riscv_vmsleu_vx_u8m1_b8 (block, '9', vl), vl);
+    case ClassKind::Alnum:
+      {
+        vbool8_t up = __riscv_vmand_mm_b8 (
+            __riscv_vmsgeu_vx_u8m1_b8 (block, 'A', vl),
+            __riscv_vmsleu_vx_u8m1_b8 (block, 'Z', vl), vl);
+        vbool8_t lo = __riscv_vmand_mm_b8 (
+            __riscv_vmsgeu_vx_u8m1_b8 (block, 'a', vl),
+            __riscv_vmsleu_vx_u8m1_b8 (block, 'z', vl), vl);
+        vbool8_t dg = __riscv_vmand_mm_b8 (
+            __riscv_vmsgeu_vx_u8m1_b8 (block, '0', vl),
+            __riscv_vmsleu_vx_u8m1_b8 (block, '9', vl), vl);
+        return __riscv_vmor_mm_b8 (__riscv_vmor_mm_b8 (up, lo, vl), dg, vl);
+      }
+    case ClassKind::Word:
+      {
+        vbool8_t up = __riscv_vmand_mm_b8 (
+            __riscv_vmsgeu_vx_u8m1_b8 (block, 'A', vl),
+            __riscv_vmsleu_vx_u8m1_b8 (block, 'Z', vl), vl);
+        vbool8_t lo = __riscv_vmand_mm_b8 (
+            __riscv_vmsgeu_vx_u8m1_b8 (block, 'a', vl),
+            __riscv_vmsleu_vx_u8m1_b8 (block, 'z', vl), vl);
+        vbool8_t dg = __riscv_vmand_mm_b8 (
+            __riscv_vmsgeu_vx_u8m1_b8 (block, '0', vl),
+            __riscv_vmsleu_vx_u8m1_b8 (block, '9', vl), vl);
+        vbool8_t un = __riscv_vmseq_vx_u8m1_b8 (block, '_', vl);
+        return __riscv_vmor_mm_b8 (
+            __riscv_vmor_mm_b8 (__riscv_vmor_mm_b8 (up, lo, vl), dg, vl),
