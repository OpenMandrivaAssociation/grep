+
+intmax_t
+scan_class_run (const ClassRunPat &pat, const char *data, size_t size,
+                bool count_lines, bool only_exists, intmax_t max_count)
+{
+  if (!pat.active () || !data || !size)
+    return 0;
+
+  const unsigned min_r = pat.min_run;
+  const ClassKind k = pat.kind;
+  const bool has_pfx = pat.has_prefix ();
+  const ClassKind fk = pat.first_kind;
+  /* Prefix form: 1 first_kind + min_r of kind (may differ).  Scan for first_kind.  */
+  const ClassKind seek_k = has_pfx ? fk : k;
+  /* Minimum total span for a hit.  */
+  const unsigned need_tail = has_pfx ? min_r : min_r;
+  const unsigned need_total = has_pfx ? (1u + min_r) : min_r;
+  const char *p = data;
+  const char *const end = data + size;
+  intmax_t matches = 0;
+  unsigned run = 0;
+  bool in_pfx = false; /* after matching first_kind, counting kind run */
+#if defined(RG_ARCH_X86_64)
+  x86_init ();
+  /* Fast path: non-prefix patterns on AVX2.  */
+  if (!has_pfx && g_have_avx2)
+    return scan_class_run_avx2_impl (k, min_r, data, size, count_lines,
+                                     only_exists, max_count);
+#elif defined(RG_ARCH_AARCH64)
+  if (!has_pfx)
+    return scan_class_run_neon_impl (k, min_r, data, size, count_lines,
+                                     only_exists, max_count);
+#elif defined(RG_HAVE_LSX)
+  if (!has_pfx)
+    return scan_class_run_lsx_impl (k, min_r, data, size, count_lines,
+                                     only_exists, max_count);
+#elif defined(RG_HAVE_RVV)
+  if (!has_pfx)
+    return scan_class_run_rvv_impl (k, min_r, data, size, count_lines,
+                                     only_exists, max_count);
+#endif
+
+  while (p < end)
+    {
+      if (run == 0 && !in_pfx)
+        {
+          bool advanced = false;
+          if (seek_k == ClassKind::Alpha)
+            {
+#if defined(RG_ARCH_X86_64)
+              if (g_have_avx2)
+                {
+                  while (p + 32 <= end)
+                    {
+                      int idx = first_alpha_avx2 (p);
+                      if (idx >= 0)
+                        {
+                          p += idx;
+                          advanced = true;
+                          break;
+                        }
+                      p += 32;
+                    }
+                }
+              if (!advanced)
+                {
+                  while (p + 16 <= end)
+                    {
+                      int idx = first_alpha_sse2 (p);
+                      if (idx >= 0)
+                        {
+                          p += idx;
+                          advanced = true;
+                          break;
+                        }
+                      p += 16;
+                    }
+                }
+#elif defined(RG_ARCH_AARCH64)
+              while (p + 16 <= end)
+                {
+                  int idx = first_alpha_neon (p);
+                  if (idx >= 0)
+                    {
+                      p += idx;
+                      advanced = true;
+                      break;
+                    }
+                  p += 16;
+                }
+#elif defined(RG_HAVE_LSX)
+              while (p + 16 <= end)
+                {
+                  int idx = first_alpha_lsx (p);
+                  if (idx >= 0)
+                    {
+                      p += idx;
+                      advanced = true;
+                      break;
+                    }
+                  p += 16;
+                }
+#elif defined(RG_HAVE_RVV)
+              while (p < end)
+                {
+                  size_t avail = static_cast<size_t> (end - p);
+                  size_t vl = __riscv_vsetvl_e8m1 (avail);
+                  long idx = first_alpha_rvv (p, vl);
+                  if (idx >= 0)
+                    {
+                      p += idx;
+                      advanced = true;
+                      break;
+                    }
+                  p += vl;
+                }
+#endif
+            }
+          if (!advanced && seek_k == ClassKind::Word)
+            {
+              while (p + 8 <= end)
+                {
+                  uint64_t v;
+                  std::memcpy (&v, p, 8);
+                  int idx = first_word_byte_in_u64 (v);
+                  if (idx >= 0)
+                    {
+                      p += idx;
+                      advanced = true;
+                      break;
+                    }
+                  p += 8;
+                }
+            }
+          if (!advanced)
+            {
+              while (p + 8 <= end)
+                {
+                  uint64_t v;
+                  std::memcpy (&v, p, 8);
+                  int idx = first_class_byte_in_u64 (seek_k, v);
+                  if (idx >= 0)
+                    {
+                      p += idx;
+                      advanced = true;
+                      break;
+                    }
+                  p += 8;
+                }
+            }
+          if (!advanced && p >= end)
+            break;
+          if (!advanced)
+            {
+              /* scalar tail scan for first seek class byte */
+              while (p < end
+                     && !class_byte_ok (seek_k, static_cast<unsigned char> (*p)))
+                p++;
+              if (p >= end)
+                break;
+            }
+        }
+
+      unsigned char ch = static_cast<unsigned char> (*p);
+      if (has_pfx && !in_pfx)
+        {
+          /* Consume exactly one first_kind byte, then count kind run.  */
+          if (class_byte_ok (fk, ch))
+            {
+              in_pfx = true;
+              run = 0;
+            }
+          p++;
+          continue;
+        }
+
+      if (class_byte_ok (k, ch))
+        {
+          run++;
+          if (run == need_tail)
+            {
+              matches++;
+              if (only_exists)
+                return 1;
+              if (matches >= max_count)
+                return matches;
+              if (count_lines)
+                {
+                  const void *nl = std::memchr (p, '\n', static_cast<size_t> (end - p));
+                  if (!nl)
+                    return matches;
+                  p = static_cast<const char *> (nl) + 1;
+                  run = 0;
+                  in_pfx = false;
+                  continue;
+                }
+            }
+        }
+      else
+        {
+          run = 0;
+          in_pfx = false;
+        }
+      p++;
+    }
+  (void) need_total;
+  return matches;
+}
+
+/* AVX2 forward scan: find first class run >= min_r in [data, data+size).
+   Returns pointer to the first byte of the matching run, or nullptr.
+   *run_end is set to pointer past the end of the full contiguous run.  */
+#if defined(RG_ARCH_X86_64)
+#if defined(__GNUC__) || defined(__clang__)
+__attribute__ ((target ("avx2")))
+#endif
+static const char *
+find_class_run_forward_avx2 (ClassKind k, unsigned min_r,
+                              const char *data, size_t size,
+                              const char **run_end_out) noexcept
+{
+  const char *p = data;
+  const char *const end = data + size;
+  unsigned carry = 0;
+  const char *carry_start = nullptr;
+
+  while (p + 32 <= end)
+    {
+      uint32_t mask = class_mask_avx2 (k, p);
+
+      if (mask == 0)
+        {
+          if (carry >= min_r)
+            {
+              /* Carry qualifies.  */
+              const char *rs = carry_start;
+              *run_end_out = p;
+              return rs;
+            }
+          carry = 0;
+          p += 32;
+          continue;
+        }
+
+      if (mask == 0xFFFFFFFFu)
+        {
+          if (carry == 0)
+            carry_start = p;
+          carry += 32;
+          p += 32;
+          continue;
+        }
+
+      /* Mixed chunk.  */
+      uint32_t inv = ~mask;
+
+      /* Handle carry extension with leading 1-bits.  */
+      if (carry > 0 && (mask & 1u))
+        {
+          unsigned leading = static_cast<unsigned> (__builtin_ctz (inv));
+          carry += leading;
+          if (carry >= min_r)
+            {
+              /* Extend to full run end.  */
+              const char *re = p + leading;
+              while (re < end
+                     && class_byte_ok (k, static_cast<unsigned char> (*re)))
+                re++;
+              *run_end_out = re;
+              return carry_start;
+            }
+          carry = 0;
+        }
+      else if (carry > 0)
+        {
+          if (carry >= min_r)
+            {
+              *run_end_out = p;
+              return carry_start;
+            }
+          carry = 0;
+        }
+
+      /* Iterate runs of 1-bits in remaining mask.  */
+      uint32_t rem = mask;
+      unsigned bit = 0;
+      /* Skip past leading bits already handled by carry.  */
+      if (mask & 1u)
+        {
+          unsigned skip = static_cast<unsigned> (__builtin_ctz (inv));
+          rem >>= skip;
+          bit += skip;
+        }
+      while (rem)
+        {
+          unsigned skip = static_cast<unsigned> (__builtin_ctz (rem));
+          rem >>= skip;
+          bit += skip;
+          if (!rem)
+            break;
+          uint32_t inv1 = ~rem;
+          unsigned run_len;
+          if (inv1)
+            run_len = static_cast<unsigned> (__builtin_ctz (inv1));
+          else
+            run_len = 32 - bit;
+          if (bit + run_len >= 32)
+            {
+              /* Extends to end of chunk → becomes carry.  */
+              carry = run_len;
+              carry_start = p + bit;
+              goto next_chunk;
+            }
+          if (run_len >= min_r)
+            {
+              /* Extend to full run end.  */
+              const char *rs = p + bit;
+              const char *re = p + bit + run_len;
+              while (re < end
+                     && class_byte_ok (k, static_cast<unsigned char> (*re)))
+                re++;
+              *run_end_out = re;
+              return rs;
+            }
+          rem >>= run_len;
+          bit += run_len;
+        }
+      carry = 0;
+    next_chunk:
+      p += 32;
+    }
+
+  /* Scalar tail.  */
+  unsigned run = carry;
+  const char *run_start = carry_start;
+  while (p < end)
+    {
+      if (class_byte_ok (k, static_cast<unsigned char> (*p)))
+        {
+          if (run == 0)
+            run_start = p;
+          run++;
+          if (run >= min_r)
+            {
+              const char *re = p + 1;
+              while (re < end
+                     && class_byte_ok (k, static_cast<unsigned char> (*re)))
+                re++;
+              *run_end_out = re;
+              return run_start;
+            }
+        }
+      else
+        {
+          if (run >= min_r)
+            {
+              *run_end_out = p;
+              return run_start;
+            }
+          run = 0;
+        }
+      p++;
+    }
+  if (run >= min_r)
+    {
+      *run_end_out = p;
+      return run_start;
+    }
+  return nullptr;
+}
+#endif /* RG_ARCH_X86_64 */
+
+/* Find the first class_run match in [data, data+size) and return its
+   start offset in *so and end offset in *eo.  Returns true if found.
+   Used by find_match_span to provide correct match position for colored
+   output of class_run patterns like [a-z]{8}.  */
+bool
+find_class_run_span (const ClassRunPat &pat, const char *data, size_t size,
+                     intmax_t *so, intmax_t *eo)
+{
+  if (!pat.active () || !data || !size)
+    return false;
+
+  const ClassKind k = pat.kind;
+  const unsigned min_r = pat.min_run;
+  const bool has_pfx = pat.has_prefix ();
+
+#if defined(RG_ARCH_X86_64)
+  if (!has_pfx && g_have_avx2)
+    {
+      const char *run_end = nullptr;
+      const char *rs
+          = find_class_run_forward_avx2 (k, min_r, data, size, &run_end);
+      if (rs)
+        {
+          *so = static_cast<intmax_t> (rs - data);
+          *eo = static_cast<intmax_t> (run_end - data);
+          return true;
+        }
+      return false;
+    }
+#elif defined(RG_ARCH_AARCH64)
+  if (!has_pfx)
+    {
+      const char *run_end = nullptr;
+      const char *rs
+          = find_class_run_forward_neon (k, min_r, data, size, &run_end);
+      if (rs)
+        {
+          *so = static_cast<intmax_t> (rs - data);
+          *eo = static_cast<intmax_t> (run_end - data);
+          return true;
+        }
+      return false;
+    }
+#elif defined(RG_HAVE_LSX)
+  if (!has_pfx)
+    {
+      const char *run_end = nullptr;
+      const char *rs
+          = find_class_run_forward_lsx (k, min_r, data, size, &run_end);
+      if (rs)
+        {
+          *so = static_cast<intmax_t> (rs - data);
+          *eo = static_cast<intmax_t> (run_end - data);
+          return true;
+        }
+      return false;
+    }
+#endif
+
+  const ClassKind fk = pat.first_kind;
+  const char *p = data;
+  const char *const end = data + size;
+  unsigned run = 0;
+  bool in_pfx = false;
+  const char *run_start = nullptr;
+
+  while (p < end)
+    {
+      unsigned char ch = static_cast<unsigned char> (*p);
+      if (has_pfx && !in_pfx)
+        {
+          if (class_byte_ok (fk, ch))
+            {
+              run_start = p;
+              in_pfx = true;
+              run = 0;
+            }
+          p++;
+          continue;
+        }
+
+      if (class_byte_ok (k, ch))
+        {
+          if (run == 0 && !has_pfx)
+            run_start = p;
+          run++;
+          if (run >= min_r)
+            {
+              /* Found a match.  run_start is where the run began (or
+                 the prefix byte for prefix patterns).  */
+              size_t match_start = static_cast<size_t> (run_start - data);
+              /* Extend to end of full run.  */
+              const char *re = p + 1;
+              while (re < end && class_byte_ok (k, static_cast<unsigned char> (*re)))
+                re++;
+              *so = static_cast<intmax_t> (match_start);
+              *eo = static_cast<intmax_t> (re - data);
+              return true;
+            }
+        }
+      else
+        {
+          run = 0;
+          in_pfx = false;
+        }
+      p++;
+    }
+  return false;
+}
+
+/* Lightweight exists check for class_run in a line.  Directly delegates to
+   scan_class_run with only_exists=true.  The compiler + PGO can inline this
+   as a direct call to scan_class_run_avx2_impl.  */
+bool
+class_run_line_exists (const ClassRunPat &pat, const char *data, size_t size)
+{
+  return scan_class_run (pat, data, size, false, true, 1) > 0;
+}
+
+} /* namespace rg_simd */
