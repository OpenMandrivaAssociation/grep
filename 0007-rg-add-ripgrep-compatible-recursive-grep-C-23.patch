+"\n"
+"USAGE:\n"
+"    rg [OPTIONS] PATTERN [PATH ...]\n"
+"    rg [OPTIONS] -e PATTERN ... [PATH ...]\n"
+"    rg [OPTIONS] -f PATTERNFILE ... [PATH ...]\n"
+"    rg [OPTIONS] --files [PATH ...]\n"
+"    command | rg [OPTIONS] PATTERN\n"
+"\n"
+"Directories recurse by default (like ripgrep).  There is no -r recurse flag;\n"
+"-r/--replace is search-and-replace in output (also like ripgrep).\n"
+"\n"
+"INPUT:\n"
+"    -e, --regexp=PATTERN         Pattern (repeatable; also for leading '-')\n"
+"    -f, --file=PATTERNFILE       Patterns from file (one per line)\n"
+"    -F, --fixed-strings          Literal match\n"
+"    -r, --replace=TEXT           Replace each match with TEXT in output\n"
+"\n"
+"SEARCH:\n"
+"    -i, --ignore-case            Case insensitive\n"
+"    -s, --case-sensitive         Case sensitive (default)\n"
+"    -S, --smart-case             -i unless pattern has uppercase\n"
+"    -w, --word-regexp            Word boundaries\n"
+"    -x, --line-regexp            Whole line\n"
+"    -v, --invert-match           Invert\n"
+"    -m, --max-count=NUM          Max matches per file\n"
+"    --max-depth=NUM              Max directory depth\n"
+"    --max-filesize=NUM           Skip larger files\n"
+"\n"
+"FILTER:\n"
+"    -g, --glob=GLOB              Include glob (repeatable)\n"
+"    --iglob=GLOB                 Case-insensitive glob\n"
+"    -t, --type=TYPE              File type\n"
+"    -T, --type-not=TYPE          Exclude type\n"
+"    --type-list                  List types and exit\n"
+"    -u, --unrestricted           Reduce ignore (-uu/-uuu like rg)\n"
+"    --hidden                     Search hidden files\n"
+"    --no-ignore                  Don't respect ignore files\n"
+"    --no-ignore-vcs              Don't respect .gitignore\n"
+"    -L, --follow                 Follow symlinks\n"
+"    -a, --text                   Search binary as text\n"
+"\n"
+"OUTPUT:\n"
+"    -c, --count                  Count lines\n"
+"    -l, --files-with-matches     Only filenames\n"
+"    --files-without-match        Files without matches\n"
+"    -n, --line-number            Show line numbers\n"
+"    -N, --no-line-number         Hide line numbers (default)\n"
+"    -H, --with-filename          Show filename\n"
+"    --no-filename                Hide filename\n"
+"    -o, --only-matching          Only matching text\n"
+"    -q, --quiet                  Exit code only\n"
+"    -A/-B/-C NUM                 Context (accepted; output is best-effort)\n"
+"    --column                     Show column (best-effort)\n"
+"    --json                       JSON lines (subset)\n"
+"    --vimgrep                    Vim-friendly output\n"
+"    --stats                      Print stats to stderr\n"
+"    --color=WHEN                 never/auto/always (accepted)\n"
+"    -0, --null                   NUL path separator\n"
+"\n"
+"OTHER:\n"
+"    -j, --threads=NUM            Search threads\n"
+"    --files                      List files that would be searched\n"
+"    --sort=path                  Sort paths (accepted)\n"
+"    --mmap / --no-mmap           Memory map control\n"
+"    --passthru                   Print all lines\n"
+"    --no-config                  Ignore RIPGREP_CONFIG_PATH\n"
+"    -h, --help                   Help\n"
+"    -V, --version                Version\n"
+"\n"
+"Exit status is 0 if a match is found, 1 if no match, 2 on error (like rg).\n");
+  exit (0);
+}
