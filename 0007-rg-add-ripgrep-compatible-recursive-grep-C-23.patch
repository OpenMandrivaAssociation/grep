+static void die (const char *fmt, ...) __attribute__ ((noreturn, format (printf, 1, 2)));
+static void
+die (const char *fmt, ...)
+{
+  va_list ap;
+  fprintf (stderr, "%s: ", g_prog);
+  va_start (ap, fmt);
+  vfprintf (stderr, fmt, ap);
+  va_end (ap);
+  fputc ('\n', stderr);
+  exit (2);
+}
+
+static bool
+str_eq (const char *a, const char *b)
+{
+  return a && b && std::strcmp (a, b) == 0;
+}
+
+static bool
+glob_match (std::string_view pat, std::string_view name);
+
+/* True if pattern has no glob metacharacters.  */
+static bool
+pat_is_literal_s (std::string_view p)
+{
+  for (char c : p)
+    if (c == '*' || c == '?' || c == '[')
+      return false;
+  return true;
+}
+
+/* True if pattern is exactly "*." + extension (no other metacharacters).  */
+static bool
+pat_is_star_ext (std::string_view p, std::string *ext_out)
+{
+  if (p.size () < 3 || p[0] != '*' || p[1] != '.')
+    return false;
+  for (size_t i = 2; i < p.size (); i++)
+    {
+      char c = p[i];
+      if (c == '*' || c == '?' || c == '[' || c == '/')
+        return false;
+    }
+  if (ext_out)
+    *ext_out = std::string (p.substr (2));
+  return true;
+}
+
+static void
+compile_ignore_frame (IgnoreFrame &fr)
+{
+  /* If any rule is a non-trivial glob/negation mix, keep full ordered list
+     (gitignore last-match-wins).  Only hoist when every rule is a simple
+     positive/negative exact name or *.ext — order within those sets is
+     commutative for our apply order (neg sets checked after pos sets).  */
+  bool all_simple = true;
+  for (auto &r : fr.rules)
+    {
+      r.is_lit = pat_is_literal_s (r.pat);
+      if (r.is_lit && !r.dir_only && !r.anchored && !r.anywhere)
+        continue;
+      std::string ext;
+      if (!r.dir_only && !r.anchored && !r.anywhere && pat_is_star_ext (r.pat, &ext))
+        continue;
+      all_simple = false;
+      fr.has_glob_rules = true;
+      break;
+    }
+  if (!all_simple)
+    {
+      /* Preserve order; only mark is_lit for the matcher.  */
+      for (auto &r : fr.rules)
+        r.is_lit = pat_is_literal_s (r.pat);
+      fr.has_glob_rules = true;
+      return;
+    }
+  std::vector<IgnoreRule> rest;
+  for (auto &r : fr.rules)
+    {
+      r.is_lit = pat_is_literal_s (r.pat);
+      if (r.is_lit && !r.dir_only && !r.anchored && !r.anywhere)
+        {
+          if (r.neg)
+            fr.lit_names_neg.insert (r.pat);
+          else
+            fr.lit_names.insert (r.pat);
+        }
+      else
+        {
+          std::string ext;
+          if (pat_is_star_ext (r.pat, &ext))
+            {
+              if (r.neg)
+                fr.lit_exts_neg.insert (std::move (ext));
+              else
+                fr.lit_exts.insert (std::move (ext));
+            }
+          else
+            rest.push_back (std::move (r));
+        }
+    }
+  fr.rules = std::move (rest);
+}
+
+static void
+push_ignore_file (const std::string &dirpath, const std::string &filepath)
+{
+  if (opt_no_ignore || opt_unrestricted >= 1)
+    return;
+  FILE *f = fopen (filepath.c_str (), "r");
+  if (!f)
+    return;
+  IgnoreFrame fr;
+  fr.dir = dirpath;
+  char *line = nullptr;
+  size_t n = 0;
+  while (getline (&line, &n, f) > 0)
+    {
+      char *p = line;
+      while (*p == ' ' || *p == '\t')
+        p++;
+      if (*p == '#' || *p == '\n' || !*p)
+        continue;
+      size_t len = std::strlen (p);
+      while (len && (p[len - 1] == '\n' || p[len - 1] == '\r' || p[len - 1] == ' '))
+        p[--len] = 0;
+      if (!len)
+        continue;
+      IgnoreRule r;
+      if (*p == '!')
+        {
+          r.neg = true;
+          p++;
+        }
+      if (*p == '/')
+        {
+          r.anchored = true;
+          p++;
+        }
+      len = std::strlen (p);
+      if (len && p[len - 1] == '/')
+        {
+          r.dir_only = true;
+          p[--len] = 0;
+        }
+      r.pat = p;
+      if (r.pat.find ('/') != std::string::npos)
+        r.anywhere = true;
+      fr.rules.push_back (std::move (r));
+    }
+  free (line);
+  fclose (f);
+  if (fr.rules.empty ())
+    return;
+  compile_ignore_frame (fr);
+  if (!fr.empty ())
+    g_ignore_stack.push_back (std::move (fr));
+}
+
+/* Parse ignore file into a frame (no global stack side effects).  */
+static bool
+parse_ignore_file_to_frame (const std::string &dirpath, const std::string &filepath,
+                            IgnoreFrame *out)
+{
+  FILE *f = fopen (filepath.c_str (), "r");
+  if (!f)
+    return false;
+  IgnoreFrame fr;
+  fr.dir = dirpath;
+  char *line = nullptr;
+  size_t n = 0;
+  while (getline (&line, &n, f) > 0)
+    {
+      char *p = line;
+      while (*p == ' ' || *p == '\t')
+        p++;
+      if (*p == '#' || *p == '\n' || !*p)
+        continue;
+      size_t len = std::strlen (p);
+      while (len && (p[len - 1] == '\n' || p[len - 1] == '\r' || p[len - 1] == ' '))
+        p[--len] = 0;
+      if (!len)
+        continue;
+      IgnoreRule r;
+      if (*p == '!')
+        {
+          r.neg = true;
+          p++;
+        }
+      if (*p == '/')
+        {
+          r.anchored = true;
+          p++;
+        }
+      len = std::strlen (p);
+      if (len && p[len - 1] == '/')
+        {
+          r.dir_only = true;
+          p[--len] = 0;
+        }
+      r.pat = p;
+      if (r.pat.find ('/') != std::string::npos)
+        r.anywhere = true;
+      fr.rules.push_back (std::move (r));
+    }
+  free (line);
+  fclose (f);
+  if (fr.rules.empty ())
+    return false;
+  compile_ignore_frame (fr);
+  if (fr.empty ())
+    return false;
+  *out = std::move (fr);
+  return true;
+}
+
+/* Ensure ignore files for dirpath are registered (thread-safe, once).  */
+static void
+ensure_dir_ignores_registered (const std::string &dirpath, const std::string &relbase)
+{
+  if (opt_no_ignore || opt_unrestricted >= 1)
+    return;
+  {
+    std::lock_guard lk (g_ignore_reg_mu);
+    if (g_ignore_reg_loaded.count (dirpath))
+      return;
+  }
+  /* Probe files outside lock; insert under lock if still missing.  */
+  std::vector<IgnoreFrame> pending;
+  auto try_one = [&] (const char *name, bool vcs_only, bool dot_ignore) {
+    if (vcs_only && opt_no_ignore_vcs)
+      return;
+    if (dot_ignore && opt_no_ignore_dot)
+      return;
+    if (vcs_only && opt_no_ignore_exclude && std::strstr (name, "exclude"))
+      return;
+    std::string path = dirpath;
+    path.push_back ('/');
+    path += name;
+    if (access (path.c_str (), R_OK) != 0)
+      return;
+    IgnoreFrame fr;
+    if (parse_ignore_file_to_frame (relbase, path, &fr))
+      pending.push_back (std::move (fr));
+  };
+  if (!opt_no_ignore_vcs)
+    try_one (".gitignore", true, false);
+  try_one (".ignore", false, true);
+  try_one (".rgignore", false, true);
+
+  std::lock_guard lk (g_ignore_reg_mu);
+  if (g_ignore_reg_loaded.count (dirpath))
+    return;
+  for (auto &fr : pending)
+    {
+      size_t idx = g_ignore_reg.size ();
+      std::string dkey = fr.dir;
+      g_ignore_reg.push_back (std::move (fr));
+      g_ignore_reg_by_dir[dkey].push_back (idx);
+    }
+  g_ignore_reg_loaded.insert (dirpath);
+}
+
+/* Register global frames (empty dir key) once from existing stack load.  */
+static void
+register_global_frames_from_stack ()
+{
+  std::lock_guard lk (g_ignore_reg_mu);
+  for (const auto &fr : g_ignore_stack)
+    {
+      if (!fr.dir.empty ())
+        continue;
+      size_t idx = g_ignore_reg.size ();
+      g_ignore_reg.push_back (fr);
+      g_ignore_reg_by_dir[""].push_back (idx);
+    }
+}
+
+/* Load all ignore files ripgrep consults in a directory (order matters).
+   Results cached per absolute/relative dirpath so we never re-open.  */
+static int
+push_dir_ignores (const std::string &dirpath, const std::string &relbase)
+{
+  if (opt_no_ignore || opt_unrestricted >= 1)
+    return 0;
+  auto cit = g_ignore_dir_cache.find (dirpath);
+  if (cit != g_ignore_dir_cache.end ())
+    {
+      /* Already loaded: frames stay on stack until pop; cache stores count
+         only for first visit.  Re-walk shouldn't happen for same dirpath.  */
+      return cit->second;
+    }
+  /* Always probe every directory: a child .ignore/.rgignore (and .gitignore
+     inside a git work tree) can appear anywhere.  Skipping probes misses
+     nested rules and is incorrect.  */
+  size_t before = g_ignore_stack.size ();
+  const bool in_git = !opt_no_ignore_vcs && dir_in_git_worktree (dirpath);
+  auto try_one = [&] (const char *name, bool vcs_only, bool dot_ignore) {
+    if (vcs_only && opt_no_ignore_vcs)
+      return;
+    if (vcs_only && !in_git)
+      return; /* ripgrep: no .gitignore outside a git work tree */
+    if (dot_ignore && opt_no_ignore_dot)
+      return;
+    if (vcs_only && opt_no_ignore_exclude && std::strstr (name, "exclude"))
+      return;
+    /* Single stack buffer for dirpath/name; avoids 3× string alloc per dir.  */
+    thread_local std::string probe;
+    probe.clear ();
+    probe.reserve (dirpath.size () + 16);
+    probe.append (dirpath);
+    probe.push_back ('/');
+    probe.append (name);
+    /* Cheap existence probe before fopen+parse.  */
+    if (access (probe.c_str (), R_OK) != 0)
+      return;
+    push_ignore_file (relbase, probe);
+  };
+  if (!opt_no_ignore_vcs)
+    try_one (".gitignore", true, false);
+  try_one (".ignore", false, true);
+  try_one (".rgignore", false, true);
+  int frames_added = static_cast<int> (g_ignore_stack.size () - before);
+  g_ignore_dir_cache.emplace (dirpath, frames_added);
+  return frames_added;
+}
+
+/* Resolve path to absolute (best effort).  */
+static std::string
+abs_path_of (const std::string &p)
+{
+  if (p.empty () || p == ".")
+    {
+      char cwd[PATH_MAX];
+      if (getcwd (cwd, sizeof cwd))
+        return std::string (cwd);
+      return ".";
+    }
+  if (!p.empty () && p[0] == '/')
+    return p;
+  char cwd[PATH_MAX];
+  if (!getcwd (cwd, sizeof cwd))
+    return p;
+  std::string out = cwd;
+  out.push_back ('/');
+  out += p;
+  return out;
+}
+
+/* Relative path of `abs` under `root_abs`; empty if abs == root_abs.
+   Returns false if abs is not under root_abs.  */
+static bool
+rel_under_root (const std::string &abs, const std::string &root_abs, std::string *rel_out)
+{
+  if (abs == root_abs)
+    {
+      *rel_out = "";
+      return true;
+    }
+  if (abs.size () > root_abs.size ()
+      && abs.compare (0, root_abs.size (), root_abs) == 0
+      && abs[root_abs.size ()] == '/')
+    {
+      *rel_out = abs.substr (root_abs.size () + 1);
+      return true;
+    }
+  return false;
+}
+
+/* Global / parent ignores (ripgrep-style), loaded once before walk.
+   Parent-directory .gitignore files are scoped to their containing dir
+   (relative to search root), never applied as global — that wrongly matches
+   e.g. /lib/uniwidth/ against any path ending in lib/uniwidth.  */
+static void
+load_global_and_parent_ignores (const std::string &start_dir)
+{
+  if (opt_no_ignore || opt_unrestricted >= 1)
+    return;
+
+  auto try_push_scoped = [&] (const std::string &frame_dir, const std::string &path,
+                              bool vcs) {
+    if (vcs && opt_no_ignore_vcs)
+      return;
+    if (!vcs && opt_no_ignore_global)
+      return;
+    push_ignore_file (frame_dir, path);
+  };
+
+  if (!opt_no_ignore_global)
+    {
+      /* Home / XDG global excludes (true global: frame_dir empty).  */
+      const char *home = std::getenv ("HOME");
+      if (home && *home)
+        {
+          try_push_scoped ("", std::string (home) + "/.gitignore", false);
+          try_push_scoped ("", std::string (home) + "/.config/git/ignore", false);
+          try_push_scoped ("", std::string (home) + "/.ignore", false);
+          try_push_scoped ("", std::string (home) + "/.rgignore", false);
+        }
+      const char *xdg = std::getenv ("XDG_CONFIG_HOME");
+      if (xdg && *xdg)
+        try_push_scoped ("", std::string (xdg) + "/git/ignore", false);
+    }
+
+  if (!opt_no_ignore_parent)
+    {
+      /* Walk start_dir upward.  Ignores at/under search root are scoped to
+         their dir; ignores above the root are still scoped (frame_dir empty
+         but only affect via absolute-prefix semantics — we approximate by
+         not loading above-root .gitignore for in-tree paths that will be
+         loaded again when the walk visits those dirs).  */
+      std::string root_abs = abs_path_of (start_dir.empty () ? "." : start_dir);
+      const bool root_in_git = !opt_no_ignore_vcs && dir_in_git_worktree (root_abs);
+      std::string cur = root_abs;
+      for (int guard = 0; guard < 64; guard++)
+        {
+          std::string frame_dir;
+          bool under = rel_under_root (cur, root_abs, &frame_dir);
+          if (!under)
+            {
+              /* Above search root: only load if we'd miss it otherwise.
+                 Scope as empty but patterns are relative to that parent dir;
+                 skip loading in-tree files from parent walk (walk loads them).  */
+              break;
+            }
+          /* At/under search root: scoped to frame_dir.  These may duplicate
+             walk-time loads; ignore stack/registry tolerates duplicate frames.  */
+          if (!opt_no_ignore_vcs && root_in_git)
+            {
+              try_push_scoped (frame_dir, cur + "/.gitignore", true);
+              try_push_scoped (frame_dir, cur + "/.git/info/exclude", true);
+            }
+          if (!opt_no_ignore_dot)
+            {
+              try_push_scoped (frame_dir, cur + "/.ignore", false);
+              try_push_scoped (frame_dir, cur + "/.rgignore", false);
+            }
+
+          auto slash = cur.rfind ('/');
+          if (slash == std::string::npos || slash == 0)
+            break;
+          std::string parent = cur.substr (0, slash);
+          if (parent.empty ())
+            parent = "/";
+          if (parent == cur)
+            break;
+          cur = parent;
+        }
+    }
+}
+
+/* Global ignore: RIPGREP_CONFIG_PATH / ~/.config/ripgrep/config — accept, light parse.  */
+static void
+load_rg_config_env ()
+{
+  if (opt_no_config)
+    return;
+  const char *cfg = std::getenv ("RIPGREP_CONFIG_PATH");
+  std::string cfg_s;
+  if (!cfg || !*cfg)
+    {
+      const char *home = std::getenv ("HOME");
+      if (home)
+        {
+          cfg_s = std::string (home) + "/.config/ripgrep/config";
+          cfg = cfg_s.c_str ();
+        }
+    }
+  if (!cfg || !*cfg)
+    return;
+  FILE *f = fopen (cfg, "r");
+  if (!f)
+    return;
+  char *line = nullptr;
+  size_t n = 0;
+  while (getline (&line, &n, f) > 0)
+    {
+      char *p = line;
+      while (*p == ' ' || *p == '\t')
+        p++;
+      if (*p == '#' || *p == '\n' || !*p)
+        continue;
+      size_t len = std::strlen (p);
+      while (len && (p[len - 1] == '\n' || p[len - 1] == '\r'))
+        p[--len] = 0;
+      if (std::strncmp (p, "--hidden", 8) == 0)
+        opt_hidden = true;
+      else if (std::strncmp (p, "--no-ignore", 11) == 0)
+        opt_no_ignore = true;
+      else if (std::strncmp (p, "--glob=", 7) == 0)
+        opt_globs.emplace_back (p + 7);
+      else if (std::strncmp (p, "-g=", 3) == 0)
+        opt_globs.emplace_back (p + 3);
+      else if (std::strncmp (p, "--max-depth=", 12) == 0)
+        opt_max_depth = atoll (p + 12);
+      else if (std::strncmp (p, "--iglob=", 8) == 0)
+        opt_iglobs.emplace_back (p + 8);
+    }
+  free (line);
+  fclose (f);
+}
+
+static void
+pop_ignore ()
+{
+  if (!g_ignore_stack.empty ())
+    g_ignore_stack.pop_back ();
+}
+
+/* Gitignore-style glob: * does not cross /, ** crosses directories.  */
+static bool
+glob_match (std::string_view pat, std::string_view name)
+{
+  size_t pi = 0, ni = 0;
+  size_t star_p = std::string_view::npos, star_n = 0;
+  while (ni < name.size ())
+    {
+      if (pi < pat.size () && pat[pi] == '*')
+        {
+          if (pi + 1 < pat.size () && pat[pi + 1] == '*')
+            {
+              /* ** — match any path segment sequence */
+              pi += 2;
+              if (pi < pat.size () && pat[pi] == '/')
+                pi++;
+              if (pi >= pat.size ())
+                return true;
+              for (size_t k = ni; k <= name.size (); k++)
+                {
+                  if (k > ni && name[k - 1] != '/' && k != name.size ())
+                    continue; /* only try at segment boundaries for efficiency */
+                  if (glob_match (pat.substr (pi), name.substr (k)))
+                    return true;
+                }
+              /* Also allow non-boundary tries for patterns like a**b */
+              for (size_t k = ni; k <= name.size (); k++)
+                if (glob_match (pat.substr (pi), name.substr (k)))
+                  return true;
+              return false;
+            }
+          /* single * — within one segment (no /) */
+          star_p = ++pi;
+          star_n = ni;
+        }
+      else if (pi < pat.size () && (pat[pi] == '?' || pat[pi] == name[ni]))
+        {
+          if (pat[pi] == '?' && name[ni] == '/')
+            return false;
+          pi++;
+          ni++;
+        }
+      else if (star_p != std::string_view::npos)
+        {
+          if (name[star_n] == '/')
+            return false; /* * cannot span / */
+          pi = star_p;
+          ni = ++star_n;
+        }
+      else
+        return false;
+    }
+  while (pi < pat.size () && pat[pi] == '*')
+    {
+      if (pi + 1 < pat.size () && pat[pi + 1] == '*')
+        pi += 2;
+      else
+        pi++;
+    }
+  return pi == pat.size ();
+}
+
+/* Match remaining (glob / complex) rule against path relative to frame.  */
+static bool
+ignore_rule_matches (const IgnoreRule &r, std::string_view path, bool is_dir)
+{
+  if (r.dir_only && !is_dir)
+    return false;
+
+  auto slash = path.rfind ('/');
+  std::string_view base = slash == std::string_view::npos
+    ? path
+    : path.substr (slash + 1);
+
+  if (r.is_lit)
+    {
+      std::string_view rp (r.pat);
+      if (r.anchored)
+        {
+          /* Anchored at frame root only: exact or path is under the pattern.  */
+          if (path == rp)
+            return true;
+          if (path.size () > rp.size () && path.starts_with (rp)
+              && path[rp.size ()] == '/')
+            return true;
+          return false;
+        }
+      if (r.anywhere)
+        {
+          /* Pattern contains '/': match full relative path segments.  */
+          if (path == rp)
+            return true;
+          if (path.size () > rp.size () && path.starts_with (rp)
+              && path[rp.size ()] == '/')
+            return true;
+          /* Also allow match at any path segment (unanchored slash patterns).  */
+          if (path.size () > rp.size () && path.ends_with (rp)
+              && path[path.size () - rp.size () - 1] == '/')
+            return true;
+          return false;
+        }
+      /* Unanchored basename / segment.  */
+      if (base == rp || path == rp)
+        return true;
+      if (path.size () > rp.size ())
+        {
+          if (path.ends_with (rp))
+            {
+              size_t at = path.size () - rp.size ();
+              if (at == 0 || path[at - 1] == '/')
+                return true;
+            }
+          if (path.starts_with (rp) && path[rp.size ()] == '/')
+            return true;
+        }
+      return false;
+    }
+
+  if (r.anchored)
+    return glob_match (r.pat, path);
+  if (r.anywhere)
+    {
+      if (glob_match (r.pat, path))
+        return true;
+      for (size_t i = 1; i < path.size (); i++)
+        if (path[i - 1] == '/' && glob_match (r.pat, path.substr (i)))
+          return true;
+      return false;
+    }
+
+  if (glob_match (r.pat, base))
+    return true;
+  if (glob_match (r.pat, path))
+    return true;
+  for (size_t i = 1; i < path.size (); i++)
+    {
+      if (path[i - 1] == '/')
+        {
+          if (glob_match (r.pat, path.substr (i)))
+            return true;
+        }
+    }
+  return false;
+}
+
+/* Apply one compiled frame to a path (relative to that frame).  */
+static void
+apply_ignore_frame (const IgnoreFrame &fr, std::string_view sub, bool is_dir,
+                    bool *ignored)
+{
+  auto slash = sub.rfind ('/');
+  std::string_view base = slash == std::string_view::npos ? sub : sub.substr (slash + 1);
+
+  /* Reuse TLS buffers for set lookups (unordered_set needs std::string key).  */
+  thread_local std::string tls_base;
+  thread_local std::string tls_path;
+  tls_base.assign (base);
+  const std::string *path_p = nullptr;
+  auto path_s = [&] () -> const std::string & {
+    if (!path_p)
+      {
+        tls_path.assign (sub);
+        path_p = &tls_path;
+      }
+    return *path_p;
+  };
+
+  /* O(1) exact basename / path hits first.  */
+  if (!fr.lit_names.empty () || !fr.lit_names_neg.empty ())
+    {
+      if (fr.lit_names.count (tls_base))
+        *ignored = true;
+      if (fr.lit_names_neg.count (tls_base))
+        *ignored = false;
+    }
+  if (!fr.lit_paths.empty () || !fr.lit_paths_neg.empty ())
+    {
+      if (fr.lit_paths.count (path_s ()))
+        *ignored = true;
+      if (fr.lit_paths_neg.count (path_s ()))
+        *ignored = false;
+    }
+  if (!fr.lit_exts.empty () || !fr.lit_exts_neg.empty ())
+    {
+      auto dot = base.rfind ('.');
+      if (dot != std::string_view::npos && dot + 1 < base.size ())
+        {
+          thread_local std::string tls_ext;
+          tls_ext.assign (base.substr (dot + 1));
+          if (fr.lit_exts.count (tls_ext))
+            *ignored = true;
+          if (fr.lit_exts_neg.count (tls_ext))
+            *ignored = false;
+        }
+    }
+
+  if (!fr.has_glob_rules && fr.rules.empty ())
+    return;
+  for (const auto &r : fr.rules)
+    {
+      if (ignore_rule_matches (r, sub, is_dir))
+        *ignored = !r.neg;
+    }
+}
+
+/* Parallel-safe ignore check: walk ancestors via registry (no stack).
+   Reuses TLS string for ancestor prefixes to avoid per-entry allocations.  */
+static bool
+should_ignore_path_reg (const std::string &relpath, bool is_dir)
+{
+  if (opt_no_ignore || opt_unrestricted >= 1)
+    return false;
+  if (opt_unrestricted < 3)
+    {
+      if (relpath == ".git" || relpath.starts_with (".git/"))
+        return true;
+    }
+  bool ignored = false;
+  std::string_view rpv (relpath);
+  const std::string *vcs = enclosing_vcs_root_ptr (relpath);
+
+  auto apply_idxs = [&] (const std::vector<size_t> *idxs, std::string_view sub,
+                         const std::string &frame_dir) {
+    if (!idxs)
+      return;
+    if (!frame_applies_under_vcs (frame_dir, vcs))
+      return;
+    for (size_t idx : *idxs)
+      {
+        if (idx >= g_ignore_reg.size ())
+          continue;
+        apply_ignore_frame (g_ignore_reg[idx], sub, is_dir, &ignored);
+      }
+  };
+
+  {
+    auto it = g_ignore_reg_by_dir.find ("");
+    if (it != g_ignore_reg_by_dir.end ())
+      apply_idxs (&it->second, rpv, "");
+  }
+
+  thread_local std::string tls_prefix;
+  size_t pos = 0;
+  while (pos < relpath.size ())
+    {
+      size_t slash = relpath.find ('/', pos);
+      if (slash == std::string::npos)
+        tls_prefix.assign (relpath);
+      else
+        tls_prefix.assign (relpath, 0, slash);
+      auto it = g_ignore_reg_by_dir.find (tls_prefix);
+      if (it != g_ignore_reg_by_dir.end ())
+        {
+          std::string_view sub = slash == std::string::npos
+            ? std::string_view (".")
+            : rpv.substr (slash + 1);
+          apply_idxs (&it->second, sub, tls_prefix);
+        }
+      if (slash == std::string::npos)
+        break;
+      pos = slash + 1;
+    }
+  return ignored;
+}
+
+static bool
+is_hidden_name (const char *name)
+{
+  return name[0] == '.' && name[1] && !(name[1] == '.' && !name[2]);
+}
+
+/* Ripgrep: ignore negations can whitelist otherwise-hidden paths (e.g.
+   !/.github/ in .ignore).  Return true if any loaded frame would un-ignore
+   this path (negation match).  Cheap path: only run when entry is hidden.  */
+static bool
+ignore_whitelists_path (const std::string &relpath, bool is_dir)
+{
+  if (opt_no_ignore || opt_unrestricted >= 1)
+    return false;
+  auto check_fr = [&] (const IgnoreFrame &fr, std::string_view sub) -> bool {
+    /* Negations only matter for whitelist of hidden.  */
+    for (const auto &r : fr.rules)
+      {
+        if (!r.neg)
+          continue;
+        if (ignore_rule_matches (r, sub, is_dir))
+          return true;
+      }
+    /* Lit neg sets */
+    auto slash = sub.rfind ('/');
+    std::string_view base = slash == std::string_view::npos ? sub : sub.substr (slash + 1);
+    thread_local std::string tls_b, tls_p;
+    tls_b.assign (base);
+    if (fr.lit_names_neg.count (tls_b))
+      return true;
+    if (!fr.lit_paths_neg.empty ())
+      {
+        tls_p.assign (sub);
+        if (fr.lit_paths_neg.count (tls_p))
+          return true;
+      }
+    return false;
+  };
+
+  std::string_view rpv (relpath);
+  if (!g_ignore_reg.empty ())
+    {
+      auto it = g_ignore_reg_by_dir.find ("");
+      if (it != g_ignore_reg_by_dir.end ())
+        for (size_t idx : it->second)
+          if (idx < g_ignore_reg.size () && check_fr (g_ignore_reg[idx], rpv))
+            return true;
+      size_t pos = 0;
+      while (pos < relpath.size ())
+        {
+          size_t slash = relpath.find ('/', pos);
+          std::string prefix = slash == std::string::npos
+            ? relpath : relpath.substr (0, slash);
+          auto jt = g_ignore_reg_by_dir.find (prefix);
+          if (jt != g_ignore_reg_by_dir.end ())
+            {
+              std::string_view sub = slash == std::string::npos
+                ? std::string_view (".") : rpv.substr (slash + 1);
+              for (size_t idx : jt->second)
+                if (idx < g_ignore_reg.size () && check_fr (g_ignore_reg[idx], sub))
+                  return true;
+            }
+          if (slash == std::string::npos)
+            break;
+          pos = slash + 1;
+        }
+      return false;
+    }
+  for (const auto &fr : g_ignore_stack)
+    {
+      std::string_view sub = rpv;
+      if (!fr.dir.empty ())
+        {
+          const std::string &fd = fr.dir;
+          if (relpath.size () == fd.size () && relpath == fd)
+            sub = ".";
+          else if (relpath.size () > fd.size ()
+                   && relpath.compare (0, fd.size (), fd) == 0
+                   && relpath[fd.size ()] == '/')
+            sub = rpv.substr (fd.size () + 1);
+          else
+            continue;
+        }
+      if (check_fr (fr, sub))
+        return true;
+    }
+  return false;
+}
+
+/* True if this dirent name should be skipped as hidden (ripgrep default),
+   unless ignore rules whitelist it.  */
+static bool
+skip_hidden_entry (const char *name, const std::string &relpath, bool is_dir)
+{
+  if (opt_hidden || opt_unrestricted >= 2)
+    return false;
+  if (!is_hidden_name (name))
+    return false;
+  /* Always keep .git out unless fully unrestricted.  */
+  if (opt_unrestricted < 3 && (str_eq (name, ".git") || relpath == ".git"
+                               || relpath.starts_with (".git/")))
+    return true;
+  if (ignore_whitelists_path (relpath, is_dir))
+    return false;
+  return true;
+}
+
+/* Emit path without leading "./" (ripgrep style).  */
+static const char *
+display_path (const std::string &p)
+{
+  if (p.size () >= 2 && p[0] == '.' && p[1] == '/')
+    return p.c_str () + 2;
+  return p.c_str ();
+}
+
+static bool
+should_ignore_path (const std::string &relpath, bool is_dir)
+{
+  /* ripgrep: -u disables ignore files; -uu also enables hidden; -uuu binary.  */
+  if (opt_no_ignore || opt_unrestricted >= 1)
+    return false;
+  /* No loaded frames: nothing to ignore (except .git handled by walk skips).  */
+  if (g_ignore_stack.empty () && g_ignore_reg.empty ())
+    return false;
+  if (opt_unrestricted < 3)
+    {
+      if (relpath == ".git" || relpath.starts_with (".git/"))
+        return true;
+    }
+  if (g_ignore_stack.empty () && g_ignore_reg.empty ())
+    return false;
+
+  /* Prefer registry when populated (parallel walk); else sequential stack.  */
+  if (!g_ignore_reg.empty () && g_ignore_stack.empty ())
+    return should_ignore_path_reg (relpath, is_dir);
+
+  /* Later frames (deeper dirs) override earlier; walk stack top-down.
+     Rules only apply under their frame directory; match path is relative
+     to that frame (gitignore / ripgrep semantics).  */
+  bool ignored = false;
+  std::string_view rpv (relpath);
+  const std::string *vcs = enclosing_vcs_root_ptr (relpath);
+  for (const auto &fr : g_ignore_stack)
+    {
+      if (fr.empty ())
+        continue;
+      if (!frame_applies_under_vcs (fr.dir, vcs))
+        continue;
+      std::string_view sub = rpv;
+      if (!fr.dir.empty ())
+        {
+          const std::string &fd = fr.dir;
+          if (relpath.size () == fd.size () && relpath == fd)
+            sub = ".";
+          else if (relpath.size () > fd.size ()
+                   && relpath.compare (0, fd.size (), fd) == 0
+                   && relpath[fd.size ()] == '/')
+            sub = rpv.substr (fd.size () + 1);
+          else
+            continue;
+        }
+      apply_ignore_frame (fr, sub, is_dir, &ignored);
+    }
+  return ignored;
+}
+
+static bool
+type_ok (const std::string &path)
+{
+  if (!opt_type && !opt_type_not)
+    return true;
+  auto ext_pos = path.rfind ('.');
+  std::string ext = ext_pos == std::string::npos ? "" : path.substr (ext_pos);
+  auto slash = path.rfind ('/');
+  std::string base = slash == std::string::npos ? path : path.substr (slash + 1);
+  auto is_c = ext == ".c" || ext == ".h" || ext == ".cpp" || ext == ".cc" || ext == ".hpp";
+  auto is_rs = ext == ".rs";
+  auto is_py = ext == ".py";
+  auto is_js = ext == ".js" || ext == ".ts" || ext == ".jsx";
+  auto is_go = ext == ".go";
+  auto is_java = ext == ".java";
+  auto is_md = ext == ".md" || ext == ".markdown";
+  auto is_sh = ext == ".sh" || ext == ".bash";
+  auto is_make = base == "Makefile" || base == "makefile" || ext == ".mk";
+
+  auto matches = [&] (const char *t) {
+    if (!t)
+      return true;
+    if (str_eq (t, "c") || str_eq (t, "cpp") || str_eq (t, "cc"))
+      return is_c;
+    if (str_eq (t, "rust") || str_eq (t, "rs"))
+      return is_rs;
+    if (str_eq (t, "py") || str_eq (t, "python"))
+      return is_py;
+    if (str_eq (t, "js") || str_eq (t, "javascript") || str_eq (t, "ts"))
+      return is_js;
+    if (str_eq (t, "go"))
+      return is_go;
+    if (str_eq (t, "java"))
+      return is_java;
+    if (str_eq (t, "md") || str_eq (t, "markdown"))
+      return is_md;
+    if (str_eq (t, "sh") || str_eq (t, "bash"))
+      return is_sh;
+    if (str_eq (t, "make") || str_eq (t, "makefile"))
+      return is_make;
+    return true;
+  };
+  if (opt_type && !matches (opt_type))
+    return false;
+  if (opt_type_not && matches (opt_type_not))
+    return false;
+  return true;
+}
+
+static bool
+glob_ok (const std::string &path)
+{
+  /* Fast path: no include/exclude globs (common recurse default).  */
+  if (opt_globs.empty () && !opt_glob && opt_iglobs.empty () && !opt_iglob)
+    return true;
+  auto slash = path.rfind ('/');
+  std::string_view base = slash == std::string::npos ? std::string_view (path)
+                                                     : std::string_view (path).substr (slash + 1);
+  auto match_one = [&] (const std::string &g) {
+    return glob_match (g, base) || glob_match (g, path);
+  };
+  if (!opt_globs.empty ())
+    {
+      bool any = false;
+      for (const auto &g : opt_globs)
+        if (match_one (g))
+          {
+            any = true;
+            break;
+          }
+      if (!any)
+        return false;
+    }
+  else if (opt_glob)
+    {
+      if (!glob_match (opt_glob, base) && !glob_match (opt_glob, path))
+        return false;
+    }
+  if (!opt_iglobs.empty ())
+    {
+      /* Case-insensitive: fold path/base lower (ASCII only).  */
+      std::string path_l (path), base_l (base);
+      for (char &ch : path_l)
+        ch = static_cast<char> (std::tolower (static_cast<unsigned char> (ch)));
+      for (char &ch : base_l)
+        ch = static_cast<char> (std::tolower (static_cast<unsigned char> (ch)));
+      bool any = false;
+      for (const auto &g : opt_iglobs)
+        {
+          std::string gl (g);
+          for (char &ch : gl)
+            ch = static_cast<char> (std::tolower (static_cast<unsigned char> (ch)));
+          if (glob_match (gl, base_l) || glob_match (gl, path_l))
+            {
+              any = true;
+              break;
+            }
+        }
+      if (!any)
+        return false;
+    }
+  return type_ok (path);
+}
+
+/* ---------- pattern compile ---------- */
+
+static bool
+pattern_is_literal (std::string_view pat)
+{
+  static const char meta[] = ".^$*+?()[]{}|\\";
+  for (char c : pat)
+    if (std::strchr (meta, c))
+      return false;
+  return true;
+}
+
+/* memmem_icase moved to rg_simd.cpp as memmem_icase_fast (AVX2 accelerated). */
+
+/* Ripgrep -U: treat `\n` in the pattern as a real newline (not stray backslash).
+   Leave other escapes alone so ERE/PCRE still see `\w`, `\d`, etc.  */
+static std::string
+multiline_preprocess_pattern (const std::string &pat)
+{
+  std::string out;
+  out.reserve (pat.size ());
+  for (size_t i = 0; i < pat.size (); ++i)
+    {
+      if (pat[i] == '\\' && i + 1 < pat.size () && pat[i + 1] == 'n')
+        {
+          out.push_back ('\n');
+          ++i;
+        }
+      else
+        out.push_back (pat[i]);
+    }
+  return out;
+}
+
+/* Try to decompose an ERE pattern into a chain of literals connected by
+   `.*` or `.+`: `lit1 .* lit2 [.* lit3 ...]`.  Each literal may include
+   backslash-escaped metacharacters (e.g. `\(` → `(`).  Returns true and
+   fills `chain` with ≥2 segments on success.  */
+static bool
+try_parse_lit_chain (std::string_view pat, std::vector<LitChainSeg> &chain)
+{
+  chain.clear ();
+  std::string cur_lit;
+  size_t i = 0;
+  while (i < pat.size ())
+    {
+      char c = pat[i];
+      /* Backslash escape: next char is literal.  */
+      if (c == '\\' && i + 1 < pat.size ())
+        {
+          cur_lit.push_back (pat[i + 1]);
+          i += 2;
+          continue;
+        }
+      /* `.* ` or `.+` separator (possibly lazy `.*?` / `.+?`).  */
+      if (c == '.' && i + 1 < pat.size ()
+          && (pat[i + 1] == '*' || pat[i + 1] == '+'))
+        {
+          if (cur_lit.empty ())
+            return false; /* leading .* or consecutive .*.* */
+          bool dp = (pat[i + 1] == '+');
+          chain.push_back ({std::move (cur_lit), dp});
+          cur_lit.clear ();
+          i += 2;
+          if (i < pat.size () && pat[i] == '?')
+            i++; /* skip lazy ? */
+          continue;
+        }
+      /* Any other unescaped metachar → not our pattern.  */
+      if (c == '.' || c == '^' || c == '$' || c == '*' || c == '+' || c == '?'
+          || c == '(' || c == ')' || c == '[' || c == ']' || c == '{'
+          || c == '}' || c == '|')
+        return false;
+      cur_lit.push_back (c);
+      i++;
+    }
+  /* Trailing literal (after the last .*).  */
+  if (cur_lit.empty ())
+    return false;
+  chain.push_back ({std::move (cur_lit), false});
+  return chain.size () >= 2;
+}
+
+static void
+compile_pattern (const std::string &pat_in)
+{
+  /* -U: convert `\n` escapes to real newlines before anything else (ripgrep).  */
+  std::string pat = opt_multiline ? multiline_preprocess_pattern (pat_in)
+                                  : pat_in;
+  const bool pat_has_nl = (pat.find ('\n') != std::string::npos);
+  g_ml_whole_buffer = false;
+  g_ml_fixed.clear ();
+
+  bool want_fixed = opt_fixed;
+  if (!want_fixed && !opt_word && !opt_line && !opt_pcre2 && !opt_multiline
+      && pattern_is_literal (pat))
+    want_fixed = true;
+
+  /* Detect \bLITERAL\b → treat as -w LITERAL (memmem fast path + word
+     boundary check, avoids slow DFA for word-boundary anchors).  */
+  if (!want_fixed && !opt_word && !opt_line && !opt_pcre2 && !opt_multiline
+      && pat.size () >= 5 /* \b + 1 char + \b */
+      && pat[0] == '\\' && pat[1] == 'b'
+      && pat[pat.size () - 2] == '\\' && pat[pat.size () - 1] == 'b')
+    {
+      std::string_view inner (pat.data () + 2, pat.size () - 4);
+      if (pattern_is_literal (inner))
+        {
+          /* Rewrite: strip \b wrappers, enable word mode.  */
+          pat.assign (inner);
+          want_fixed = true;
+          opt_word = true;
+        }
+    }
+
+  match_icase = opt_ignore_case;
+  match_words = opt_word;
+  match_lines = opt_line;
+  eolbyte = opt_null_data ? '\0' : '\n';
+  init_localeinfo (&localeinfo);
+  if (opt_word || opt_line)
+    wordinit ();
+
+  /* Build ripgrep-style SIMD/literal prefilter for all search modes.  */
+  g_prefilter = rg_simd::build_prefilter (pat, opt_ignore_case, want_fixed);
+  g_class_run = rg_simd::build_class_run_pat (pat, opt_ignore_case);
+  /* -w/-x/-U: class-run alone is not sufficient.  -P may keep class_run when
+     the whole pattern is \w{n,}/[A-Za-z]{n} etc. (faster than Pexecute).  */
+  if (opt_word || opt_line || opt_multiline)
+    g_class_run = rg_simd::ClassRunPat{};
+
+  if (want_fixed && !opt_line && !opt_pcre2 && !opt_multiline)
+    {
+      g_fixed = pat;
+      g_use_dfa = false;
+      opt_fixed = true;
+      /* -w -F: search_fixed handles word-boundary check inline via
+         find_fixed_word.  No DFA needed — line_matches_pattern also checks
+         via opt_fixed path with find_fixed_word.  */
+      return;
+    }
+
+  g_keys_storage = pat;
+  g_keys_storage.push_back ('\n');
+  idx_t keycc = static_cast<idx_t> (pat.size ());
+
+#if HAVE_LIBPCRE
+  /* -U (multiline) without -P: force PCRE2 for regex patterns so the engine
+     can see across newlines.  EGexecute is line-oriented and cannot handle
+     \n or cross-line patterns correctly.  */
+  /* -U with a literal pattern: skip PCRE2 — use direct memmem via g_ml_fixed.
+     This avoids ~45ms PCRE2 JIT compile overhead for patterns like 'void\n'.  */
+  if (opt_multiline && !opt_pcre2 && !want_fixed
+      && (pattern_is_literal (pat) || opt_fixed))
+    {
+      g_ml_fixed = pat;
+      g_pat = Fcompile (g_keys_storage.data (), keycc, 0, false);
+      g_exec = Fexecute;
+      g_use_dfa = true;
+      g_ml_whole_buffer = true;
+      return;
+    }
+
+  if ((opt_pcre2 || (opt_multiline && !want_fixed)) && !want_fixed)
+    {
+      /* PCRE2 via GNU grep pcresearch; supports (?s) via pattern or we prepend.
+         Keep SIMD prefilter (built above) so search_dfa_* can skip cold regions
+         before expensive Pexecute/JIT — same strategy as rust rg -P.
+         Use original pattern for non-PCRE2 multiline: PCRE2 handles \n natively
+         so we must NOT pass the preprocessed pattern (which has literal \n bytes
+         that Pcompile rejects as "multiple patterns").  */
+      std::string pcre_pat = (!opt_pcre2 && opt_multiline) ? pat_in : pat;
+      if (opt_multiline && opt_multiline_dotall
+          && !(pcre_pat.size () >= 2 && pcre_pat[0] == '(' && pcre_pat[1] == '?'))
+        pcre_pat = "(?s)" + pcre_pat;
+      g_keys_storage = pcre_pat;
+      g_keys_storage.push_back ('\n');
+      keycc = static_cast<idx_t> (pcre_pat.size ());
+      g_pat = Pcompile (g_keys_storage.data (), keycc, 0, false);
+      /* -U needs whole-buffer matching; line-oriented Pexecute cannot span \n.  */
+      if (opt_multiline)
+        {
+          g_exec = Pexecute_whole;
+          g_ml_whole_buffer = true;
+          /* If the preprocessed pattern is pure literal, stash it for the
+             memmem fast path in search_multiline_buffer.  */
+          if (pattern_is_literal (pat) || opt_fixed)
+            g_ml_fixed = pat;
+        }
+      else
+        g_exec = Pexecute;
+      g_use_dfa = true;
+      /* class_run stays active for whole-pattern \w{n,}/\d{n,} (faster than Pexecute).  */
+      return;
+    }
+#else
+  if (opt_pcre2 && !opt_no_messages)
+    fprintf (stderr, "%s: warning: --pcre2 requested but this build lacks PCRE2; using GNU DFA\n",
+             g_prog);
+#endif
+
+  if (want_fixed || pattern_is_literal (pat))
+    {
+      g_pat = Fcompile (g_keys_storage.data (), keycc, 0, false);
+      g_exec = Fexecute;
+      g_use_dfa = true;
+      /* Embedded newline in -U fixed pattern: whole-buffer + start_ptr.  */
+      if (opt_multiline && pat_has_nl)
+        g_ml_whole_buffer = true;
+      if (!opt_word && !opt_line && !opt_multiline)
+        {
+          g_fixed = pat;
+          g_use_dfa = false;
+          opt_fixed = true;
+        }
+    }
+  else
+    {
+      g_pat = GEAcompile (g_keys_storage.data (), keycc, RE_SYNTAX_EGREP, false);
+      g_exec = EGexecute;
+      g_use_dfa = true;
+      if (opt_multiline && pat_has_nl)
+        g_ml_whole_buffer = true;
+      /* Dual-literal fast path: detect `literal .* literal` and bypass DFA.
+         Only when no -w/-x/-U modifiers that change line semantics.  */
+      if (!opt_word && !opt_line && !opt_multiline)
+        {
+          if (try_parse_lit_chain (pat, g_lit_chain))
+            g_lit_chain_active = true;
+        }
+    }
+}
+
+/* ---------- output ---------- */
+
+static bool
+want_filename (const char *path)
+{
+  return opt_with_filename && !opt_no_filename && path && !str_eq (path, "-");
+}
+
+/* Thread-local output scratch: amortize putchar/printf; batch under lock.
+   Uses a raw char buffer to avoid std::string per-append overhead
+   (capacity check + ABI call).  Grows via realloc if needed.  */
+struct OutBuf {
+  char *buf = nullptr;
+  size_t pos = 0;
+  size_t cap = 0;
+  static constexpr size_t INIT_CAP = 1u << 17; /* 128 KiB */
+
+  void clear () { pos = 0; }
+  void ensure_cap ()
+  {
+    if (__builtin_expect (!buf, 0))
+      {
+        buf = static_cast<char *> (std::malloc (INIT_CAP));
+        cap = INIT_CAP;
+      }
+  }
+  void grow (size_t need)
+  {
+    size_t nc = cap ? cap * 2 : INIT_CAP;
+    while (nc < need)
+      nc *= 2;
+    buf = static_cast<char *> (std::realloc (buf, nc));
+    cap = nc;
+  }
+  void append (const char *p, size_t n)
+  {
+    if (__builtin_expect (pos + n > cap, 0))
+      grow (pos + n);
+    std::memcpy (buf + pos, p, n);
+    pos += n;
+  }
+  void append (const char *p)
+  {
+    if (p)
+      {
+        size_t n = std::strlen (p);
+        append (p, n);
+      }
+  }
+  void append (char c)
+  {
+    if (__builtin_expect (pos >= cap, 0))
+      grow (pos + 1);
+    buf[pos++] = c;
+  }
+  void append_int (intmax_t v)
+  {
+    char tmp[24];
+    char *p = tmp + sizeof tmp;
+    bool neg = v < 0;
+    uintmax_t u = neg ? static_cast<uintmax_t> (-v) : static_cast<uintmax_t> (v);
+    do
+      { *--p = '0' + static_cast<char> (u % 10); u /= 10; }
+    while (u);
+    if (neg) *--p = '-';
+    size_t n = static_cast<size_t> (tmp + sizeof tmp - p);
+    append (p, n);
+  }
+  bool empty () const { return pos == 0; }
+  const char *data () const { return buf; }
+  size_t size () const { return pos; }
+  void flush_locked ()
+  {
+    if (pos)
+      {
+        /* We already hold g_out_mu; skip stdio's redundant internal lock.
+           fwrite_unlocked is a glibc/POSIX extension.  */
+#if defined(__GLIBC__)
+        fwrite_unlocked (buf, 1, pos, stdout);
+#else
+        fwrite (buf, 1, pos, stdout);
+#endif
+        pos = 0;
+      }
+  }
+  /* 128 KiB batch: fewer locks/syscalls under high-output modes (-n, -v).  */
+  bool should_flush () const { return pos > INIT_CAP; }
+};
+static thread_local OutBuf tls_obuf;
+
+/* Flush TLS output buffer under the global output lock.  */
+static void
+out_flush_tls ()
+{
+  if (tls_obuf.empty ())
+    return;
+  std::lock_guard<std::mutex> lock (g_out_mu);
+  tls_obuf.flush_locked ();
+}
+
+/* Append a complete line (incl. newline) to TLS buf; flush in batches.  */
+static void
+out_batch_line (const char *data, size_t n)
+{
+  tls_obuf.append (data, n);
+  if (tls_obuf.should_flush ())
+    out_flush_tls ();
+}
+
+/* Minimal JSON string escape into OutBuf.  */
+static void
+json_escape_append (OutBuf &ob, const char *s, size_t n)
+{
+  ob.append ('"');
+  for (size_t i = 0; i < n; i++)
+    {
+      unsigned char c = static_cast<unsigned char> (s[i]);
+      switch (c)
+        {
+        case '"': ob.append ("\\\"", 2); break;
+        case '\\': ob.append ("\\\\", 2); break;
+        case '\n': ob.append ("\\n", 2); break;
+        case '\r': ob.append ("\\r", 2); break;
+        case '\t': ob.append ("\\t", 2); break;
+        default:
+          if (c < 0x20)
+            {
+              char u[8];
+              snprintf (u, sizeof u, "\\u%04x", c);
+              ob.append (u, 6);
+            }
+          else
+            ob.append (static_cast<char> (c));
+        }
+    }
+  ob.append ('"');
+}
+
+static void
+json_escape_append_cstr (OutBuf &ob, const char *s)
+{
+  json_escape_append (ob, s, s ? std::strlen (s) : 0);
+}
+
+/* Back-compat: write directly to stdout (non-hot paths).  */
+static void
+json_escape_write (const char *s, size_t n)
+{
+  OutBuf &ob = tls_obuf;
+  size_t mark = ob.size ();
+  json_escape_append (ob, s, n);
+  fwrite (ob.data () + mark, 1, ob.size () - mark, stdout);
+  ob.pos = mark;
+}
+
+static void
+json_escape_cstr (const char *s)
+{
+  json_escape_write (s, s ? std::strlen (s) : 0);
+}
+
+static const char *
+json_path_label (const char *path)
+{
+  if (!path || !*path || str_eq (path, "-"))
+    return "<stdin>";
+  return path;
+}
+
+static void
+json_emit_elapsed_ob (OutBuf &ob, intmax_t nanos)
+{
+  intmax_t secs = nanos / 1000000000LL;
+  intmax_t sub = nanos % 1000000000LL;
+  char human[64];
+  format_human_dur (nanos, human, sizeof human);
+  ob.append ("\"elapsed\":{\"secs\":", 18);
+  ob.append_int (secs);
+  ob.append (",\"nanos\":", 9);
+  ob.append_int (sub);
+  ob.append (",\"human\":", 9);
+  json_escape_append_cstr (ob, human);
+  ob.append ('}');
+}
+
+static void
+json_emit_elapsed (intmax_t nanos)
+{
+  OutBuf &ob = tls_obuf;
+  size_t mark = ob.size ();
+  json_emit_elapsed_ob (ob, nanos);
+  fwrite (ob.data () + mark, 1, ob.size () - mark, stdout);
+  ob.pos = mark;
+}
+
+static void
+json_emit_begin (const char *path)
+{
+  if (!opt_json)
+    return;
+  OutBuf &ob = tls_obuf;
+  ob.append ("{\"type\":\"begin\",\"data\":{\"path\":{\"text\":", 41);
+  json_escape_append_cstr (ob, json_path_label (path));
+  ob.append ("}}}\n", 4);
+}
+
+static void
+json_emit_line_event (const char *type, const char *path, intmax_t lno, intmax_t abs_off,
+                      const char *line, size_t llen, intmax_t so, intmax_t eo, bool with_sub)
+{
+  OutBuf &ob = tls_obuf;
+  ob.append ("{\"type\":\"", 9);
+  ob.append (type);
+  ob.append ("\",\"data\":{\"path\":{\"text\":", 25);
+  json_escape_append_cstr (ob, json_path_label (path));
+  ob.append ("},\"lines\":{\"text\":", 17);
+  json_escape_append (ob, line, llen);
+  ob.append ("},\"line_number\":", 15);
+  ob.append_int (lno);
+  ob.append (",\"absolute_offset\":", 19);
+  ob.append_int (abs_off >= 0 ? abs_off : 0);
+  if (with_sub)
+    {
+      ob.append (",\"submatches\":[{\"match\":{\"text\":", 31);
+      if (so >= 0 && eo > so && static_cast<size_t> (eo) <= llen)
+        json_escape_append (ob, line + so, static_cast<size_t> (eo - so));
+      else
+        ob.append ("\"\"", 2);
+      ob.append ("},\"start\":", 10);
+      ob.append_int (so >= 0 ? so : 0);
+      ob.append (",\"end\":", 7);
+      ob.append_int (eo > so ? eo : 0);
+      ob.append ("}]", 2);
+    }
+  else
+    ob.append (",\"submatches\":[]", 16);
+  ob.append ("}}\n", 3);
+}
+
+static void
+json_emit_match (const char *path, intmax_t lno, intmax_t abs_off,
+                 const char *line, size_t llen, intmax_t so, intmax_t eo)
+{
+  json_emit_line_event ("match", path, lno, abs_off, line, llen, so, eo, true);
+}
+
+static void
+json_emit_context (const char *path, intmax_t lno, intmax_t abs_off,
+                   const char *line, size_t llen)
+{
+  json_emit_line_event ("context", path, lno, abs_off, line, llen, 0, 0, false);
+}
+
+static void
+json_emit_end (const char *path, intmax_t matched_lines, intmax_t matches,
+               intmax_t bytes_searched, intmax_t search_nanos)
+{
+  OutBuf &ob = tls_obuf;
+  ob.append ("{\"type\":\"end\",\"data\":{\"path\":{\"text\":", 39);
+  json_escape_append_cstr (ob, json_path_label (path));
+  intmax_t swm = matched_lines > 0 ? 1 : 0;
+  intmax_t bp = stat_bytes_printed.load (std::memory_order_relaxed);
+  ob.append ("},\"binary_offset\":null,\"stats\":{", 33);
+  json_emit_elapsed_ob (ob, search_nanos);
+  ob.append (",\"searches\":1,\"searches_with_match\":", 35);
+  ob.append_int (swm);
+  ob.append (",\"bytes_searched\":", 17);
+  ob.append_int (bytes_searched);
+  ob.append (",\"bytes_printed\":", 16);
+  ob.append_int (bp);
+  ob.append (",\"matched_lines\":", 16);
+  ob.append_int (matched_lines);
+  ob.append (",\"matches\":", 11);
+  ob.append_int (matches);
+  ob.append ("}}}\n", 4);
+}
+
+static void
+json_emit_summary (intmax_t matched_lines, intmax_t matches, intmax_t bytes_searched,
+                   intmax_t searches, intmax_t searches_with_match, intmax_t total_nanos,
+                   intmax_t search_nanos)
+{
+  intmax_t bp = stat_bytes_printed.load (std::memory_order_relaxed);
+  intmax_t tsecs = total_nanos / 1000000000LL;
+  intmax_t tsub = total_nanos % 1000000000LL;
+  char thuman[64];
+  format_human_dur (total_nanos, thuman, sizeof thuman);
+  fputs ("{\"type\":\"summary\",\"data\":{\"elapsed_total\":{\"human\":", stdout);
+  json_escape_cstr (thuman);
+  printf (",\"nanos\":%" PRIdMAX ",\"secs\":%" PRIdMAX "},\"stats\":{\"bytes_printed\":%"
+          PRIdMAX ",\"bytes_searched\":%" PRIdMAX ",",
+          tsub, tsecs, bp, bytes_searched);
+  json_emit_elapsed (search_nanos);
+  printf (",\"matched_lines\":%" PRIdMAX ",\"matches\":%" PRIdMAX ",\"searches\":%" PRIdMAX
+          ",\"searches_with_match\":%" PRIdMAX "}}}\n",
+          matched_lines, matches, searches, searches_with_match);
+  maybe_flush ();
+}
+
+static thread_local intmax_t tls_last_printed_lno = -2; /* for context separators */
+static thread_local bool tls_file_json_begun = false;
+
+static void
+print_prefix (const char *path, intmax_t lno, bool is_match_line, intmax_t byte_off)
+{
+  const char *fsep = is_match_line ? opt_field_match_sep : opt_field_context_sep;
+  if (!fsep)
+    fsep = is_match_line ? ":" : "-";
+  if (want_filename (path) && !opt_heading)
+    {
+      color_on (col_path);
+      c_puts (path);
+      color_off ();
+      if (!opt_null)
+        c_puts (fsep);
+      else
+        c_putc ('\0');
+    }
+  else if (want_filename (path) && opt_heading)
+    ; /* path printed once as heading */
+  if (opt_byte_offset && byte_off >= 0)
+    {
+      color_on (col_line);
+      printf ("%" PRIdMAX, byte_off);
+      color_off ();
+      c_puts (fsep);
+    }
+  if (opt_line_number)
+    {
+      color_on (col_line);
+      printf ("%" PRIdMAX, lno);
+      color_off ();
+      c_puts (fsep);
+    }
+}
+
+static void
+write_line_highlighted (const char *line, size_t len, intmax_t so, intmax_t eo)
+{
+  if (opt_max_columns > 0 && static_cast<intmax_t> (len) > opt_max_columns)
+    {
+      if (opt_max_columns_preview)
+        {
+          size_t show = static_cast<size_t> (opt_max_columns);
+          c_write (line, show);
+          c_puts (" [... omitted end of long line]");
+          if (!len || line[len - 1] != '\n')
+            c_putc ('\n');
+        }
+      return; /* omit line entirely without preview */
+    }
+  if (opt_replace && so >= 0 && eo > so)
+    {
+      /* -r: print prefix + replacement + suffix (single occurrence).  */
+      c_write (line, static_cast<size_t> (so));
+      color_on (col_match);
+      c_puts (opt_replace);
+      color_off ();
+      size_t tail_off = static_cast<size_t> (eo);
+      if (tail_off < len)
+        c_write (line + tail_off, len - tail_off);
+      if (!len || line[len - 1] != '\n')
+        c_putc ('\n');
+      return;
+    }
+  if (g_use_color && so >= 0 && eo > so && static_cast<size_t> (eo) <= len)
+    {
+      c_write (line, static_cast<size_t> (so));
+      color_on (col_match);
+      c_write (line + so, static_cast<size_t> (eo - so));
+      color_off ();
+      if (static_cast<size_t> (eo) < len)
+        c_write (line + eo, len - static_cast<size_t> (eo));
+      if (!len || line[len - 1] != '\n')
+        c_putc ('\n');
+    }
+  else
+    {
+      c_write (line, len);
+      if (!len || line[len - 1] != '\n')
+        c_putc ('\n');
+    }
+}
+
+/* abs_off: byte offset of line start in file buffer; -1 if unknown.  */
+static void
+print_match_line (const char *path, intmax_t lno, intmax_t col,
+                  const char *line, size_t len, intmax_t so, intmax_t eo,
+                  intmax_t abs_off = -1)
+{
+  /* Fast path: build line in TLS (optionally with color SGR), flush in batches.
+     Handles heading, byte-offset, and replace inline.  Skips context/json/
+     vimgrep/trim/passthru which need more state.  */
+  const bool batchable = !opt_json && !opt_vimgrep
+                         && !opt_column && !opt_only_matching
+                         && opt_context_before <= 0
+                         && opt_context_after <= 0 && !opt_passthru
+                         && !opt_max_columns && !opt_trim;
+  if (batchable)
+    {
+      const bool cpath = g_use_color && col_path_len;
+      const bool clno  = g_use_color && col_line_len;
+      const bool cmatch = g_use_color && col_match_len;
+      const bool wfn = want_filename (path);
+      const size_t plen = wfn ? std::strlen (path) : 0;
+      /* --heading: emit path once as heading before first match in file.  */
+      if (opt_heading && wfn
+          && (tls_last_printed_lno < 0 || tls_last_printed_lno == -2))
+        {
+          if (cpath)
+            tls_obuf.append (col_path, col_path_len);
+          tls_obuf.append (path, plen);
+          if (cpath)
+            tls_obuf.append (col_reset, col_reset_len);
+          tls_obuf.append ('\n');
+        }
+      if (wfn && !opt_heading)
+        {
+          if (cpath)
+            tls_obuf.append (col_path, col_path_len);
+          tls_obuf.append (path, plen);
+          if (cpath)
+            tls_obuf.append (col_reset, col_reset_len);
+          tls_obuf.append (opt_null ? '\0' : ':');
+        }
+      if (opt_byte_offset && abs_off >= 0)
+        {
+          if (clno)
+            tls_obuf.append (col_line, col_line_len);
+          tls_obuf.append_int (abs_off);
+          if (clno)
+            tls_obuf.append (col_reset, col_reset_len);
+          tls_obuf.append (':');
+        }
+      if (opt_line_number)
+        {
+          if (clno)
+            tls_obuf.append (col_line, col_line_len);
+          tls_obuf.append_int (lno);
+          if (clno)
+            tls_obuf.append (col_reset, col_reset_len);
+          tls_obuf.append (':');
+        }
+      if (opt_replace && so >= 0 && eo > so)
+        {
+          /* -r: prefix + replacement + suffix.  */
+          if (so > 0)
+            tls_obuf.append (line, static_cast<size_t> (so));
+          if (cmatch)
+            tls_obuf.append (col_match, col_match_len);
+          tls_obuf.append (opt_replace, opt_replace_len);
+          if (cmatch)
+            tls_obuf.append (col_reset, col_reset_len);
+          size_t tail = static_cast<size_t> (eo);
+          if (tail < len)
+            tls_obuf.append (line + tail, len - tail);
+        }
+      else if (cmatch && so >= 0 && eo > so && static_cast<size_t> (eo) <= len)
+        {
+          if (so > 0)
+            tls_obuf.append (line, static_cast<size_t> (so));
+          tls_obuf.append (col_match, col_match_len);
+          tls_obuf.append (line + so, static_cast<size_t> (eo - so));
+          tls_obuf.append (col_reset, col_reset_len);
+          if (static_cast<size_t> (eo) < len)
+            tls_obuf.append (line + eo, len - static_cast<size_t> (eo));
+        }
+      else
+        tls_obuf.append (line, len);
+      if (!len || line[len - 1] != '\n')
+        tls_obuf.append ('\n');
+      tls_last_printed_lno = lno;
+      if (tls_obuf.should_flush ())
+        out_flush_tls ();
+      return;
+    }
+
+  std::lock_guard<std::mutex> lock (g_out_mu);
+  if (opt_json)
+    {
+      if (!tls_file_json_begun)
+        {
+          json_emit_begin (path);
+          tls_file_json_begun = true;
+        }
+      intmax_t aoff = abs_off >= 0 ? abs_off : 0;
+      json_emit_match (path, lno, aoff, line, len, so, eo);
+      /* Batch JSON in TLS; flush only when large (was: every line).  */
+      if (tls_obuf.should_flush ())
+        tls_obuf.flush_locked ();
+      return;
+    }
+  if (opt_vimgrep)
+    {
+      printf ("%s:%" PRIdMAX ":%" PRIdMAX ":", path, lno, col > 0 ? col : 1);
+      fwrite (line, 1, len, stdout);
+      if (!len || line[len - 1] != '\n')
+        putchar ('\n');
+      maybe_flush ();
+      return;
+    }
+  if (opt_heading && want_filename (path)
+      && (tls_last_printed_lno < 0 || tls_last_printed_lno == -2))
+    {
+      color_on (col_path);
+      c_puts (path);
+      color_off ();
+      c_putc ('\n');
+    }
+  if (opt_context_before > 0 || opt_context_after > 0 || opt_passthru)
+    {
+      if (!opt_no_context_sep && tls_last_printed_lno >= 0 && lno > tls_last_printed_lno + 1
+          && opt_context_sep && *opt_context_sep)
+        {
+          c_puts (opt_context_sep);
+          c_putc ('\n');
+        }
+    }
+  print_prefix (path, lno, true, abs_off);
+  if (opt_column && col > 0)
+    {
+      color_on (col_column);
+      printf ("%" PRIdMAX, col);
+      color_off ();
+      c_puts (opt_field_match_sep ? opt_field_match_sep : ":");
+    }
+  if (opt_only_matching && so >= 0 && eo > so)
+    {
+      color_on (col_match);
+      c_write (line + so, static_cast<size_t> (eo - so));
+      color_off ();
+      c_putc ('\n');
+    }
+  else
+    write_line_highlighted (line, len, so, eo);
+  tls_last_printed_lno = lno;
+  maybe_flush ();
+}
+
+static void
+print_context_line (const char *path, intmax_t lno, const char *line, size_t len,
+                    intmax_t abs_off = -1)
+{
+  std::lock_guard<std::mutex> lock (g_out_mu);
+  if (opt_json)
+    {
+      if (!tls_file_json_begun)
+        {
+          json_emit_begin (path);
+          tls_file_json_begun = true;
+        }
+      json_emit_context (path, lno, abs_off >= 0 ? abs_off : 0, line, len);
+      tls_obuf.flush_locked ();
+      maybe_flush ();
+      return;
+    }
+  if (!opt_no_context_sep && tls_last_printed_lno >= 0 && lno > tls_last_printed_lno + 1
+      && opt_context_sep && *opt_context_sep)
+    {
+      c_puts (opt_context_sep);
+      c_putc ('\n');
+    }
+  print_prefix (path, lno, false, abs_off);
+  write_line_highlighted (line, len, -1, -1);
+  tls_last_printed_lno = lno;
+  maybe_flush ();
+}
+
+static void
+emit_count (const char *path, intmax_t n)
+{
+  /* Format off-lock into TLS batch buffer.  */
+  char line[PATH_MAX + 48];
+  int len;
+  if (want_filename (path))
+    len = snprintf (line, sizeof line, "%s%c%" PRIdMAX "\n",
+                    path, opt_null ? '\0' : ':', n);
+  else
+    len = snprintf (line, sizeof line, "%" PRIdMAX "\n", n);
+  if (len < 0)
+    return;
+  if (static_cast<size_t> (len) >= sizeof line)
+    {
+      std::lock_guard<std::mutex> lock (g_out_mu);
+      tls_obuf.flush_locked ();
+      if (want_filename (path))
+        printf ("%s%c", path, opt_null ? '\0' : ':');
+      printf ("%" PRIdMAX "\n", n);
+      return;
+    }
+  out_batch_line (line, static_cast<size_t> (len));
+}
+
+static void
+emit_path_only (const char *path)
+{
+  size_t plen = std::strlen (path);
+  tls_obuf.append (path, plen);
+  tls_obuf.append (opt_null ? '\0' : '\n');
+  if (tls_obuf.should_flush ())
+    out_flush_tls ();
+}
+
+/* ---------- search ---------- */
+
+struct SearchResult {
+  intmax_t matches = 0;
+  bool found = false;
+};
+
+/* Split buffer into line index for context printing.
+   Only stores starts[]; line length is derived on-the-fly from
+   starts[i+1] (or end-of-buffer), halving the vector allocation.  */
+struct LineIndex {
+  std::vector<const char *> starts; /* start of each line */
+  const char *base = nullptr;
+  size_t size = 0;
+
+  void build (const char *data, size_t sz)
+  {
+    base = data;
+    size = sz;
+    starts.clear ();
+    if (!data || !sz)
+      return;
+    /* Heuristic reserve: ~40 chars/line average for source code.
+       Avoids the extra full-pass SIMD newline count just for sizing.  */
+    size_t est = sz / 40 + 1;
+    starts.reserve (est);
+    const char *p = data;
+    const char *endp = data + sz;
+    while (p < endp)
+      {
+        starts.push_back (p);
+        const void *nl = memchr (p, '\n', static_cast<size_t> (endp - p));
+        if (nl)
+          p = static_cast<const char *> (nl) + 1;
+        else
+          break;
+      }
+  }
+
+  size_t count () const { return starts.size (); }
+
+  /* Line length (incl. newline if present) for line i.  */
+  size_t len (size_t i) const
+  {
+    size_t n = starts.size ();
+    if (i + 1 < n)
+      return static_cast<size_t> (starts[i + 1] - starts[i]);
+    return static_cast<size_t> (base + size - starts[i]);
+  }
+
+  /* Line number (1-based) containing offset, or 0.  */
+  intmax_t line_of_offset (size_t off) const
+  {
+    if (!base || off > size)
+      return 0;
+    const char *pos = base + off;
+    /* binary search starts */
+    size_t lo = 0, hi = starts.size ();
+    while (lo < hi)
+      {
+        size_t mid = lo + (hi - lo) / 2;
+        if (starts[mid] <= pos)
+          lo = mid + 1;
+        else
+          hi = mid;
+      }
+    return lo == 0 ? 1 : static_cast<intmax_t> (lo);
+  }
+
+  /* 0-based line index containing pointer `pos`.  Starts search at `hint`.
+     Returns nlines if pos is out of range.  */
+  size_t index_of_ptr (const char *pos, size_t hint = 0) const
+  {
+    if (starts.empty () || pos < starts[0])
+      return starts.size ();
+    /* Linear probe from hint first (good for sequential scanning).  */
+    size_t n = starts.size ();
+    if (hint < n && starts[hint] <= pos
+        && (hint + 1 >= n || starts[hint + 1] > pos))
+      return hint;
+    /* Binary search.  */
+    size_t lo = 0, hi = n;
+    while (lo < hi)
+      {
+        size_t mid = lo + (hi - lo) / 2;
+        if (mid + 1 < n && starts[mid + 1] <= pos)
+          lo = mid + 1;
+        else if (starts[mid] > pos)
+          hi = mid;
+        else
+          return mid;
+      }
+    return lo < n ? lo : n;
+  }
+};
+
+/* TLS recycled vectors for search_lines_with_context: avoid per-file
+   heap alloc of is_match/print_line/line_spans (2M+ entries each).  */
+static thread_local std::vector<uint8_t> tls_is_match;
+static thread_local std::vector<uint8_t> tls_print_line;
+static thread_local std::vector<intmax_t> tls_line_spans;
+static thread_local LineIndex tls_line_idx;
+
+/* Forward declaration (defined with search_lit_chain below).  */
+static inline bool
+lit_chain_line_match (const char *ls, size_t llen, bool icase,
+                      intmax_t *so, intmax_t *eo);
+
+static inline const char *find_fixed_word (const char *, size_t, const char *, const char *);
+
+static bool
+line_matches_pattern (const char *ls, size_t llen)
+{
+  if (opt_fixed && !g_fixed.empty ())
+    return find_fixed_word (ls, llen, ls, ls + llen) != nullptr;
+  if (g_lit_chain_active)
+    {
+      intmax_t so, eo;
+      return lit_chain_line_match (ls, llen, opt_ignore_case, &so, &eo);
+    }
+  if (g_class_run.active ())
+    return rg_simd::scan_class_run (g_class_run, ls, llen, false, true, 1) > 0;
+  if (g_prefilter.kind == rg_simd::PrefKind::LitsAny)
+    {
+      size_t mlen = 0;
+      return rg_simd::lits_any_find_first (g_prefilter, ls, ls + llen, &mlen) < ls + llen;
+    }
+  if (g_use_dfa && g_exec && g_pat)
+    {
+      idx_t ms = 0;
+      ptrdiff_t mo = g_exec (g_pat, ls, static_cast<idx_t> (llen), &ms, nullptr);
+      return mo >= 0;
+    }
+  return false;
+}
+
+static size_t
+trim_line_bounds (const char *ls, size_t llen, size_t *out_off)
+{
+  size_t off = 0;
+  size_t mlen = llen;
+  if (mlen && ls[mlen - 1] == '\n')
+    mlen--;
+  if (opt_crlf && mlen && ls[mlen - 1] == '\r')
+    mlen--;
+  if (opt_trim)
+    {
+      while (off < mlen && (ls[off] == ' ' || ls[off] == '\t'))
+        off++;
+      while (mlen > off && (ls[mlen - 1] == ' ' || ls[mlen - 1] == '\t'))
+        mlen--;
+    }
+  *out_off = off;
+  return mlen - off;
+}
+
+static void
+find_match_span (const char *ls, size_t mlen, intmax_t *so, intmax_t *eo, intmax_t *nspans)
+{
+  *so = 0;
+  *eo = static_cast<intmax_t> (mlen);
+  *nspans = 0;
+  if (opt_fixed && !g_fixed.empty ())
+    {
+      const char *cur = ls;
+      size_t left = mlen;
+      while (left >= g_fixed.size ())
+        {
+          const char *m = find_fixed_word (cur, left, ls, ls + mlen);
+          if (!m)
+            break;
+          (*nspans)++;
+          if (*nspans == 1)
+            {
+              *so = static_cast<intmax_t> (m - ls);
+              *eo = *so + static_cast<intmax_t> (g_fixed.size ());
+            }
+          size_t step = static_cast<size_t> (m - cur) + 1;
+          if (step > left)
+            break;
+          cur += step;
+          left -= step;
+        }
+      return;
+    }
+  if (g_lit_chain_active)
+    {
+      intmax_t cso, ceo;
+      if (lit_chain_line_match (ls, mlen, opt_ignore_case, &cso, &ceo))
+        {
+          *so = cso;
+          *eo = ceo;
+          *nspans = 1;
+        }
+      return;
+    }
+  if (g_use_dfa && g_exec && g_pat)
+    {
+      idx_t off = 0;
+      while (off < static_cast<idx_t> (mlen))
+        {
+          idx_t ms = 0;
+          ptrdiff_t mo = g_exec (g_pat, ls + off, static_cast<idx_t> (mlen) - off, &ms, nullptr);
+          if (mo < 0)
+            break;
+          (*nspans)++;
+          if (*nspans == 1)
+            {
+              *so = off + mo;
+              *eo = *so + static_cast<intmax_t> (ms);
+            }
+          off += mo + (ms ? ms : 1);
+        }
+    }
+  else if (g_class_run.active ())
+    {
+      intmax_t cso = 0, ceo = 0;
+      if (rg_simd::find_class_run_span (g_class_run, ls, mlen, &cso, &ceo))
+        {
+          *so = cso;
+          *eo = ceo;
+          *nspans = 1;
+        }
+    }
+}
+
+/* Line-oriented search with -A/-B/-C context (ripgrep/grep style).  */
+static SearchResult
+search_lines_with_context (const char *path, const char *data, size_t size)
+{
+  SearchResult r{};
+  tls_last_printed_lno = -2;
+  tls_file_json_begun = false;
+  tls_search_t0 = Clock::now ();
+  intmax_t total_spans = 0;
+
+  LineIndex &idx = tls_line_idx;
+  idx.build (data, size);
+  const size_t nlines = idx.count ();
+  if (!nlines)
+    {
+      if (opt_count && opt_include_zero)
+        emit_count (path, 0);
+      return r;
+    }
+
+  /* Recycle TLS vectors: resize + zero avoids per-file heap alloc.  */
+  tls_is_match.resize (nlines);
+  std::memset (tls_is_match.data (), 0, nlines);
+  auto &is_match = tls_is_match;
+  const bool need_spans = opt_count_matches || opt_stats;
+  if (need_spans)
+    {
+      tls_line_spans.resize (nlines);
+      std::memset (tls_line_spans.data (), 0, nlines * sizeof (intmax_t));
+    }
+  auto &line_spans = tls_line_spans;
+
+  /* Prefilter-skip matching: for fixed strings and lit-chains, use memmem
+     to jump directly to candidate lines rather than checking every line.
+     Works for both normal and inverted (-v) modes: in invert mode, we mark
+     positive matches then flip the array, turning O(2M×line_matches) into
+     O(~1000×memmem) for the common case of few-matches-many-lines.  */
+  const bool can_skip = !opt_stop_on_nonmatch
+                        && ((!g_fixed.empty () && opt_fixed)
+                            || g_lit_chain_active
+                            || g_prefilter.kind == rg_simd::PrefKind::LitsAny);
+  if (can_skip)
+    {
+      const char *cur = data;
+      const char *end = data + size;
+      size_t hint = 0;
+      while (cur < end)
+        {
+          const char *hit_pos = nullptr;
+          /* Find next candidate position using fastest available scanner.  */
+          if (!g_fixed.empty () && opt_fixed)
+            {
+              hit_pos = opt_ignore_case
+                ? rg_simd::memmem_icase_fast (cur, static_cast<size_t> (end - cur),
+                                              g_fixed.data (), g_fixed.size ())
+                : rg_simd::memmem_fast (cur, static_cast<size_t> (end - cur),
+                                        g_fixed.data (), g_fixed.size ());
+            }
+          else if (g_lit_chain_active)
+            {
+              const auto &lead = g_lit_chain[0];
+              hit_pos = opt_ignore_case
+                ? rg_simd::memmem_icase_fast (cur, static_cast<size_t> (end - cur),
+                                              lead.lit.data (), lead.lit.size ())
+                : rg_simd::memmem_fast (cur, static_cast<size_t> (end - cur),
+                                        lead.lit.data (), lead.lit.size ());
+            }
+          else if (g_prefilter.kind == rg_simd::PrefKind::LitsAny)
+            {
+              size_t mlen = 0;
+              const char *p = rg_simd::lits_any_find_first (g_prefilter, cur, end, &mlen);
+              hit_pos = (p < end) ? p : nullptr;
+            }
+          if (!hit_pos)
+            break;
+          /* Find which line this hit is on.  */
+          size_t li = idx.index_of_ptr (hit_pos, hint);
+          if (li >= nlines)
+            break;
+          hint = li;
+          const size_t li_len = idx.len (li);
+          if (!is_match[li])
+            {
+              const char *ls = idx.starts[li];
+              size_t toff = 0;
+              size_t ml = trim_line_bounds (ls, li_len, &toff);
+              const char *mp = ls + toff;
+              bool ok = line_matches_pattern (mp, ml);
+              if (ok)
+                {
+                  is_match[li] = 1;
+                  r.found = true;
+                  r.matches++;
+                  if (need_spans)
+                    {
+                      intmax_t so, eo, ns;
+                      find_match_span (mp, ml, &so, &eo, &ns);
+                      if (ns == 0)
+                        ns = 1;
+                      line_spans[li] = ns;
+                      total_spans += ns;
+                    }
+                }
+            }
+          /* Skip past this line.  */
+          const char *line_end = idx.starts[li] + li_len;
+          cur = (line_end <= cur) ? cur + 1 : line_end;
+        }
+      /* Invert mode: flip is_match so marked=positive → is_match=inverted.
+         XOR-flip all entries branchlessly.  Count = nlines - positive_hits.  */
+      if (opt_invert)
+        {
+          intmax_t pos_hits = r.matches;
+          /* Branchless XOR flip: toggle every byte 0↔1.  */
+          uint8_t *p = is_match.data ();
+          size_t n = nlines;
+          /* SIMD-width XOR for bulk.  */
+          size_t k = 0;
+          const uint64_t ones8 = 0x0101010101010101ULL;
+          for (; k + 8 <= n; k += 8)
+            {
+              uint64_t v;
+              std::memcpy (&v, p + k, 8);
+              v ^= ones8;
+              std::memcpy (p + k, &v, 8);
+            }
+          for (; k < n; k++)
+            p[k] ^= 1;
+          r.matches = static_cast<intmax_t> (nlines) - pos_hits;
+          r.found = r.matches > 0;
+        }
+    }
+  else
+    {
+      for (size_t i = 0; i < nlines; i++)
+        {
+          const char *ls = idx.starts[i];
+          size_t llen = idx.len(i);
+          size_t toff = 0;
+          size_t mlen = trim_line_bounds (ls, llen, &toff);
+          const char *mp = ls + toff;
+          bool hit = line_matches_pattern (mp, mlen);
+          if (opt_invert)
+            hit = !hit;
+          if (hit)
+            {
+              is_match[i] = 1;
+              r.found = true;
+              r.matches++;
+              if (need_spans)
+                {
+                  intmax_t so, eo, ns;
+                  find_match_span (mp, mlen, &so, &eo, &ns);
+                  if (ns == 0)
+                    ns = 1;
+                  line_spans[i] = ns;
+                  total_spans += ns;
+                }
+            }
+          else if (opt_stop_on_nonmatch && r.found)
+            break;
+        }
+    }
+
+  if (opt_quiet || opt_files_with_matches)
+    {
+      if (r.found && opt_files_with_matches)
+        emit_path_only (path);
+      return r;
+    }
+  if (opt_files_without_match)
+    {
+      if (!r.found)
+        emit_path_only (path);
+      return r;
+    }
+  if (opt_count || opt_count_matches)
+    {
+      intmax_t n = opt_count_matches ? total_spans : r.matches;
+      if (n > 0 || opt_include_zero)
+        emit_count (path, n);
+      if (__builtin_expect (opt_stats, 0))
+        {
+          stat_lines_matched.fetch_add (r.matches, std::memory_order_relaxed);
+          stat_match_spans.fetch_add (total_spans, std::memory_order_relaxed);
+        }
+      return r;
+    }
+
+  /* Compute print_line on-the-fly from is_match + context ranges.
+     No-context fast path: when no -A/-B/-C and no --passthru, print_line
+     is identical to is_match — skip the separate TLS array entirely.  */
+  const intmax_t ctx_before = opt_context_before > 0 ? opt_context_before : 0;
+  const intmax_t ctx_after = opt_context_after > 0 ? opt_context_after : 0;
+  const bool have_context = ctx_before > 0 || ctx_after > 0 || opt_passthru;
+  uint8_t *print_line;
+  if (!have_context)
+    {
+      /* No context: print_line == is_match, zero extra work.  */
+      print_line = is_match.data ();
+    }
+  else
+    {
+      tls_print_line.resize (nlines);
+      print_line = tls_print_line.data ();
+      if (opt_passthru)
+        std::memset (print_line, 1, nlines);
+      else
+        {
+          std::memset (print_line, 0, nlines);
+          /* Mark context ranges: jump between matches with memchr (skip
+             large non-matching gaps in 2M-line files).  */
+          {
+            size_t i = 0;
+            while (i < nlines)
+              {
+                if (!is_match[i])
+                  {
+                    /* Skip to next match using memchr (fast for large gaps).  */
+                    const void *next = memchr (is_match.data () + i, 1, nlines - i);
+                    if (!next)
+                      break;
+                    i = static_cast<size_t> (static_cast<const uint8_t *> (next) - is_match.data ());
+                  }
+                size_t b = i > static_cast<size_t> (ctx_before)
+                             ? i - static_cast<size_t> (ctx_before) : 0;
+                size_t a = i + static_cast<size_t> (ctx_after);
+                if (a >= nlines)
+                  a = nlines - 1;
+                std::memset (print_line + b, 1, a - b + 1);
+                i = a + 1;
+              }
+          }
+        }
+    }
+
+  /* Batchable context path: build all output in TLS buffer, single flush.
+     Avoids per-line mutex lock (print_context_line/print_match_line each
+     lock g_out_mu individually in the slow path).  */
+  const bool ctx_batch = !opt_json && !opt_vimgrep && !opt_column
+                         && !opt_only_matching && !opt_max_columns && !opt_trim;
+  const bool ctx_want_fn = want_filename (path);
+  const size_t ctx_pathlen = ctx_want_fn ? std::strlen (path) : 0;
+  const char *ctx_context_sep_str = opt_context_sep ? opt_context_sep : "--";
+  const size_t ctx_context_sep_len = std::strlen (ctx_context_sep_str);
+  const bool ctx_cpath  = g_use_color && col_path_len;
+  const bool ctx_clno   = g_use_color && col_line_len;
+  const bool ctx_cmatch = g_use_color && col_match_len;
+  /* Pre-compute field separators with lengths to avoid per-line strlen.  */
+  const char *fsep_match   = opt_field_match_sep ? opt_field_match_sep : ":";
+  const size_t fsep_match_len = std::strlen (fsep_match);
+  const char *fsep_context = opt_field_context_sep ? opt_field_context_sep : "-";
+  const size_t fsep_context_len = std::strlen (fsep_context);
+
+  intmax_t emitted = 0;
+
+  /* Bare-invert fast path: no prefix, no color, no context, no sep.
+     Emit contiguous runs of is_match=1 lines as single memcpy blocks.
+     Avoids per-line idx.len + append overhead for ~2M inverted lines.  */
+  if (opt_invert && ctx_batch && !ctx_want_fn && !opt_line_number
+      && !opt_byte_offset && !ctx_cmatch && !opt_replace && !have_context)
+    {
+      size_t i = 0;
+      while (i < nlines)
+        {
+          if (!is_match[i])
+            {
+              const void *next = memchr (is_match.data () + i, 1, nlines - i);
+              if (!next)
+                break;
+              i = static_cast<size_t> (static_cast<const uint8_t *> (next)
+                                       - is_match.data ());
+            }
+          /* Find end of contiguous is_match run.  */
+          size_t run_start = i;
+          const void *end_p = memchr (is_match.data () + i, 0, nlines - i);
+          size_t run_end = end_p
+            ? static_cast<size_t> (static_cast<const uint8_t *> (end_p)
+                                   - is_match.data ())
+            : nlines;
+          /* Clamp to max_count.  */
+          intmax_t run_count = static_cast<intmax_t> (run_end - run_start);
+          if (emitted + run_count > opt_max_count)
+            {
+              run_end = run_start + static_cast<size_t> (opt_max_count - emitted);
+              run_count = opt_max_count - emitted;
+            }
+          /* Emit entire contiguous region as single memcpy.  */
+          const char *region_start = idx.starts[run_start];
+          const char *region_end;
+          if (run_end < nlines)
+            region_end = idx.starts[run_end];
+          else
+            region_end = data + size;
+          size_t region_len = static_cast<size_t> (region_end - region_start);
+          tls_obuf.append (region_start, region_len);
+          if (tls_obuf.should_flush ())
+            out_flush_tls ();
+          emitted += run_count;
+          i = run_end;
+          if (emitted >= opt_max_count)
+            break;
+        }
+      out_flush_tls ();
+      return r;
+    }
+
+  /* Invert-print fast path: -v with line numbers / filename / byte-offset
+     but no color/replace/context.  Emits each inverted line with prefix
+     using pre-built path prefix and tight itoa, skipping find_match_span.  */
+  if (opt_invert && ctx_batch && !ctx_cmatch && !opt_replace && !have_context
+      && (ctx_want_fn || opt_line_number || opt_byte_offset))
+    {
+      const bool iv_cpath = g_use_color && col_path_len;
+      const bool iv_clno  = g_use_color && col_line_len;
+      /* Pre-build path prefix: "COLOR path COLOR_RESET :" once.  */
+      char iv_ppfx[PATH_MAX + 64];
+      size_t iv_ppfx_len = 0;
+      if (ctx_want_fn && !opt_heading)
+        {
+          char *pp = iv_ppfx;
+          if (iv_cpath)
+            { std::memcpy (pp, col_path, col_path_len); pp += col_path_len; }
+          std::memcpy (pp, path, ctx_pathlen); pp += ctx_pathlen;
+          if (iv_cpath)
+            { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+          *pp++ = ':';
+          iv_ppfx_len = static_cast<size_t> (pp - iv_ppfx);
+        }
+      /* Emit heading once if needed.  */
+      if (opt_heading && ctx_want_fn)
+        {
+          if (iv_cpath)
+            tls_obuf.append (col_path, col_path_len);
+          tls_obuf.append (path, ctx_pathlen);
+          if (iv_cpath)
+            tls_obuf.append (col_reset, col_reset_len);
+          tls_obuf.append ('\n');
+        }
+      for (size_t i = 0; i < nlines; i++)
+        {
+          if (!is_match[i])
+            continue;
+          if (emitted >= opt_max_count)
+            break;
+          const char *ls = idx.starts[i];
+          size_t llen = idx.len (i);
+          /* Path prefix.  */
+          if (iv_ppfx_len)
+            tls_obuf.append (iv_ppfx, iv_ppfx_len);
+          /* Byte-offset + line-number using stack buffer merge.  */
+          if (opt_byte_offset || opt_line_number)
+            {
+              char pfx[64];
+              char *pp = pfx;
+              auto fast_itoa = [&] (intmax_t v) {
+                char tmp[24]; char *t = tmp + sizeof tmp;
+                uintmax_t u = static_cast<uintmax_t> (v);
+                do { *--t = '0' + static_cast<char> (u % 10); u /= 10; } while (u);
+                size_t n = static_cast<size_t> (tmp + sizeof tmp - t);
+                std::memcpy (pp, t, n); pp += n;
+              };
+              if (opt_byte_offset)
+                {
+                  if (iv_clno)
+                    { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+                  fast_itoa (static_cast<intmax_t> (ls - data));
+                  if (iv_clno)
+                    { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+                  *pp++ = ':';
+                }
+              if (opt_line_number)
+                {
+                  if (iv_clno)
+                    { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+                  fast_itoa (static_cast<intmax_t> (i + 1));
+                  if (iv_clno)
+                    { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+                  *pp++ = ':';
+                }
+              tls_obuf.append (pfx, static_cast<size_t> (pp - pfx));
+            }
+          tls_obuf.append (ls, llen);
+          if (!llen || ls[llen - 1] != '\n')
+            tls_obuf.append ('\n');
+          emitted++;
+          if (tls_obuf.should_flush ())
+            out_flush_tls ();
+        }
+      out_flush_tls ();
+      return r;
+    }
+
+  /* Pre-build heading line and path prefix (avoid per-line color/path appends).
+     ctx_heading_pfx: "COLOR_PATH path COLOR_RESET \n" (emitted once per file)
+     ctx_path_match/ctx_path_context: "COLOR_PATH path COLOR_RESET sep" with
+     match vs context separator.  */
+  char ctx_heading_pfx[PATH_MAX + 64];
+  size_t ctx_heading_pfx_len = 0;
+  char ctx_path_pfx_match[PATH_MAX + 64];
+  size_t ctx_path_pfx_match_len = 0;
+  char ctx_path_pfx_context[PATH_MAX + 64];
+  size_t ctx_path_pfx_context_len = 0;
+  if (ctx_want_fn)
+    {
+      if (opt_heading)
+        {
+          char *pp = ctx_heading_pfx;
+          if (ctx_cpath)
+            { std::memcpy (pp, col_path, col_path_len); pp += col_path_len; }
+          std::memcpy (pp, path, ctx_pathlen); pp += ctx_pathlen;
+          if (ctx_cpath)
+            { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+          *pp++ = '\n';
+          ctx_heading_pfx_len = static_cast<size_t> (pp - ctx_heading_pfx);
+        }
+      if (!opt_heading)
+        {
+          /* Build match-separator variant.  */
+          {
+            char *pp = ctx_path_pfx_match;
+            if (ctx_cpath)
+              { std::memcpy (pp, col_path, col_path_len); pp += col_path_len; }
+            std::memcpy (pp, path, ctx_pathlen); pp += ctx_pathlen;
+            if (ctx_cpath)
+              { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+            if (!opt_null)
+              { std::memcpy (pp, fsep_match, fsep_match_len); pp += fsep_match_len; }
+            else
+              *pp++ = '\0';
+            ctx_path_pfx_match_len = static_cast<size_t> (pp - ctx_path_pfx_match);
+          }
+          /* Build context-separator variant.  */
+          {
+            char *pp = ctx_path_pfx_context;
+            if (ctx_cpath)
+              { std::memcpy (pp, col_path, col_path_len); pp += col_path_len; }
+            std::memcpy (pp, path, ctx_pathlen); pp += ctx_pathlen;
+            if (ctx_cpath)
+              { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+            if (!opt_null)
+              { std::memcpy (pp, fsep_context, fsep_context_len); pp += fsep_context_len; }
+            else
+              *pp++ = '\0';
+            ctx_path_pfx_context_len = static_cast<size_t> (pp - ctx_path_pfx_context);
+          }
+        }
+    }
+
+  auto ctx_emit_prefix = [&] (intmax_t lno, bool is_match_line, intmax_t abs_off) {
+    if (opt_heading && ctx_want_fn
+        && (tls_last_printed_lno < 0 || tls_last_printed_lno == -2))
+      tls_obuf.append (ctx_heading_pfx, ctx_heading_pfx_len);
+    if (ctx_want_fn && !opt_heading)
+      {
+        if (is_match_line)
+          tls_obuf.append (ctx_path_pfx_match, ctx_path_pfx_match_len);
+        else
+          tls_obuf.append (ctx_path_pfx_context, ctx_path_pfx_context_len);
+      }
+    /* Merge numeric prefix (byte-offset + line-number) into stack buffer.  */
+    if (opt_byte_offset || opt_line_number)
+      {
+        const char *fsep = is_match_line ? fsep_match : fsep_context;
+        const size_t fsep_len = is_match_line ? fsep_match_len : fsep_context_len;
+        char pfx[96];
+        char *pp = pfx;
+        auto pfx_int = [&] (intmax_t v) {
+          char tmp[24]; char *t = tmp + sizeof tmp;
+          uintmax_t u = static_cast<uintmax_t> (v);
+          do { *--t = '0' + static_cast<char> (u % 10); u /= 10; } while (u);
+          size_t n = static_cast<size_t> (tmp + sizeof tmp - t);
+          std::memcpy (pp, t, n); pp += n;
+        };
+        if (opt_byte_offset && abs_off >= 0)
+          {
+            if (ctx_clno)
+              { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+            pfx_int (abs_off);
+            if (ctx_clno)
+              { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+            std::memcpy (pp, fsep, fsep_len); pp += fsep_len;
+          }
+        if (opt_line_number)
+          {
+            if (ctx_clno)
+              { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+            pfx_int (lno);
+            if (ctx_clno)
+              { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+            std::memcpy (pp, fsep, fsep_len); pp += fsep_len;
+          }
+        tls_obuf.append (pfx, static_cast<size_t> (pp - pfx));
+      }
+  };
+
+  auto ctx_emit_sep = [&] (intmax_t lno) {
+    if (!opt_no_context_sep && tls_last_printed_lno >= 0
+        && lno > tls_last_printed_lno + 1
+        && ctx_context_sep_str && *ctx_context_sep_str)
+      {
+        tls_obuf.append (ctx_context_sep_str, ctx_context_sep_len);
+        tls_obuf.append ('\n');
+      }
+  };
+
+  for (size_t i = 0; i < nlines; )
+    {
+      if (!print_line[i])
+        {
+          /* Skip to next printable line using memchr (fast for large gaps).  */
+          const void *next = memchr (print_line + i, 1, nlines - i);
+          if (!next)
+            break;
+          i = static_cast<size_t> (static_cast<const uint8_t *> (next) - print_line);
+        }
+      if (emitted >= opt_max_count && is_match[i])
+        break;
+      const char *ls = idx.starts[i];
+      size_t llen = idx.len(i);
+      intmax_t lno = static_cast<intmax_t> (i + 1);
+      intmax_t abs_off = static_cast<intmax_t> (ls - data);
+      if (is_match[i])
+        {
+          if (ctx_batch)
+            {
+              ctx_emit_sep (lno);
+              ctx_emit_prefix (lno, true, abs_off);
+              /* Invert mode: "match" lines are non-matching, emit raw (no
+                 color, no find_match_span — the pattern doesn't appear).  */
+              if (__builtin_expect (opt_invert, 0))
+                tls_obuf.append (ls, llen);
+              else
+                {
+                  size_t toff = 0;
+                  size_t mlen = trim_line_bounds (ls, llen, &toff);
+                  const char *mp = ls + toff;
+                  intmax_t so, eo, ns;
+                  find_match_span (mp, mlen, &so, &eo, &ns);
+                  so += static_cast<intmax_t> (toff);
+                  eo += static_cast<intmax_t> (toff);
+                  if (opt_replace && so >= 0 && eo > so)
+                    {
+                      if (so > 0)
+                        tls_obuf.append (ls, static_cast<size_t> (so));
+                      if (ctx_cmatch)
+                        tls_obuf.append (col_match, col_match_len);
+                      tls_obuf.append (opt_replace, opt_replace_len);
+                      if (ctx_cmatch)
+                        tls_obuf.append (col_reset, col_reset_len);
+                      size_t tail = static_cast<size_t> (eo);
+                      if (tail < llen)
+                        tls_obuf.append (ls + tail, llen - tail);
+                    }
+                  else if (ctx_cmatch && so >= 0 && eo > so
+                           && static_cast<size_t> (eo) <= llen)
+                    {
+                      if (so > 0)
+                        tls_obuf.append (ls, static_cast<size_t> (so));
+                      tls_obuf.append (col_match, col_match_len);
+                      tls_obuf.append (ls + so, static_cast<size_t> (eo - so));
+                      tls_obuf.append (col_reset, col_reset_len);
+                      if (static_cast<size_t> (eo) < llen)
+                        tls_obuf.append (ls + eo, llen - static_cast<size_t> (eo));
+                    }
+                  else
+                    tls_obuf.append (ls, llen);
+                }
+              if (!llen || ls[llen - 1] != '\n')
+                tls_obuf.append ('\n');
+              tls_last_printed_lno = lno;
+            }
+          else
+            {
+              if (__builtin_expect (opt_invert, 0))
+                {
+                  /* Invert: no pattern match to highlight.  */
+                  print_match_line (path, lno, 0, ls, llen, -1, -1, abs_off);
+                }
+              else
+                {
+                  size_t toff = 0;
+                  size_t mlen = trim_line_bounds (ls, llen, &toff);
+                  const char *mp = ls + toff;
+                  intmax_t so, eo, ns;
+                  find_match_span (mp, mlen, &so, &eo, &ns);
+                  so += static_cast<intmax_t> (toff);
+                  eo += static_cast<intmax_t> (toff);
+                  print_match_line (path, lno, so + 1, ls, llen, so, eo, abs_off);
+                }
+            }
+          if (__builtin_expect (opt_stats, 0))
+            {
+              stat_lines_matched.fetch_add (1, std::memory_order_relaxed);
+              if (need_spans)
+                stat_match_spans.fetch_add (line_spans[i], std::memory_order_relaxed);
+            }
+          emitted++;
+          if (emitted >= opt_max_count)
+            {
+              size_t a = i + static_cast<size_t> (opt_context_after);
+              if (a >= nlines)
+                a = nlines - 1;
+              for (size_t j = i + 1; j <= a; j++)
+                {
+                  if (!print_line[j] || is_match[j])
+                    continue;
+                  intmax_t jlno = static_cast<intmax_t> (j + 1);
+                  intmax_t ja = static_cast<intmax_t> (idx.starts[j] - data);
+                  if (ctx_batch)
+                    {
+                      size_t jlen = idx.len (j);
+                      ctx_emit_sep (jlno);
+                      ctx_emit_prefix (jlno, false, ja);
+                      tls_obuf.append (idx.starts[j], jlen);
+                      if (!jlen || idx.starts[j][jlen - 1] != '\n')
+                        tls_obuf.append ('\n');
+                      tls_last_printed_lno = jlno;
+                    }
+                  else
+                    print_context_line (path, jlno, idx.starts[j], idx.len (j), ja);
+                }
+              break;
+            }
+        }
+      else
+        {
+          if (ctx_batch)
+            {
+              ctx_emit_sep (lno);
+              ctx_emit_prefix (lno, false, abs_off);
+              tls_obuf.append (ls, llen);
+              if (!llen || ls[llen - 1] != '\n')
+                tls_obuf.append ('\n');
+              tls_last_printed_lno = lno;
+              if (tls_obuf.should_flush ())
+                out_flush_tls ();
+            }
+          else
+            print_context_line (path, lno, ls, llen, abs_off);
+        }
+      i++;
+    }
+  if (ctx_batch)
+    out_flush_tls ();
+
+  if (opt_json)
+    {
+      std::lock_guard<std::mutex> lock (g_out_mu);
+      if (tls_file_json_begun || r.found)
+        {
+          if (!tls_file_json_begun)
+            json_emit_begin (path);
+          json_emit_end (path, r.matches, total_spans > 0 ? total_spans : r.matches,
+                         static_cast<intmax_t> (size), elapsed_nanos (tls_search_t0));
+          tls_obuf.flush_locked ();
+          maybe_flush ();
+        }
+      tls_file_json_begun = false;
+    }
+  return r;
+}
+
+static bool
+needs_line_mode ()
+{
+  if (opt_multiline)
+    return false; /* whole-buffer multiline path */
+  /* Count/exists/quiet/files_with* do not need line output; keep fast DFA/class
+     paths even when --color is set (color only affects printed match lines).
+     Heading + count still needs line mode for heading-formatted count output.
+     Replace / byte-offset are irrelevant for count-mode output.  */
+  if (opt_count || opt_quiet || opt_files_with_matches || opt_files_without_match)
+    {
+      if (!opt_json && !opt_invert && !opt_passthru && !opt_trim
+          && !opt_count_matches && !opt_stop_on_nonmatch && !opt_heading
+          && opt_max_columns <= 0 && opt_context_before <= 0 && opt_context_after <= 0)
+        return false;
+    }
+  /* JSON alone: dedicated streaming path (no full LineIndex).  */
+  if (opt_json && !opt_invert && !opt_passthru && !opt_replace && !opt_trim
+      && !opt_count_matches && opt_context_before <= 0 && opt_context_after <= 0
+      && !opt_stop_on_nonmatch && opt_max_columns <= 0 && !opt_heading)
+    return false;
+  /* Color alone does NOT require line mode.  Heading / byte-offset / replace
+     are handled by streaming batchable paths (print_match_line) when no
+     context/invert/trim/passthru is requested.  */
+  return opt_context_before > 0 || opt_context_after > 0 || opt_json
+         || opt_invert || opt_passthru || opt_trim || opt_count_matches
+         || opt_stop_on_nonmatch || opt_max_columns > 0;
+}
+
+/* Count newlines in [start, end).  */
+static intmax_t
+count_newlines_span (const char *start, const char *end)
+{
+  intmax_t n = 0;
+  const char *p = start;
+  while (p < end)
+    {
+      const void *nl = memchr (p, '\n', static_cast<size_t> (end - p));
+      if (!nl)
+        break;
+      n++;
+      p = static_cast<const char *> (nl) + 1;
+    }
+  return n;
+}
+
+/* Fast JSON: scan with memmem/DFA/class_run; emit match events without building
+   a full line index (only line number via running newline count).  */
+static SearchResult
+search_json_stream (const char *path, const char *data, size_t size)
+{
+  SearchResult r{};
+  tls_file_json_begun = false;
+  tls_search_t0 = Clock::now ();
+  tls_obuf.clear ();
+
+  const char *base = data;
+  const char *end = data + size;
+  const char *scan = data;
+  intmax_t lno = 1;
+  const char *line_count_upto = data; /* newlines counted in [data, line_count_upto) */
+  intmax_t spans = 0;
+
+  auto line_bounds = [&] (const char *hit, const char **ls_out, size_t *llen_out,
+                          intmax_t *abs_off_out) {
+    const char *ls = static_cast<const char *> (
+      memrchr (base, '\n', static_cast<size_t> (hit - base)));
+    ls = ls ? ls + 1 : base;
+    const char *nl = static_cast<const char *> (
+      memchr (hit, '\n', static_cast<size_t> (end - hit)));
+    size_t llen = nl ? static_cast<size_t> (nl - ls + 1) : static_cast<size_t> (end - ls);
+    *ls_out = ls;
+    *llen_out = llen;
+    *abs_off_out = static_cast<intmax_t> (ls - base);
+    /* Advance line number to this line start.  */
+    if (ls > line_count_upto)
+      {
+        lno += count_newlines_span (line_count_upto, ls);
+        line_count_upto = ls;
+      }
+    else if (ls < line_count_upto)
+      {
+        lno = 1 + count_newlines_span (base, ls);
+        line_count_upto = ls;
+      }
+  };
+
+  auto emit_hit = [&] (const char *hit, size_t mlen) {
+    const char *ls = nullptr;
+    size_t llen = 0;
+    intmax_t abs_off = 0;
+    line_bounds (hit, &ls, &llen, &abs_off);
+    intmax_t so = static_cast<intmax_t> (hit - ls);
+    intmax_t eo = so + static_cast<intmax_t> (mlen);
+    r.found = true;
+    r.matches++;
+    spans++;
+    if (__builtin_expect (opt_stats, 0))
+      stat_lines_matched.fetch_add (1, std::memory_order_relaxed);
+    if (!tls_file_json_begun)
+      {
+        json_emit_begin (path);
+        tls_file_json_begun = true;
+      }
+    json_emit_match (path, lno, abs_off, ls, llen, so, eo);
+    /* Flush periodically to bound TLS buffer growth on huge match counts.  */
+    if (tls_obuf.size () > (1u << 16))
+      {
+        std::lock_guard<std::mutex> lock (g_out_mu);
+        tls_obuf.flush_locked ();
+      }
+  };
+
+  if (opt_fixed && !g_fixed.empty () && !opt_ignore_case)
+    {
+      const size_t nlen = g_fixed.size ();
+      while (scan < end)
+        {
+          const char *m = rg_simd::memmem_fast (scan, static_cast<size_t> (end - scan),
+                                                 g_fixed.data (), nlen);
+          if (!m)
+            break;
+          emit_hit (m, nlen);
+          if (r.matches >= opt_max_count)
+            break;
+          const char *nl = static_cast<const char *> (
+            memchr (m, '\n', static_cast<size_t> (end - m)));
+          scan = nl ? nl + 1 : end; /* one event per line like normal mode */
+        }
+    }
+  else if (g_prefilter.kind == rg_simd::PrefKind::LitsAny)
+    {
+      while (scan < end)
+        {
+          size_t best_len = 0;
+          const char *best = rg_simd::lits_any_find_first (g_prefilter, scan, end,
+                                                           &best_len);
+          if (best >= end)
+            break;
+          emit_hit (best, best_len);
+          if (r.matches >= opt_max_count)
+            break;
+          const char *nl = static_cast<const char *> (
+            memchr (best, '\n', static_cast<size_t> (end - best)));
+          scan = nl ? nl + 1 : end;
+        }
+    }
+  else if (g_class_run.active () || (g_use_dfa && g_exec && g_pat))
+    /* Shared DFA/class path: engine execute with prefilter; class_run falls
+       through via g_exec when compile selected GEA, else we use exec loop.  */
+    {
+      /* Prefer DFA execute when available; class_run-only uses DFA still.  */
+      if (!g_use_dfa || !g_exec || !g_pat)
+        return search_lines_with_context (path, data, size);
+      idx_t off = 0;
+      while (off < static_cast<idx_t> (size))
+        {
+          if (g_prefilter.active ())
+            {
+              const char *c0 = base + off;
+              const char *pf = rg_simd::prefilter_next (g_prefilter, c0, end);
+              if (pf >= end)
+                break;
+              off = static_cast<idx_t> (pf - base);
+            }
+          idx_t ms = 0;
+          ptrdiff_t mo = g_exec (g_pat, base + off, size - off, &ms, nullptr);
+          if (mo < 0)
+            break;
+          const char *hit = base + off + mo;
+          emit_hit (hit, ms ? static_cast<size_t> (ms) : 1);
+          if (r.matches >= opt_max_count)
+            break;
+          const char *nl = static_cast<const char *> (
+            memchr (hit, '\n', static_cast<size_t> (end - hit)));
+          if (!nl)
+            break;
+          off = static_cast<idx_t> (nl - base + 1);
+        }
+    }
+  else
+    return search_lines_with_context (path, data, size);
+
+  {
+    std::lock_guard<std::mutex> lock (g_out_mu);
+    if (tls_file_json_begun || r.found)
+      {
+        if (!tls_file_json_begun)
+          json_emit_begin (path);
+        json_emit_end (path, r.matches, spans > 0 ? spans : r.matches,
+                       static_cast<intmax_t> (size), elapsed_nanos (tls_search_t0));
+        tls_obuf.flush_locked ();
+        maybe_flush ();
+      }
+    tls_file_json_begun = false;
+  }
+  return r;
+}
+
+/* Multiline (-U): search entire buffer as one subject; report first line of
+   each hit (ripgrep prints each line the match spans — we emit the start line
+   with column/match clipped to that line for normal output).  */
+static SearchResult
+search_multiline_buffer (const char *path, const char *data, size_t size)
+{
+  SearchResult r{};
+  tls_last_printed_lno = -2;
+  tls_file_json_begun = false;
+  tls_search_t0 = Clock::now ();
+
+  if (!g_use_dfa || !g_exec || !g_pat)
+    return search_lines_with_context (path, data, size);
+
+  /* Pexecute_whole / ERE-with-embedded-newline: full buffer + start_ptr so
+     engines keep data[-1] BOL sentinel and can span newlines.  Otherwise slice
+     at abs_off with start_ptr=nullptr (EGexecute line-orients; returns line
+     span — fine for reporting the hit line).  */
+  auto ml_exec = [&] (idx_t abs_off, idx_t *ms_out) -> ptrdiff_t {
+    if (abs_off > static_cast<idx_t> (size))
+      return -1;
+    if (g_ml_whole_buffer)
+      return g_exec (g_pat, data, static_cast<idx_t> (size), ms_out,
+                     data + abs_off);
+    ptrdiff_t mo = g_exec (g_pat, data + abs_off,
+                           static_cast<idx_t> (size) - abs_off, ms_out,
+                           nullptr);
+    if (mo < 0)
+      return mo;
+    return mo + static_cast<ptrdiff_t> (abs_off);
+  };
+
+  /* Fast path: when g_ml_fixed is set, use parallel memmem for count/exists.
+     Much faster than Pexecute_whole for literal patterns like 'void\n'.  */
+  auto ml_memmem = [&] (const char *hay, size_t hlen) -> const char * {
+    if (opt_ignore_case)
+      return rg_simd::memmem_icase_fast (hay, hlen,
+                                          g_ml_fixed.data (), g_ml_fixed.size ());
+    return rg_simd::memmem_fast (hay, hlen,
+                                  g_ml_fixed.data (), g_ml_fixed.size ());
+  };
+
+  /* Count-only / quiet / files-with-matches: skip LineIndex build.  */
+  if (opt_quiet || opt_files_with_matches || opt_files_without_match || opt_count
+      || opt_count_matches)
+    {
+      idx_t off = 0;
+      intmax_t spans = 0;
+      if (!g_ml_fixed.empty ())
+        {
+          /* Direct memmem scan: much faster than PCRE2 for literal patterns.  */
+          const char *p = data;
+          const char *end = data + size;
+          while (p < end)
+            {
+              const char *m = ml_memmem (p, static_cast<size_t> (end - p));
+              if (!m)
+                break;
+              r.found = true;
+              r.matches++;
+              spans++;
+              if (opt_quiet || opt_files_with_matches)
+                break;
+              if (r.matches >= opt_max_count && !opt_count_matches)
+                break;
+              p = m + g_ml_fixed.size ();
+            }
+        }
+      else
+      while (off < static_cast<idx_t> (size))
+        {
+          idx_t ms = 0;
+          ptrdiff_t mo = ml_exec (off, &ms);
+          if (mo < 0)
+            break;
+          r.found = true;
+          r.matches++;
+          spans++;
+          if (opt_quiet || opt_files_with_matches)
+            {
+              if (opt_files_with_matches)
+                emit_path_only (path);
+              return r;
+            }
+          if (r.matches >= opt_max_count && !opt_count_matches)
+            break;
+          if (spans >= opt_max_count && opt_count_matches)
+            break;
+          /* Advance past this match; avoid infinite loop on empty matches.  */
+          off = static_cast<idx_t> (mo) + (ms ? ms : 1);
+        }
+      if (opt_files_without_match && !r.found)
+        emit_path_only (path);
+      if (opt_count || opt_count_matches)
+        {
+          intmax_t n = opt_count_matches ? spans : r.matches;
+          if (n > 0 || opt_include_zero)
+            emit_count (path, n);
+        }
+      if (__builtin_expect (opt_stats, 0))
+        {
+          stat_lines_matched.fetch_add (r.matches, std::memory_order_relaxed);
+          stat_match_spans.fetch_add (spans, std::memory_order_relaxed);
+        }
+      return r;
+    }
+
+  /* Print path: build line index for match → line mapping.  */
+  LineIndex idx;
+  idx.build (data, size);
+
+  auto line_of = [&] (size_t off) -> intmax_t {
+    if (idx.count () == 0)
+      return 1;
+    return idx.line_of_offset (off);
+  };
+  auto line_start_off = [&] (intmax_t lno) -> intmax_t {
+    size_t li = static_cast<size_t> (lno > 0 ? lno - 1 : 0);
+    if (li >= idx.count ())
+      return 0;
+    return static_cast<intmax_t> (idx.starts[li] - data);
+  };
+  auto line_ptr_len = [&] (intmax_t lno, const char **ls, size_t *llen) {
+    size_t li = static_cast<size_t> (lno > 0 ? lno - 1 : 0);
+    if (li >= idx.count ())
+      {
+        *ls = data;
+        *llen = size;
+        return;
+      }
+    *ls = idx.starts[li];
+    *llen = idx.len(li);
+  };
+
+  idx_t off = 0;
+  intmax_t emitted = 0;
+  intmax_t spans = 0;
+  while (off < static_cast<idx_t> (size))
+    {
+      idx_t ms = 0;
+      ptrdiff_t mo = ml_exec (off, &ms);
+      if (mo < 0)
+        break;
+      size_t moff = static_cast<size_t> (mo);
+      size_t mend = moff + static_cast<size_t> (ms);
+      intmax_t lno_start = line_of (moff);
+      /* Whole-buffer engines can return a match that truly spans newlines;
+         EGexecute/Fexecute line-orients and returns one line — do not expand.  */
+      intmax_t lno_end = lno_start;
+      if (g_ml_whole_buffer && mend > moff)
+        lno_end = line_of (mend - 1);
+      for (intmax_t lno = lno_start; lno <= lno_end; ++lno)
+        {
+          const char *ls = nullptr;
+          size_t llen = 0;
+          line_ptr_len (lno, &ls, &llen);
+          intmax_t abs_line = line_start_off (lno);
+          intmax_t so = static_cast<intmax_t> (moff) - abs_line;
+          intmax_t eo = static_cast<intmax_t> (mend) - abs_line;
+          if (so < 0)
+            so = 0;
+          if (eo > static_cast<intmax_t> (llen))
+            eo = static_cast<intmax_t> (llen);
+          if (so > static_cast<intmax_t> (llen))
+            so = static_cast<intmax_t> (llen);
+          if (eo < so)
+            eo = so;
+          r.found = true;
+          if (lno == lno_start)
+            r.matches++;
+          spans++;
+          print_match_line (path, lno, so + 1, ls, llen, so, eo, abs_line);
+          if (__builtin_expect (opt_stats, 0))
+            stat_lines_matched.fetch_add (1, std::memory_order_relaxed);
+          emitted++;
+          if (emitted >= opt_max_count)
+            goto ml_done;
+        }
+      off = static_cast<idx_t> (mo) + (ms ? ms : 1);
+    }
+ml_done:
+  if (__builtin_expect (opt_stats, 0))
+    stat_match_spans.fetch_add (spans, std::memory_order_relaxed);
+
+  if (opt_json)
+    {
+      std::lock_guard<std::mutex> lock (g_out_mu);
+      if (tls_file_json_begun || r.found)
+        {
+          if (!tls_file_json_begun)
+            json_emit_begin (path);
+          json_emit_end (path, r.matches, spans > 0 ? spans : r.matches,
+                         static_cast<intmax_t> (size), elapsed_nanos (tls_search_t0));
+          tls_obuf.flush_locked ();
+          maybe_flush ();
+        }
+      tls_file_json_begun = false;
+    }
+  return r;
+}
+
+static int n_workers (); /* defined with parallel file search */
+
+/* Adaptive shard threshold: avoid thread spawn on small/medium buffers.  */
+static constexpr size_t k_chunk_parallel_min = 512 * 1024; /* 512 KiB floor */
+static constexpr size_t k_chunk_bytes_per_worker = 1024 * 1024; /* ~1 MiB/worker */
+
+static int
+chunk_worker_count (size_t size)
+{
+  int nw = n_workers ();
+  if (nw <= 1 || size < k_chunk_parallel_min || opt_passthru)
+    return 1;
+  /* Cap workers so each shard has enough work; exists can use more (early stop).  */
+  size_t ideal = size / k_chunk_bytes_per_worker;
+  if (ideal < 2)
+    return 1;
+  if (ideal > static_cast<size_t> (nw))
+    ideal = static_cast<size_t> (nw);
+  return static_cast<int> (ideal);
+}
+
+/* Split [data, data+size) into up to NW line-aligned shards (start at BOL).
+   Last shard absorbs the tail; each line belongs to exactly one shard.  */
+static void
+build_line_chunks (const char *data, size_t size, int nw,
+                   std::vector<std::pair<const char *, size_t>> *chunks)
+{
+  chunks->clear ();
+  if (!data || !size || nw < 1)
+    return;
+  if (nw == 1)
+    {
+      chunks->emplace_back (data, size);
+      return;
+    }
+  const size_t target = size / static_cast<size_t> (nw);
+  const char *end = data + size;
+  const char *cur = data;
+  for (int i = 0; i < nw && cur < end; i++)
+    {
+      const char *seg_start = cur;
+      const char *seg_end;
+      if (i + 1 >= nw)
+        seg_end = end;
+      else
+        {
+          const char *aim = data + target * static_cast<size_t> (i + 1);
+          if (aim >= end)
+            aim = end;
+          /* End at the first newline at/after aim so the next shard starts BOL.  */
+          const char *nl = static_cast<const char *> (
+            memchr (aim, '\n', static_cast<size_t> (end - aim)));
+          seg_end = nl ? nl + 1 : end;
+        }
+      size_t slen = static_cast<size_t> (seg_end - seg_start);
+      if (slen)
+        chunks->emplace_back (seg_start, slen);
+      cur = seg_end;
+    }
+}
+
+/* Parallel line count on large buffers (thread-safe scan_fn only: LitsAny,
+   class_run, fixed memmem).  only_exists: workers may stop early.  */
+template <typename ScanFn>
+static intmax_t
+parallel_count_chunks (const char *data, size_t size, bool only_exists,
+                       intmax_t max_count, ScanFn &&scan_fn)
+{
+  int nw = chunk_worker_count (size);
+  /* Exists/quiet: more workers OK — first hit wins.  */
+  if (only_exists && size >= k_chunk_parallel_min)
+    {
+      int full = n_workers ();
+      if (full > nw)
+        nw = full;
+    }
+  if (nw <= 1)
+    return scan_fn (data, size, only_exists, max_count);
+
+  std::vector<std::pair<const char *, size_t>> chunks;
+  build_line_chunks (data, size, nw, &chunks);
+  if (chunks.size () <= 1)
+    return scan_fn (data, size, only_exists, max_count);
+
+  std::atomic<intmax_t> total{0};
+  std::atomic<bool> stop{false};
+  std::vector<std::thread> ths;
+  ths.reserve (chunks.size ());
+
+  for (const auto &ch : chunks)
+    {
+      ths.emplace_back ([&, ch] () {
+        if (stop.load (std::memory_order_relaxed))
+          return;
+        bool oe = only_exists;
+        intmax_t mc = max_count;
+        /* Per-chunk: exists path stops at 1; count has no per-chunk max
+           (global max applied after sum; overshoot is fine for -c).  */
+        intmax_t local_mc = oe ? 1 : 0;
+        intmax_t n = scan_fn (ch.first, ch.second, oe, local_mc);
+        if (n > 0)
+          {
+            total.fetch_add (n, std::memory_order_relaxed);
+            if (oe)
+              stop.store (true, std::memory_order_relaxed);
+          }
+        (void) mc;
+      });
+    }
+  for (auto &t : ths)
+    t.join ();
+
+  intmax_t n = total.load (std::memory_order_relaxed);
+  if (only_exists)
+    return n > 0 ? 1 : 0;
+  if (max_count > 0 && n > max_count)
+    n = max_count;
+  return n;
+}
+
+/* Class-run SIMD path (e.g. [A-Za-z]{8}): no DFA, line-oriented count.  */
+static SearchResult
+search_class_run_count_or_exists (const char *path, const char *data, size_t size,
+                                  bool only_exists)
+{
+  SearchResult r{};
+  bool line_mode = opt_count || only_exists || opt_quiet || opt_files_with_matches
+                   || opt_files_without_match;
+  bool oe = only_exists || opt_quiet || opt_files_with_matches;
+  intmax_t mc = opt_max_count > 0 ? opt_max_count : 0;
+  /* No parallel chunking: class_run tracks a running char class state that
+     can span chunk boundaries, causing undercounts when split.  Single-thread
+     is fine — SIMD scan is already 3ms for 60MB.  */
+  intmax_t n = rg_simd::scan_class_run (g_class_run, data, size, line_mode, oe, mc);
+  if (n > 0)
+    {
+      r.found = true;
+      r.matches = n;
+      if (__builtin_expect (opt_stats, 0))
+        stat_lines_matched.fetch_add (n, std::memory_order_relaxed);
+    }
+  if (opt_count && !opt_files_with_matches && !opt_files_without_match
+      && (r.matches > 0 || opt_include_zero))
+    emit_count (path, r.matches);
+  if (opt_files_without_match && !r.found)
+    emit_path_only (path);
+  if (opt_files_with_matches && r.found)
+    emit_path_only (path);
+  return r;
+}
+
+/* Class-run print path: SIMD class_run scan for matching lines, emit with
+   color highlighting.  Avoids DFA per-line execute for patterns like [a-z]{8}.
+   Uses scan_class_run for line detection + find_class_run_span for match
+   position within each matching line.  */
+static SearchResult
+search_class_run_print (const char *path, const char *data, size_t size)
+{
+  SearchResult r{};
+  const char *base = data;
+  const char *end = data + size;
+  const char *cur = base;
+  const char *last_ls = base;
+  intmax_t lno = 1;
+
+  const bool batchable = !opt_json && !opt_vimgrep
+                         && !opt_column && !opt_only_matching
+                         && opt_context_before <= 0 && opt_context_after <= 0
+                         && !opt_passthru && !opt_max_columns
+                         && !opt_count_matches && !opt_trim && !opt_invert;
+  const bool wfn = want_filename (path);
+  const size_t pathlen = wfn ? std::strlen (path) : 0;
+  const char path_sep = opt_null ? '\0' : ':';
+  const bool emit_path = batchable && wfn && !opt_heading;
+  const bool emit_heading = batchable && wfn && opt_heading;
+  const bool emit_lno = batchable && opt_line_number;
+  const bool emit_boff = batchable && opt_byte_offset;
+  const bool emit_replace = batchable && opt_replace;
+  const bool color_path  = g_use_color && col_path_len;
+  const bool color_lno   = g_use_color && col_line_len;
+  const bool color_match = g_use_color && col_match_len;
+
+  /* Pre-build path prefix.  */
+  char cr_path_pfx[PATH_MAX + 32];
+  size_t cr_path_pfx_len = 0;
+  if (emit_path)
+    {
+      char *pp = cr_path_pfx;
+      if (color_path)
+        { std::memcpy (pp, col_path, col_path_len); pp += col_path_len; }
+      std::memcpy (pp, path, pathlen); pp += pathlen;
+      if (color_path)
+        { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+      *pp++ = path_sep;
+      cr_path_pfx_len = static_cast<size_t> (pp - cr_path_pfx);
+    }
+  char cr_heading_pfx[PATH_MAX + 32];
+  size_t cr_heading_pfx_len = 0;
+  if (emit_heading)
+    {
+      char *pp = cr_heading_pfx;
+      if (color_path)
+        { std::memcpy (pp, col_path, col_path_len); pp += col_path_len; }
+      std::memcpy (pp, path, pathlen); pp += pathlen;
+      if (color_path)
+        { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+      *pp++ = '\n';
+      cr_heading_pfx_len = static_cast<size_t> (pp - cr_heading_pfx);
+    }
+
+  auto pfx_int_fn = [] (char *&pp, intmax_t v) {
+    char tmp[24]; char *t = tmp + sizeof tmp;
+    uintmax_t u = static_cast<uintmax_t> (v);
+    do { *--t = '0' + static_cast<char> (u % 10); u /= 10; } while (u);
+    size_t sz = static_cast<size_t> (tmp + sizeof tmp - t);
+    std::memcpy (pp, t, sz); pp += sz;
+  };
+
+  /* Two-pass approach for batchable output (no color/json/replace/context):
+     Pass 1: parallel AVX2 scan to build a bitmap of which byte offsets start
+             a matching run (using scan_class_run count_lines=true).
+     Pass 2: iterate lines, check bitmap, output matching lines.
+     This is much faster because pass 1 uses parallel_count_chunks and the
+     proven scan_class_run_avx2_impl, while pass 2 only does memchr + output.
+
+     For non-batchable output (color/json/etc), fall back to per-line scan.  */
+  if (batchable && !color_match && !emit_replace)
+    {
+      /* Pass 1: parallel match scan.  Build a per-chunk match bitmap.
+         Actually, simpler: do a single-pass scan_class_run with count_lines=true
+         on each chunk, and collect matching line OFFSETS in a vector.
+         Then pass 2 iterates the buffer and emits matching lines.
+
+         Even simpler: scan_class_run_avx2_impl with count_lines=true already
+         skips to next line after a hit.  Use it in a custom loop that records
+         the byte offset of each matching line start.  */
+
+      /* Collect matching line start offsets.  Use a thread-parallel scan where
+         each thread collects offsets for its chunk.  */
+      const int nw = chunk_worker_count (size);
+      std::vector<std::pair<const char *, size_t>> chunks;
+      build_line_chunks (data, size, nw, &chunks);
+
+      /* Per-chunk offset lists.  */
+      std::vector<std::vector<const char *>> chunk_matches (chunks.size ());
+
+      if (chunks.size () > 1)
+        {
+          std::vector<std::thread> ths;
+          ths.reserve (chunks.size ());
+          for (size_t ci = 0; ci < chunks.size (); ci++)
+            ths.emplace_back ([&, ci] {
+              const char *cd = chunks[ci].first;
+              size_t csz = chunks[ci].second;
+              const char *cend = cd + csz;
+              const char *p = cd;
+              auto &offsets = chunk_matches[ci];
+              offsets.reserve (csz / 200);  /* rough estimate */
+              while (p < cend)
+                {
+                  const char *nl = static_cast<const char *> (
+                    memchr (p, '\n', static_cast<size_t> (cend - p)));
+                  const char *le = nl ? nl + 1 : cend;
+                  size_t llen = static_cast<size_t> (le - p);
+                  intmax_t n = rg_simd::scan_class_run (g_class_run, p, llen,
+                                                         false, true, 1);
+                  if (n > 0)
+                    offsets.push_back (p);
+                  p = le;
+                }
+            });
+          for (auto &t : ths)
+            t.join ();
+        }
+      else
+        {
+          const char *p = data;
+          auto &offsets = chunk_matches[0];
+          offsets.reserve (size / 200);
+          while (p < end)
+            {
+              const char *nl = static_cast<const char *> (
+                memchr (p, '\n', static_cast<size_t> (end - p)));
+              const char *le = nl ? nl + 1 : end;
+              size_t llen = static_cast<size_t> (le - p);
+              intmax_t n = rg_simd::scan_class_run (g_class_run, p, llen,
+                                                     false, true, 1);
+              if (n > 0)
+                offsets.push_back (p);
+              p = le;
+            }
+        }
+
+      /* Merge: total count and emit.  */
+      size_t total = 0;
+      for (auto &v : chunk_matches)
+        total += v.size ();
+      if (total == 0)
+        {
+          out_flush_tls ();
+          return r;
+        }
+
+      r.found = true;
+      r.matches = static_cast<intmax_t> (total);
+      if (__builtin_expect (opt_stats, 0))
+        stat_lines_matched.fetch_add (r.matches, std::memory_order_relaxed);
+
+      /* Pass 2: emit matching lines in order.  */
+      bool need_lno = emit_lno || emit_boff;
+      if (cr_heading_pfx_len
+          && (tls_last_printed_lno < 0 || tls_last_printed_lno == -2))
+        tls_obuf.append (cr_heading_pfx, cr_heading_pfx_len);
+
+      intmax_t emitted = 0;
+      for (size_t ci = 0; ci < chunk_matches.size (); ci++)
+        {
+          for (const char *ls : chunk_matches[ci])
+            {
+              /* Find line end.  */
+              const char *nl = static_cast<const char *> (
+                memchr (ls, '\n', static_cast<size_t> (end - ls)));
+              const char *le = nl ? nl + 1 : end;
+              size_t llen = static_cast<size_t> (le - ls);
+
+              if (cr_path_pfx_len)
+                tls_obuf.append (cr_path_pfx, cr_path_pfx_len);
+              if (need_lno)
+                {
+                  /* Count newlines between last position and this line start.  */
+                  while (cur < ls)
+                    {
+                      const char *n = static_cast<const char *> (
+                        memchr (cur, '\n', static_cast<size_t> (ls - cur)));
+                      if (!n)
+                        break;
+                      lno++;
+                      cur = n + 1;
+                    }
+                  char pfx[64];
+                  char *pp = pfx;
+                  if (emit_boff)
+                    {
+                      if (color_lno)
+                        { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+                      pfx_int_fn (pp, static_cast<intmax_t> (ls - base));
+                      if (color_lno)
+                        { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+                      *pp++ = ':';
+                    }
+                  if (emit_lno)
+                    {
+                      if (color_lno)
+                        { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+                      pfx_int_fn (pp, lno);
+                      if (color_lno)
+                        { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+                      *pp++ = ':';
+                    }
+                  tls_obuf.append (pfx, static_cast<size_t> (pp - pfx));
+                }
+              tls_obuf.append (ls, llen);
+              if (!llen || ls[llen - 1] != '\n')
+                tls_obuf.append ('\n');
+              tls_last_printed_lno = lno;
+              if (tls_obuf.should_flush ())
+                out_flush_tls ();
+              emitted++;
+              if (emitted >= opt_max_count)
+                goto done_cr_print;
+            }
+        }
+    done_cr_print:
+      out_flush_tls ();
+      return r;
+    }
+
+  /* Fallback: per-line scan for color/replace/json/context.  */
+  while (cur < end)
+    {
+      const char *nl = static_cast<const char *> (
+        memchr (cur, '\n', static_cast<size_t> (end - cur)));
+      const char *le = nl ? nl + 1 : end;
+      size_t llen = static_cast<size_t> (le - cur);
+      if (rg_simd::class_run_line_exists (g_class_run, cur, llen))
+        {
+          r.found = true;
+          r.matches++;
+          if (__builtin_expect (opt_stats, 0))
+            stat_lines_matched.fetch_add (1, std::memory_order_relaxed);
+          if (batchable)
+            {
+              if (cr_heading_pfx_len
+                  && (tls_last_printed_lno < 0 || tls_last_printed_lno == -2))
+                tls_obuf.append (cr_heading_pfx, cr_heading_pfx_len);
+              if (cr_path_pfx_len)
+                tls_obuf.append (cr_path_pfx, cr_path_pfx_len);
+              if (emit_boff || emit_lno)
+                {
+                  char pfx[64];
+                  char *pp = pfx;
+                  if (emit_boff)
+                    {
+                      if (color_lno)
+                        { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+                      pfx_int_fn (pp, static_cast<intmax_t> (cur - base));
+                      if (color_lno)
+                        { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+                      *pp++ = ':';
+                    }
+                  if (emit_lno)
+                    {
+                      if (color_lno)
+                        { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+                      pfx_int_fn (pp, lno);
+                      if (color_lno)
+                        { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+                      *pp++ = ':';
+                    }
+                  tls_obuf.append (pfx, static_cast<size_t> (pp - pfx));
+                }
+              if (color_match)
+                {
+                  intmax_t so = 0, eo = 0;
+                  if (rg_simd::find_class_run_span (g_class_run, cur, llen,
+                                                     &so, &eo)
+                      && so >= 0 && eo > so)
+                    {
+                      if (so > 0)
+                        tls_obuf.append (cur, static_cast<size_t> (so));
+                      tls_obuf.append (col_match, col_match_len);
+                      tls_obuf.append (cur + so,
+                                       static_cast<size_t> (eo - so));
+                      tls_obuf.append (col_reset, col_reset_len);
+                      if (static_cast<size_t> (eo) < llen)
+                        tls_obuf.append (cur + eo,
+                                         llen - static_cast<size_t> (eo));
+                    }
+                  else
+                    tls_obuf.append (cur, llen);
+                }
+              else if (emit_replace)
+                {
+                  intmax_t so = 0, eo = 0;
+                  rg_simd::find_class_run_span (g_class_run, cur, llen,
+                                                &so, &eo);
+                  if (so > 0)
+                    tls_obuf.append (cur, static_cast<size_t> (so));
+                  if (color_match)
+                    tls_obuf.append (col_match, col_match_len);
+                  tls_obuf.append (opt_replace, opt_replace_len);
+                  if (color_match)
+                    tls_obuf.append (col_reset, col_reset_len);
+                  size_t tail = static_cast<size_t> (eo);
+                  if (tail < llen)
+                    tls_obuf.append (cur + tail, llen - tail);
+                }
+              else
+                tls_obuf.append (cur, llen);
+              if (!llen || cur[llen - 1] != '\n')
+                tls_obuf.append ('\n');
+              tls_last_printed_lno = lno;
+              if (tls_obuf.should_flush ())
+                out_flush_tls ();
+            }
+          else
+            {
+              intmax_t so = 0, eo = 0;
+              rg_simd::find_class_run_span (g_class_run, cur, llen, &so, &eo);
+              print_match_line (path, lno, so + 1, cur, llen, so, eo,
+                                static_cast<intmax_t> (cur - base));
+            }
+          if (r.matches >= opt_max_count)
+            break;
+        }
+      lno++;
+      cur = le;
+    }
+  out_flush_tls ();
+  return r;
+}
+
+/* Pure alternation of fixed literals (a|b|c): hybrid AC / multi-memmem.  */
+static SearchResult
+search_lits_any_count_or_exists (const char *path, const char *data, size_t size,
+                                 bool only_exists)
+{
+  SearchResult r{};
+  if (g_prefilter.lits.empty ())
+    return r;
+
+  bool oe = only_exists || opt_quiet || opt_files_with_matches;
+  intmax_t mc = opt_max_count > 0 ? opt_max_count : 0;
+  intmax_t n = parallel_count_chunks (
+    data, size, oe, mc,
+    [&] (const char *d, size_t sz, bool oex, intmax_t mx) -> intmax_t {
+      return rg_simd::lits_any_scan_lines (g_prefilter, d, sz, oex, mx);
+    });
+  if (n > 0)
+    {
+      r.found = true;
+      r.matches = n;
+      if (opt_stats)
+        stat_lines_matched.fetch_add (n, std::memory_order_relaxed);
+    }
+  if (only_exists || opt_quiet || opt_files_with_matches)
+    {
+      if (opt_files_with_matches && r.found)
+        emit_path_only (path);
+      return r;
+    }
+  if (opt_count && !opt_files_with_matches && !opt_files_without_match
+      && (r.matches > 0 || opt_include_zero))
+    emit_count (path, r.matches);
+  if (opt_files_without_match && !r.found)
+    emit_path_only (path);
+  if (opt_files_with_matches && r.found)
+    emit_path_only (path);
+  return r;
+}
+
+/* Fast count/exists using whole-buffer execute loop (grepbuf-style).
+   SIMD prefilter advances off past regions that cannot match.
+   After a hit, skip to next line (grep -c counts lines, not match spans).  */
+static SearchResult
+search_dfa_count_or_exists (const char *path, const char *data, size_t size,
+                            bool only_exists)
+{
+  if (g_class_run.active ())
+    return search_class_run_count_or_exists (path, data, size, only_exists);
+  if (g_prefilter.kind == rg_simd::PrefKind::LitsAny && !opt_invert)
+    return search_lits_any_count_or_exists (path, data, size, only_exists);
+
+  SearchResult r{};
+  idx_t off = 0;
+  const char *base = data;
+  const char *buf_end = base + size;
+  while (off < static_cast<idx_t> (size))
+    {
+      if (g_prefilter.active ())
+        {
+          const char *cur = base + off;
+          const char *pf = rg_simd::prefilter_next (g_prefilter, cur, buf_end);
+          if (pf >= buf_end)
+            break;
+          off = static_cast<idx_t> (pf - base);
+        }
+      idx_t ms = 0;
+      ptrdiff_t mo = g_exec (g_pat, base + off, size - off, &ms, nullptr);
+      if (mo < 0)
+        break;
+      const char *b = base + off + mo;
+      if (!opt_invert && b == base + size)
+        break;
+      if (!opt_invert)
+        {
+          r.found = true;
+          r.matches++;
+          if (__builtin_expect (opt_stats, 0))
+            stat_lines_matched.fetch_add (1, std::memory_order_relaxed);
+          if (only_exists || opt_quiet || opt_files_with_matches)
+            return r;
+          if (r.matches >= opt_max_count)
+            break;
+          /* Line-oriented: jump past EOL so we do not re-scan within the line.  */
+          const char *nl = static_cast<const char *> (
+            memchr (b, '\n', static_cast<size_t> (buf_end - b)));
+          if (!nl)
+            break;
+          off = static_cast<idx_t> (nl - base + 1);
+          continue;
+        }
+      off += mo + (ms ? ms : 1);
+    }
+  if (opt_count && !opt_files_with_matches && !opt_files_without_match
+      && (r.matches > 0 || opt_include_zero))
+    emit_count (path, r.matches);
+  if (opt_files_without_match && !r.found)
+    emit_path_only (path);
+  if (opt_files_with_matches && r.found)
+    emit_path_only (path);
+  return r;
+}
+
+static SearchResult
+search_dfa_print (const char *path, const char *data, size_t size)
+{
+  SearchResult r{};
+  const char *base = data;
+  const char *buf_end = base + size;
+
+  /* LitsAny print: hybrid memmem/AC, emit whole lines (no DFA / no LineIndex).  */
+  if (g_prefilter.kind == rg_simd::PrefKind::LitsAny && !opt_invert
+      && !opt_word && !opt_line)
+    {
+      const char *scan = base;
+      const char *last_ls = base;
+      intmax_t lno = 1;
+
+      /* Hoist invariant checks out of the per-match loop (same as search_fixed).  */
+      const bool batchable = !opt_json && !opt_vimgrep
+                             && !opt_column && !opt_only_matching
+                             && opt_context_before <= 0 && opt_context_after <= 0
+                             && !opt_passthru && !opt_max_columns
+                             && !opt_count_matches && !opt_trim;
+      const bool emit_path = batchable && want_filename (path) && !opt_heading;
+      const bool emit_heading = batchable && want_filename (path) && opt_heading;
+      const size_t pathlen = (emit_path || emit_heading) ? std::strlen (path) : 0;
+      const char path_sep = opt_null ? '\0' : ':';
+      const bool emit_lno = batchable && opt_line_number;
+      const bool emit_boff = batchable && opt_byte_offset;
+      const bool emit_replace = batchable && opt_replace;
+      const bool color_path  = g_use_color && col_path_len;
+      const bool color_lno   = g_use_color && col_line_len;
+      const bool color_match = g_use_color && col_match_len;
+      /* Pre-build path prefix for single-append emit.  */
+      char dfa_path_pfx[PATH_MAX + 32];
+      size_t dfa_path_pfx_len = 0;
+      if (emit_path)
+        {
+          char *pp = dfa_path_pfx;
+          if (color_path)
+            { std::memcpy (pp, col_path, col_path_len); pp += col_path_len; }
+          std::memcpy (pp, path, pathlen); pp += pathlen;
+          if (color_path)
+            { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+          *pp++ = path_sep;
+          dfa_path_pfx_len = static_cast<size_t> (pp - dfa_path_pfx);
+        }
+      /* Pre-build heading prefix for single-append emit.  */
+      char dfa_heading_pfx[PATH_MAX + 32];
+      size_t dfa_heading_pfx_len = 0;
+      if (emit_heading)
+        {
+          char *pp = dfa_heading_pfx;
+          if (color_path)
+            { std::memcpy (pp, col_path, col_path_len); pp += col_path_len; }
+          std::memcpy (pp, path, pathlen); pp += pathlen;
+          if (color_path)
+            { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+          *pp++ = '\n';
+          dfa_heading_pfx_len = static_cast<size_t> (pp - dfa_heading_pfx);
+        }
+
+      /* Two-pass parallel LitsAny print: same approach as class_run_print.
+         Pass 1: parallel multi-thread scan collects matching line start ptrs.
+         Pass 2: single-thread output emits lines in order.  */
+      if (batchable && !color_match && !emit_replace)
+        {
+          const int nw = chunk_worker_count (size);
+          std::vector<std::pair<const char *, size_t>> la_chunks;
+          build_line_chunks (base, size, nw, &la_chunks);
+
+          std::vector<std::vector<const char *>> la_matches (la_chunks.size ());
+
+          auto la_scan_chunk = [&] (size_t ci) {
+            const char *cd = la_chunks[ci].first;
+            size_t csz = la_chunks[ci].second;
+            const char *cend = cd + csz;
+            const char *p = cd;
+            auto &offsets = la_matches[ci];
+            offsets.reserve (csz / 200);
+            while (p < cend)
+              {
+                size_t ml = 0;
+                const char *hit = rg_simd::lits_any_find_first (
+                  g_prefilter, p, cend, &ml);
+                if (hit >= cend)
+                  break;
+                /* Backward scan to line start (chunks are line-aligned so
+                   ls stays within the chunk).  */
+                const char *ls = hit;
+                while (ls > cd && ls[-1] != '\n')
+                  ls--;
+                offsets.push_back (ls);
+                /* Skip past line end.  */
+                const char *nl = static_cast<const char *> (
+                  memchr (hit, '\n', static_cast<size_t> (cend - hit)));
+                p = nl ? nl + 1 : cend;
+              }
+          };
+
+          if (la_chunks.size () > 1)
+            {
+              std::vector<std::thread> ths;
+              ths.reserve (la_chunks.size ());
+              for (size_t ci = 0; ci < la_chunks.size (); ci++)
+                ths.emplace_back ([&, ci] { la_scan_chunk (ci); });
+              for (auto &t : ths)
+                t.join ();
+            }
+          else if (!la_chunks.empty ())
+            la_scan_chunk (0);
+
+          size_t la_total = 0;
+          for (auto &v : la_matches)
+            la_total += v.size ();
+          if (la_total == 0)
+            {
+              out_flush_tls ();
+              return r;
+            }
+
+          r.found = true;
+          r.matches = static_cast<intmax_t> (la_total);
+          if (__builtin_expect (opt_stats, 0))
+            stat_lines_matched.fetch_add (r.matches, std::memory_order_relaxed);
+
+          /* Pass 2: emit.  */
+          const bool la_need_lno = emit_lno || emit_boff;
+          if (dfa_heading_pfx_len
+              && (tls_last_printed_lno < 0 || tls_last_printed_lno == -2))
+            tls_obuf.append (dfa_heading_pfx, dfa_heading_pfx_len);
+
+          const char *la_cur = base;
+          intmax_t la_lno = 1;
+          intmax_t la_emitted = 0;
+          for (size_t ci = 0; ci < la_matches.size (); ci++)
+            {
+              for (const char *ls : la_matches[ci])
+                {
+                  const char *nl = static_cast<const char *> (
+                    memchr (ls, '\n', static_cast<size_t> (buf_end - ls)));
+                  const char *le = nl ? nl + 1 : buf_end;
+                  size_t llen = static_cast<size_t> (le - ls);
+
+                  if (dfa_path_pfx_len)
+                    tls_obuf.append (dfa_path_pfx, dfa_path_pfx_len);
+                  if (la_need_lno)
+                    {
+                      while (la_cur < ls)
+                        {
+                          const char *n = static_cast<const char *> (
+                            memchr (la_cur, '\n',
+                                    static_cast<size_t> (ls - la_cur)));
+                          if (!n)
+                            break;
+                          la_lno++;
+                          la_cur = n + 1;
+                        }
+                      char pfx[64];
+                      char *pp = pfx;
+                      auto la_pfx_int = [&] (intmax_t v) {
+                        char tmp[24]; char *t = tmp + sizeof tmp;
+                        uintmax_t u = static_cast<uintmax_t> (v);
+                        do {
+                          *--t = '0' + static_cast<char> (u % 10);
+                          u /= 10;
+                        } while (u);
+                        size_t n = static_cast<size_t> (tmp + sizeof tmp - t);
+                        std::memcpy (pp, t, n);
+                        pp += n;
+                      };
+                      if (emit_boff)
+                        {
+                          if (color_lno)
+                            { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+                          la_pfx_int (static_cast<intmax_t> (ls - base));
+                          if (color_lno)
+                            { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+                          *pp++ = ':';
+                        }
+                      if (emit_lno)
+                        {
+                          if (color_lno)
+                            { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+                          la_pfx_int (la_lno);
+                          if (color_lno)
+                            { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+                          *pp++ = ':';
+                        }
+                      tls_obuf.append (pfx, static_cast<size_t> (pp - pfx));
+                    }
+                  tls_obuf.append (ls, llen);
+                  if (!llen || ls[llen - 1] != '\n')
+                    tls_obuf.append ('\n');
+                  tls_last_printed_lno = la_lno;
+                  if (tls_obuf.should_flush ())
+                    out_flush_tls ();
+                  la_emitted++;
+                  if (la_emitted >= opt_max_count)
+                    goto done_la_par;
+                }
+            }
+        done_la_par:
+          out_flush_tls ();
+          return r;
+        }
+
+      while (scan < buf_end)
+        {
+          size_t mlen = 0;
+          const char *hit = rg_simd::lits_any_find_first (g_prefilter, scan, buf_end, &mlen);
+          if (hit >= buf_end)
+            break;
+          /* Count newlines: scalar for small gaps, SIMD for large.  */
+          if (hit > last_ls)
+            {
+              size_t gap = static_cast<size_t> (hit - last_ls);
+              if (gap <= 128)
+                {
+                  for (const char *p = last_ls; p < hit; p++)
+                    if (*p == '\n')
+                      { lno++; last_ls = p + 1; }
+                }
+              else
+                {
+                  const char *after_nl = nullptr;
+                  intmax_t nc = rg_simd::count_newlines (
+                    last_ls, gap, &after_nl);
+                  lno += nc;
+                  if (after_nl && after_nl > last_ls)
+                    last_ls = after_nl;
+                }
+            }
+          const char *ls = last_ls;
+          const char *nl = static_cast<const char *> (
+            memchr (hit, '\n', static_cast<size_t> (buf_end - hit)));
+          size_t llen = nl ? static_cast<size_t> (nl - ls + 1)
+                           : static_cast<size_t> (buf_end - ls);
+          r.found = true;
+          r.matches++;
+          if (__builtin_expect (opt_stats, 0))
+            stat_lines_matched.fetch_add (1, std::memory_order_relaxed);
+          if (batchable)
+            {
+              if (emit_heading
+                  && (tls_last_printed_lno < 0 || tls_last_printed_lno == -2))
+                tls_obuf.append (dfa_heading_pfx, dfa_heading_pfx_len);
+              if (emit_path)
+                tls_obuf.append (dfa_path_pfx, dfa_path_pfx_len);
+              if (emit_boff || emit_lno)
+                {
+                  char pfx[64];
+                  char *pp = pfx;
+                  auto pfx_int = [&] (intmax_t v) {
+                    char tmp[24]; char *t = tmp + sizeof tmp;
+                    uintmax_t u = static_cast<uintmax_t> (v);
+                    do { *--t = '0' + static_cast<char> (u % 10); u /= 10; } while (u);
+                    size_t n = static_cast<size_t> (tmp + sizeof tmp - t);
+                    std::memcpy (pp, t, n); pp += n;
+                  };
+                  if (emit_boff)
+                    {
+                      if (color_lno)
+                        { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+                      pfx_int (static_cast<intmax_t> (ls - base));
+                      if (color_lno)
+                        { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+                      *pp++ = ':';
+                    }
+                  if (emit_lno)
+                    {
+                      if (color_lno)
+                        { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+                      pfx_int (lno);
+                      if (color_lno)
+                        { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+                      *pp++ = ':';
+                    }
+                  tls_obuf.append (pfx, static_cast<size_t> (pp - pfx));
+                }
+              intmax_t so = static_cast<intmax_t> (hit - ls);
+              intmax_t eo = so + static_cast<intmax_t> (mlen);
+              if (emit_replace)
+                {
+                  if (so > 0)
+                    tls_obuf.append (ls, static_cast<size_t> (so));
+                  if (color_match)
+                    tls_obuf.append (col_match, col_match_len);
+                  tls_obuf.append (opt_replace, opt_replace_len);
+                  if (color_match)
+                    tls_obuf.append (col_reset, col_reset_len);
+                  size_t tail = static_cast<size_t> (eo);
+                  if (tail < llen)
+                    tls_obuf.append (ls + tail, llen - tail);
+                }
+              else if (color_match)
+                {
+                  if (so > 0)
+                    tls_obuf.append (ls, static_cast<size_t> (so));
+                  tls_obuf.append (col_match, col_match_len);
+                  tls_obuf.append (ls + so, static_cast<size_t> (eo - so));
+                  tls_obuf.append (col_reset, col_reset_len);
+                  if (static_cast<size_t> (eo) < llen)
+                    tls_obuf.append (ls + eo, llen - static_cast<size_t> (eo));
+                }
+              else
+                tls_obuf.append (ls, llen);
+              if (!llen || ls[llen - 1] != '\n')
+                tls_obuf.append ('\n');
+              tls_last_printed_lno = lno;
+              if (tls_obuf.should_flush ())
+                out_flush_tls ();
+            }
+          else
+            {
+              intmax_t so = static_cast<intmax_t> (hit - ls);
+              intmax_t eo = so + static_cast<intmax_t> (mlen);
+              print_match_line (path, lno, so + 1, ls, llen, so, eo,
+                                static_cast<intmax_t> (ls - base));
+            }
+          if (r.matches >= opt_max_count)
+            break;
+          scan = nl ? nl + 1 : buf_end;
+        }
+      out_flush_tls ();
+      return r;
+    }
+
+  idx_t off = 0;
+  intmax_t lno = 1;
+  const char *line_base = base;
+
+  while (off < static_cast<idx_t> (size))
+    {
+      if (g_prefilter.active ())
+        {
+          const char *cur = base + off;
+          const char *pf = rg_simd::prefilter_next (g_prefilter, cur, buf_end);
+          if (pf >= buf_end)
+            break;
+          /* Bulk newline count: SIMD popcount from line_base to pf.  */
+          if (pf > line_base)
+            {
+              const char *after_nl = nullptr;
+              intmax_t nc = rg_simd::count_newlines (
+                line_base, static_cast<size_t> (pf - line_base), &after_nl);
+              lno += nc;
+              line_base = pf;
+            }
+          off = static_cast<idx_t> (pf - base);
+        }
+      idx_t ms = 0;
+      ptrdiff_t mo = g_exec (g_pat, base + off, size - off, &ms, nullptr);
+      if (mo < 0)
+        break;
+      const char *ls = base + off + mo;
+      if (!opt_invert && ls == base + size)
+        break;
+      if (!opt_invert)
+        {
+          r.found = true;
+          r.matches++;
+          if (__builtin_expect (opt_stats, 0))
+            stat_lines_matched.fetch_add (1, std::memory_order_relaxed);
+          /* Bulk newline count: SIMD popcount from line_base to ls.  */
+          if (ls > line_base)
+            {
+              const char *after_nl = nullptr;
+              intmax_t nc = rg_simd::count_newlines (
+                line_base, static_cast<size_t> (ls - line_base), &after_nl);
+              lno += nc;
+            }
+          line_base = ls;
+          /* Expand to full line for display (hit may be mid-line).  */
+          const char *line_start = ls;
+          while (line_start > base && line_start[-1] != '\n')
+            line_start--;
+          const char *nl = static_cast<const char *> (
+            memchr (ls, '\n', static_cast<size_t> (buf_end - ls)));
+          size_t llen = nl ? static_cast<size_t> (nl - line_start + 1)
+                           : static_cast<size_t> (buf_end - line_start);
+          intmax_t so = static_cast<intmax_t> (ls - line_start);
+          intmax_t eo = so + static_cast<intmax_t> (ms);
+          print_match_line (path, lno, so + 1, line_start, llen, so, eo,
+                            static_cast<intmax_t> (line_start - base));
+          if (r.matches >= opt_max_count)
+            break;
+          if (!nl)
+            break;
+          off = static_cast<idx_t> (nl - base + 1);
+          line_base = base + off;
+          lno++;
+          continue;
+        }
+      off += mo + (ms ? ms : 1);
+    }
+  out_flush_tls ();
+  return r;
+}
+
+/* ---------- dual-literal fast path (lit1 .* lit2) ---------- */
+
+/* Line-by-line test: does [ls, ls+llen) contain all chain literals in order?
+   Returns true and sets so/eo to the match span (first byte of first lit to
+   last byte of last lit) on success.  */
+static inline bool
+lit_chain_line_match (const char *ls, size_t llen, bool icase,
+                      intmax_t *so, intmax_t *eo)
+{
+  const char *cur = ls;
+  size_t rem = llen;
+  const char *first_hit = nullptr;
+  const char *last_end = nullptr;
+
+  for (size_t k = 0; k < g_lit_chain.size (); k++)
+    {
+      const auto &seg = g_lit_chain[k];
+      const char *m = icase
+        ? rg_simd::memmem_icase_fast (cur, rem, seg.lit.data (), seg.lit.size ())
+        : rg_simd::memmem_fast (cur, rem, seg.lit.data (), seg.lit.size ());
+      if (!m)
+        return false;
+      if (k == 0)
+        first_hit = m;
+      last_end = m + seg.lit.size ();
+      /* Advance past this match (+ 1 for .+ gap between this and next seg).  */
+      size_t advance = static_cast<size_t> (m - cur) + seg.lit.size ();
+      if (k + 1 < g_lit_chain.size () && seg.dotplus)
+        advance++;
+      if (advance >= rem && k + 1 < g_lit_chain.size ())
+        return false;
+      cur += advance;
+      rem -= advance < rem ? advance : rem;
+    }
+  *so = static_cast<intmax_t> (first_hit - ls);
+  *eo = static_cast<intmax_t> (last_end - ls);
+  return true;
+}
+
+static SearchResult
+search_lit_chain_count (const char *path, const char *data, size_t size,
+                        bool only_exists)
+{
+  SearchResult r{};
+  const bool icase = opt_ignore_case;
+  const auto &lead = g_lit_chain[0];
+
+  const char *cur = data;
+  const char *end = data + size;
+  while (cur < end)
+    {
+      /* Scan for first literal to jump to candidate line.  */
+      size_t rem = static_cast<size_t> (end - cur);
+      const char *m1 = icase
+        ? rg_simd::memmem_icase_fast (cur, rem, lead.lit.data (), lead.lit.size ())
+        : rg_simd::memmem_fast (cur, rem, lead.lit.data (), lead.lit.size ());
+      if (!m1)
+        break;
+      const char *ls = m1;
+      while (ls > data && ls[-1] != '\n')
+        ls--;
+      const char *nl = static_cast<const char *> (
+        memchr (m1, '\n', static_cast<size_t> (end - m1)));
+      size_t llen = nl ? static_cast<size_t> (nl - ls) : static_cast<size_t> (end - ls);
+      intmax_t so, eo;
+      if (lit_chain_line_match (ls, llen, icase, &so, &eo))
+        {
+          r.found = true;
+          r.matches++;
+          if (only_exists)
+            return r;
+          if (r.matches >= opt_max_count)
+            break;
+        }
+      cur = nl ? nl + 1 : end;
+    }
+  if (__builtin_expect (opt_stats, 0) && r.matches > 0)
+    stat_lines_matched.fetch_add (r.matches, std::memory_order_relaxed);
+  if (only_exists)
+    {
+      if (opt_files_with_matches && r.found)
+        emit_path_only (path);
+      return r;
+    }
+  if (opt_count && !opt_files_with_matches && !opt_files_without_match
+      && (r.matches > 0 || opt_include_zero))
+    emit_count (path, r.matches);
+  if (opt_files_without_match && !r.found)
+    emit_path_only (path);
+  return r;
+}
+
+static SearchResult
+search_lit_chain_print (const char *path, const char *data, size_t size)
+{
+  SearchResult r{};
+  const bool icase = opt_ignore_case;
+  const auto &lead = g_lit_chain[0];
+  const char *cur = data;
+  const char *end = data + size;
+  const char *last_ls = data;
+  intmax_t lno = 1;
+
+  /* Hoist invariant checks (same as search_fixed batchable).  */
+  const bool batchable = !opt_json && !opt_vimgrep
+                         && !opt_column && !opt_only_matching
+                         && opt_context_before <= 0 && opt_context_after <= 0
+                         && !opt_passthru && !opt_max_columns
+                         && !opt_count_matches && !opt_trim;
+  const bool emit_path = batchable && want_filename (path) && !opt_heading;
+  const bool emit_heading = batchable && want_filename (path) && opt_heading;
+  const size_t pathlen = (emit_path || emit_heading) ? std::strlen (path) : 0;
+  const char path_sep = opt_null ? '\0' : ':';
+  const bool emit_lno = batchable && opt_line_number;
+  const bool emit_boff = batchable && opt_byte_offset;
+  const bool emit_replace = batchable && opt_replace;
+  const bool lc_color_path  = g_use_color && col_path_len;
+  const bool lc_color_lno   = g_use_color && col_line_len;
+  const bool lc_color_match = g_use_color && col_match_len;
+  /* Pre-build path prefix for single-append emit.  */
+  char lc_path_pfx[PATH_MAX + 32];
+  size_t lc_path_pfx_len = 0;
+  if (emit_path)
+    {
+      char *pp = lc_path_pfx;
+      if (lc_color_path)
+        { std::memcpy (pp, col_path, col_path_len); pp += col_path_len; }
+      std::memcpy (pp, path, pathlen); pp += pathlen;
+      if (lc_color_path)
+        { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+      *pp++ = path_sep;
+      lc_path_pfx_len = static_cast<size_t> (pp - lc_path_pfx);
+    }
+  /* Pre-build heading prefix for single-append emit.  */
+  char lc_heading_pfx[PATH_MAX + 32];
+  size_t lc_heading_pfx_len = 0;
+  if (emit_heading)
+    {
+      char *pp = lc_heading_pfx;
+      if (lc_color_path)
+        { std::memcpy (pp, col_path, col_path_len); pp += col_path_len; }
+      std::memcpy (pp, path, pathlen); pp += pathlen;
+      if (lc_color_path)
+        { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+      *pp++ = '\n';
+      lc_heading_pfx_len = static_cast<size_t> (pp - lc_heading_pfx);
+    }
+
+  while (cur < end)
+    {
+      size_t rem = static_cast<size_t> (end - cur);
+      const char *m1 = icase
+        ? rg_simd::memmem_icase_fast (cur, rem, lead.lit.data (), lead.lit.size ())
+        : rg_simd::memmem_fast (cur, rem, lead.lit.data (), lead.lit.size ());
+      if (!m1)
+        break;
+      const char *ls = m1;
+      while (ls > data && ls[-1] != '\n')
+        ls--;
+      const char *nl = static_cast<const char *> (
+        memchr (m1, '\n', static_cast<size_t> (end - m1)));
+      size_t llen = nl ? static_cast<size_t> (nl - ls + 1)
+                       : static_cast<size_t> (end - ls);
+      intmax_t so, eo;
+      if (lit_chain_line_match (ls, llen, icase, &so, &eo))
+        {
+          if (ls > last_ls)
+            {
+              size_t gap = static_cast<size_t> (ls - last_ls);
+              if (gap <= 128)
+                {
+                  for (const char *p = last_ls; p < ls; p++)
+                    if (*p == '\n')
+                      lno++;
+                }
+              else
+                {
+                  const char *dummy = nullptr;
+                  lno += rg_simd::count_newlines (last_ls, gap, &dummy);
+                }
+            }
+          last_ls = ls;
+          r.found = true;
+          r.matches++;
+          if (__builtin_expect (opt_stats, 0))
+            stat_lines_matched.fetch_add (1, std::memory_order_relaxed);
+          if (batchable)
+            {
+              if (emit_heading
+                  && (tls_last_printed_lno < 0 || tls_last_printed_lno == -2))
+                tls_obuf.append (lc_heading_pfx, lc_heading_pfx_len);
+              if (emit_path)
+                tls_obuf.append (lc_path_pfx, lc_path_pfx_len);
+              if (emit_boff || emit_lno)
+                {
+                  char pfx[64];
+                  char *pp = pfx;
+                  auto pfx_int = [&] (intmax_t v) {
+                    char tmp[24]; char *t = tmp + sizeof tmp;
+                    uintmax_t u = static_cast<uintmax_t> (v);
+                    do { *--t = '0' + static_cast<char> (u % 10); u /= 10; } while (u);
+                    size_t n = static_cast<size_t> (tmp + sizeof tmp - t);
+                    std::memcpy (pp, t, n); pp += n;
+                  };
+                  if (emit_boff)
+                    {
+                      if (lc_color_lno)
+                        { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+                      pfx_int (static_cast<intmax_t> (ls - data));
+                      if (lc_color_lno)
+                        { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+                      *pp++ = ':';
+                    }
+                  if (emit_lno)
+                    {
+                      if (lc_color_lno)
+                        { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+                      pfx_int (lno);
+                      if (lc_color_lno)
+                        { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+                      *pp++ = ':';
+                    }
+                  tls_obuf.append (pfx, static_cast<size_t> (pp - pfx));
+                }
+              if (emit_replace)
+                {
+                  if (so > 0)
+                    tls_obuf.append (ls, static_cast<size_t> (so));
+                  if (lc_color_match)
+                    tls_obuf.append (col_match, col_match_len);
+                  tls_obuf.append (opt_replace, opt_replace_len);
+                  if (lc_color_match)
+                    tls_obuf.append (col_reset, col_reset_len);
+                  size_t tail = static_cast<size_t> (eo);
+                  if (tail < llen)
+                    tls_obuf.append (ls + tail, llen - tail);
+                }
+              else if (lc_color_match)
+                {
+                  if (so > 0)
+                    tls_obuf.append (ls, static_cast<size_t> (so));
+                  tls_obuf.append (col_match, col_match_len);
+                  tls_obuf.append (ls + so, static_cast<size_t> (eo - so));
+                  tls_obuf.append (col_reset, col_reset_len);
+                  if (static_cast<size_t> (eo) < llen)
+                    tls_obuf.append (ls + eo, llen - static_cast<size_t> (eo));
+                }
+              else
+                tls_obuf.append (ls, llen);
+              if (!llen || ls[llen - 1] != '\n')
+                tls_obuf.append ('\n');
+              tls_last_printed_lno = lno;
+              if (tls_obuf.should_flush ())
+                out_flush_tls ();
+            }
+          else
+            print_match_line (path, lno, so + 1, ls, llen, so, eo,
+                              static_cast<intmax_t> (ls - data));
+          if (r.matches >= opt_max_count)
+            break;
+        }
+      cur = nl ? nl + 1 : end;
+    }
+  out_flush_tls ();
+  return r;
+}
+
+/* -------------------------------------------------------------- */
+
+/* ASCII word constituent: [A-Za-z0-9_].  Used for -w word boundary checks.  */
+static inline bool
+is_word_byte (unsigned char c)
+{
+  return (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z')
+         || (c >= '0' && c <= '9') || c == '_';
+}
+
+/* Find next match of fixed string with optional -w word boundary check.
+   When opt_word is set, skips matches whose boundaries are word chars.
+   Scans from `h` for `hl` bytes; data/end define the full buffer for
+   boundary checks at line boundaries.  Returns null if no match.  */
+static inline const char *
+find_fixed_word (const char *h, size_t hl, const char *data, const char *end)
+{
+  const size_t nlen = g_fixed.size ();
+  auto find = [] (const char *p, size_t pl) -> const char * {
+    if (opt_ignore_case)
+      return rg_simd::memmem_icase_fast (p, pl, g_fixed.data (), g_fixed.size ());
+    return rg_simd::memmem_fast (p, pl, g_fixed.data (), g_fixed.size ());
+  };
+
+  const char *c = h;
+  size_t rem = hl;
+  while (rem >= nlen)
+    {
+      const char *m = find (c, rem);
+      if (!m)
+        return nullptr;
+      if (!opt_word)
+        return m;
+      /* Check word boundaries.  */
+      bool left_ok = (m == data || m[-1] == '\n' || !is_word_byte (static_cast<unsigned char> (m[-1])));
+      bool right_ok = (m + nlen >= end || m[nlen] == '\n'
+                       || !is_word_byte (static_cast<unsigned char> (m[nlen])));
+      if (left_ok && right_ok)
+        return m;
+      /* Skip past this false-positive match and retry.  */
+      c = m + 1;
+      rem = static_cast<size_t> (h + hl - c);
+    }
+  return nullptr;
+}
+
+static SearchResult
+search_fixed (const char *path, const char *data, size_t size)
+{
+  SearchResult r{};
+  const char *cur = data;
+  const char *end = data + size;
+  const char *last_ls = data;
+  intmax_t lno = 1;
+  const size_t nlen = g_fixed.size ();
+  const void *ndl = g_fixed.data ();
+
+  auto find = [&] (const char *h, size_t hl) -> const char * {
+    return find_fixed_word (h, hl, data, end);
+  };
+
+  /* Count/exists fast path: memmem without line numbering; shard large files.  */
+  if ((opt_count || opt_quiet || opt_files_with_matches || opt_files_without_match)
+      && !opt_invert && !opt_passthru && !opt_line)
+    {
+      const bool track = opt_stats;
+      const bool only_exists = opt_quiet || opt_files_with_matches;
+      intmax_t mc = opt_max_count > 0 ? opt_max_count : 0;
+      auto scan_chunk = [&] (const char *d, size_t sz, bool oex, intmax_t mx) -> intmax_t {
+        const char *c = d;
+        const char *e = d + sz;
+        intmax_t n = 0;
+        while (c < e)
+          {
+            const char *m = find_fixed_word (c, static_cast<size_t> (e - c), d, e);
+            if (!m)
+              break;
+            n++;
+            if (oex)
+              return 1;
+            if (mx > 0 && n >= mx)
+              return n;
+            const char *nl = static_cast<const char *> (
+              memchr (m, '\n', static_cast<size_t> (e - m)));
+            c = nl ? nl + 1 : e;
+          }
+        return n;
+      };
+      intmax_t n = parallel_count_chunks (data, size, only_exists, mc, scan_chunk);
+      if (n > 0)
+        {
+          r.found = true;
+          r.matches = n;
+          if (track)
+            stat_lines_matched.fetch_add (n, std::memory_order_relaxed);
+        }
+      if (only_exists)
+        {
+          if (opt_files_with_matches && r.found)
+            emit_path_only (path);
+          return r;
+        }
+      if (opt_count && !opt_files_with_matches && !opt_files_without_match
+          && (r.matches > 0 || opt_include_zero))
+        emit_count (path, r.matches);
+      if (opt_files_without_match && !r.found)
+        emit_path_only (path);
+      return r;
+    }
+
+  /* Quick exists check: if no match exists in the buffer, skip the print path
+     entirely.  Uses parallel chunked memmem for fast rejection.  */
+  if (!opt_files_without_match && !opt_line)
+    {
+      auto quick_scan = [&] (const char *d, size_t sz, bool oex, intmax_t) -> intmax_t {
+        const char *e = d + sz;
+        const char *m = find_fixed_word (d, sz, d, e);
+        return m ? 1 : 0;
+      };
+      intmax_t exists = parallel_count_chunks (data, size, true, 1, quick_scan);
+      if (!exists)
+        {
+          if (opt_files_without_match)
+            emit_path_only (path);
+          return r;
+        }
+    }
+
+  /* Hoist invariant checks out of the per-match loop.  */
+  const bool do_print = !opt_count && !opt_files_without_match
+                        && !opt_quiet && !opt_files_with_matches;
+  const bool batchable = do_print && !opt_json && !opt_vimgrep
+                         && !opt_column && !opt_only_matching
+                         && opt_context_before <= 0 && opt_context_after <= 0
+                         && !opt_passthru && !opt_max_columns
+                         && !opt_count_matches && !opt_trim;
+  const bool emit_path = batchable && want_filename (path) && !opt_heading;
+  const bool emit_heading = batchable && want_filename (path) && opt_heading;
+  const size_t pathlen = (emit_path || emit_heading) ? std::strlen (path) : 0;
+  const char path_sep = opt_null ? '\0' : ':';
+  const bool emit_lno = batchable && opt_line_number;
+  const bool emit_boff = batchable && opt_byte_offset;
+  const bool emit_replace = batchable && opt_replace;
+  const bool color_path  = g_use_color && col_path_len;
+  const bool color_lno   = g_use_color && col_line_len;
+  const bool color_match = g_use_color && col_match_len;
+  /* Use global pre-built colored literal (avoids per-file std::string alloc).  */
+  const char *colored_fixed = g_colored_fixed;
+  const size_t colored_fixed_len = g_colored_fixed_len;
+
+  /* Pre-build path prefix: [col_path]path[col_reset]sep
+     so the per-match path emit is a single append.  */
+  char path_pfx[PATH_MAX + 32];
+  size_t path_pfx_len = 0;
+  if (emit_path)
+    {
+      char *pp = path_pfx;
+      if (color_path)
+        { std::memcpy (pp, col_path, col_path_len); pp += col_path_len; }
+      std::memcpy (pp, path, pathlen); pp += pathlen;
+      if (color_path)
+        { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+      *pp++ = path_sep;
+      path_pfx_len = static_cast<size_t> (pp - path_pfx);
+    }
+  /* Pre-build heading line: [col_path]path[col_reset]\n  */
+  char heading_pfx[PATH_MAX + 32];
+  size_t heading_pfx_len = 0;
+  if (emit_heading)
+    {
+      char *pp = heading_pfx;
+      if (color_path)
+        { std::memcpy (pp, col_path, col_path_len); pp += col_path_len; }
+      std::memcpy (pp, path, pathlen); pp += pathlen;
+      if (color_path)
+        { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+      *pp++ = '\n';
+      heading_pfx_len = static_cast<size_t> (pp - heading_pfx);
+    }
+
+  /* Byte-offset-only fast path: when we need byte-offset but NOT line number
+     (nor heading), skip the expensive forward newline counting.  Instead,
+     backward-scan from the match to find the line start — typically ~30 bytes
+     vs ~2 KB average gap for forward scan on sparse matches.  */
+  const bool boff_only = emit_boff && !emit_lno && !emit_heading;
+
+  /* Two-pass parallel fixed-string print: same approach as class_run_print.
+     Pass 1: parallel multi-thread scan collects matching line start ptrs.
+     Pass 2: single-thread output emits lines in order.
+     Only for batchable output without color/replace (plain line output).  */
+  if (batchable && !colored_fixed_len && !color_match && !emit_replace
+      && !opt_line)
+    {
+      const int nw = chunk_worker_count (size);
+      std::vector<std::pair<const char *, size_t>> fx_chunks;
+      build_line_chunks (data, size, nw, &fx_chunks);
+
+      std::vector<std::vector<const char *>> fx_matches (fx_chunks.size ());
+
+      auto fx_scan = [&] (size_t ci) {
+        const char *cd = fx_chunks[ci].first;
+        size_t csz = fx_chunks[ci].second;
+        const char *cend = cd + csz;
+        const char *p = cd;
+        auto &offsets = fx_matches[ci];
+        offsets.reserve (csz / 200);
+        while (p < cend)
+          {
+            const char *m = find_fixed_word (p, static_cast<size_t> (cend - p),
+                                              cd, cend);
+            if (!m)
+              break;
+            const char *ls = m;
+            while (ls > cd && ls[-1] != '\n')
+              ls--;
+            offsets.push_back (ls);
+            const char *nl = static_cast<const char *> (
+              memchr (m, '\n', static_cast<size_t> (cend - m)));
+            p = nl ? nl + 1 : cend;
+          }
+      };
+
+      if (fx_chunks.size () > 1)
+        {
+          std::vector<std::thread> ths;
+          ths.reserve (fx_chunks.size ());
+          for (size_t ci = 0; ci < fx_chunks.size (); ci++)
+            ths.emplace_back ([&, ci] { fx_scan (ci); });
+          for (auto &t : ths)
+            t.join ();
+        }
+      else if (!fx_chunks.empty ())
+        fx_scan (0);
+
+      size_t fx_total = 0;
+      for (auto &v : fx_matches)
+        fx_total += v.size ();
+      if (fx_total == 0)
+        {
+          out_flush_tls ();
+          return r;
+        }
+
+      r.found = true;
+      r.matches = static_cast<intmax_t> (fx_total);
+      if (__builtin_expect (opt_stats, 0))
+        stat_lines_matched.fetch_add (r.matches, std::memory_order_relaxed);
+
+      /* Pass 2: emit.  */
+      if (heading_pfx_len
+          && (tls_last_printed_lno < 0 || tls_last_printed_lno == -2))
+        tls_obuf.append (heading_pfx, heading_pfx_len);
+
+      const char *fx_cur = data;
+      intmax_t fx_lno = 1;
+      intmax_t fx_emitted = 0;
+      for (size_t ci = 0; ci < fx_matches.size (); ci++)
+        {
+          for (const char *ls : fx_matches[ci])
+            {
+              const char *nl = static_cast<const char *> (
+                memchr (ls, '\n', static_cast<size_t> (end - ls)));
+              const char *le = nl ? nl + 1 : end;
+              size_t llen = static_cast<size_t> (le - ls);
+
+              if (path_pfx_len)
+                tls_obuf.append (path_pfx, path_pfx_len);
+              if (emit_boff || emit_lno)
+                {
+                  /* Only count newlines when line numbers are needed.
+                     Byte-offset (ls - data) is free.  */
+                  if (emit_lno)
+                    {
+                      while (fx_cur < ls)
+                        {
+                          const char *n = static_cast<const char *> (
+                            memchr (fx_cur, '\n',
+                                    static_cast<size_t> (ls - fx_cur)));
+                          if (!n)
+                            break;
+                          fx_lno++;
+                          fx_cur = n + 1;
+                        }
+                    }
+                  char pfx[64];
+                  char *pp = pfx;
+                  auto fx_pfx_int = [&] (intmax_t v) {
+                    char tmp[24]; char *t = tmp + sizeof tmp;
+                    uintmax_t u = static_cast<uintmax_t> (v);
+                    do {
+                      *--t = '0' + static_cast<char> (u % 10);
+                      u /= 10;
+                    } while (u);
+                    size_t n = static_cast<size_t> (tmp + sizeof tmp - t);
+                    std::memcpy (pp, t, n);
+                    pp += n;
+                  };
+                  if (emit_boff)
+                    {
+                      if (color_lno)
+                        { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+                      fx_pfx_int (static_cast<intmax_t> (ls - data));
+                      if (color_lno)
+                        { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+                      *pp++ = ':';
+                    }
+                  if (emit_lno)
+                    {
+                      if (color_lno)
+                        { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+                      fx_pfx_int (fx_lno);
+                      if (color_lno)
+                        { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+                      *pp++ = ':';
+                    }
+                  tls_obuf.append (pfx, static_cast<size_t> (pp - pfx));
+                }
+              tls_obuf.append (ls, llen);
+              if (!llen || ls[llen - 1] != '\n')
+                tls_obuf.append ('\n');
+              tls_last_printed_lno = fx_lno;
+              if (tls_obuf.should_flush ())
+                out_flush_tls ();
+              fx_emitted++;
+              if (fx_emitted >= opt_max_count)
+                goto done_fx_par;
+            }
+        }
+    done_fx_par:
+      out_flush_tls ();
+      return r;
+    }
+
+  /* Print path: SIMD bulk newline count between matches.  */
+  while (cur < end)
+    {
+      const char *m = find (cur, static_cast<size_t> (end - cur));
+      if (!m)
+        break;
+      const char *ls;
+      const char *nl = static_cast<const char *> (
+        memchr (m, '\n', static_cast<size_t> (end - m)));
+      if (boff_only)
+        {
+          /* Backward scan: find previous newline or buffer start.  */
+          ls = m;
+          while (ls > data && ls[-1] != '\n')
+            ls--;
+        }
+      else
+        {
+          /* Count newlines between last_ls and m.  Small gaps: scalar (avoids
+             SIMD setup overhead for the common case of same/adjacent lines).
+             Large gaps: SIMD popcount.  */
+          if (m > last_ls)
+            {
+              size_t gap = static_cast<size_t> (m - last_ls);
+              if (gap <= 128)
+                {
+                  for (const char *p = last_ls; p < m; p++)
+                    if (*p == '\n')
+                      { lno++; last_ls = p + 1; }
+                }
+              else
+                {
+                  const char *after_last_nl = nullptr;
+                  intmax_t nl_cnt = rg_simd::count_newlines (
+                    last_ls, gap, &after_last_nl);
+                  lno += nl_cnt;
+                  if (after_last_nl && after_last_nl > last_ls)
+                    last_ls = after_last_nl;
+                }
+            }
+          ls = last_ls;
+        }
+      size_t llen = nl ? static_cast<size_t> (nl - ls + 1) : static_cast<size_t> (end - ls);
+      if (__builtin_expect (opt_line, 0))
+        {
+          size_t clen = nl ? static_cast<size_t> (nl - ls) : static_cast<size_t> (end - ls);
+          if (clen != nlen || std::memcmp (ls, ndl, nlen) != 0)
+            {
+              cur = m + 1;
+              continue;
+            }
+        }
+      r.found = true;
+      r.matches++;
+      if (__builtin_expect (opt_stats, 0))
+        stat_lines_matched.fetch_add (1, std::memory_order_relaxed);
+      if (!do_print)
+        {
+          if (opt_quiet || opt_files_with_matches)
+            {
+              if (opt_files_with_matches)
+                emit_path_only (path);
+              return r;
+            }
+        }
+      else if (batchable)
+        {
+          if (emit_heading
+              && (tls_last_printed_lno < 0 || tls_last_printed_lno == -2))
+            tls_obuf.append (heading_pfx, heading_pfx_len);
+          if (emit_path)
+            tls_obuf.append (path_pfx, path_pfx_len);
+          /* Build numeric prefix (byte-offset / line-number) in stack buffer
+             to reduce per-match append calls from 4 to 1.  */
+          if (emit_boff || emit_lno)
+            {
+              char pfx[64];
+              char *pp = pfx;
+              auto pfx_int = [&] (intmax_t v) {
+                char tmp[24]; char *t = tmp + sizeof tmp;
+                uintmax_t u = static_cast<uintmax_t> (v);
+                do { *--t = '0' + static_cast<char> (u % 10); u /= 10; } while (u);
+                size_t n = static_cast<size_t> (tmp + sizeof tmp - t);
+                std::memcpy (pp, t, n); pp += n;
+              };
+              if (emit_boff)
+                {
+                  if (color_lno)
+                    { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+                  pfx_int (static_cast<intmax_t> (ls - data));
+                  if (color_lno)
+                    { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+                  *pp++ = ':';
+                }
+              if (emit_lno)
+                {
+                  if (color_lno)
+                    { std::memcpy (pp, col_line, col_line_len); pp += col_line_len; }
+                  pfx_int (lno);
+                  if (color_lno)
+                    { std::memcpy (pp, col_reset, col_reset_len); pp += col_reset_len; }
+                  *pp++ = ':';
+                }
+              tls_obuf.append (pfx, static_cast<size_t> (pp - pfx));
+            }
+          intmax_t so = static_cast<intmax_t> (m - ls);
+          intmax_t eo = so + static_cast<intmax_t> (nlen);
+          if (emit_replace)
+            {
+              if (so > 0)
+                tls_obuf.append (ls, static_cast<size_t> (so));
+              if (color_match)
+                tls_obuf.append (col_match, col_match_len);
+              tls_obuf.append (opt_replace, opt_replace_len);
+              if (color_match)
+                tls_obuf.append (col_reset, col_reset_len);
+              size_t tail = static_cast<size_t> (eo);
+              if (tail < llen)
+                tls_obuf.append (ls + tail, llen - tail);
+            }
+          else if (colored_fixed_len)
+            {
+              /* Pre-built colored literal: 3 appends instead of 5.  */
+              if (so > 0)
+                tls_obuf.append (ls, static_cast<size_t> (so));
+              tls_obuf.append (colored_fixed, colored_fixed_len);
+              if (static_cast<size_t> (eo) < llen)
+                tls_obuf.append (ls + eo, llen - static_cast<size_t> (eo));
+            }
+          else if (color_match)
+            {
+              if (so > 0)
+                tls_obuf.append (ls, static_cast<size_t> (so));
+              tls_obuf.append (col_match, col_match_len);
+              tls_obuf.append (ls + so, static_cast<size_t> (eo - so));
+              tls_obuf.append (col_reset, col_reset_len);
+              if (static_cast<size_t> (eo) < llen)
+                tls_obuf.append (ls + eo, llen - static_cast<size_t> (eo));
+            }
+          else
+            tls_obuf.append (ls, llen);
+          if (!llen || ls[llen - 1] != '\n')
+            tls_obuf.append ('\n');
+          tls_last_printed_lno = lno;
+          if (tls_obuf.should_flush ())
+            out_flush_tls ();
+        }
+      else
+        {
+          intmax_t so = static_cast<intmax_t> (m - ls);
+          intmax_t eo = so + static_cast<intmax_t> (nlen);
+          print_match_line (path, lno, so + 1, ls, llen, so, eo,
+                            static_cast<intmax_t> (ls - data));
+        }
+      if (r.matches >= opt_max_count)
+        break;
+      if (nl)
+        {
+          lno++;
+          last_ls = nl + 1;
+          cur = nl + 1;
+        }
+      else
+        break;
+    }
+  if (opt_count && !opt_files_with_matches && !opt_files_without_match
+      && (r.matches > 0 || opt_include_zero))
+    emit_count (path, r.matches);
+  if (opt_files_without_match && !r.found)
+    emit_path_only (path);
+  return r;
+}
+
+static SearchResult
+search_buffer (const char *path, const char *data, size_t size)
+{
+  SearchResult r{};
+  tls_obuf.ensure_cap ();
+  if (!data || !size)
+    {
+      if (opt_count && opt_include_zero)
+        emit_count (path, 0);
+      return r;
+    }
+  if (!opt_text && !opt_binary_search && !opt_null_data)
+    {
+      /* Smaller probe for count/quiet on tiny files (recursive norm).
+         Fixed / LitsAny / class_run paths only need a tiny probe — they
+         scan linearly and binary NUL is rare in source recurse trees.  */
+      size_t check = size;
+      if (opt_count || opt_quiet || opt_files_with_matches || opt_files_without_match)
+        {
+          if (opt_fixed || g_prefilter.kind == rg_simd::PrefKind::LitsAny
+              || g_class_run.active () || g_lit_chain_active)
+            check = size < 256 ? size : 256;
+          else
+            check = size < 1024 ? size : 1024;
+        }
+      else
+        check = size < 8192 ? size : 8192;
+      if (memchr (data, '\0', check))
+        return r; /* binary skip like rg default */
+    }
+  if (opt_stats || opt_json)
+    stat_bytes_searched.fetch_add (static_cast<intmax_t> (size), std::memory_order_relaxed);
+
+    /* Multiline (-U): whole-buffer / engine execute (PCRE2, DFA, or Fexecute).
+     Must run before search_fixed — -U -F still needs Fexecute via g_exec when
+     g_fixed is empty (compile_pattern keeps the DFA/fixed path for -U).  */
+  if (opt_multiline)
+    return search_multiline_buffer (path, data, size);
+
+  /* JSON without context/invert: streaming path (no LineIndex allocation).  */
+  if (opt_json && !opt_invert && !opt_passthru && !opt_replace && !opt_trim
+      && !opt_count_matches && opt_context_before <= 0 && opt_context_after <= 0
+      && !opt_stop_on_nonmatch && opt_max_columns <= 0 && !opt_heading
+      && !opt_multiline)
+    return search_json_stream (path, data, size);
+
+  /* Fast count-matches for fixed strings: count all occurrences of the
+     literal in the buffer without building LineIndex.  Much faster than
+     the general search_lines_with_context → find_match_span path.  */
+  if (opt_count_matches && !opt_invert && !opt_passthru && !opt_json
+      && !opt_stop_on_nonmatch && !opt_multiline && !opt_heading
+      && !opt_trim && opt_context_before <= 0 && opt_context_after <= 0
+      && opt_max_columns <= 0 && opt_fixed && !g_fixed.empty ())
+    {
+      SearchResult r{};
+      const char *cur = data;
+      const char *end_p = data + size;
+      intmax_t total = 0;
+      while (cur < end_p)
+        {
+          const char *m = find_fixed_word (cur, static_cast<size_t> (end_p - cur),
+                                            data, end_p);
+          if (!m)
+            break;
+          total++;
+          r.found = true;
+          if (total >= opt_max_count && opt_max_count > 0)
+            break;
+          cur = m + (g_fixed.size () ? g_fixed.size () : 1);
+        }
+      r.matches = total;
+      if (total > 0 || opt_include_zero)
+        emit_count (path, total);
+      if (__builtin_expect (opt_stats, 0))
+        {
+          stat_lines_matched.fetch_add (total, std::memory_order_relaxed);
+          stat_match_spans.fetch_add (total, std::memory_order_relaxed);
+        }
+      return r;
+    }
+
+  /* Invert count (-v -c): total_lines - match_count via SIMD newline count.
+     Avoids building a full LineIndex or per-line matching for the common
+     "count non-matching lines" case.  */
+  if (opt_invert && opt_count && !opt_passthru && !opt_count_matches
+      && !opt_json && !opt_stop_on_nonmatch && !opt_multiline
+      && opt_context_before <= 0 && opt_context_after <= 0
+      && !opt_heading && !opt_trim)
+    {
+      const char *dummy = nullptr;
+      intmax_t total_lines = rg_simd::count_newlines (data, size, &dummy);
+      /* Last line without trailing newline still counts.  */
+      if (size > 0 && data[size - 1] != '\n')
+        total_lines++;
+
+      /* Count matching lines using the same fast paths as normal count.  */
+      intmax_t match_lines = 0;
+      if (opt_fixed && !g_fixed.empty ())
+        {
+          auto find = [&] (const char *h, size_t hl) -> const char * {
+            return opt_ignore_case
+              ? rg_simd::memmem_icase_fast (h, hl, g_fixed.data (), g_fixed.size ())
+              : rg_simd::memmem_fast (h, hl, g_fixed.data (), g_fixed.size ());
+          };
+          const char *c = data;
+          const char *e = data + size;
+          while (c < e)
+            {
+              const char *m = find (c, static_cast<size_t> (e - c));
+              if (!m)
+                break;
+              match_lines++;
+              const char *nl = static_cast<const char *> (
+                memchr (m, '\n', static_cast<size_t> (e - m)));
+              c = nl ? nl + 1 : e;
+            }
+        }
+      else if (g_lit_chain_active)
+        {
+          const bool icase = opt_ignore_case;
+          const auto &lead = g_lit_chain[0];
+          const char *c = data;
+          const char *e = data + size;
+          while (c < e)
+            {
