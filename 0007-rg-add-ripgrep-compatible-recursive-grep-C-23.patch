+/* Dispatch: slim (2-8 needles) or fat (9-16) nibble Teddy.  */
+static intmax_t
+lits_any_teddy_nibble_avx2 (const Prefilter &pf, const char *data, size_t size,
+                            bool only_exists, intmax_t max_count)
+{
+  const size_t nlits = pf.lits.size ();
+  if (nlits < 2 || nlits > 16)
+    return -1;
+  for (const auto &lit : pf.lits)
+    if (lit.size () < 2)
